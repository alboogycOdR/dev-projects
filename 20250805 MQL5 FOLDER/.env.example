# SECURITY TEMPLATE: Copy this file to .env and fill in your actual credentials
# WARNING: .env is in .gitignore and should NEVER be committed to version control

# DeepSeek API Configuration
# Get your API key from: https://api.deepseek.com/
DEEPSEEK_API_KEY=sk_your_actual_deepseek_key_here

# Telegram Bot Configuration
# Create a bot with BotFather on Telegram and get your token
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh

# Trade Copier Configuration
# Generate your secure access keys for trade copying functionality
SUBSCRIBER_ACCESS_KEY=your_secure_subscriber_access_key_here
PUBLISHER_PRIVATE_KEY=your_secure_publisher_private_key_here

# WebSocket Server Configuration
WS_SERVER_URL=ws://localhost:9000/
WS_SERVER_PORT=9000

# Database Configuration (if applicable)
DATABASE_URL=your_database_connection_string_here
DATABASE_USER=your_db_username
DATABASE_PASSWORD=your_db_password

# Trading Configuration
# MT5 Account credentials (if auto-login is used)
MT5_ACCOUNT_LOGIN=your_mt5_account_number
MT5_ACCOUNT_PASSWORD=your_mt5_account_password
MT5_ACCOUNT_SERVER=your_mt5_broker_server

# API Rate Limiting and Security
API_RATE_LIMIT=100
API_TIMEOUT_SECONDS=30
ENABLE_REQUEST_LOGGING=false

# Environment Type
ENVIRONMENT=development
# Values: development, testing, production

# Logging Level
LOG_LEVEL=INFO
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL

var array<dailySessionLevel> londonAftLevels = array.new<dailySessionLevel>()
var array<dailySessionLevel> nyseLevels = array.new<dailySessionLevel>()
var array<dailySessionLevel> cmeLevels = array.new<dailySessionLevel>()
var array<dailySessionLevel> globexLevels = array.new<dailySessionLevel>()

// Daily Session Lines and Labels Storage
var array<line> tokyoHighLines = array.new<line>()
var array<line> tokyoLowLines = array.new<line>()
var array<label> tokyoHighLabels = array.new<label>()
var array<label> tokyoLowLabels = array.new<label>()

var array<line> asianPhysicalHighLines = array.new<line>()
var array<line> asianPhysicalLowLines = array.new<line>()
var array<label> asianPhysicalHighLabels = array.new<label>()
var array<label> asianPhysicalLowLabels = array.new<label>()

var array<line> londonPreHighLines = array.new<line>()
var array<line> londonPreLowLines = array.new<line>()
var array<label> londonPreHighLabels = array.new<label>()
var array<label> londonPreLowLabels = array.new<label>()

var array<line> londonGoldMornHighLines = array.new<line>()
var array<line> londonGoldMornLowLines = array.new<line>()
var array<label> londonGoldMornHighLabels = array.new<label>()
var array<label> londonGoldMornLowLabels = array.new<label>()

var array<line> londonMornHighLines = array.new<line>()
var array<line> londonMornLowLines = array.new<line>()
var array<label> londonMornHighLabels = array.new<label>()

                    array.push(asianPhysicalLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=asianPhysicalLowColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

        // London Pre-Open Levels
        if showLondonPreOpen and array.size(londonPreLevels) > 0
            for i = 0 to array.size(londonPreLevels) - 1

        // London Morning Fix Levels
        if showLondonMorningFix and array.size(londonMornLevels) > 0
            for i = 0 to array.size(londonMornLevels) - 1
                levelData = array.get(londonMornLevels, i)
                h = levelData.high
                l = levelData.low
                t = levelData.barTime

                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – London Afternoon Fix LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

        // NYSE Close
        if showNYSEClose and array.size(nyseLevels) > 0
            for i = 0 to array.size(nyseLevels) - 1
                levelData = array.get(nyseLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – NYSE Close HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – NYSE Close LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

        // CME Settlement
        if showCMESettlement and array.size(cmeLevels) > 0
            for i = 0 to array.size(cmeLevels) - 1
                levelData = array.get(cmeLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – CME Settlement HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – CME Settlement LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

        // Globex Roll
        if showGlobexRoll and array.size(globexLevels) > 0
            for i = 0 to array.size(globexLevels) - 1
                levelData = array.get(globexLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – Globex Roll HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – Globex Roll LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

    // Wednesday Events
    if showWednesdayEvents
        // EIA Oil Inventory
        if showEIAOil and array.size(eiaLevels) > 0
            for i = 0 to array.size(eiaLevels) - 1
                levelData = array.get(eiaLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – EIA Oil Inventory HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – EIA Oil Inventory LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

        // FOMC Announcements
        if showFOMC and array.size(fomcLevels) > 0
            for i = 0 to array.size(fomcLevels) - 1
                levelData = array.get(fomcLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – FOMC Announcement HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – FOMC Announcement LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

    // Friday Events
    if showFridayEvents
        // Non-Farm Payrolls
        if showNFP and array.size(nfpLevels) > 0
            for i = 0 to array.size(nfpLevels) - 1
                levelData = array.get(nfpLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – NFP HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – NFP LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

        // Quadruple-Witch Settlement
        if showQuadWitch and array.size(quadWitchLevels) > 0
            for i = 0 to array.size(quadWitchLevels) - 1
                levelData = array.get(quadWitchLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – Quad Witch HIGH (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)
                if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                    sent := true, msg = "WICK TOUCH – Quad Witch LOW (" + syminfo.ticker + ")"
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

    if sent
        lastAlertTime := timenow

// ───── EXECUTION & DRAWING ───────────────────────────────────────────────────
if barstate.islast
    // --- Cleanup previous drawings ---
    for id in wednesdayHighLines
        line.delete(id)
    for id in wednesdayLowLines
        line.delete(id)
    for id in wednesdayOpenLines
        line.delete(id)
    for id in wednesdayHighLabels
        label.delete(id)
    for id in wednesdayLowLabels
        label.delete(id)
    for id in wednesdayOpenLabels
        label.delete(id)

    array.clear(wednesdayHighLines), array.clear(wednesdayLowLines), array.clear(wednesdayOpenLines)
    array.clear(wednesdayHighLabels), array.clear(wednesdayLowLabels), array.clear(wednesdayOpenLabels)

    // --- Cleanup Daily Session Lines and Labels ---
    for id in tokyoHighLines
        line.delete(id)
    for id in tokyoLowLines
        line.delete(id)
    for id in tokyoHighLabels
        label.delete(id)
    for id in tokyoLowLabels
        label.delete(id)

    for id in londonPreHighLines
        line.delete(id)
    for id in londonPreLowLines
        line.delete(id)
    for id in londonPreHighLabels
        label.delete(id)
    for id in londonPreLowLabels
        label.delete(id)

    for id in londonMornHighLines
        line.delete(id)
    for id in londonMornLowLines
        line.delete(id)
    for id in londonMornHighLabels
        label.delete(id)
    for id in londonMornLowLabels
        label.delete(id)

    for id in londonAftHighLines
        line.delete(id)
    for id in londonAftLowLines
        line.delete(id)
    for id in londonAftHighLabels
        label.delete(id)
    for id in londonAftLowLabels
        label.delete(id)

    for id in nyseHighLines
        line.delete(id)
    for id in nyseLowLines
        line.delete(id)
    for id in nyseHighLabels
        label.delete(id)
    for id in nyseLowLabels
        label.delete(id)

    for id in cmeHighLines
        line.delete(id)
    for id in cmeLowLines
        line.delete(id)
    for id in cmeHighLabels
        label.delete(id)
    for id in cmeLowLabels
        label.delete(id)

    for id in globexHighLines
        line.delete(id)
    for id in globexLowLines
        line.delete(id)
    for id in globexHighLabels
        label.delete(id)
    for id in globexLowLabels
        label.delete(id)

    array.clear(tokyoHighLines), array.clear(tokyoLowLines)
    array.clear(tokyoHighLabels), array.clear(tokyoLowLabels)
    array.clear(londonPreHighLines), array.clear(londonPreLowLines)
    array.clear(londonPreHighLabels), array.clear(londonPreLowLabels)
    array.clear(londonMornHighLines), array.clear(londonMornLowLines)
    array.clear(londonMornHighLabels), array.clear(londonMornLowLabels)
    array.clear(londonAftHighLines), array.clear(londonAftLowLines)
    array.clear(londonAftHighLabels), array.clear(londonAftLowLabels)
    array.clear(nyseHighLines), array.clear(nyseLowLines)
    array.clear(nyseHighLabels), array.clear(nyseLowLabels)
    array.clear(cmeHighLines), array.clear(cmeLowLines)
    array.clear(cmeHighLabels), array.clear(cmeLowLabels)
    array.clear(globexHighLines), array.clear(globexLowLines)
    array.clear(globexHighLabels), array.clear(globexLowLabels)

    if (showWednesdays or showWednesdayOpen) and array.size(eventTimes) > 0
        filteredIndices = array.new_int()

        if enableLevelFiltering
            currentPrice = close
            
            // Create array of indices with their minimum distances
            array<wedIndexDistance> wednesdayDistances = array.new<wedIndexDistance>()
            
            for i = 0 to array.size(eventTimes) - 1
                h = array.get(hiPrice, i)
                l = array.get(loPrice, i)
                o = array.get(opPrice, i)
                minDist = math.min(math.abs(h - currentPrice), math.abs(l - currentPrice), math.abs(o - currentPrice))
                array.push(wednesdayDistances, wedIndexDistance.new(i, minDist))
            
            // Sort by distance using bubble sort
            n = array.size(wednesdayDistances)
            for i = 0 to n - 2
                for j = 0 to n - i - 2
                    if array.get(wednesdayDistances, j).dist > array.get(wednesdayDistances, j + 1).dist
                        temp = array.get(wednesdayDistances, j)
                        array.set(wednesdayDistances, j, array.get(wednesdayDistances, j + 1))
                        array.set(wednesdayDistances, j + 1, temp)
            
            // Separate into above and below
            aboveIndices = array.new_int()
            belowIndices = array.new_int()
            
            for i = 0 to array.size(wednesdayDistances) - 1
                item = array.get(wednesdayDistances, i)
                h = array.get(hiPrice, item.idx)
                l = array.get(loPrice, item.idx)
                o = array.get(opPrice, item.idx)
                if h >= currentPrice or l >= currentPrice or o >= currentPrice
                    array.push(aboveIndices, item.idx)
                if h <= currentPrice or l <= currentPrice or o <= currentPrice
                    array.push(belowIndices, item.idx)

            // Take the required number of levels
            if array.size(aboveIndices) > 0
                for i = 0 to math.min(array.size(aboveIndices) - 1, levelsAbovePrice - 1)
                    array.push(filteredIndices, array.get(aboveIndices, i))
            
            if array.size(belowIndices) > 0
                for i = 0 to math.min(array.size(belowIndices) - 1, levelsBelowPrice - 1)
                    idx = array.get(belowIndices, i)
                    if not array.includes(filteredIndices, idx)
                        array.push(filteredIndices, idx)
        else
            for i = 0 to array.size(eventTimes) - 1
                array.push(filteredIndices, i)

        bar_width_ms = time - nz(time[1], time)
        for i = 0 to array.size(filteredIndices) - 1
            originalIndex = array.get(filteredIndices, i)
            w = array.get(wedRank, originalIndex)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h = array.get(hiPrice, originalIndex), l = array.get(loPrice, originalIndex), o = array.get(opPrice, originalIndex)
            t = array.get(eventTimes, originalIndex), dStr = array.get(dateLbl, originalIndex)

            hiCol = switch w
                1 => hiC1
                2 => hiC2
                3 => hiC3
                4 => hiC4
                5 => hiC5
                => na
            loCol = switch w
                1 => loC1
                2 => loC2
                3 => loC3
                4 => loC4
                5 => loC5
                => na
            opCol = switch w
                1 => opC1
                2 => opC2
                3 => opC3
                4 => opC4
                5 => opC5
                => na
            hiW = switch w
                1 => globalLineWidth
                2 => globalLineWidth
                3 => globalLineWidth
                4 => globalLineWidth
                5 => globalLineWidth
                => na
            loW = switch w
                1 => globalLineWidth
                2 => globalLineWidth
                3 => globalLineWidth
                4 => globalLineWidth
                5 => globalLineWidth
                => na
            opW = switch w
                1 => globalLineWidth
                2 => globalLineWidth
                3 => globalLineWidth
                4 => globalLineWidth
                5 => globalLineWidth
                => na
            
            x2 = extendRight ? t + 50 * bar_width_ms : t + MS_IN_DAY - 1
            label_x_position = extendRight ? t + (wednesdayLabelOffset + 50) * bar_width_ms : x2
            
            if showWednesdays
                array.push(wednesdayHighLines, line.new(t, h, x2, h, xloc=xloc.bar_time, color=hiCol, width=hiW))
                array.push(wednesdayLowLines, line.new(t, l, x2, l, xloc=xloc.bar_time, color=loCol, width=loW))
            if showWednesdayOpen
                array.push(wednesdayOpenLines, line.new(t, o, x2, o, xloc=xloc.bar_time, color=opCol, width=opW))
            
            if labelText
                highLabelText = str.format("{0} High {1}", dStr, str.tostring(h, format.mintick))
                lowLabelText  = str.format("{0} Low {1}", dStr, str.tostring(l, format.mintick))
                openLabelText = str.format("{0} Open {1}", dStr, str.tostring(o, format.mintick))
                if showWednesdays
                    array.push(wednesdayHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=hiCol, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                    array.push(wednesdayLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=loCol, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                if showWednesdayOpen
                    array.push(wednesdayOpenLabels, label.new(label_x_position, o, openLabelText, xloc=xloc.bar_time, color=color(na), textcolor=opCol, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

    // --- Draw Daily Session Levels ---
    if showDailySessions
        bar_width_ms = time - nz(time[1], time)
        // Tokyo Open Levels
        if showTokyoOpen and array.size(tokyoLevels) > 0
            for i = 0 to array.size(tokyoLevels) - 1

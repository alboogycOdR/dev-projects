                array.push(londonMornLowLines, line.new(t, l, x2_time, l, xloc=xloc.bar_time, color=londonMornLowColor, width=globalLineWidth))
                
                if labelText
                    highLabelText = str.format("{0} High {1}", sessionName, str.tostring(h, format.mintick))
                    lowLabelText = str.format("{0} Low {1}", sessionName, str.tostring(l, format.mintick))
                    label_x_position = extendRight ? t + 50 * bar_width_ms : x2_time
                    
                    array.push(londonMornHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=londonMornHighColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                    array.push(londonMornLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=londonMornLowColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

        // London Afternoon Fix Levels
        if showLondonAfternoonFix and array.size(londonAftLevels) > 0
            for i = 0 to array.size(londonAftLevels) - 1
                levelData = array.get(londonAftLevels, i)
                h = levelData.high
                l = levelData.low
                t = levelData.barTime
                sessionName = levelData.sessionName
                
                x2_time = extendRight ? time_close + 50 * bar_width_ms : t + MS_IN_DAY - 1
                
                array.push(londonAftHighLines, line.new(t, h, x2_time, h, xloc=xloc.bar_time, color=londonAftHighColor, width=globalLineWidth))
                array.push(londonAftLowLines, line.new(t, l, x2_time, l, xloc=xloc.bar_time, color=londonAftLowColor, width=globalLineWidth))
                
                if labelText
                    highLabelText = str.format("{0} High {1}", sessionName, str.tostring(h, format.mintick))
                    lowLabelText = str.format("{0} Low {1}", sessionName, str.tostring(l, format.mintick))
                    label_x_position = extendRight ? t + 50 * bar_width_ms : x2_time
                    
                    array.push(londonAftHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=londonAftHighColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                    array.push(londonAftLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=londonAftLowColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

        // NYSE Close Levels
        if showNYSEClose and array.size(nyseLevels) > 0
            for i = 0 to array.size(nyseLevels) - 1
                levelData = array.get(nyseLevels, i)
                h = levelData.high
                l = levelData.low
                t = levelData.barTime
                sessionName = levelData.sessionName
                
                x2_time = extendRight ? time_close + 50 * bar_width_ms : t + MS_IN_DAY - 1
                
                array.push(nyseHighLines, line.new(t, h, x2_time, h, xloc=xloc.bar_time, color=nyseHighColor, width=globalLineWidth))
                array.push(nyseLowLines, line.new(t, l, x2_time, l, xloc=xloc.bar_time, color=nyseLowColor, width=globalLineWidth))
                
                if labelText
                    highLabelText = str.format("{0} High {1}", sessionName, str.tostring(h, format.mintick))
                    lowLabelText = str.format("{0} Low {1}", sessionName, str.tostring(l, format.mintick))
                    label_x_position = extendRight ? t + 50 * bar_width_ms : x2_time
                    
                    array.push(nyseHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=nyseHighColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                    array.push(nyseLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=nyseLowColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

        // CME Settlement Levels
        if showCMESettlement and array.size(cmeLevels) > 0
            for i = 0 to array.size(cmeLevels) - 1
                levelData = array.get(cmeLevels, i)
                h = levelData.high
                l = levelData.low
                t = levelData.barTime
                sessionName = levelData.sessionName
                
                x2_time = extendRight ? time_close + 50 * bar_width_ms : t + MS_IN_DAY - 1
                
                array.push(cmeHighLines, line.new(t, h, x2_time, h, xloc=xloc.bar_time, color=cmeHighColor, width=globalLineWidth))
                array.push(cmeLowLines, line.new(t, l, x2_time, l, xloc=xloc.bar_time, color=cmeLowColor, width=globalLineWidth))
                
                if labelText
                    highLabelText = str.format("{0} High {1}", sessionName, str.tostring(h, format.mintick))
                    lowLabelText = str.format("{0} Low {1}", sessionName, str.tostring(l, format.mintick))
                    label_x_position = extendRight ? t + 50 * bar_width_ms : x2_time
                    
                    array.push(cmeHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=cmeHighColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                    array.push(cmeLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=cmeLowColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

        // Globex Roll Levels
        if showGlobexRoll and array.size(globexLevels) > 0
            for i = 0 to array.size(globexLevels) - 1
                levelData = array.get(globexLevels, i)
                h = levelData.high
                l = levelData.low
                t = levelData.barTime
                sessionName = levelData.sessionName
                
                x2_time = extendRight ? time_close + 50 * bar_width_ms : t + MS_IN_DAY - 1
                
                array.push(globexHighLines, line.new(t, h, x2_time, h, xloc=xloc.bar_time, color=globexHighColor, width=globalLineWidth))
                array.push(globexLowLines, line.new(t, l, x2_time, l, xloc=xloc.bar_time, color=globexLowColor, width=globalLineWidth))
                
                if labelText
                    highLabelText = str.format("{0} High {1}", sessionName, str.tostring(h, format.mintick))
                    lowLabelText = str.format("{0} Low {1}", sessionName, str.tostring(l, format.mintick))
                    label_x_position = extendRight ? t + 50 * bar_width_ms : x2_time
                    
                    array.push(globexHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=globexHighColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))
                    array.push(globexLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=globexLowColor, style=label.style_label_right, size=actualLabelSize, textalign=text.align_right))

if extendRight and (showWednesdays or showWednesdayOpen)
    bar_width_ms = time - nz(time[1], time)
    if array.size(wednesdayHighLines) > 0
        for i = 0 to array.size(wednesdayHighLines) - 1
            if i < array.size(wednesdayHighLines)
                array.get(wednesdayHighLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(wednesdayHighLabels)
                array.get(wednesdayHighLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)
    if array.size(wednesdayLowLines) > 0
        for i = 0 to array.size(wednesdayLowLines) - 1
            if i < array.size(wednesdayLowLines)
                array.get(wednesdayLowLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(wednesdayLowLabels)
                array.get(wednesdayLowLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)
    if array.size(wednesdayOpenLines) > 0
        for i = 0 to array.size(wednesdayOpenLines) - 1
            if i < array.size(wednesdayOpenLines)
                array.get(wednesdayOpenLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(wednesdayOpenLabels)
                array.get(wednesdayOpenLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)

    // Update midnight lines to extend to current time
    if extendRight and showMidnightLevelsInput
        if array.size(midnightHighLines) > 0
            for i = 0 to array.size(midnightHighLines) - 1
                if i < array.size(midnightHighLines)
                    array.get(midnightHighLines, i).set_x2(time_close + 50 * bar_width_ms)
        if array.size(midnightLowLines) > 0
            for i = 0 to array.size(midnightLowLines) - 1
                if i < array.size(midnightLowLines)
                    array.get(midnightLowLines, i).set_x2(time_close + 50 * bar_width_ms)

// ───── PLAYBOOK MODE LOGIC ────────────────────────────────────────────────────
if enablePlaybookMode
    // Alert cooldown logic (using existing lastAlertTime from main alert system)
    canSend = (time - lastAlertTime) >= (alertCooldown * 1000)
    
    // Session Strategy Detection
    currentHour = hour(time, TARGET_TIMEZONE)
    currentMinute = minute(time, TARGET_TIMEZONE)
    
    // Determine current session and strategy
    var string sessionStrategy = ""
    var color sessionColor = color.white
    
    if currentHour >= 2 and currentHour < 8
        sessionStrategy := "ASIAN SESSION - MEAN REVERSION Strategy"
        sessionColor := color.purple
    else if currentHour >= 8 and currentHour < 14
        sessionStrategy := "LONDON SESSION - BREAKOUT Strategy"
        sessionColor := color.blue
    else if currentHour >= 14 and currentHour < 18
        sessionStrategy := "LONDON/NY OVERLAP - MOMENTUM Strategy"
        sessionColor := color.green
    else if currentHour >= 18 and currentHour < 22
        sessionStrategy := "NY SESSION - RANGE FADE Strategy"
        sessionColor := color.orange
    else if currentHour >= 22 or currentHour < 2
        sessionStrategy := "NY CLOSE - CONSOLIDATION"
        sessionColor := color.gray
    
    // Display session strategy
    if playbookSessionStrategy
        label.new(time, high, sessionStrategy, xloc=xloc.bar_time, yloc=yloc.abovebar, 
                 color=color(na), textcolor=sessionColor, style=label.style_label_down, 
                 size=size.normal, textalign=text.align_center)
    
    // Level Hierarchy Detection and Proximity Alerts
    if playbookLevelHierarchy or playbookAlertDistance > 0
        // Check proximity to all active levels
        var array<float> allLevels = array.new<float>()
        var array<string> levelTiers = array.new<string>()
        
        // Collect all active levels with their tiers
        if array.size(tokyoLevels) > 0
            for i = 0 to array.size(tokyoLevels) - 1
                levelData = array.get(tokyoLevels, i)
                array.push(allLevels, levelData.high)
                array.push(allLevels, levelData.low)
                array.push(levelTiers, "TIER 2")
                array.push(levelTiers, "TIER 2")
        
        if array.size(asianPhysicalLevels) > 0
            for i = 0 to array.size(asianPhysicalLevels) - 1
                levelData = array.get(asianPhysicalLevels, i)
                array.push(allLevels, levelData.high)
                array.push(allLevels, levelData.low)
                array.push(levelTiers, "TIER 2")
                array.push(levelTiers, "TIER 2")
        
        if array.size(londonGoldMornLevels) > 0
            for i = 0 to array.size(londonGoldMornLevels) - 1
                levelData = array.get(londonGoldMornLevels, i)
                array.push(allLevels, levelData.high)
                array.push(allLevels, levelData.low)
                array.push(levelTiers, "TIER 1")
                array.push(levelTiers, "TIER 1")
        
        if array.size(londonAftLevels) > 0
            for i = 0 to array.size(londonAftLevels) - 1
                levelData = array.get(londonAftLevels, i)
                array.push(allLevels, levelData.high)
                array.push(allLevels, levelData.low)
                array.push(levelTiers, "TIER 1")
                array.push(levelTiers, "TIER 1")
        
        // Check proximity to levels
        if array.size(allLevels) > 0
            for i = 0 to array.size(allLevels) - 1
                var float levelPrice = array.get(allLevels, i)
                var string levelTier = array.get(levelTiers, i)
                
                var float distance = math.abs(close - levelPrice)
                
                // Proximity alert
                if distance <= playbookAlertDistance
                    var color tierColor = levelTier == "TIER 1" ? color.red : levelTier == "TIER 2" ? color.orange : color.yellow
                    var string alertText = str.format("🎯 {0} LEVEL APPROACH: {1} (Distance: {2})", levelTier, str.tostring(levelPrice, format.mintick), str.tostring(distance, "#.##"))
                    
                    if canSend
                        lastAlertTime := time
                        var string msg = alertText + " - " + syminfo.ticker
                        if sendEmail 
                            alert(msg, alert.freq_once_per_bar)
                        if sendPush 
                            alert(msg, alert.freq_once_per_bar)
                    
                    // Visual indicator
                    label.new(time, levelPrice, levelTier, xloc=xloc.bar_time, yloc=yloc.price, 
                             color=color(na), textcolor=tierColor, style=label.style_label_left, 
                             size=size.small, textalign=text.align_left)
    
    // London Fix Special Detection (10:25-10:35 EST and 14:55-15:05 EST)
    // 10:25-10:35 EST = 16:25-16:35 UTC+2, 14:55-15:05 EST = 20:55-21:05 UTC+2
    var bool isLondonFixWindow = (currentHour == 16 and currentMinute >= 25 and currentMinute <= 35) or 
                       (currentHour == 20 and currentMinute >= 55) or 
                       (currentHour == 21 and currentMinute <= 5)
    
    if isLondonFixWindow
        var string londonFixAlert = "🔥 LONDON FIX WINDOW ACTIVE - Setup C Brackets Ready"
        if canSend
            lastAlertTime := time
            var string msg = londonFixAlert + " - " + syminfo.ticker
            if sendEmail 
                alert(msg, alert.freq_once_per_bar)
            if sendPush 
                alert(msg, alert.freq_once_per_bar)
        
        label.new(time, high, "LONDON FIX WINDOW", xloc=xloc.bar_time, yloc=yloc.abovebar, 
                 color=color(na), textcolor=color.red, style=label.style_label_down, 
                 size=size.large, textalign=text.align_center)

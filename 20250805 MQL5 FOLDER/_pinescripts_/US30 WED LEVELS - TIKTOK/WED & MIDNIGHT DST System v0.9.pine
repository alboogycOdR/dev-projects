        // London Afternoon Fix
        if showLondonAfternoonFix and array.size(londonAftLevels) > 0
            for i = 0 to array.size(londonAftLevels) - 1
                levelData = array.get(londonAftLevels, i)
                h = levelData.high, l = levelData.low
                if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                    sent := true, msg = "WICK TOUCH – London Afternoon Fix HIGH (" + syminfo.ticker + ")"
                    if sendEmail 

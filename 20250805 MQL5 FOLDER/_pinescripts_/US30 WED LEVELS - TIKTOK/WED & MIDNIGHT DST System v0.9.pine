// ┌─────────────────────────────────────────────────────────────────────────────┐
// │  WED, MIDNIGHT & NY PREMARKET DST System v0.9 – Complete with All Market   │
// │  Session Levels, Economic Events & Wick-Reaction Alerts                    │
// │  © 2024 – Free to use & modify (Enhanced by AI)                           │
// └─────────────────────────────────────────────────────────────────────────────┘
// ───── DESCRIPTION ─────────────────────────────────────────────────────────────────
//
// This script identifies and visualizes specific, recurring price levels based on
// multiple time-based systems including Wednesday SAST, Midnight, NY PreMarket,
// and comprehensive market session levels for global trading sessions.
//
// -----------------------------------------------------------------------------
// │ KEY FEATURES (Enhanced Version 0.9)                                       │
// -----------------------------------------------------------------------------
//
// 1. Wednesday SAST Lines (14:30 EST):
//    - Identifies the high, low, and open of the first five Wednesdays of each month.
//    - Uses request.security() to always fetch data from the 15-minute timeframe.
//
// 2. Midnight Levels (18:00 EST):
//    - Plots the high and low of the 00:00 candle (15-minute timeframe) for each day.
//
// 3. NY PreMarket Levels (08:00 EST):
//    - Plots the high and low of the 14:00 candle (15-minute timeframe) for each day.
//
// 4. Daily Market Session Levels:
//    - Tokyo Open (04:00 EST / 10:00 UTC+2)
//    - London Pre-Open (07:00 EST / 13:00 UTC+2)
//    - London Morning Fix (11:00 EST / 17:00 UTC+2)
//    - London Afternoon Fix (15:00 EST / 21:00 UTC+2)
//    - NYSE Close (16:00 EST / 22:00 UTC+2)
//    - CME Settlement (16:30 EST / 22:30 UTC+2)
//    - Globex Roll (20:00 EST / 02:00 UTC+2)
//
// 5. Wednesday-Specific Economic Events:
//    - EIA Oil Inventory (10:30 EST / 16:30 UTC+2)
//    - FOMC Announcements (14:00 EST / 20:00 UTC+2)
//
// 6. Friday-Specific Economic Events:
//    - Non-Farm Payrolls (08:30 EST / 14:30 UTC+2)
//    - Quadruple-Witch Settlement (15:00 EST / 21:00 UTC+2)
//
// 7. Wick Interaction Visuals & Alert System:
//    - Real-time alerts when price wicks touch any active level.
//    - Visual markers with color-coded system identification.
//
// 8. Level Optimization & Performance:
//    - Dynamic filtering to show only relevant levels above/below current price.
//    - Full Pine Script v5 compliance with optimized performance.
//
// 9. Gold Trading Optimization:
//    - London Gold Fix Morning (10:30 EST / 15:30 UTC+2) - TIER 1
//    - London Gold Fix Afternoon (15:00 EST / 20:00 UTC+2) - TIER 1  
//    - Asian Physical Open (20:00 EST / 02:00 UTC+2) - TIER 2
//    - Enhanced visibility with gold-themed colors and priority line widths
//
// 10. Playbook Mode (Semi-Automated Trading Intelligence):
//    - Dedicated "Playbook" input section with organized settings
//    - Session Strategy Detection:
//      * Asian Session (20:00-02:00 EST): "MEAN REVERSION Strategy" (Purple)
//      * London Session (02:00-08:00 EST): "BREAKOUT Strategy" (Blue)
//      * London/NY Overlap (08:00-11:00 EST): "MOMENTUM Strategy" (Green)
//      * NY Session (11:00-16:00 EST): "RANGE FADE Strategy" (Orange)
//      * NY Close (16:00-20:00 EST): "CONSOLIDATION" (Gray)
//    - Level Hierarchy System:
//      * TIER 1 (Red): London Gold Fix Morning & Afternoon (10:30 & 15:00 EST)
//      * TIER 2 (Orange): Asian Physical Open & Tokyo Open (20:00 & 04:00 EST)
//      * TIER 3 (Yellow): Other levels
//    - Proximity Alert System:
//      * Automatic Detection: When price approaches within 0.5 points of any level
//      * Tier-Based Alerts: Different alert messages for Tier 1/2/3 levels
//      * Visual Indicators: Color-coded labels on chart
//      * Smart Alerts: Email/Push notifications with level details
//    - London Fix Special Detection:
//      * Morning Window: 10:25-10:35 EST
//      * Afternoon Window: 14:55-15:05 EST
//      * Special Alerts: "🔥 LONDON FIX WINDOW ACTIVE - Setup C Brackets Ready"
//      * Visual Warnings: Large red labels during critical windows
//    - Key Benefits:
//      * Preserves Existing System: All current keylevel tracking remains unchanged
//      * Semi-Automation: Automates detection and alerts, keeps decision-making manual
//      * Playbook Integration: Implements the exact playbook scenarios
//      * Session Awareness: Knows which strategy to use when
//      * Level Prioritization: Focuses on most important levels first
//      * Time-Based Triggers: Special alerts for London Fix windows
//      * Visual Feedback: Clear chart indicators for all scenarios
//
// -----------------------------------------------------------------------------
//@version=5

indicator(
     title   = "WED, MIDNIGHT & NY PREMARKET DST System v0.9 (All Market Sessions)",
     overlay = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     dynamic_requests = true)


// ───── WEDNESDAY LINES ───────────────────────────────────────────────────────
GROUP_WEDNESDAY = "Wednesday SAST Lines (14:30 EST)"
showWednesdays = input.bool(false, "Show Wednesday High/Low Lines", group=GROUP_WEDNESDAY, tooltip="Master switch to show/hide Wednesday High/Low lines.")
showWednesdayOpen = input.bool(false, "Show Wednesday Open Line", group=GROUP_WEDNESDAY, tooltip="Toggles the visibility of the Wednesday Open line.")

showW1 = input.bool(false, "Show 1st Wednesday", group=GROUP_WEDNESDAY, inline="W1")
hiC1 = input.color(color.new(color.red, 0), "High Color", inline="W1_colors", group=GROUP_WEDNESDAY)
loC1 = input.color(color.new(color.blue, 0), "Low Color", inline="W1_colors", group=GROUP_WEDNESDAY)
opC1 = input.color(color.new(color.gray, 0), "Open Color", inline="W1_colors", group=GROUP_WEDNESDAY)

showW2 = input.bool(false, "Show 2nd Wednesday", group=GROUP_WEDNESDAY, inline="W2")
hiC2 = input.color(color.new(color.orange, 0), "High Color", inline="W2_colors", group=GROUP_WEDNESDAY)
loC2 = input.color(color.new(color.aqua, 0), "Low Color", inline="W2_colors", group=GROUP_WEDNESDAY)
opC2 = input.color(color.new(color.gray, 0), "Open Color", inline="W2_colors", group=GROUP_WEDNESDAY)

showW3 = input.bool(false, "Show 3rd Wednesday", group=GROUP_WEDNESDAY, inline="W3")
hiC3 = input.color(color.new(color.green, 0), "High Color", inline="W3_colors", group=GROUP_WEDNESDAY)
loC3 = input.color(color.new(color.fuchsia, 0), "Low Color", inline="W3_colors", group=GROUP_WEDNESDAY)
opC3 = input.color(color.new(color.gray, 0), "Open Color", inline="W3_colors", group=GROUP_WEDNESDAY)

showW4 = input.bool(false, "Show 4th Wednesday", group=GROUP_WEDNESDAY, inline="W4")
hiC4 = input.color(color.new(color.purple, 0), "High Color", inline="W4_colors", group=GROUP_WEDNESDAY)
loC4 = input.color(color.new(color.lime, 0), "Low Color", inline="W4_colors", group=GROUP_WEDNESDAY)
opC4 = input.color(color.new(color.gray, 0), "Open Color", inline="W4_colors", group=GROUP_WEDNESDAY)

showW5 = input.bool(false, "Show 5th Wednesday", group=GROUP_WEDNESDAY, inline="W5")
hiC5 = input.color(color.new(color.gray, 0), "High Color", inline="W5_colors", group=GROUP_WEDNESDAY)
loC5 = input.color(color.new(color.black, 0), "Low Color", inline="W5_colors", group=GROUP_WEDNESDAY)
opC5 = input.color(color.new(color.gray, 0), "Open Color", inline="W5_colors", group=GROUP_WEDNESDAY)

// ───── MIDNIGHT LEVELS ───────────────────────────────────────────────────────
GROUP_MIDNIGHT = "Midnight Levels (18:00 EST)"
showMidnightLevelsInput = input.bool(true, 'Show Midnight Levels', group=GROUP_MIDNIGHT, tooltip='Shows the high and low of the 00:00 (UTC+2) candle on the 15m timeframe.')
midnightLookbackDaysInput = input.int(21, 'Lookback (Days)', group=GROUP_MIDNIGHT, minval=1, tooltip='Number of past days to show the midnight levels for.')
midnightHighColorInput = input.color(color.new(color.orange, 50), 'High Color', group=GROUP_MIDNIGHT, inline='midnight_high')
midnightHighStyleInput = input.string("Solid", 'High Style', group=GROUP_MIDNIGHT, options=["Solid", "Dashed", "Dotted"], inline='midnight_high')
midnightLowColorInput = input.color(color.new(color.purple, 50), 'Low Color', group=GROUP_MIDNIGHT, inline='midnight_low')
midnightLowStyleInput = input.string("Solid", 'Low Style', group=GROUP_MIDNIGHT, options=["Solid", "Dashed", "Dotted"], inline='midnight_low')
midnightHighLabelColorInput = input.color(color.new(color.orange, 0), 'High Label Color', group=GROUP_MIDNIGHT)
midnightLowLabelColorInput = input.color(color.new(color.purple, 0), 'Low Label Color', group=GROUP_MIDNIGHT)
midnightLabelSizeInput = input.string("Tiny", 'Label Text Size', group=GROUP_MIDNIGHT, options=["Tiny","Small","Normal","Large","Huge"])

// ───── NY PREMARKET LEVELS ───────────────────────────────────────────────────
GROUP_NY_PREMARKET = "NY PreMarket Levels (08:00 EST)"
showNYPreMarketLevelsInput = input.bool(false, 'Show NY PreMarket Levels', group=GROUP_NY_PREMARKET, tooltip='Shows the high and low of the 14:00 (UTC+2) candle on the 15m timeframe.')
nyPreMarketLookbackDaysInput = input.int(21, 'Lookback (Days)', group=GROUP_NY_PREMARKET, minval=1, tooltip='Number of past days to show the NY PreMarket levels for.')
nyPreMarketHighColorInput = input.color(color.new(color.purple, 50), 'High Color', group=GROUP_NY_PREMARKET, inline='ny_high')
nyPreMarketHighStyleInput = input.string("Solid", 'High Style', group=GROUP_NY_PREMARKET, options=["Solid", "Dashed", "Dotted"], inline='ny_high')
nyPreMarketLowColorInput = input.color(color.new(color.blue, 50), 'Low Color', group=GROUP_NY_PREMARKET, inline='ny_low')
nyPreMarketLowStyleInput = input.string("Solid", 'Low Style', group=GROUP_NY_PREMARKET, options=["Solid", "Dashed", "Dotted"], inline='ny_low')
nyPreMarketHighLabelColorInput = input.color(color.new(color.purple, 0), 'High Label Color', group=GROUP_NY_PREMARKET)
nyPreMarketLowLabelColorInput = input.color(color.new(color.blue, 0), 'Low Label Color', group=GROUP_NY_PREMARKET)
nyPreMarketLabelSizeInput = input.string("Tiny", 'Label Text Size', group=GROUP_NY_PREMARKET, options=["Tiny","Small","Normal","Large","Huge"])

// ───── DAILY MARKET SESSION LEVELS ──────────────────────────────────────────
GROUP_DAILY_SESSIONS = "Daily Market Session Levels"
showDailySessions = input.bool(false, "Show Daily Session Levels", group=GROUP_DAILY_SESSIONS, tooltip="Master switch for all daily market session levels")
dailyLookbackDaysInput = input.int(14, "Lookback (Days)", group=GROUP_DAILY_SESSIONS, minval=1, tooltip="Number of past days to show daily session levels")

// ───── ASIAN SESSION ────────────────────────────────────────────────────────
GROUP_ASIAN_SESSION = "Asian Session"
showTokyoOpen = input.bool(false, "Tokyo Open (04:00 EST)", group=GROUP_ASIAN_SESSION, tooltip="Tokyo market open levels")
tokyoHighColor = input.color(color.new(color.yellow, 50), "High Color", group=GROUP_ASIAN_SESSION, inline="tokyo_colors")
tokyoLowColor = input.color(color.new(color.yellow, 50), "Low Color", group=GROUP_ASIAN_SESSION, inline="tokyo_colors")

showAsianPhysicalOpen = input.bool(false, "Asian Physical Open (20:00 EST)", group=GROUP_ASIAN_SESSION, tooltip="Shanghai Gold Exchange opens - largest physical gold demand globally")
asianPhysicalHighColor = input.color(color.new(color.orange, 50), "High Color", inline="asian_physical_colors", group=GROUP_ASIAN_SESSION)
asianPhysicalLowColor = input.color(color.new(color.orange, 50), "Low Color", inline="asian_physical_colors", group=GROUP_ASIAN_SESSION)

// ───── LONDON SESSION ───────────────────────────────────────────────────────
GROUP_LONDON_SESSION = "London Session"
showLondonPreOpen = input.bool(false, "London Pre-Open (07:00 EST)", group=GROUP_LONDON_SESSION, tooltip="London pre-market levels")
londonPreHighColor = input.color(color.new(color.navy, 50), "High Color", group=GROUP_LONDON_SESSION, inline="london_pre_colors")
londonPreLowColor = input.color(color.new(color.navy, 50), "Low Color", group=GROUP_LONDON_SESSION, inline="london_pre_colors")

showLondonMorningFix = input.bool(false, "London Morning Fix (11:00 EST)", group=GROUP_LONDON_SESSION, tooltip="London morning fix levels")
londonMornHighColor = input.color(color.new(color.blue, 50), "High Color", group=GROUP_LONDON_SESSION, inline="london_morn_colors")
londonMornLowColor = input.color(color.new(color.blue, 50), "Low Color", group=GROUP_LONDON_SESSION, inline="london_morn_colors")

showLondonGoldFixMorning = input.bool(false, "London Gold Fix Morning (10:30 EST)", group=GROUP_LONDON_SESSION, tooltip="Most critical gold level - LBMA morning fix")
londonGoldMornHighColor = input.color(color.new(color.orange, 50), "High Color", inline="gold_morn_colors", group=GROUP_LONDON_SESSION)
londonGoldMornLowColor = input.color(color.new(color.orange, 50), "Low Color", inline="gold_morn_colors", group=GROUP_LONDON_SESSION)

showLondonAfternoonFix = input.bool(false, "London Gold Fix Afternoon (15:00 EST)", group=GROUP_LONDON_SESSION, tooltip="Most critical gold level - LBMA afternoon fix")
londonAftHighColor = input.color(color.new(color.orange, 50), "High Color", group=GROUP_LONDON_SESSION, inline="london_aft_colors")
londonAftLowColor = input.color(color.new(color.orange, 50), "Low Color", group=GROUP_LONDON_SESSION, inline="london_aft_colors")

// ───── NEW YORK SESSION ────────────────────────────────────────────────────
GROUP_NY_SESSION = "New York Session"
showNYSEClose = input.bool(false, "NYSE Close (16:00 EST)", group=GROUP_NY_SESSION, tooltip="NYSE market close levels")
nyseHighColor = input.color(color.new(color.green, 50), "High Color", group=GROUP_NY_SESSION, inline="nyse_colors")
nyseLowColor = input.color(color.new(color.green, 50), "Low Color", group=GROUP_NY_SESSION, inline="nyse_colors")

showCMESettlement = input.bool(false, "CME Settlement (16:30 EST)", group=GROUP_NY_SESSION, tooltip="CME futures settlement levels")
cmeHighColor = input.color(color.new(color.maroon, 50), "High Color", group=GROUP_NY_SESSION, inline="cme_colors")
cmeLowColor = input.color(color.new(color.maroon, 50), "Low Color", group=GROUP_NY_SESSION, inline="cme_colors")

// ───── GLOBEX SESSION ───────────────────────────────────────────────────────
GROUP_GLOBEX_SESSION = "Globex Session"
showGlobexRoll = input.bool(false, "Globex Roll (20:00 EST)", group=GROUP_GLOBEX_SESSION, tooltip="Globex futures roll levels")
globexHighColor = input.color(color.new(color.silver, 50), "High Color", group=GROUP_GLOBEX_SESSION, inline="globex_colors")
globexLowColor = input.color(color.new(color.silver, 50), "Low Color", group=GROUP_GLOBEX_SESSION, inline="globex_colors")

// ───── WEDNESDAY ECONOMIC EVENTS ────────────────────────────────────────────
GROUP_WEDNESDAY_EVENTS = "Wednesday Economic Events"
showWednesdayEvents = input.bool(false, "Show Wednesday Events", group=GROUP_WEDNESDAY_EVENTS, tooltip="Master switch for Wednesday-specific economic events")
wednesdayLookbackDaysInput = input.int(8, "Lookback (Days)", group=GROUP_WEDNESDAY_EVENTS, minval=1, tooltip="Number of past Wednesdays to show event levels")

// EIA Oil Inventory (10:30 EST / 16:30 UTC+2)
showEIAOil = input.bool(false, "EIA Oil Inventory (10:30 EST)", group=GROUP_WEDNESDAY_EVENTS, inline="eia")
eiaHighColor = input.color(color.new(color.orange, 50), "High Color", inline="eia_colors")
eiaLowColor = input.color(color.new(color.orange, 50), "Low Color", inline="eia_colors")
eiaWidth = input.int(1, "Line Width", minval=1, maxval=4, inline="eia_colors")

// FOMC Announcements (14:00 EST / 20:00 UTC+2)
showFOMC = input.bool(false, "FOMC Announcements (14:00 EST)", group=GROUP_WEDNESDAY_EVENTS, inline="fomc")
fomcHighColor = input.color(color.new(color.red, 50), "High Color", inline="fomc_colors")
fomcLowColor = input.color(color.new(color.red, 50), "Low Color", inline="fomc_colors")
fomcWidth = input.int(1, "Line Width", minval=1, maxval=4, inline="fomc_colors")

// ───── FRIDAY ECONOMIC EVENTS ──────────────────────────────────────────────
GROUP_FRIDAY_EVENTS = "Friday Economic Events"
showFridayEvents = input.bool(false, "Show Friday Events", group=GROUP_FRIDAY_EVENTS, tooltip="Master switch for Friday-specific economic events")
fridayLookbackDaysInput = input.int(8, "Lookback (Days)", group=GROUP_FRIDAY_EVENTS, minval=1, tooltip="Number of past Fridays to show event levels")

// Non-Farm Payrolls (08:30 EST / 14:30 UTC+2)
showNFP = input.bool(false, "Non-Farm Payrolls (08:30 EST)", group=GROUP_FRIDAY_EVENTS, inline="nfp")
nfpHighColor = input.color(color.new(color.lime, 50), "High Color", inline="nfp_colors")
nfpLowColor = input.color(color.new(color.lime, 50), "Low Color", inline="nfp_colors")
nfpWidth = input.int(1, "Line Width", minval=1, maxval=4, inline="nfp_colors")

// Quadruple-Witch Settlement (15:00 EST / 21:00 UTC+2)
showQuadWitch = input.bool(false, "Quadruple-Witch Settlement (15:00 EST)", group=GROUP_FRIDAY_EVENTS, inline="quad")
quadHighColor = input.color(color.new(color.fuchsia, 50), "High Color", inline="quad_colors")
quadLowColor = input.color(color.new(color.fuchsia, 50), "Low Color", inline="quad_colors")
quadWidth = input.int(1, "Line Width", minval=1, maxval=4, inline="quad_colors")


// ───── GENERAL SETTINGS ──────────────────────────────────────────────────────
GROUP_GENERAL = "General Settings"
extendRight = input.bool(true, "Extend Lines into Future", group=GROUP_GENERAL)
labelText   = input.bool(true, "Show Date Labels", group=GROUP_GENERAL)
labelSize   = input.string("Tiny", "Label Size", options=["Tiny","Small","Normal","Large","Huge"], group=GROUP_GENERAL)
wednesdayLabelOffset = input.int(5, "Wednesday Label Offset", group=GROUP_GENERAL, tooltip="Number of bars to offset the Wednesday labels to the right.", minval=0)

// Alert Settings
sendEmail   = input.bool(false,  "Send Email",         group=GROUP_GENERAL)
sendPush    = input.bool(false,  "Send Push",          group=GROUP_GENERAL)
alertCooldown = input.int(30,    "Cooldown (sec)", minval=5, group=GROUP_GENERAL,
                       tooltip="Seconds between duplicate alerts")

// Interaction Visuals
showWickInteractions = input.bool(true, "Show Wick Interactions", group=GROUP_GENERAL, tooltip="Master switch to show/hide all wick interaction markers.")
interactionMarkerStyle = input.string("Circle", "Marker Style", options=["Circle", "Square", "Diamond", "Triangle Up", "Triangle Down"], group=GROUP_GENERAL)
interactionMarkerSize = input.string("Tiny", "Marker Size", options=["Tiny", "Small", "Normal", "Large", "Huge"], group=GROUP_GENERAL)

// Global Line Width
globalLineWidth = input.int(2, "Global Line Width", group=GROUP_GENERAL, minval=1, maxval=6, tooltip="Controls the width of all keylevel lines")

// ───── LEVEL OPTIMIZATION ────────────────────────────────────────────────────
GROUP_OPTIMIZATION = "Level Optimization"
enableLevelFiltering = input.bool(false, "Enable Level Filtering", group=GROUP_OPTIMIZATION, tooltip="Show only X levels above and below current price to reduce chart noise")
levelsAbovePrice = input.int(3, "Levels Above Price", group=GROUP_OPTIMIZATION, minval=1, maxval=20, tooltip="Number of levels to show above current ASK price")
levelsBelowPrice = input.int(3, "Levels Below Price", group=GROUP_OPTIMIZATION, minval=1, maxval=20, tooltip="Number of levels to show below current ASK price")

// ───── PLAYBOOK ───────────────────────────────────────────────────────────────
GROUP_PLAYBOOK = "Playbook"
enablePlaybookMode = input.bool(false, "Enable Playbook Mode", group=GROUP_PLAYBOOK, tooltip="Activate semi-automated trading playbook for gold institutional levels")
playbookAlertDistance = input.float(3.0, "Level Proximity Alert (points)", group=GROUP_PLAYBOOK, minval=0.1, maxval=20.0, tooltip="Alert when price approaches levels within this distance. For Gold at $2000+, use 3-5 points")
playbookSessionStrategy = input.bool(true, "Show Session Strategy", group=GROUP_PLAYBOOK, tooltip="Display current session trading strategy")
playbookLevelHierarchy = input.bool(true, "Show Level Hierarchy", group=GROUP_PLAYBOOK, tooltip="Display Tier 1/2/3 level classification")

// Gold Fix Priority Settings
showGoldFixPriority = input.bool(true, "Gold Fix Priority Mode", group=GROUP_PLAYBOOK, tooltip="Enhanced visibility for gold fix levels")
goldFixAlertPriority = input.bool(true, "Gold Fix Alert Priority", group=GROUP_PLAYBOOK, tooltip="Immediate alerts for gold fix level touches")

// ───── CONSTANTS ─────────────────────────────────────────────────────────────
TARGET_TIMEZONE = "UTC+2"
DAYOFWED        = 4 // 1=Sun, 2=Mon, 3=Tue, 4=Wed, 5=Thu, 6=Fri, 7=Sat
DAYOFFRI        = 6 // Friday
MS_IN_DAY       = 24 * 60 * 60 * 1000

// ───── HELPER FUNCTIONS ──────────────────────────────────────────────────────
f_size_str_to_const(size_str) =>
    switch size_str
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge
        => size.auto

getStyle(string style) =>
    switch style
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid
      
getMarkerStyle(string style) =>
    switch style
        "Circle"        => label.style_circle
        "Square"        => label.style_square
        "Diamond"       => label.style_diamond
        "Triangle Up"   => label.style_triangleup
        "Triangle Down" => label.style_triangledown
        => label.style_circle

// ───── DATA STRUCTURES ───────────────────────────────────────────────────────
type midnightLevel
    float high
    float low
    int barTime

type nyPreMarketLevel
    float high
    float low
    int barTime

type dailySessionLevel
    float high
    float low
    int barTime
    string sessionName

type wednesdayEventLevel
    float high
    float low
    int barTime
    string eventName

type fridayEventLevel
    float high
    float low
    int barTime
    string eventName

type indexDistance
    int idx
    float dist

type wedIndexDistance
    int idx
    float dist

// ───── STORAGE ───────────────────────────────────────────────────────────────
var float[] hiPrice  = array.new_float()
var float[] loPrice  = array.new_float()
var float[] opPrice  = array.new_float()
var int[]   eventTimes = array.new_int()
var int[]   wedRank  = array.new_int()
var string[] dateLbl = array.new_string()

// Midnight Levels Storage
var array<midnightLevel> midnightLevels = array.new<midnightLevel>()
var array<line> midnightHighLines = array.new<line>()
var array<line> midnightLowLines = array.new<line>()
var array<label> midnightHighLabels = array.new<label>()
var array<label> midnightLowLabels = array.new<label>()

// NY PreMarket Levels Storage

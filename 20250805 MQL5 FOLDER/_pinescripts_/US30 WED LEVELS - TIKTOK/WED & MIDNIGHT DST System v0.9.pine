    fomcTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 20, 0)
    array.push(fomcLevels, wednesdayEventLevel.new(fomc_h_req, fomc_l_req, fomcTimestamp, "FOMC"))
    
    while array.size(fomcLevels) > wednesdayLookbackDaysInput
        array.shift(fomcLevels)

// ───── FRIDAY ECONOMIC EVENTS LOGIC ────────────────────────────────────────
// Non-Farm Payrolls (08:30 EST / 14:30 UTC+2)
varip float nfpHigh_15m = na
varip float nfpLow_15m = na
isNFPCandle = timeframe.isintraday and timeframe.multiplier == 15 and dayofweek(time, TARGET_TIMEZONE) == DAYOFFRI and hour(time, TARGET_TIMEZONE) == 14 and minute(time, TARGET_TIMEZONE) == 30
if isNFPCandle
    nfpHigh_15m := high
    nfpLow_15m := low

[nfp_h_req, nfp_l_req] = request.security(syminfo.tickerid, "15", [nfpHigh_15m[1], nfpLow_15m[1]], lookahead=barmerge.lookahead_off)
isNewNFPData = not na(nfp_h_req) and (array.size(nfpLevels) > 0 ? nfp_h_req != array.last(nfpLevels).high : true)

if isNewNFPData
    nfpTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 14, 30)
    array.push(nfpLevels, fridayEventLevel.new(nfp_h_req, nfp_l_req, nfpTimestamp, "NFP"))
    
    while array.size(nfpLevels) > fridayLookbackDaysInput
        array.shift(nfpLevels)

// Quadruple-Witch Settlement (15:00 EST / 21:00 UTC+2)
varip float quadHigh_15m = na
varip float quadLow_15m = na
isQuadCandle = timeframe.isintraday and timeframe.multiplier == 15 and dayofweek(time, TARGET_TIMEZONE) == DAYOFFRI and hour(time, TARGET_TIMEZONE) == 21 and minute(time, TARGET_TIMEZONE) == 0
if isQuadCandle
    quadHigh_15m := high
    quadLow_15m := low

[quad_h_req, quad_l_req] = request.security(syminfo.tickerid, "15", [quadHigh_15m[1], quadLow_15m[1]], lookahead=barmerge.lookahead_off)
isNewQuadData = not na(quad_h_req) and (array.size(quadWitchLevels) > 0 ? quad_h_req != array.last(quadWitchLevels).high : true)

if isNewQuadData
    quadTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 21, 0)
    array.push(quadWitchLevels, fridayEventLevel.new(quad_h_req, quad_l_req, quadTimestamp, "Quad Witch"))
    
    while array.size(quadWitchLevels) > fridayLookbackDaysInput
        array.shift(quadWitchLevels)

// ───── WICK-REACTION ALERT ENGINE ────────────────────────────────────────────
if barstate.isconfirmed
    min_oc = math.min(open, close)
    max_oc = math.max(open, close)
    canSend = timenow - lastAlertTime >= alertCooldown * 1000
    sent = false

    // Wednesday lines
    if array.size(eventTimes) > 0
        for i = 0 to array.size(eventTimes) - 1
            w = array.get(wedRank, i)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h = array.get(hiPrice, i)
            l = array.get(loPrice, i)
            o = array.get(opPrice, i)
            dStr = array.get(dateLbl, i)

            if showWednesdays and (high >= h and low <= h) and (h > max_oc or h < min_oc)
                hiCol = switch w
                    1 => hiC1
                    2 => hiC2
                    3 => hiC3
                    4 => hiC4
                    5 => hiC5
                    => na
                if showWickInteractions
                    label.new(time, h, "", xloc=xloc.bar_time, yloc=yloc.price, style=actualMarkerStyle, color=hiCol, size=actualMarkerSize)
                if canSend
                    sent := true, msg = str.format("WICK TOUCH – {0} Wednesday HIGH ({1})", dStr, syminfo.ticker)
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

            if showWednesdays and (high >= l and low <= l) and (l > max_oc or l < min_oc)
                loCol = switch w
                    1 => loC1
                    2 => loC2
                    3 => loC3
                    4 => loC4
                    5 => loC5
                    => na
                if showWickInteractions
                    label.new(time, l, "", xloc=xloc.bar_time, yloc=yloc.price, style=actualMarkerStyle, color=loCol, size=actualMarkerSize)
                if canSend
                    sent := true, msg = str.format("WICK TOUCH – {0} Wednesday LOW ({1})", dStr, syminfo.ticker)
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

            if showWednesdayOpen and (high >= o and low <= o) and (o > max_oc or o < min_oc)
                opCol = switch w
                    1 => opC1
                    2 => opC2
                    3 => opC3
                    4 => opC4
                    5 => opC5
                    => na
                if showWickInteractions
                    label.new(time, o, "", xloc=xloc.bar_time, yloc=yloc.price, style=actualMarkerStyle, color=opCol, size=actualMarkerSize)
                if canSend
                    sent := true, msg = str.format("WICK TOUCH – {0} Wednesday OPEN ({1})", dStr, syminfo.ticker)
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

    // Midnight lines
    if array.size(midnightLevels) > 0 and showMidnightLevelsInput
        for i = 0 to array.size(midnightLevels) - 1
            levelData = array.get(midnightLevels, i)
            h = levelData.high, l = levelData.low
            if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                sent := true, msg = "WICK TOUCH – Midnight HIGH (" + syminfo.ticker + ")"
                if sendEmail 
                    alert(msg, alert.freq_once_per_bar)
                if sendPush 
                    alert(msg, alert.freq_once_per_bar)
            if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                sent := true, msg = "WICK TOUCH – Midnight LOW (" + syminfo.ticker + ")"
                if sendEmail 
                    alert(msg, alert.freq_once_per_bar)
                if sendPush 
                    alert(msg, alert.freq_once_per_bar)

    // NY PreMarket lines
    if array.size(nyPreMarketLevels) > 0 and showNYPreMarketLevelsInput
        for i = 0 to array.size(nyPreMarketLevels) - 1
            levelData = array.get(nyPreMarketLevels, i)
            h = levelData.high, l = levelData.low

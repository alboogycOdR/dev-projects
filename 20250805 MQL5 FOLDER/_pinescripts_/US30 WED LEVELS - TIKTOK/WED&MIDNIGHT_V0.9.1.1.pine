if isQuadCandle
    quadHigh_15m := high
    quadLow_15m := low

[quad_h_req, quad_l_req] = request.security(syminfo.tickerid, "15", [quadHigh_15m[1], quadLow_15m[1]], lookahead=barmerge.lookahead_off)
isNewQuadData = not na(quad_h_req) and (array.size(quadWitchLevels) > 0 ? quad_h_req != array.last(quadWitchLevels).high : true)

if isNewQuadData
    quadTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 21, 0)
    array.push(quadWitchLevels, fridayEventLevel.new(quad_h_req, quad_l_req, quadTimestamp, "Quad Witch"))
    
    while array.size(quadWitchLevels) > fridayLookbackDaysInput
        array.shift(quadWitchLevels)

// ───── WICK-REACTION ALERT ENGINE (REFACTORED) ─────────────────────────────────
if barstate.isconfirmed
    min_oc = math.min(open, close)
    max_oc = math.max(open, close)
    alertSentInThisBar = false

    // Process levels inline (functions cannot be defined inside conditional blocks)

    // Wednesday lines
    if showWednesdays and array.size(eventTimes) > 0
        for i = 0 to array.size(eventTimes) - 1
            w = array.get(wedRank, i)
            show = switch w
                1 => showW1, 
                2 => showW2, 
                3 => showW3, 
                4 => showW4, 
                5 => showW5 
                => false
            if show
                h = array.get(hiPrice, i), l = array.get(loPrice, i), o = array.get(opPrice, i), dStr = array.get(dateLbl, i)
                hiCol = switch w
                    1 => hiC1, 
                    2 => hiC2, 
                    3 => hiC3, 
                    4 => hiC4, 
                    5 => hiC5 
                    => na
                loCol = switch w
                    1 => loC1, 
                    2 => loC2, 
                    3 => loC3, 
                    4 => loC4, 
                    5 => loC5 
                    => na
                opCol = switch w
                    1 => opC1, 
                    2 => opC2, 
                    3 => opC3, 
                    4 => opC4, 
                    5 => opC5 
                    => na

                if f_checkAndAlert(h, dStr + " Wednesday HIGH", hiCol, min_oc, max_oc)
                    alertSentInThisBar := true
                if f_checkAndAlert(l, dStr + " Wednesday LOW", loCol, min_oc, max_oc)
                    alertSentInThisBar := true
                if showWednesdayOpen and f_checkAndAlert(o, dStr + " Wednesday OPEN", opCol, min_oc, max_oc)
                    alertSentInThisBar := true

    // Midnight levels
    if showMidnightLevelsInput
        if processLevels(midnightLevels, "Midnight", midnightHighColorInput, midnightLowColorInput, min_oc, max_oc)
            alertSentInThisBar := true
    // NY PreMarket lines
    if showNYPreMarketLevelsInput
        if processLevels(nyPreMarketLevels, "NY PreMarket", nyPreMarketHighColorInput, nyPreMarketLowColorInput, min_oc, max_oc)
            alertSentInThisBar := true

    // Daily Session Levels
    if showDailySessions
        if showTokyoOpen
            if processLevels(tokyoLevels, "Tokyo Open", tokyoHighColor, tokyoLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showLondonPreOpen
            if processLevels(londonPreLevels, "London Pre-Open", londonPreHighColor, londonPreLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showLondonMorningFix
            if processLevels(londonMornLevels, "London Morning Fix", londonMornHighColor, londonMornLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showLondonAfternoonFix
            if processLevels(londonAftLevels, "London Afternoon Fix", londonAftHighColor, londonAftLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showNYSEClose
            if processLevels(nyseLevels, "NYSE Close", nyseHighColor, nyseLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showCMESettlement
            if processLevels(cmeLevels, "CME Settlement", cmeHighColor, cmeLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showGlobexRoll
            if processLevels(globexLevels, "Globex Roll", globexHighColor, globexLowColor, min_oc, max_oc)
                alertSentInThisBar := true

    // Wednesday Events
    if showWednesdayEvents
        if showEIAOil
            if processLevels(eiaLevels, "EIA Oil Inventory", eiaHighColor, eiaLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showFOMC
            if processLevels(fomcLevels, "FOMC Announcement", fomcHighColor, fomcLowColor, min_oc, max_oc)
                alertSentInThisBar := true

    // Friday Events
    if showFridayEvents
        if showNFP
            if processLevels(nfpLevels, "NFP", nfpHighColor, nfpLowColor, min_oc, max_oc)
                alertSentInThisBar := true
        if showQuadWitch
            if processLevels(quadWitchLevels, "Quad Witch", quadHighColor, quadLowColor, min_oc, max_oc)
                alertSentInThisBar := true

    // Update the master cooldown timer ONCE if any alert was sent in this bar
    if alertSentInThisBar
        lastAlertTime := timenow

// ───── EXECUTION & DRAWING ───────────────────────────────────────────────────
if barstate.islast
    // --- Cleanup previous drawings ---
    for id in wednesdayHighLines
        line.delete(id)
    for id in wednesdayLowLines
        line.delete(id)
    for id in wednesdayOpenLines
        line.delete(id)
    for id in wednesdayHighLabels
        label.delete(id)
    for id in wednesdayLowLabels
        label.delete(id)
    for id in wednesdayOpenLabels
        label.delete(id)

    array.clear(wednesdayHighLines), array.clear(wednesdayLowLines), array.clear(wednesdayOpenLines)
    array.clear(wednesdayHighLabels), array.clear(wednesdayLowLabels), array.clear(wednesdayOpenLabels)

    // --- Cleanup Daily Session Lines and Labels ---
    for id in tokyoHighLines
        line.delete(id)
    for id in tokyoLowLines
        line.delete(id)
    for id in tokyoHighLabels
        label.delete(id)
    for id in tokyoLowLabels
        label.delete(id)

    for id in londonPreHighLines
        line.delete(id)
    for id in londonPreLowLines
        line.delete(id)
    for id in londonPreHighLabels
        label.delete(id)
    for id in londonPreLowLabels
        label.delete(id)

    for id in londonMornHighLines
        line.delete(id)
    for id in londonMornLowLines
        line.delete(id)
    for id in londonMornHighLabels
        label.delete(id)
    for id in londonMornLowLabels
        label.delete(id)

    for id in londonAftHighLines
        line.delete(id)
    for id in londonAftLowLines
        line.delete(id)
    for id in londonAftHighLabels
        label.delete(id)
    for id in londonAftLowLabels
        label.delete(id)

    for id in nyseHighLines
        line.delete(id)
    for id in nyseLowLines
        line.delete(id)
    for id in nyseHighLabels
        label.delete(id)
    for id in nyseLowLabels
        label.delete(id)

    for id in cmeHighLines
        line.delete(id)
    for id in cmeLowLines
        line.delete(id)
    for id in cmeHighLabels
        label.delete(id)
    for id in cmeLowLabels
        label.delete(id)

    for id in globexHighLines
        line.delete(id)
    for id in globexLowLines
        line.delete(id)
    for id in globexHighLabels
        label.delete(id)
    for id in globexLowLabels
        label.delete(id)

    array.clear(tokyoHighLines), array.clear(tokyoLowLines)
    array.clear(tokyoHighLabels), array.clear(tokyoLowLabels)
    array.clear(londonPreHighLines), array.clear(londonPreLowLines)
    array.clear(londonPreHighLabels), array.clear(londonPreLowLabels)
    array.clear(londonMornHighLines), array.clear(londonMornLowLines)
    array.clear(londonMornHighLabels), array.clear(londonMornLowLabels)
    array.clear(londonAftHighLines), array.clear(londonAftLowLines)
    array.clear(londonAftHighLabels), array.clear(londonAftLowLabels)
    array.clear(nyseHighLines), array.clear(nyseLowLines)
    array.clear(nyseHighLabels), array.clear(nyseLowLabels)
    array.clear(cmeHighLines), array.clear(cmeLowLines)
    array.clear(cmeHighLabels), array.clear(cmeLowLabels)
    array.clear(globexHighLines), array.clear(globexLowLines)
    array.clear(globexHighLabels), array.clear(globexLowLabels)

    if (showWednesdays or showWednesdayOpen) and array.size(eventTimes) > 0
        filteredIndices = array.new_int()

        if enableLevelFiltering
            currentPrice = close
            
            // Create array of indices with their minimum distances
            array<wedIndexDistance> wednesdayDistances = array.new<wedIndexDistance>()
            
            for i = 0 to array.size(eventTimes) - 1
                h = array.get(hiPrice, i)
                l = array.get(loPrice, i)
                o = array.get(opPrice, i)
                minDist = math.min(math.abs(h - currentPrice), math.abs(l - currentPrice), math.abs(o - currentPrice))
                array.push(wednesdayDistances, wedIndexDistance.new(i, minDist))
            
            // Sort by distance using bubble sort
            n = array.size(wednesdayDistances)
            for i = 0 to n - 2
                for j = 0 to n - i - 2
                    if array.get(wednesdayDistances, j).dist > array.get(wednesdayDistances, j + 1).dist
                        temp = array.get(wednesdayDistances, j)
                        array.set(wednesdayDistances, j, array.get(wednesdayDistances, j + 1))
                        array.set(wednesdayDistances, j + 1, temp)
            
            // Separate into above and below
            aboveIndices = array.new_int()
            belowIndices = array.new_int()
            
            for i = 0 to array.size(wednesdayDistances) - 1
                item = array.get(wednesdayDistances, i)
                h = array.get(hiPrice, item.idx)
                l = array.get(loPrice, item.idx)
                o = array.get(opPrice, item.idx)
                if h >= currentPrice or l >= currentPrice or o >= currentPrice
                    array.push(aboveIndices, item.idx)
                if h <= currentPrice or l <= currentPrice or o <= currentPrice
                    array.push(belowIndices, item.idx)

            // Take the required number of levels
            if array.size(aboveIndices) > 0
                for i = 0 to math.min(array.size(aboveIndices) - 1, levelsAbovePrice - 1)
                    array.push(filteredIndices, array.get(aboveIndices, i))
            
            if array.size(belowIndices) > 0
                for i = 0 to math.min(array.size(belowIndices) - 1, levelsBelowPrice - 1)
                    idx = array.get(belowIndices, i)
                    if not array.includes(filteredIndices, idx)
                        array.push(filteredIndices, idx)
        else
            for i = 0 to array.size(eventTimes) - 1
                array.push(filteredIndices, i)

        bar_width_ms = time - nz(time[1], time)
        for i = 0 to array.size(filteredIndices) - 1
            originalIndex = array.get(filteredIndices, i)
            w = array.get(wedRank, originalIndex)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h = array.get(hiPrice, originalIndex), l = array.get(loPrice, originalIndex), o = array.get(opPrice, originalIndex)
            t = array.get(eventTimes, originalIndex), dStr = array.get(dateLbl, originalIndex)

            hiCol = switch w
                1 => hiC1
                2 => hiC2
                3 => hiC3
                4 => hiC4
                5 => hiC5
                => na
            loCol = switch w
                1 => loC1
                2 => loC2
                3 => loC3
                4 => loC4
                5 => loC5
                => na
            opCol = switch w
                1 => opC1
                2 => opC2
                3 => opC3
                4 => opC4
                5 => opC5
                => na
            hiW = switch w
                1 => globalLineWidth
                2 => globalLineWidth
                3 => globalLineWidth
                4 => globalLineWidth
                5 => globalLineWidth
                => na
            loW = switch w
                1 => globalLineWidth
                2 => globalLineWidth
                3 => globalLineWidth
                4 => globalLineWidth
                5 => globalLineWidth
                => na
            opW = switch w
                1 => globalLineWidth
                2 => globalLineWidth
                3 => globalLineWidth
                4 => globalLineWidth
                5 => globalLineWidth
                => na
            
            x2 = extendRight ? t + 50 * bar_width_ms : t + MS_IN_DAY - 1
            label_x_position = extendRight ? t + (wednesdayLabelOffset + 50) * bar_width_ms : x2
            
            if showWednesdays
                array.push(wednesdayHighLines, line.new(t, h, x2, h, xloc=xloc.bar_time, color=hiCol, width=hiW))

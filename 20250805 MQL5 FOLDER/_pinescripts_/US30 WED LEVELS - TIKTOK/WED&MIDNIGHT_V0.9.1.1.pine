            if i < array.size(wednesdayOpenLabels)
                array.get(wednesdayOpenLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)

// Update midnight lines to extend to current time
if extendRight and showMidnightLevelsInput

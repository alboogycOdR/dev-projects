    if array.size(asianPhysicalLowLines) > 0
        for i = 0 to array.size(asianPhysicalLowLines) - 1
            if i < array.size(asianPhysicalLowLines)
                array.get(asianPhysicalLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // London Pre-Open Lines
    if array.size(londonPreHighLines) > 0
        for i = 0 to array.size(londonPreHighLines) - 1
            if i < array.size(londonPreHighLines)
                array.get(londonPreHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(londonPreLowLines) > 0
        for i = 0 to array.size(londonPreLowLines) - 1
            if i < array.size(londonPreLowLines)
                array.get(londonPreLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // London Gold Fix Morning Lines
    if array.size(londonGoldMornHighLines) > 0
        for i = 0 to array.size(londonGoldMornHighLines) - 1
            if i < array.size(londonGoldMornHighLines)
                array.get(londonGoldMornHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(londonGoldMornLowLines) > 0
        for i = 0 to array.size(londonGoldMornLowLines) - 1
            if i < array.size(londonGoldMornLowLines)
                array.get(londonGoldMornLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // London Morning Fix Lines
    if array.size(londonMornHighLines) > 0
        for i = 0 to array.size(londonMornHighLines) - 1
            if i < array.size(londonMornHighLines)
                array.get(londonMornHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(londonMornLowLines) > 0
        for i = 0 to array.size(londonMornLowLines) - 1
            if i < array.size(londonMornLowLines)
                array.get(londonMornLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // London Afternoon Fix Lines
    if array.size(londonAftHighLines) > 0
        for i = 0 to array.size(londonAftHighLines) - 1
            if i < array.size(londonAftHighLines)
                array.get(londonAftHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(londonAftLowLines) > 0
        for i = 0 to array.size(londonAftLowLines) - 1
            if i < array.size(londonAftLowLines)
                array.get(londonAftLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // NYSE Close Lines
    if array.size(nyseHighLines) > 0
        for i = 0 to array.size(nyseHighLines) - 1
            if i < array.size(nyseHighLines)
                array.get(nyseHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(nyseLowLines) > 0
        for i = 0 to array.size(nyseLowLines) - 1
            if i < array.size(nyseLowLines)
                array.get(nyseLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // CME Settlement Lines
    if array.size(cmeHighLines) > 0
        for i = 0 to array.size(cmeHighLines) - 1
            if i < array.size(cmeHighLines)
                array.get(cmeHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(cmeLowLines) > 0
        for i = 0 to array.size(cmeLowLines) - 1
            if i < array.size(cmeLowLines)
                array.get(cmeLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // Globex Roll Lines
    if array.size(globexHighLines) > 0
        for i = 0 to array.size(globexHighLines) - 1
            if i < array.size(globexHighLines)
                array.get(globexHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(globexLowLines) > 0
        for i = 0 to array.size(globexLowLines) - 1
            if i < array.size(globexLowLines)
                array.get(globexLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // US Data Release Lines (08:30 EST / 14:30 UTC+2) - CRITICAL GOLD LEVEL
    if array.size(usDataReleaseHighLines) > 0
        for i = 0 to array.size(usDataReleaseHighLines) - 1
            if i < array.size(usDataReleaseHighLines)
                array.get(usDataReleaseHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(usDataReleaseLowLines) > 0
        for i = 0 to array.size(usDataReleaseLowLines) - 1
            if i < array.size(usDataReleaseLowLines)
                array.get(usDataReleaseLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // NYSE Open Lines (09:30 EST / 15:30 UTC+2)
    if array.size(nyseOpenHighLines) > 0
        for i = 0 to array.size(nyseOpenHighLines) - 1
            if i < array.size(nyseOpenHighLines)
                array.get(nyseOpenHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(nyseOpenLowLines) > 0
        for i = 0 to array.size(nyseOpenLowLines) - 1
            if i < array.size(nyseOpenLowLines)
                array.get(nyseOpenLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    
    // Institutional Rebalancing Lines (10:00 EST / 16:00 UTC+2)
    if array.size(institutionalRebalHighLines) > 0
        for i = 0 to array.size(institutionalRebalHighLines) - 1
            if i < array.size(institutionalRebalHighLines)
                array.get(institutionalRebalHighLines, i).set_x2(time_close + 50 * bar_width_ms)
    if array.size(institutionalRebalLowLines) > 0
        for i = 0 to array.size(institutionalRebalLowLines) - 1
            if i < array.size(institutionalRebalLowLines)
                array.get(institutionalRebalLowLines, i).set_x2(time_close + 50 * bar_width_ms)

// ───── PLAYBOOK MODE LOGIC ────────────────────────────────────────────────────
if enablePlaybookMode
    // Alert cooldown logic (using existing lastAlertTime from main alert system)
    canSend = (time - lastAlertTime) >= (alertCooldown * 1000)
    
    // DXY Confluence Analysis - Remove 'var' for local variables
    float dxyCorrelation = 0.0
    string dxyBias = ""
    bool dxyConfluenceAlert = false
    float dxyClose = na
    float dxyHigh = na
    float dxyLow = na
    float correlationSum = 0.0
    int validBars = 0
    float goldChange = 0.0
    float dxyChange = 0.0
    dailySessionLevel levelData = na
    float levelPrice = 0.0
    string levelTier = ""
    float distance = 0.0
    string confluenceMsg = ""
    color confluenceColor = color.white
    float liquidityGrabThreshold = 2.0
    int liquidityGrabBars = 3
    color tierColor = color.white
    string alertText = ""
    string msg = ""
    string londonFixAlert = ""
    bool isUSDataReleaseWindow = false
    string usDataAlert = ""
    bool isNYSEOpenWindow = false
    string nyseAlert = ""
    bool isInstitutionalWindow = false
    string instAlert = ""
    
    if enableDXYConfluence
        // Fetch DXY data for correlation analysis
        dxyClose = request.security(dxySymbol, timeframe.period, close, lookahead=barmerge.lookahead_off)
        dxyHigh = request.security(dxySymbol, timeframe.period, high, lookahead=barmerge.lookahead_off)
        dxyLow = request.security(dxySymbol, timeframe.period, low, lookahead=barmerge.lookahead_off)
        
        // Calculate correlation over lookback period
        if not na(dxyClose) and not na(close)
            correlationSum = 0.0
            validBars = 0
            
            for i = 1 to math.min(dxyLookbackPeriod, bar_index)
                if i < bar_index
                    goldChange = (close[i] - close[i+1]) / close[i+1]
                    dxyChange = (dxyClose[i] - dxyClose[i+1]) / dxyClose[i+1]
                    
                    if not na(goldChange) and not na(dxyChange) and dxyChange != 0
                        correlationSum += (goldChange * dxyChange) / (math.abs(goldChange) * math.abs(dxyChange))
                        validBars += 1
            
            if validBars > 0
                dxyCorrelation := correlationSum / validBars
                
                // Determine DXY bias
                if dxyCorrelation < -dxyCorrelationThreshold
                    dxyBias := "INVERSE"  // DXY up = Gold down
                else if dxyCorrelation > dxyCorrelationThreshold
                    dxyBias := "POSITIVE"  // DXY up = Gold up
                else
                    dxyBias := "NEUTRAL"
    
    // Session Strategy Detection
    currentHour = hour(time, TARGET_TIMEZONE)
    currentMinute = minute(time, TARGET_TIMEZONE)
    
    // Determine current session and strategy
    sessionStrategy = ""
    sessionColor = color.white
    
    // Enhanced session strategy with US Data times
    if currentHour >= 2 and currentHour < 8
        sessionStrategy := "ASIAN SESSION - MEAN REVERSION Strategy"
        sessionColor := color.purple
    else if currentHour >= 8 and currentHour < 14
        sessionStrategy := "LONDON SESSION - BREAKOUT Strategy"
        sessionColor := color.blue
    else if currentHour == 14 and currentMinute >= 25 and currentMinute <= 35
        sessionStrategy := "US DATA RELEASE WINDOW - CRITICAL GOLD LEVEL"
        sessionColor := color.red
    else if currentHour == 15 and currentMinute >= 25 and currentMinute <= 35
        sessionStrategy := "NYSE OPEN WINDOW - LIQUIDITY GRAB ZONE"
        sessionColor := color.lime
    else if currentHour == 16 and currentMinute >= 0 and currentMinute <= 10
        sessionStrategy := "INSTITUTIONAL REBALANCING - FLOW DETECTION"
        sessionColor := color.fuchsia
    else if currentHour >= 14 and currentHour < 18
        sessionStrategy := "LONDON/NY OVERLAP - MOMENTUM Strategy"
        sessionColor := color.green
    else if currentHour >= 18 and currentHour < 22
        sessionStrategy := "NY SESSION - RANGE FADE Strategy"
        sessionColor := color.orange
    else if currentHour >= 22 or currentHour < 2
        sessionStrategy := "NY CLOSE - CONSOLIDATION"
        sessionColor := color.gray
    
    // Display session strategy
    if playbookSessionStrategy
        label.new(time, high, sessionStrategy, xloc=xloc.bar_time, yloc=yloc.abovebar, 
                 color=color(na), textcolor=sessionColor, style=label.style_label_down, 
                 size=size.normal, textalign=text.align_center)
    
    // Level Hierarchy Detection and Proximity Alerts
    // Remove 'var' - these should be recreated each bar
    array<float> allLevels = array.new<float>()
    array<string> levelTiers = array.new<string>()
    
    // Collect all active levels with their tiers (always available for DXY confluence and alerts)
    if array.size(tokyoLevels) > 0
        for i = 0 to array.size(tokyoLevels) - 1
            levelData = array.get(tokyoLevels, i)
            array.push(allLevels, levelData.high)
            array.push(allLevels, levelData.low)
            array.push(levelTiers, "TIER 2")
            array.push(levelTiers, "TIER 2")
    
    if array.size(asianPhysicalLevels) > 0
        for i = 0 to array.size(asianPhysicalLevels) - 1
            levelData = array.get(asianPhysicalLevels, i)
            array.push(allLevels, levelData.high)
            array.push(allLevels, levelData.low)
            array.push(levelTiers, "TIER 2")
            array.push(levelTiers, "TIER 2")
    
    if array.size(londonGoldMornLevels) > 0
        for i = 0 to array.size(londonGoldMornLevels) - 1
            levelData = array.get(londonGoldMornLevels, i)
            array.push(allLevels, levelData.high)
            array.push(allLevels, levelData.low)
            array.push(levelTiers, "TIER 1")
            array.push(levelTiers, "TIER 1")
    
    // US Data Release Levels - TIER 1 (CRITICAL GOLD LEVEL)
    if array.size(usDataReleaseLevels) > 0
        for i = 0 to array.size(usDataReleaseLevels) - 1
            levelData = array.get(usDataReleaseLevels, i)
            array.push(allLevels, levelData.high)
            array.push(allLevels, levelData.low)
            array.push(levelTiers, "TIER 1")
            array.push(levelTiers, "TIER 1")
    
    // NYSE Open Levels - TIER 2
    if array.size(nyseOpenLevels) > 0
        for i = 0 to array.size(nyseOpenLevels) - 1
            levelData = array.get(nyseOpenLevels, i)
            array.push(allLevels, levelData.high)
            array.push(allLevels, levelData.low)
            array.push(levelTiers, "TIER 2")
            array.push(levelTiers, "TIER 2")
    
    // Institutional Rebalancing Levels - TIER 2
    if array.size(institutionalRebalLevels) > 0
        for i = 0 to array.size(institutionalRebalLevels) - 1
            levelData = array.get(institutionalRebalLevels, i)
            array.push(allLevels, levelData.high)
            array.push(allLevels, levelData.low)
            array.push(levelTiers, "TIER 2")
            array.push(levelTiers, "TIER 2")
    
    if playbookLevelHierarchy or playbookAlertDistance > 0
        // Check proximity to all active levels
        
        if array.size(londonAftLevels) > 0
            for i = 0 to array.size(londonAftLevels) - 1
                levelData = array.get(londonAftLevels, i)
                array.push(allLevels, levelData.high)
                array.push(allLevels, levelData.low)
                array.push(levelTiers, "TIER 1")
                array.push(levelTiers, "TIER 1")
        
        // Check proximity to levels
        if array.size(allLevels) > 0
            for i = 0 to array.size(allLevels) - 1
                levelPrice = array.get(allLevels, i)
                levelTier = array.get(levelTiers, i)
                
                distance = math.abs(close - levelPrice)
                
                // Proximity alert
                if distance <= playbookAlertDistance
                    tierColor = levelTier == "TIER 1" ? color.red : levelTier == "TIER 2" ? color.orange : color.yellow
                    alertText = str.format("🎯 {0} LEVEL APPROACH: {1} (Distance: {2})", levelTier, str.tostring(levelPrice, format.mintick), str.tostring(distance, "#.##"))
                    
                    if canSend
                        lastAlertTime := time
                        msg = alertText + " - " + syminfo.ticker
                        if sendEmail 
                            alert(msg, alert.freq_once_per_bar)
                        if sendPush 
                            alert(msg, alert.freq_once_per_bar)
                    
                    // Visual indicator
                    label.new(time, levelPrice, levelTier, xloc=xloc.bar_time, yloc=yloc.price, 
                             color=color(na), textcolor=tierColor, style=label.style_label_left, 
                             size=size.small, textalign=text.align_right)
    
    // London Fix Special Detection (10:25-10:35 EST and 14:55-15:05 EST)
    // 10:25-10:35 EST = 16:25-16:35 UTC+2, 14:55-15:05 EST = 20:55-21:05 UTC+2
    isLondonFixWindow = (currentHour == 16 and currentMinute >= 25 and currentMinute <= 35) or 
                       (currentHour == 20 and currentMinute >= 55) or 
                       (currentHour == 21 and currentMinute <= 5)
    
    if isLondonFixWindow
        londonFixAlert = "🔥 LONDON FIX WINDOW ACTIVE - Setup C Brackets Ready"
        if canSend
            lastAlertTime := time
            msg = londonFixAlert + " - " + syminfo.ticker
            if sendEmail 
                alert(msg, alert.freq_once_per_bar)
            if sendPush 
                alert(msg, alert.freq_once_per_bar)
        
        label.new(time, high, "LONDON FIX WINDOW", xloc=xloc.bar_time, yloc=yloc.abovebar, 
                 color=color(na), textcolor=color.red, style=label.style_label_down, 
                 size=size.large, textalign=text.align_center)
    
    // Advanced Alert System
    if enableDataReleaseAlerts
        // US Data Release Window (08:25-08:35 EST / 14:25-14:35 UTC+2)
        isUSDataReleaseWindow = currentHour == 14 and currentMinute >= 25 and currentMinute <= 35
        if isUSDataReleaseWindow and canSend
            lastAlertTime := time
            usDataAlert = "📊 US DATA RELEASE WINDOW - CRITICAL GOLD LEVEL"
            msg = usDataAlert + " - " + syminfo.ticker
            if sendEmail 
                alert(msg, alert.freq_once_per_bar)
            if sendPush 
                alert(msg, alert.freq_once_per_bar)
            
            label.new(time, high, "US DATA RELEASE", xloc=xloc.bar_time, yloc=yloc.abovebar, 
                     color=color(na), textcolor=color.red, style=label.style_label_down, 
                     size=size.large, textalign=text.align_center)
        
        // NYSE Open Window (09:25-09:35 EST / 15:25-15:35 UTC+2)
        isNYSEOpenWindow = currentHour == 15 and currentMinute >= 25 and currentMinute <= 35
        if isNYSEOpenWindow and canSend
            lastAlertTime := time
            nyseAlert = "🏛️ NYSE OPEN WINDOW - LIQUIDITY GRAB ZONE"
            msg = nyseAlert + " - " + syminfo.ticker
            if sendEmail 
                alert(msg, alert.freq_once_per_bar)
            if sendPush 
                alert(msg, alert.freq_once_per_bar)
            
            label.new(time, high, "NYSE OPEN WINDOW", xloc=xloc.bar_time, yloc=yloc.abovebar, 
                     color=color(na), textcolor=color.lime, style=label.style_label_down, 
                     size=size.large, textalign=text.align_center)
        
        // Institutional Rebalancing Window (09:55-10:05 EST / 15:55-16:05 UTC+2)
        isInstitutionalWindow = currentHour == 15 and currentMinute >= 55 or (currentHour == 16 and currentMinute <= 5)
        if isInstitutionalWindow and canSend
            lastAlertTime := time
            instAlert = "🏦 INSTITUTIONAL REBALANCING - FLOW DETECTION"
            msg = instAlert + " - " + syminfo.ticker
            if sendEmail 
                alert(msg, alert.freq_once_per_bar)
            if sendPush 
                alert(msg, alert.freq_once_per_bar)
            
            label.new(time, high, "INSTITUTIONAL WINDOW", xloc=xloc.bar_time, yloc=yloc.abovebar, 
                     color=color(na), textcolor=color.fuchsia, style=label.style_label_down, 
                     size=size.large, textalign=text.align_center)
    
    // DXY Confluence Alerts
    if enableDXYConfluenceAlerts and enableDXYConfluence and dxyBias != ""
        // Check for DXY confluence on level approaches
        if array.size(allLevels) > 0
            for i = 0 to array.size(allLevels) - 1
                levelPrice = array.get(allLevels, i)
                levelTier = array.get(levelTiers, i)
                distance = math.abs(close - levelPrice)
                
                if distance <= playbookAlertDistance
                    // DXY Confluence Analysis
                    confluenceMsg = ""
                    confluenceColor = color.white
                    
                    if dxyBias == "INVERSE"
                        confluenceMsg := "🔴 DXY INVERSE CONFLUENCE - DXY UP = GOLD DOWN"
                        confluenceColor := color.red
                    else if dxyBias == "POSITIVE"
                        confluenceMsg := "🟢 DXY POSITIVE CONFLUENCE - DXY UP = GOLD UP"
                        confluenceColor := color.green
                    else
                        confluenceMsg := "⚪ DXY NEUTRAL - NO CLEAR BIAS"
                        confluenceColor := color.gray
                    
                    if canSend
                        lastAlertTime := time
                        msg = confluenceMsg + " - " + levelTier + " Level: " + str.tostring(levelPrice, format.mintick)
                        if sendEmail 
                            alert(msg, alert.freq_once_per_bar)
                        if sendPush 
                            alert(msg, alert.freq_once_per_bar)
                    
                    // Visual confluence indicator
                    label.new(time, levelPrice, "DXY: " + dxyBias, xloc=xloc.bar_time, yloc=yloc.price, 
                             color=color(na), textcolor=confluenceColor, style=label.style_label_left, 
                             size=size.small, textalign=text.align_right)
    
    // Liquidity Grab Detection
    if enableLiquidityGrabAlerts
        // Detect liquidity grabs (quick spikes above/below levels with sharp rejection)
        liquidityGrabThreshold = 2.0  // 2 points above/below level
        liquidityGrabBars = 3  // Within 3 bars
        
        if array.size(allLevels) > 0
            for i = 0 to array.size(allLevels) - 1
                levelPrice = array.get(allLevels, i)
                levelTier = array.get(levelTiers, i)
                
                // Check for liquidity grab above level
                if high >= levelPrice + liquidityGrabThreshold and close < levelPrice
                    if canSend
                        lastAlertTime := time
                        string grabAlert = "🎯 LIQUIDITY GRAB DETECTED - " + levelTier + " Level Rejected"
                        string grabMsg = grabAlert + " - " + str.tostring(levelPrice, format.mintick) + " - " + syminfo.ticker
                        if sendEmail 
                            alert(grabMsg, alert.freq_once_per_bar)
                        if sendPush 
                            alert(grabMsg, alert.freq_once_per_bar)
                    
                    // Visual liquidity grab indicator
                    label.new(time, high, "LIQUIDITY GRAB", xloc=xloc.bar_time, yloc=yloc.abovebar, 
                             color=color(na), textcolor=color.orange, style=label.style_label_down, 
                             size=size.normal, textalign=text.align_center)
                
                // Check for liquidity grab below level
                if low <= levelPrice - liquidityGrabThreshold and close > levelPrice
                    if canSend
                        lastAlertTime := time
                        string grabAlert = "🎯 LIQUIDITY GRAB DETECTED - " + levelTier + " Level Rejected"
                        string grabMsg = grabAlert + " - " + str.tostring(levelPrice, format.mintick) + " - " + syminfo.ticker
                        if sendEmail 
                            alert(grabMsg, alert.freq_once_per_bar)
                        if sendPush 
                            alert(grabMsg, alert.freq_once_per_bar)
                    
                    // Visual liquidity grab indicator
                    label.new(time, low, "LIQUIDITY GRAB", xloc=xloc.bar_time, yloc=yloc.belowbar, 
                             color=color(na), textcolor=color.orange, style=label.style_label_up, 
                             size=size.normal, textalign=text.align_center)
 
// ───── COMMON VARIABLES ──────────────────────────────────────────────────────
actualLabelSize = f_size_str_to_const(labelSize)
actualMidnightLabelSize = f_size_str_to_const(midnightLabelSizeInput)
actualNYPreMarketLabelSize = f_size_str_to_const(nyPreMarketLabelSizeInput)

// ───── WEDNESDAY LOGIC ───────────────────────────────────────────────────────
f_getTargetTime(int ts) =>
    _year = year(ts, "UTC")
    
    start_dst_day = 8 
    for i = 0 to 6
        if dayofweek(timestamp("UTC", _year, 3, 8 + i, 2, 0)) == dayofweek.sunday
            start_dst_day := 8 + i
            break
    start_dst = timestamp("UTC", _year, 3, start_dst_day, 2, 0)

    end_dst_day = 1
    for i = 0 to 6
        if dayofweek(timestamp("UTC", _year, 11, 1 + i, 2, 0)) == dayofweek.sunday
            end_dst_day := 1 + i
            break
    end_dst = timestamp("UTC", _year, 11, end_dst_day, 2, 0)
    
    _targetHour = (ts >= start_dst and ts < end_dst) ? 19 : 20
    _targetMin = 30
    [_targetHour, _targetMin]

varip float wednesdayHigh_15m = na
varip float wednesdayLow_15m = na
varip float wednesdayOpen_15m = na
varip int wednesdayTime_15m = na
varip int wednesdayCount_15m = na

[targetHour, targetMin] = f_getTargetTime(time)
isWednesday_15m = timeframe.isintraday and timeframe.multiplier == 15 and dayofweek(time, TARGET_TIMEZONE) == DAYOFWED and hour(time, TARGET_TIMEZONE) == targetHour and minute(time, TARGET_TIMEZONE) == targetMin

if isWednesday_15m and barstate.isconfirmed
    currentDay = dayofmonth(time, TARGET_TIMEZONE)
    currentMonth = month(time, TARGET_TIMEZONE)
    currentYear = year(time, TARGET_TIMEZONE)
    wedCount = 0
    for d = 1 to currentDay
        testTime = timestamp(TARGET_TIMEZONE, currentYear, currentMonth, d, 12, 0)
        if month(testTime, TARGET_TIMEZONE) == currentMonth and dayofweek(testTime, TARGET_TIMEZONE) == DAYOFWED
            wedCount += 1
    if wedCount <= 5
        wednesdayHigh_15m := high, wednesdayLow_15m := low, wednesdayOpen_15m := open
        wednesdayTime_15m := time, wednesdayCount_15m := wedCount

[wed_high, wed_low, wed_open, wed_time, wed_count] = request.security(syminfo.tickerid, "15", [wednesdayHigh_15m[1], wednesdayLow_15m[1], wednesdayOpen_15m[1], wednesdayTime_15m[1], wednesdayCount_15m[1]], lookahead=barmerge.lookahead_off)

isNewWednesdayData = not na(wed_high) and not na(wed_count) and (array.size(eventTimes) > 0 ? wed_time != array.last(eventTimes) : true)

if isNewWednesdayData
    array.push(hiPrice, wed_high), array.push(loPrice, wed_low), array.push(opPrice, wed_open)
    array.push(eventTimes, wed_time), array.push(wedRank, wed_count)
    
    currentDay = dayofmonth(wed_time, TARGET_TIMEZONE)
    currentMonth = month(wed_time, TARGET_TIMEZONE)
    
    string monthStr = switch currentMonth
        1 => "Jan"
        2 => "Feb"
        3 => "Mar"
        4 => "Apr"
        5 => "May"
        6 => "Jun"
        7 => "Jul"
        8 => "Aug"
        9 => "Sep"
        10 => "Oct"
        11 => "Nov"
        => "Dec"

    dateStr = str.format("{0} {1}", currentDay, monthStr)
    array.push(dateLbl, dateStr)

// ───── REVISED MIDNIGHT LEVEL LOGIC (Non-Repainting & Efficient) ───────────
varip float midnightHigh_15m = na
varip float midnightLow_15m = na

isMidnightCandle = timeframe.isintraday and timeframe.multiplier == 15 and hour(time, TARGET_TIMEZONE) == 0 and minute(time, TARGET_TIMEZONE) == 0
if isMidnightCandle
    midnightHigh_15m := high
    midnightLow_15m := low

[h_req, l_req] = request.security(syminfo.tickerid, "15", [midnightHigh_15m[1], midnightLow_15m[1]], lookahead=barmerge.lookahead_off)

isNewDataPoint = not na(h_req) and (array.size(midnightLevels) > 0 ? h_req != array.last(midnightLevels).high : true)

if isNewDataPoint
    dayTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 0, 0)
    array.push(midnightLevels, midnightLevel.new(h_req, l_req, dayTimestamp))

    if showMidnightLevelsInput
        bar_width_ms = time - nz(time[1], time)
        x2_time = extendRight ? time_close + 50 * bar_width_ms : dayTimestamp + MS_IN_DAY - 1

        array.push(midnightHighLines, line.new(dayTimestamp, h_req, x2_time, h_req, xloc=xloc.bar_time, color=midnightHighColorInput, width=globalLineWidth, style=getStyle(midnightHighStyleInput)))
        array.push(midnightLowLines, line.new(dayTimestamp, l_req, x2_time, l_req, xloc=xloc.bar_time, color=midnightLowColorInput, width=globalLineWidth, style=getStyle(midnightLowStyleInput)))
        
        if labelText
            dateString = str.format_time(dayTimestamp, "yyyy.MM.dd", TARGET_TIMEZONE)
            highLabelText = str.format("Midnight High {0} {1}", str.tostring(h_req, format.mintick), dateString)
            lowLabelText  = str.format("Midnight Low {0} {1}", str.tostring(l_req, format.mintick), dateString)

            label_x_position = extendRight ? dayTimestamp + 50 * bar_width_ms : x2_time

            array.push(midnightHighLabels, label.new(label_x_position, h_req, highLabelText, xloc=xloc.bar_time, color=color(na), style=label.style_label_right, size=actualMidnightLabelSize, textalign=text.align_right))
            array.push(midnightLowLabels, label.new(label_x_position, l_req, lowLabelText, xloc=xloc.bar_time, color=color(na), style=label.style_label_right, size=actualMidnightLabelSize, textalign=text.align_right))

    while array.size(midnightLevels) > midnightLookbackDaysInput
        array.shift(midnightLevels)
        if array.size(midnightHighLines) > 0
            line.delete(array.shift(midnightHighLines))
            line.delete(array.shift(midnightLowLines))
        if array.size(midnightHighLabels) > 0
            label.delete(array.shift(midnightHighLabels))
            label.delete(array.shift(midnightLowLabels))

// ───── NY PREMARKET LEVEL LOGIC (Non-Repainting & Efficient) ───────────────
varip float nyPreMarketHigh_15m = na
varip float nyPreMarketLow_15m = na

isNYPreMarketCandle = timeframe.isintraday and timeframe.multiplier == 15 and hour(time, TARGET_TIMEZONE) == 14 and minute(time, TARGET_TIMEZONE) == 0
if isNYPreMarketCandle
    nyPreMarketHigh_15m := high
    nyPreMarketLow_15m := low

[ny_h_req, ny_l_req] = request.security(syminfo.tickerid, "15", [nyPreMarketHigh_15m[1], nyPreMarketLow_15m[1]], lookahead=barmerge.lookahead_off)

isNewNYPreMarketDataPoint = not na(ny_h_req) and (array.size(nyPreMarketLevels) > 0 ? ny_h_req != array.last(nyPreMarketLevels).high : true)

if isNewNYPreMarketDataPoint
    // Use 14:00 timestamp instead of 00:00 for NY PreMarket levels
    nyPreMarketTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 14, 0)
    array.push(nyPreMarketLevels, nyPreMarketLevel.new(ny_h_req, ny_l_req, nyPreMarketTimestamp))

    if showNYPreMarketLevelsInput
        x2_time = extendRight ? time_close + 50 * (time_close - nz(time_close[1], time_close)) : nyPreMarketTimestamp + MS_IN_DAY - 1

        array.push(nyPreMarketHighLines, line.new(nyPreMarketTimestamp, ny_h_req, x2_time, ny_h_req, xloc=xloc.bar_time))
        array.push(nyPreMarketLowLines, line.new(nyPreMarketTimestamp, ny_l_req, x2_time, ny_l_req, xloc=xloc.bar_time))
        
        if labelText
            dateString = str.format_time(nyPreMarketTimestamp, "yyyy.MM.dd", TARGET_TIMEZONE)
            highLabelText = str.format("NY PreMarket High {0} {1}", str.tostring(ny_h_req, format.mintick), dateString)
            lowLabelText  = str.format("NY PreMarket Low {0} {1}", str.tostring(ny_l_req, format.mintick), dateString)

            array.push(nyPreMarketHighLabels, label.new(x2_time, ny_h_req, highLabelText, xloc=xloc.bar_time, color=color(na), style=label.style_label_left, size=actualNYPreMarketLabelSize, textalign=text.align_left))
            array.push(nyPreMarketLowLabels, label.new(x2_time, ny_l_req, lowLabelText, xloc=xloc.bar_time, color=color(na), style=label.style_label_left, size=actualNYPreMarketLabelSize, textalign=text.align_left))

    while array.size(nyPreMarketLevels) > nyPreMarketLookbackDaysInput
        array.shift(nyPreMarketLevels)
        if array.size(nyPreMarketHighLines) > 0
            line.delete(array.shift(nyPreMarketHighLines))
            line.delete(array.shift(nyPreMarketLowLines))
        if array.size(nyPreMarketHighLabels) > 0
            label.delete(array.shift(nyPreMarketHighLabels))
            label.delete(array.shift(nyPreMarketLowLabels))


                array.get(midnightLowLines, i).set_x2(time_close + 50 * bar_width_ms)
    if labelText and array.size(midnightHighLabels) > 0
        for i = 0 to array.size(midnightHighLabels) - 1
            if i < array.size(midnightHighLabels)
                array.get(midnightHighLabels, i).set_x(time_close + 50 * bar_width_ms)
    if labelText and array.size(midnightLowLabels) > 0
        for i = 0 to array.size(midnightLowLabels) - 1
            if i < array.size(midnightLowLabels)
                array.get(midnightLowLabels, i).set_x(time_close + 50 * bar_width_ms)

// Update daily session lines to extend to current time
if extendRight and showDailySessions

//@version=5
indicator("Advanced ORB + ICT System v2.0", overlay=true, max_boxes_count=500, max_labels_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS - ENHANCED WITH MODERN ORB CONCEPTS
// ═══════════════════════════════════════════════════════════════════════════════

// Session Settings
sessionType = input.string("New York", "Session Type", options=["New York", "London", "Tokyo", "Custom"], group="Session")
customSession = input.session("0930-1600", "Custom Session", group="Session")
orbDuration = input.string("30", "ORB Duration", options=["5", "15", "30", "60"], group="Session")
usePremarket = input.bool(true, "Include Pre-Market Levels", group="Session")

// Advanced ORB Filters
useRVol = input.bool(true, "Use Relative Volume Filter", group="Advanced Filters")
rvolThreshold = input.float(2.0, "RVol Threshold", minval=1.0, maxval=5.0, step=0.1, group="Advanced Filters")
rvolLookback = input.int(20, "RVol Lookback Days", minval=5, maxval=50, group="Advanced Filters")
useATRFilter = input.bool(true, "Use ATR Range Filter", group="Advanced Filters")
narrowRangeATR = input.float(0.5, "Narrow Range (% of ATR)", minval=0.1, maxval=1.0, group="Advanced Filters")
wideRangeATR = input.float(1.5, "Wide Range (% of ATR)", minval=1.0, maxval=3.0, group="Advanced Filters")

// Entry Methods
entryMethod = input.string("Pullback", "Entry Method", options=["Immediate", "Pullback", "Both"], group="Entry")
waitForClose = input.bool(true, "Wait for Candle Close", group="Entry")
requireBOS = input.bool(true, "Require Break of Structure", group="Entry")
bosLookback = input.int(10, "BOS Lookback Bars", minval=5, maxval=20, group="Entry")

// ICT Integration
useLiquidityGrabs = input.bool(true, "Use Liquidity Grabs", group="ICT Concepts")
showFVG = input.bool(true, "Show Fair Value Gaps", group="ICT Concepts")
showOrderBlocks = input.bool(true, "Show Order Blocks", group="ICT Concepts")
fvgMinSize = input.float(0.3, "FVG Min Size (ATR)", minval=0.1, maxval=1.0, group="ICT Concepts")

// Risk Management
stopMethod = input.string("Structure", "Stop Loss Method", options=["Range", "Structure", "ATR", "Hybrid"], group="Risk")
atrMultiplier = input.float(1.5, "ATR Stop Multiplier", minval=0.5, maxval=3.0, group="Risk")
riskRewardRatio = input.float(2.0, "Default R:R Ratio", minval=1.0, maxval=5.0, group="Risk")
useScaling = input.bool(true, "Enable Scaling Out", group="Risk")
scale1RR = input.float(1.0, "First Scale R:R", minval=0.5, maxval=2.0, group="Risk")
scale2RR = input.float(2.0, "Second Scale R:R", minval=1.5, maxval=5.0, group="Risk")

// Market Structure
useHTFBias = input.bool(true, "Use Higher Timeframe Bias", group="Market Structure")
htfTimeframe = input.timeframe("240", "HTF for Bias", group="Market Structure")
showPrevDayLevels = input.bool(true, "Show Previous Day Levels", group="Market Structure")
showKeyLevels = input.bool(true, "Show Key Liquidity Levels", group="Market Structure")

// Visual Settings
showDashboard = input.bool(true, "Show Dashboard", group="Visuals")
showORBBox = input.bool(true, "Show ORB Box", group="Visuals")
showEntryZones = input.bool(true, "Show Entry Zones", group="Visuals")
orbColor = input.color(color.new(color.blue, 80), "ORB Color", group="Visuals")
bullishColor = input.color(color.new(color.green, 70), "Bullish Color", group="Visuals")
bearishColor = input.color(color.new(color.red, 70), "Bearish Color", group="Visuals")
neutralColor = input.color(color.new(color.gray, 80), "Neutral Color", group="Visuals")

// ═══════════════════════════════════════════════════════════════════════════════
// FUNCTIONS AND CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Session Functions
getSessionString() =>
    switch sessionType
        "New York" => "0930-1600:1234567"
        "London" => "0300-1200:1234567"
        "Tokyo" => "0000-0900:1234567"
        => customSession

isInSession() =>
    sessionString = getSessionString()
    timeZone = sessionType == "Tokyo" ? "Asia/Tokyo" : sessionType == "London" ? "Europe/London" : "America/New_York"
    time(timeframe.period, sessionString, timeZone) != 0

getORBMinutes() =>
    switch orbDuration
        "5" => 5
        "15" => 15
        "30" => 30
        "60" => 60
        => 30

isORBPeriod() =>
    sessionString = getSessionString()
    timeZone = sessionType == "Tokyo" ? "Asia/Tokyo" : sessionType == "London" ? "Europe/London" : "America/New_York"
    sessionStart = time(timeframe.period, sessionString, timeZone)
    if not na(sessionStart)
        timeSinceStart = (time - sessionStart) / 60000
        timeSinceStart <= getORBMinutes()
    else
        false

// ═══════════════════════════════════════════════════════════════════════════════
// RELATIVE VOLUME CALCULATION
// ═══════════════════════════════════════════════════════════════════════════════

// Calculate average volume for this time of day
calculateRVol() =>
    currentHour = hour(time)
    currentMinute = minute(time)
    
    var float[] historicalVolumes = array.new_float()
    
    // Store volume for same time over lookback period
    if dayofweek != dayofweek[1]
        array.clear(historicalVolumes)
    
    if hour == currentHour and minute == currentMinute
        array.push(historicalVolumes, volume)
        if array.size(historicalVolumes) > rvolLookback
            array.shift(historicalVolumes)
    
    avgVol = array.size(historicalVolumes) > 0 ? array.avg(historicalVolumes) : volume
    currentRVol = avgVol > 0 ? volume / avgVol : 1.0
    currentRVol

rvol = useRVol ? calculateRVol() : 1.0

// ═══════════════════════════════════════════════════════════════════════════════
// ATR AND RANGE ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

atr = ta.atr(14)
dailyATR = request.security(syminfo.tickerid, "D", ta.atr(14))

// ═══════════════════════════════════════════════════════════════════════════════
// PREVIOUS DAY AND KEY LEVELS
// ═══════════════════════════════════════════════════════════════════════════════

var float prevDayHigh = na
var float prevDayLow = na
var float prevDayClose = na
var float premarketHigh = na
var float premarketLow = na

// Update previous day levels
if ta.change(time("D"))
    prevDayHigh := high[1]
    prevDayLow := low[1]
    prevDayClose := close[1]

// Track premarket levels
if not isInSession() and usePremarket
    if na(premarketHigh) or high > premarketHigh
        premarketHigh := high
    if na(premarketLow) or low < premarketLow
        premarketLow := low

// Reset premarket at session start
if isInSession() and not isInSession()[1]
    if na(premarketHigh)
        premarketHigh := high
    if na(premarketLow)
        premarketLow := low

// ═══════════════════════════════════════════════════════════════════════════════
// HIGHER TIMEFRAME BIAS
// ═══════════════════════════════════════════════════════════════════════════════

htfHigh = request.security(syminfo.tickerid, htfTimeframe, high)
htfLow = request.security(syminfo.tickerid, htfTimeframe, low)
htfClose = request.security(syminfo.tickerid, htfTimeframe, close)

// Determine HTF trend
htfTrend = htfClose > htfClose[1] and htfLow > htfLow[1] ? 1 :  // Uptrend (HH, HL)
           htfClose < htfClose[1] and htfHigh < htfHigh[1] ? -1 : // Downtrend (LL, LH)
           0  // Neutral

// ═══════════════════════════════════════════════════════════════════════════════
// ORB CALCULATION WITH ADVANCED FEATURES
// ═══════════════════════════════════════════════════════════════════════════════

var float orbHigh = na
var float orbLow = na
var int orbStartBar = na
var box orbBox = na
var bool orbComplete = false
var float orbWidth = na
var string rangeType = "Normal"

// Detect new session and initialize ORB
if isInSession() and not isInSession()[1]
    orbHigh := high
    orbLow := low
    orbStartBar := bar_index
    orbComplete := false
    if not na(orbBox) and showORBBox
        box.delete(orbBox)
    if showORBBox
        orbBox := box.new(bar_index, high, bar_index + 1, low, 
                         border_color=color.blue, bgcolor=orbColor, border_width=2)

// Update ORB during formation
if isORBPeriod() and not orbComplete
    orbHigh := math.max(orbHigh, high)
    orbLow := math.min(orbLow, low)
    if not na(orbBox) and showORBBox
        box.set_top(orbBox, orbHigh)
        box.set_bottom(orbBox, orbLow)
        box.set_right(orbBox, bar_index)

// Mark ORB complete and analyze range
if not isORBPeriod() and isORBPeriod()[1]
    orbComplete := true
    orbWidth := orbHigh - orbLow
    
    // Classify range type
    if useATRFilter
        rangeRatio = orbWidth / dailyATR
        rangeType := rangeRatio < narrowRangeATR ? "Narrow" :
                    rangeRatio > wideRangeATR ? "Wide" : "Normal"

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE - SWING HIGHS/LOWS
// ═══════════════════════════════════════════════════════════════════════════════

// Find swing highs and lows for structure
swingHigh = ta.pivothigh(high, bosLookback, bosLookback)
swingLow = ta.pivotlow(low, bosLookback, bosLookback)

var float lastSwingHigh = na
var float lastSwingLow = na

if not na(swingHigh)
    lastSwingHigh := swingHigh
if not na(swingLow)
    lastSwingLow := swingLow

// ═══════════════════════════════════════════════════════════════════════════════
// BREAKOUT DETECTION WITH VOLUME CONFIRMATION
// ═══════════════════════════════════════════════════════════════════════════════

var bool breakoutLong = false
var bool breakoutShort = false
var float breakoutLevel = na
var bool volumeConfirmed = false

// Detect breakouts with proper validation
if orbComplete
    // Volume confirmation
    avgVolume = ta.sma(volume, 20)
    volumeSpike = volume > avgVolume * 1.5
    rvolConfirmed = not useRVol or rvol >= rvolThreshold
    
    // Long breakout
    if close > orbHigh and not breakoutLong
        if (not waitForClose or barstate.isconfirmed) and volumeSpike and rvolConfirmed
            breakoutLong := true
            breakoutShort := false
            breakoutLevel := orbHigh
            volumeConfirmed := true
            
            // Check for BOS
            if requireBOS and not na(lastSwingHigh)
                if close > lastSwingHigh
                    label.new(bar_index, high, "BOS↑", color=bullishColor, 
                             style=label.style_label_up, textcolor=color.white, size=size.small)
    
    // Short breakout
    else if close < orbLow and not breakoutShort
        if (not waitForClose or barstate.isconfirmed) and volumeSpike and rvolConfirmed
            breakoutShort := true
            breakoutLong := false
            breakoutLevel := orbLow
            volumeConfirmed := true
            
            // Check for BOS
            if requireBOS and not na(lastSwingLow)
                if close < lastSwingLow
                    label.new(bar_index, low, "BOS↓", color=bearishColor, 
                             style=label.style_label_down, textcolor=color.white, size=size.small)

// Reset on new session
if isInSession() and not isInSession()[1]
    breakoutLong := false
    breakoutShort := false
    volumeConfirmed := false

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY GRAB DETECTION (ICT CONCEPT)
// ═══════════════════════════════════════════════════════════════════════════════

var bool liquidityGrabBull = false
var bool liquidityGrabBear = false

if orbComplete and useLiquidityGrabs
    // Bullish liquidity grab - sweep below ORB then reverse
    if low < orbLow and close > orbLow and not liquidityGrabBull
        liquidityGrabBull := true
        liquidityGrabBear := false
        label.new(bar_index, low, "LG", color=bullishColor, 
                 style=label.style_label_up, textcolor=color.white, size=size.tiny)
    
    // Bearish liquidity grab - sweep above ORB then reverse
    else if high > orbHigh and close < orbHigh and not liquidityGrabBear
        liquidityGrabBear := true
        liquidityGrabBull := false
        label.new(bar_index, high, "LG", color=bearishColor, 
                 style=label.style_label_down, textcolor=color.white, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// FAIR VALUE GAP DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

var box[] fvgBoxes = array.new<box>()

if showFVG and bar_index > 2
    // Bullish FVG (gap up)
    if low > high[2] and (low - high[2]) > fvgMinSize * atr
        fvgBox = box.new(bar_index - 2, high[2], bar_index, low, 
                        bgcolor=color.new(color.yellow, 90), 
                        border_color=color.new(bullishColor, 50))
        array.push(fvgBoxes, fvgBox)
        if array.size(fvgBoxes) > 5
            box.delete(array.shift(fvgBoxes))
    
    // Bearish FVG (gap down)
    else if high < low[2] and (low[2] - high) > fvgMinSize * atr
        fvgBox = box.new(bar_index - 2, high, bar_index, low[2], 
                        bgcolor=color.new(color.yellow, 90), 
                        border_color=color.new(bearishColor, 50))
        array.push(fvgBoxes, fvgBox)
        if array.size(fvgBoxes) > 5
            box.delete(array.shift(fvgBoxes))

// Extend FVG boxes
if array.size(fvgBoxes) > 0
    for i = 0 to math.min(array.size(fvgBoxes) - 1, 4)
        box.set_right(array.get(fvgBoxes, i), bar_index)

// ═══════════════════════════════════════════════════════════════════════════════
// PULLBACK ENTRY ZONES
// ═══════════════════════════════════════════════════════════════════════════════

var box pullbackZone = na
var bool waitingForPullback = false

if entryMethod != "Immediate" and orbComplete
    if breakoutLong and not waitingForPullback
        waitingForPullback := true
        if showEntryZones
            pullbackZone := box.new(bar_index, orbHigh * 1.001, bar_index + 10, orbHigh * 0.999, 
                                   bgcolor=color.new(bullishColor, 90), border_color=bullishColor)
    
    else if breakoutShort and not waitingForPullback
        waitingForPullback := true
        if showEntryZones
            pullbackZone := box.new(bar_index, orbLow * 1.001, bar_index + 10, orbLow * 0.999, 
                                   bgcolor=color.new(bearishColor, 90), border_color=bearishColor)

// Check for pullback completion
if waitingForPullback
    if breakoutLong and low <= orbHigh * 1.001 and close > orbHigh
        waitingForPullback := false
        label.new(bar_index, low, "ENTRY", color=bullishColor, 
                 style=label.style_label_up, textcolor=color.white, size=size.normal)
        if not na(pullbackZone)
            box.delete(pullbackZone)
    
    else if breakoutShort and high >= orbLow * 0.999 and close < orbLow
        waitingForPullback := false
        label.new(bar_index, high, "ENTRY", color=bearishColor, 
                 style=label.style_label_down, textcolor=color.white, size=size.normal)
        if not na(pullbackZone)
            box.delete(pullbackZone)

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS (ICT)
// ═══════════════════════════════════════════════════════════════════════════════

var box[] orderBlocks = array.new<box>()

if showOrderBlocks and bar_index > 3
    // Bullish order block - last down candle before up move
    if close > open and close[1] < open[1] and close > high[1]
        ob = box.new(bar_index - 1, high[1], bar_index, low[1], 
                    bgcolor=color.new(bullishColor, 85), border_color=bullishColor)
        array.push(orderBlocks, ob)
        if array.size(orderBlocks) > 3
            box.delete(array.shift(orderBlocks))
    
    // Bearish order block - last up candle before down move
    else if close < open and close[1] > open[1] and close < low[1]
        ob = box.new(bar_index - 1, high[1], bar_index, low[1], 
                    bgcolor=color.new(bearishColor, 85), border_color=bearishColor)
        array.push(orderBlocks, ob)
        if array.size(orderBlocks) > 3
            box.delete(array.shift(orderBlocks))

// ═══════════════════════════════════════════════════════════════════════════════
// STOP LOSS AND TARGET CALCULATION
// ═══════════════════════════════════════════════════════════════════════════════

calculateStopLoss(isLong) =>
    stop = 0.0
    switch stopMethod
        "Range" => stop := isLong ? orbLow : orbHigh
        "Structure" => stop := isLong ? lastSwingLow : lastSwingHigh
        "ATR" => stop := isLong ? close - (atr * atrMultiplier) : close + (atr * atrMultiplier)
        "Hybrid" => 
            rangeStop = isLong ? orbLow : orbHigh
            structureStop = isLong ? lastSwingLow : lastSwingHigh
            stop := isLong ? math.max(rangeStop, structureStop) : math.min(rangeStop, structureStop)
    stop

// ═══════════════════════════════════════════════════════════════════════════════
// DASHBOARD WITH COMPREHENSIVE INFO
// ═══════════════════════════════════════════════════════════════════════════════

if showDashboard
    var table dashboard = table.new(position.top_right, 2, 12, 
                                   bgcolor=color.new(color.black, 85),
                                   border_color=color.gray, border_width=1)
    
    if barstate.islast
        // Session Info
        table.cell(dashboard, 0, 0, "Session", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 0, sessionType + " (" + orbDuration + "m)", 
                  text_color=color.yellow, text_size=size.small)
        
        // ORB Levels
        table.cell(dashboard, 0, 1, "ORB High", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 1, str.tostring(orbHigh, "#.##"), 
                  text_color=bullishColor, text_size=size.small)
        
        table.cell(dashboard, 0, 2, "ORB Low", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 2, str.tostring(orbLow, "#.##"), 
                  text_color=bearishColor, text_size=size.small)
        
        // Range Analysis
        table.cell(dashboard, 0, 3, "Range Type", text_color=color.white, text_size=size.small)
        rangeColor = rangeType == "Narrow" ? bullishColor : 
                    rangeType == "Wide" ? bearishColor : neutralColor
        table.cell(dashboard, 1, 3, rangeType, text_color=rangeColor, text_size=size.small)
        
        // Relative Volume
        table.cell(dashboard, 0, 4, "RVol", text_color=color.white, text_size=size.small)
        rvolColor = rvol >= rvolThreshold ? bullishColor : bearishColor
        table.cell(dashboard, 1, 4, str.tostring(rvol, "#.#") + "x", 
                  text_color=rvolColor, text_size=size.small)
        
        // HTF Bias
        table.cell(dashboard, 0, 5, "HTF Bias", text_color=color.white, text_size=size.small)
        biasText = htfTrend == 1 ? "Bullish" : htfTrend == -1 ? "Bearish" : "Neutral"
        biasColor = htfTrend == 1 ? bullishColor : htfTrend == -1 ? bearishColor : neutralColor
        table.cell(dashboard, 1, 5, biasText, text_color=biasColor, text_size=size.small)
        
        // Breakout Status
        table.cell(dashboard, 0, 6, "Breakout", text_color=color.white, text_size=size.small)
        breakStatus = breakoutLong ? "Long" : breakoutShort ? "Short" : "None"
        breakColor = breakoutLong ? bullishColor : breakoutShort ? bearishColor : color.gray
        table.cell(dashboard, 1, 6, breakStatus, text_color=breakColor, text_size=size.small)
        
        // Volume Confirmation
        table.cell(dashboard, 0, 7, "Vol Confirm", text_color=color.white, text_size=size.small)
        volColor = volumeConfirmed ? color.green : color.gray
        table.cell(dashboard, 1, 7, volumeConfirmed ? "✓" : "✗", 
                  text_color=volColor, text_size=size.small)
        
        // Previous Day Levels
        table.cell(dashboard, 0, 8, "Prev High", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 8, str.tostring(prevDayHigh, "#.##"), 
                  text_color=color.aqua, text_size=size.small)
        
        table.cell(dashboard, 0, 9, "Prev Low", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 9, str.tostring(prevDayLow, "#.##"), 
                  text_color=color.aqua, text_size=size.small)
        
        // Liquidity Grabs
        table.cell(dashboard, 0, 10, "Liq Grab", text_color=color.white, text_size=size.small)
        liqStatus = liquidityGrabBull ? "Bull" : liquidityGrabBear ? "Bear" : "None"
        liqColor = liquidityGrabBull ? bullishColor : liquidityGrabBear ? bearishColor : color.gray
        table.cell(dashboard, 1, 10, liqStatus, text_color=liqColor, text_size=size.small)
        
        // Entry Method
        table.cell(dashboard, 0, 11, "Entry", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 11, entryMethod, text_color=color.orange, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// PLOTTING KEY LEVELS
// ═══════════════════════════════════════════════════════════════════════════════

// Plot ORB levels
plot(orbComplete ? orbHigh : na, "ORB High", color=color.new(color.blue, 50), 
     style=plot.style_line, linewidth=2)
plot(orbComplete ? orbLow : na, "ORB Low", color=color.new(color.blue, 50), 
     style=plot.style_line, linewidth=2)

// Plot previous day levels
if showPrevDayLevels
    plot(prevDayHigh, "Prev Day High", color=color.new(color.purple, 70), 
         style=plot.style_circles, linewidth=1)
    plot(prevDayLow, "Prev Day Low", color=color.new(color.purple, 70), 
         style=plot.style_circles, linewidth=1)

// Plot premarket levels
if usePremarket
    plot(premarketHigh, "Premarket High", color=color.new(color.orange, 70), 
         style=plot.style_cross, linewidth=1)
    plot(premarketLow, "Premarket Low", color=color.new(color.orange, 70), 
         style=plot.style_cross, linewidth=1)

// Background color for session
bgcolor(isInSession() ? color.new(color.gray, 95) : na, title="Session Background")
bgcolor(isORBPeriod() ? color.new(color.blue, 95) : na, title="ORB Period")

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS WITH COMPREHENSIVE INFORMATION
// ═══════════════════════════════════════════════════════════════════════════════

// Breakout alerts
alertcondition(breakoutLong and volumeConfirmed, "Long Breakout Confirmed", 
              "Long breakout with volume confirmation. ORB High: {{plot_0}}")
alertcondition(breakoutShort and volumeConfirmed, "Short Breakout Confirmed", 
              "Short breakout with volume confirmation. ORB Low: {{plot_1}}")

// Liquidity grab alerts
alertcondition(liquidityGrabBull, "Bullish Liquidity Grab", 
              "Bullish liquidity grab detected below ORB")
alertcondition(liquidityGrabBear, "Bearish Liquidity Grab", 
              "Bearish liquidity grab detected above ORB")

// Pullback entry alerts
alertcondition(waitingForPullback, "Waiting for Pullback", 
              "Breakout confirmed, waiting for pullback entry")

// Range type alerts
alertcondition(orbComplete and rangeType == "Narrow", "Narrow Range Detected", 
              "Narrow range detected - potential for explosive move")
alertcondition(orbComplete and rangeType == "Wide", "Wide Range Detected", 
              "Wide range detected - caution advised")
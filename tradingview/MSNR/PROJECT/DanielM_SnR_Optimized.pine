//@version=5
indicator("Malaysian SnR [OPTIMIZED by KF]", overlay=true, max_lines_count=200, max_labels_count=500)

// ════════════════════════════════════════════════════════════════════════════
// USER INPUTS
// ════════════════════════════════════════════════════════════════════════════

Length = input.int(25, "Bars to Detect A&V Levels", minval=10, tooltip="Number of past bars to analyze for A&V Levels")
gapsLength = input.int(3, "Bars to Detect Gaps", minval=3, tooltip="Number of past bars to analyze for Gaps")

showOnlyFresh = input.bool(false, "Show Only Fresh A&V Levels", tooltip="Hide unfresh levels so only fresh levels are visible on the chart.")
showGaps = input.bool(false, "Show Gap Levels")
showOnlyFreshGaps = input.bool(false, "Show Only Fresh Gap Levels", tooltip="Hide unfresh gap levels so only fresh levels are visible on the chart.")

maxALines = input.int(5, "Max A Lines", minval=4, tooltip="Maximum number of A lines to keep on the chart.")
maxVLines = input.int(5, "Max V Lines", minval=4, tooltip="Maximum number of V lines to keep on the chart.")
maxGapLines = input.int(5, "Max Gap Lines", minval=4, tooltip="Maximum number of gap lines to display on the chart.")

alertGroup = "Custom Alerts"
enableAlertFreshAV     = input.bool(true, "Alert on Fresh A/V Level Touch", group=alertGroup)
enableAlertUnfreshAV   = input.bool(true, "Alert on Unfresh A/V Levels Touch", group=alertGroup)
enableAlertFreshGaps   = input.bool(true, "Alert on Fresh Gap Touch", group=alertGroup)
enableAlertUnfreshGaps = input.bool(true, "Alert on Unfresh Gap Touch", group=alertGroup)

// ════════════════════════════════════════════════════════════════════════════
// SUPPORT & RESISTANCE DETECTION
// ════════════════════════════════════════════════════════════════════════════

Alevel = ta.pivothigh(close, Length, Length)
vlevel = ta.pivotlow(close, Length, Length)

var line[] resLines = array.new_line()
var bool[] resStates = array.new_bool()

var line[] supLines = array.new_line()
var bool[] supStates = array.new_bool()

var line[] gapLines = array.new_line()
var float[] gapLevels = array.new_float()
var bool[] gapFreshStates = array.new_bool()
var int[] gapCreatedAtBars = array.new_int()
var color[] gapColors = array.new_color()

// ════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION #1: Improved array limiting with remove() instead of shift()
// ════════════════════════════════════════════════════════════════════════════

f_limit_line_array_size(arr, stateArr, maxSize) =>
    arr_size = array.size(arr)
    while arr_size > maxSize
        // Remove from end instead of shift from beginning (O(1) vs O(n))
        lineToRemove = array.pop(arr)
        if not na(lineToRemove)
            line.delete(lineToRemove)
        if array.size(stateArr) > 0
            array.pop(stateArr)
        arr_size -= 1

f_limit_gap_array_size(arr, levelArr, stateArr, barsArr, colorArr, maxSize) =>
    arr_size = array.size(arr)
    while arr_size > maxSize
        lineToRemove = array.pop(arr)
        if not na(lineToRemove)
            line.delete(lineToRemove)
        if array.size(levelArr) > 0
            array.pop(levelArr)
        if array.size(stateArr) > 0
            array.pop(stateArr)
        if array.size(barsArr) > 0
            array.pop(barsArr)
        if array.size(colorArr) > 0
            array.pop(colorArr)
        arr_size -= 1

// ════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION #2: Consolidated line style updating function
// ════════════════════════════════════════════════════════════════════════════

f_update_line_styles(arr, stateArr, isResistance) =>
    arr_size = array.size(arr)
    if arr_size == 0
        return
    
    // Cache high/low prices
    h = high
    l = low
    o = open
    c = close
    
    // Determine base color once
    base_color = isResistance ? color.red : color.green
    
    for i = 0 to arr_size - 1
        // OPTIMIZATION #3: Cache all array reads at start of loop
        currentLine = array.get(arr, i)
        linePrice = line.get_y1(currentLine)
        lineState = array.get(stateArr, i)
        
        // Evaluate conditions once
        wickTouched = isResistance ? (h >= linePrice and l < linePrice) : (l <= linePrice and h > linePrice)
        bodyCrossed = isResistance ? ((o < linePrice and c > linePrice) or (o > linePrice and c < linePrice))
                                   : ((o > linePrice and c < linePrice) or (o < linePrice and c > linePrice))
        
        // Determine new state (only compute once)
        new_state = if wickTouched and lineState
            false
        else if bodyCrossed
            true
        else
            lineState
        
        // Only update if state changed
        if new_state != lineState
            array.set(stateArr, i, new_state)
        
        // Compute styling based on new state
        if showOnlyFresh
            final_color = new_state ? base_color : color.new(base_color, 100)
            line.set_color(currentLine, final_color)
        else
            line.set_color(currentLine, base_color)
            if new_state
                line.set_style(currentLine, line.style_solid)
            else
                line.set_style(currentLine, line.style_dashed)

// Draw resistance line if detected and bar is confirmed
if not na(Alevel) and barstate.isconfirmed
    resPrice = Alevel
    resBar = bar_index - Length
    if resBar >= 0
        resLine = line.new(x1=resBar, y1=resPrice, x2=bar_index, y2=resPrice, color=color.red, width=1, style=line.style_solid, extend=extend.right)
        array.push(resLines, resLine)
        array.push(resStates, true)
        f_limit_line_array_size(resLines, resStates, maxALines)

// Draw support line if detected and bar is confirmed
if not na(vlevel) and barstate.isconfirmed
    supPrice = vlevel
    supBar = bar_index - Length
    if supBar >= 0
        supLine = line.new(x1=supBar, y1=supPrice, x2=bar_index, y2=supPrice, color=color.green, width=1, style=line.style_solid, extend=extend.right)
        array.push(supLines, supLine)
        array.push(supStates, true)
        f_limit_line_array_size(supLines, supStates, maxVLines)

// ════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION #4: Improved gap detection with duplicate prevention
// ════════════════════════════════════════════════════════════════════════════

var float last_gap_price = na
var int last_gap_bar = -100

f_detect_and_draw_gaps() =>
    if not barstate.isconfirmed
        return
    
    for i = 1 to gapsLength
        if i >= bar_index
            continue
        
        isBullishGap = (close[i] > open[i] and close[i - 1] > open[i - 1])
        isBearishGap = (close[i] < open[i] and close[i - 1] < open[i - 1])
        
        if not (isBullishGap or isBearishGap)
            continue
        
        gapPrice = close[i]
        gapBar = bar_index - i
        gap_color = isBullishGap ? color.blue : color.new(177, 33, 243)  // Purple
        
        // OPTIMIZATION: Skip duplicate gaps (same price within recent bars)
        if not na(last_gap_price) and math.abs(gapPrice - last_gap_price) < 0.00001 and bar_index - last_gap_bar < 10
            continue
        
        // Single creation call
        gapLine = line.new(x1=gapBar, y1=gapPrice, x2=bar_index, y2=gapPrice, color=gap_color, width=1, style=line.style_solid, extend=extend.right)
        
        // Batch array operations
        array.push(gapLines, gapLine)
        array.push(gapLevels, gapPrice)
        array.push(gapFreshStates, true)
        array.push(gapCreatedAtBars, gapBar)
        array.push(gapColors, gap_color)
        
        last_gap_price := gapPrice
        last_gap_bar := gapBar
    
    f_limit_gap_array_size(gapLines, gapLevels, gapFreshStates, gapCreatedAtBars, gapColors, maxGapLines)

// ════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION #5: Improved gap freshness updating
// ════════════════════════════════════════════════════════════════════════════

f_update_gap_freshness() =>
    gaps_size = array.size(gapLevels)
    if gaps_size == 0
        return
    
    h = high
    l = low
    o = open
    c = close
    current_bar = bar_index
    
    for i = 0 to gaps_size - 1
        gapPrice = array.get(gapLevels, i)
        isFresh = array.get(gapFreshStates, i)
        gapLine = array.get(gapLines, i)
        gapColor = array.get(gapColors, i)
        createdAtBar = array.get(gapCreatedAtBars, i)
        
        // Skip for first 2 bars after creation
        if current_bar <= createdAtBar + 1
            continue
        
        wickTouched = (l <= gapPrice and h >= gapPrice)
        bodyCrossed = (o < gapPrice and c > gapPrice) or (o > gapPrice and c < gapPrice)
        
        new_state = if wickTouched and isFresh
            false
        else if bodyCrossed
            true
        else
            isFresh
        
        if new_state != isFresh
            array.set(gapFreshStates, i, new_state)
            
            if showOnlyFreshGaps
                final_color = new_state ? gapColor : color.new(gapColor, 100)
                line.set_color(gapLine, final_color)
            else
                line.set_color(gapLine, gapColor)
                line.set_style(gapLine, new_state ? line.style_solid : line.style_dashed)

if showGaps
    f_detect_and_draw_gaps()
    f_update_gap_freshness()

// ════════════════════════════════════════════════════════════════════════════
// OPTIMIZATION #6: Consolidated alert checking function
// ════════════════════════════════════════════════════════════════════════════

var bool alertFreshAVTriggered = false
var bool alertUnfreshAVTriggered = false
var bool alertFreshGapsTriggered = false
var bool alertUnfreshGapsTriggered = false

// Reset flags at bar start
alertFreshAVTriggered     := false
alertUnfreshAVTriggered   := false
alertFreshGapsTriggered   := false
alertUnfreshGapsTriggered := false

f_check_level_alerts(lineArr, stateArr, alert_fresh_enable, alert_unfresh_enable) =>
    fresh_triggered = false
    unfresh_triggered = false
    
    arr_size = array.size(lineArr)
    if arr_size == 0
        return [false, false]
    
    h = high
    l = low
    o = open
    c = close
    
    for i = 0 to arr_size - 1
        // Single cache operation
        levelPrice = line.get_y1(array.get(lineArr, i))
        levelState = array.get(stateArr, i)
        
        // Simplified touch/cross condition
        is_touched_or_crossed = (h >= levelPrice and l <= levelPrice) or 
                                ((o < levelPrice and c > levelPrice) or 
                                 (o > levelPrice and c < levelPrice))
        
        if is_touched_or_crossed
            if levelState and alert_fresh_enable
                fresh_triggered := true
            if not levelState and alert_unfresh_enable
                unfresh_triggered := true
    
    [fresh_triggered, unfresh_triggered]

// ════════════════════════════════════════════════════════════════════════════
// ALERT LOGIC
// ════════════════════════════════════════════════════════════════════════════

if enableAlertFreshAV or enableAlertUnfreshAV
    // Check both resistance and support together
    [fresh_res, unfresh_res] = f_check_level_alerts(resLines, resStates, enableAlertFreshAV, enableAlertUnfreshAV)
    [fresh_sup, unfresh_sup] = f_check_level_alerts(supLines, supStates, enableAlertFreshAV, enableAlertUnfreshAV)
    
    alertFreshAVTriggered := fresh_res or fresh_sup
    alertUnfreshAVTriggered := unfresh_res or unfresh_sup

if enableAlertFreshGaps or enableAlertUnfreshGaps
    [fresh_gaps, unfresh_gaps] = f_check_level_alerts(gapLines, gapFreshStates, enableAlertFreshGaps, enableAlertUnfreshGaps)
    alertFreshGapsTriggered := fresh_gaps
    alertUnfreshGapsTriggered := unfresh_gaps

// Send alerts based on triggered flags
if alertFreshAVTriggered and enableAlertFreshAV
    alert("Price has touched or crossed a Fresh A/V Level at " + str.tostring(close), alert.freq_once_per_bar)

if alertUnfreshAVTriggered and enableAlertUnfreshAV
    alert("Price has touched or crossed an Unfresh A/V Level at " + str.tostring(close), alert.freq_once_per_bar)

if alertFreshGapsTriggered and enableAlertFreshGaps
    alert("Price has touched or crossed a Fresh Gap Level at " + str.tostring(close), alert.freq_once_per_bar)

if alertUnfreshGapsTriggered and enableAlertUnfreshGaps
    alert("Price has touched or crossed an Unfresh Gap Level at " + str.tostring(close), alert.freq_once_per_bar)

// ════════════════════════════════════════════════════════════════════════════
// UPDATE LINE STYLES (MAIN LOOP - Called at END)
// ════════════════════════════════════════════════════════════════════════════

f_update_line_styles(resLines, resStates, true)
f_update_line_styles(supLines, supStates, false)

msg2ShowTrendline = input.bool(false, title="Trendline", group=grp_msg2, inline="msg2_display")
msg2ShowMean = input.bool(false, title="Mean", group=grp_msg2, inline="msg2_display")//msg2_display2
msg2ShowVWAP = input.bool(false, title="VWAP", group=grp_msg2, inline="msg2_display")
msg2ShowMaxMin = input.bool(false, title="Max/Min", group=grp_msg2, inline="msg2_display")

// =====================================================
// INPUT PARAMETERS - MSG RANGE 3
// =====================================================
grp_msg3 = "MSG RANGE 3"

msg3Enabled = input.bool(true, title="", group=grp_msg3, inline="msg3_main")
msg3Name = "MSG3" //input.string("MSG3", title="", group=grp_msg3, inline="msg3_main")
msg3StartHour = input.int(9, title="", minval=0, maxval=23, group=grp_msg3, inline="msg3_main")
msg3StartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg3, inline="msg3_main")
msg3EndHour = input.int(13, title="", minval=0, maxval=23, group=grp_msg3, inline="msg3_main")
msg3EndMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg3, inline="msg3_main")
msg3Color = input.color(color.new(color.aqua, 0), title="", group=grp_msg3, inline="msg3_display") //msg3_main

msg3ShowRange = input.bool(true, title="Range", group=grp_msg3, inline="msg3_display")
msg3ShowTrendline = input.bool(false, title="Trendline", group=grp_msg3, inline="msg3_display")
msg3ShowMean = input.bool(false, title="Mean", group=grp_msg3, inline="msg3_display")//msg3_display2
msg3ShowVWAP = input.bool(false, title="VWAP", group=grp_msg3, inline="msg3_display")
msg3ShowMaxMin = input.bool(false, title="Max/Min", group=grp_msg3, inline="msg3_display")

// =====================================================
// INPUT PARAMETERS - MSG RANGE 4
// =====================================================
grp_msg4 = "MSG RANGE 4"

msg4Enabled = input.bool(false, title="", group=grp_msg4, inline="msg4_main")
msg4Name = "MSG4" //input.string("MSG4", title="", group=grp_msg4, inline="msg4_main")
msg4StartHour = input.int(17, title="", minval=0, maxval=23, group=grp_msg4, inline="msg4_main")
msg4StartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg4, inline="msg4_main")
msg4EndHour = input.int(22, title="", minval=0, maxval=23, group=grp_msg4, inline="msg4_main")
msg4EndMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg4, inline="msg4_main")
msg4Color = input.color(color.purple, title="", group=grp_msg4, inline="msg4_display") //msg4_main

msg4ShowRange = input.bool(false, title="Range", group=grp_msg4, inline="msg4_display")
msg4ShowTrendline = input.bool(false, title="Trendline", group=grp_msg4, inline="msg4_display")
msg4ShowMean = input.bool(false, title="Mean", group=grp_msg4, inline="msg4_display")//msg4_display2
msg4ShowVWAP = input.bool(false, title="VWAP", group=grp_msg4, inline="msg4_display")
msg4ShowMaxMin = input.bool(false, title="Max/Min", group=grp_msg4, inline="msg4_display")

// =====================================================
// INPUT PARAMETERS - MSG SIGNAL SETTINGS
// =====================================================
grp_signal = "MSG SIGNAL SETTINGS"
enableBreakoutSignals = input.bool(true, title="Enable Breakout Signals", group=grp_signal)
showAlerts = input.bool(true, title="Show Alerts", group=grp_signal)
buySignalColor = input.color(color.green, title="Buy Signal Color", group=grp_signal)
sellSignalColor = input.color(color.red, title="Sell Signal Color", group=grp_signal)
signalBorderWidth = input.int(3, title="Signal Border Width", minval=1, maxval=5, group=grp_signal)

// =====================================================
// INPUT PARAMETERS - STRATEGY TRADE SETTINGS
// =====================================================
grp_strategy = "STRATEGY TRADE SETTINGS"
enableTrading = input.bool(true, title="Enable Trading", group=grp_strategy, tooltip="Enable/disable trade execution")
positionSizeType = input.string("Risk-Based", title="Position Size Type", options=["Fixed Contracts", "Percent of Equity", "Risk-Based"], group=grp_strategy)
positionSizeFixed = input.int(1, title="Fixed Contracts", minval=1, group=grp_strategy, tooltip="Number of contracts when using Fixed Contracts")
positionSizePercent = input.float(10.0, title="Percent of Equity", minval=0.1, maxval=100.0, step=0.1, group=grp_strategy, tooltip="Percentage of equity to use per trade")
riskPercent = input.float(1.5, title="Risk Per Trade (%)", minval=0.1, maxval=10.0, step=0.1, group=grp_strategy, tooltip="Percentage of equity to risk per trade (for Risk-Based sizing)")
maxPositions = input.int(1, title="Max Concurrent Positions", minval=1, maxval=10, group=grp_strategy, tooltip="Maximum number of concurrent positions")

// =====================================================
// INPUT PARAMETERS - STOP LOSS SETTINGS
// =====================================================
grp_sl = "STOP LOSS SETTINGS"
slMethod = input.string("ATR-Based", title="Stop Loss Method", options=["Range-Based", "ATR-Based", "Fixed Points", "Risk-Reward Ratio"], group=grp_sl, tooltip="Method to calculate stop loss")
slRangeMultiplier = input.float(0.5, title="SL Range Multiplier", minval=0.1, maxval=2.0, step=0.1, group=grp_sl, tooltip="Multiplier for range-based SL (0.5 = half the range size)")
slAtrLength = input.int(14, title="ATR Length", minval=1, maxval=50, group=grp_sl, tooltip="Period for ATR calculation")
slAtrMultiplier = input.float(2.5, title="ATR Multiplier", minval=0.5, maxval=5.0, step=0.1, group=grp_sl, tooltip="Multiplier for ATR-based SL")
slFixedPoints = input.float(50.0, title="Fixed Points", minval=1.0, step=1.0, group=grp_sl, tooltip="Fixed points for stop loss (in price units)")
slRiskRewardRatio = input.float(1.0, title="SL Risk-Reward Ratio", minval=0.5, maxval=5.0, step=0.1, group=grp_sl, tooltip="Risk-reward ratio for SL (1.0 = 1:1)")

// =====================================================
// INPUT PARAMETERS - TAKE PROFIT SETTINGS
// =====================================================
grp_tp = "TAKE PROFIT SETTINGS"
tpMethod = input.string("ATR-Based", title="Take Profit Method", options=["Range-Based", "ATR-Based", "Fixed Points", "Risk-Reward Ratio"], group=grp_tp, tooltip="Method to calculate take profit")
tpRangeMultiplier = input.float(1.5, title="TP Range Multiplier", minval=0.5, maxval=5.0, step=0.1, group=grp_tp, tooltip="Multiplier for range-based TP (1.5 = 1.5x the range size)")
tpAtrLength = input.int(14, title="ATR Length", minval=1, maxval=50, group=grp_tp, tooltip="Period for ATR calculation")
tpAtrMultiplier = input.float(4.5, title="ATR Multiplier", minval=0.5, maxval=10.0, step=0.1, group=grp_tp, tooltip="Multiplier for ATR-based TP")
tpFixedPoints = input.float(100.0, title="Fixed Points", minval=1.0, step=1.0, group=grp_tp, tooltip="Fixed points for take profit (in price units)")
tpRiskRewardRatio = input.float(2.0, title="TP Risk-Reward Ratio", minval=0.5, maxval=10.0, step=0.1, group=grp_tp, tooltip="Risk-reward ratio for TP (2.0 = 2:1)")

// =====================================================
// INPUT PARAMETERS - RISK MANAGEMENT (Feature 1)
// =====================================================
grp_risk_mgmt = "RISK MANAGEMENT"
enableDailyLossLimit = input.bool(true, title="Enable Daily Loss Limit", group=grp_risk_mgmt, tooltip="Stop trading after daily loss threshold")
dailyLossLimitPercent = input.float(4.0, title="Daily Loss Limit (%)", minval=0.1, maxval=50.0, step=0.1, group=grp_risk_mgmt, tooltip="Maximum daily loss percentage")
enableMaxDrawdown = input.bool(false, title="Enable Max Drawdown Protection", group=grp_risk_mgmt, tooltip="Pause trading if drawdown exceeds limit")
maxDrawdownPercent = input.float(20.0, title="Max Drawdown (%)", minval=1.0, maxval=50.0, step=0.1, group=grp_risk_mgmt, tooltip="Maximum drawdown percentage before pausing")
enableConsecutiveLossLimit = input.bool(true, title="Enable Consecutive Loss Limit", group=grp_risk_mgmt, tooltip="Stop trading after X consecutive losses")
consecutiveLossLimit = input.int(3, title="Max Consecutive Losses", minval=1, maxval=10, group=grp_risk_mgmt, tooltip="Number of consecutive losses before stopping")
enableTimeBasedExit = input.bool(false, title="Enable Time-Based Exit", group=grp_risk_mgmt, tooltip="Close trades after X hours/bars")
timeBasedExitHours = input.int(24, title="Exit After Hours", minval=1, maxval=168, group=grp_risk_mgmt, tooltip="Close trade after this many hours")
timeBasedExitBars = input.int(0, title="Exit After Bars (0=disabled)", minval=0, maxval=500, group=grp_risk_mgmt, tooltip="Close trade after this many bars (0 to disable)")

// =====================================================
// INPUT PARAMETERS - ADVANCED TRADE MANAGEMENT (Feature 2)
// =====================================================
grp_trade_mgmt = "ADVANCED TRADE MANAGEMENT"
enableTrailingStop = input.bool(true, title="Enable Trailing Stop Loss", group=grp_trade_mgmt, tooltip="Dynamic SL that follows price (activates after break-even)")
trailingStopType = input.string("ATR", title="Trailing Stop Type", options=["ATR", "Percentage", "Points"], group=grp_trade_mgmt)
trailingStopAtrMultiplier = input.float(2.0, title="Trailing ATR Multiplier", minval=0.5, maxval=5.0, step=0.1, group=grp_trade_mgmt)
trailingStopPercent = input.float(2.0, title="Trailing Stop %", minval=0.1, maxval=10.0, step=0.1, group=grp_trade_mgmt)
trailingStopPoints = input.float(50.0, title="Trailing Stop Points", minval=1.0, step=1.0, group=grp_trade_mgmt)
enableBreakEven = input.bool(true, title="Enable Break-Even Stop", group=grp_trade_mgmt, tooltip="Move SL to entry after reaching % of TP")
breakEvenTriggerPercent = input.float(55.0, title="BE Trigger (% of TP)", minval=10.0, maxval=100.0, step=1.0, group=grp_trade_mgmt, tooltip="Move to BE when this % of TP is reached")
enablePartialTP = input.bool(false, title="Enable Partial Profit Taking", group=grp_trade_mgmt, tooltip="Take profit in stages")
partialTP1Percent = input.float(50.0, title="TP1 Close %", minval=10.0, maxval=90.0, step=1.0, group=grp_trade_mgmt, tooltip="Percentage to close at TP1")
partialTP1Multiplier = input.float(1.0, title="TP1 Multiplier", minval=0.5, maxval=3.0, step=0.1, group=grp_trade_mgmt, tooltip="TP1 as multiple of initial TP")
partialTP2Multiplier = input.float(2.0, title="TP2 Multiplier", minval=1.0, maxval=5.0, step=0.1, group=grp_trade_mgmt, tooltip="TP2 as multiple of initial TP")
enablePyramiding = input.bool(false, title="Enable Pyramiding", group=grp_trade_mgmt, tooltip="Add to winning positions")
pyramidingLevels = input.int(2, title="Pyramiding Levels", minval=1, maxval=5, group=grp_trade_mgmt, tooltip="Number of additional positions")
pyramidingDistance = input.float(1.5, title="Pyramid Distance (ATR)", minval=0.5, maxval=5.0, step=0.1, group=grp_trade_mgmt, tooltip="Distance between pyramid entries in ATR")
enableOppositeSignalExit = input.bool(false, title="Enable Opposite Signal Exit", group=grp_trade_mgmt, tooltip="Close trades when opposite signal appears")

// =====================================================
// INPUT PARAMETERS - TRADE FILTERS (Feature 3)
// =====================================================
grp_filters = "TRADE FILTERS"
enableVolumeFilter = input.bool(true, title="Enable Volume Filter", group=grp_filters, tooltip="Only trade if volume exceeds threshold")
volumeFilterType = input.string("Average", title="Volume Filter Type", options=["Average", "Fixed"], group=grp_filters)
volumeFilterPeriod = input.int(20, title="Volume Average Period", minval=5, maxval=100, group=grp_filters)
volumeFilterMultiplier = input.float(1.2, title="Volume Multiplier", minval=0.5, maxval=5.0, step=0.1, group=grp_filters, tooltip="Volume must be X times average")
volumeFilterFixed = input.float(1000000.0, title="Fixed Volume Threshold", minval=1.0, step=1000.0, group=grp_filters)
enableTrendFilter = input.bool(true, title="Enable Trend Filter", group=grp_filters, tooltip="Require alignment with higher timeframe trend")
trendFilterTimeframe = input.timeframe("240", title="Trend Timeframe", group=grp_filters, tooltip="Timeframe for trend analysis")
trendFilterMethod = input.string("EMA", title="Trend Method", options=["EMA", "SMA", "ADX"], group=grp_filters)
trendFilterPeriod = input.int(20, title="Trend Period", minval=10, maxval=200, group=grp_filters)
enableTimeFilter = input.bool(true, title="Enable Time Filter", group=grp_filters, tooltip="Trade only during specific hours")
timeFilterStartHour = input.int(6, title="Start Hour (GMT)", minval=0, maxval=23, group=grp_filters)
timeFilterEndHour = input.int(2, title="End Hour (GMT)", minval=0, maxval=23, group=grp_filters)
enableRangeSizeFilter = input.bool(true, title="Enable Range Size Filter", group=grp_filters, tooltip="Only trade if range size meets minimum")
rangeSizeFilterType = input.string("ATR", title="Range Size Filter Type", options=["ATR", "Points", "Percentage"], group=grp_filters)
rangeSizeFilterATR = input.float(1.0, title="Min Range Size (ATR)", minval=0.1, maxval=5.0, step=0.1, group=grp_filters)
rangeSizeFilterPoints = input.float(50.0, title="Min Range Size (Points)", minval=1.0, step=1.0, group=grp_filters)

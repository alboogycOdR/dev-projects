//@version=5
strategy("MSG Enhanced LEGO System v3.0 Strategy", overlay=true, max_boxes_count=500, max_labels_count=500, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.1)

// =====================================================
// VERSION HISTORY
// =====================================================
// v3.0 Strategy Enhanced - MSG Enhanced LEGO System v3.0 Strategy
//   - Converted from indicator to strategy for automated trading
//   - Added trade execution logic with strategy.entry() and strategy.exit()
//   - Multiple stop-loss methods: Range-based, ATR-based, Fixed Points, Risk-Reward Ratio
//   - Multiple take-profit methods: Range-based, ATR-based, Fixed Points, Risk-Reward Ratio
//   - Tracks which MSG range triggered each trade for proper SL/TP calculation
//   - Position sizing options: Fixed contracts, percentage of equity, risk-based
//   - Maintains all visual features from indicator version
//   - All features from v3.0 indicator maintained
//
//   FEATURE 1 - RISK MANAGEMENT:
//   - Daily loss limit protection (enable/disable)
//   - Maximum drawdown protection (enable/disable)
//   - Consecutive loss limit (enable/disable)
//   - Time-based exit (hours/bars) (enable/disable)
//
//   FEATURE 2 - ADVANCED TRADE MANAGEMENT:
//   - Trailing stop loss (ATR/Percentage/Points) (enable/disable)
//   - Break-even stop loss (enable/disable)
//   - Partial profit taking with multiple TP levels (enable/disable)
//   - Pyramiding (add to winning positions) (enable/disable)
//   - Opposite signal exit (enable/disable)
//
//   FEATURE 3 - TRADE FILTERS:
//   - Volume filter (Average/Fixed) (enable/disable)
//   - Trend filter (EMA/SMA/ADX on higher timeframe) (enable/disable)
//   - Time filter (specific hours) (enable/disable)
//   - Range size filter (ATR/Points/Percentage) (enable/disable)
//   - Multiple range confirmation (enable/disable)
//
//   FEATURE 4 - VISUAL ENHANCEMENTS:
//   - SL/TP lines on chart (enable/disable)
//   - Trade statistics table (enable/disable)
//   - Trade history labels (enable/disable)
//   - Risk-Reward ratio visualization (enable/disable)
//
//   FEATURE 5 - ADVANCED SL/TP METHODS:
//   - Structure-based SL (swing highs/lows) (enable/disable)
//   - Fibonacci TP extensions (enable/disable)
//   - Dynamic ATR multiplier (volatility-based) (enable/disable)
//   - Percentage-based SL/TP (enable/disable)
//
//   FEATURE 6 - STRATEGY OPTIMIZATION:
//   - Performance metrics tracking (enable/disable)
//   - Trade logging (enable/disable)
//   - Custom alerts (TP hit, SL hit, Entry, Daily limit) (enable/disable)
//
// v2.0 - MSG Enhanced LEGO System
//   - Added support for 4 independent MSG ranges (MSG1-MSG4)
//   - Each range can be individually enabled/disabled
//   - Customizable time periods, names, and colors per range
//   - Display options: Range, Trendline, Mean, VWAP, Max/Min (Range implemented)
//   - All ranges process independently and create persistent boxes on historical bars
//   - Maintains session boxes (Asia, London, New York) from v1.0
//
// v1.0 - MSG Enhanced Range Breakout System (msg-t1fx.pine)
//   - Single MSG range (23:00-01:00 GMT default)
//   - Range breakout detection with buy/sell signals
//   - Risk zone visualization
//   - Session boxes and labels
//   - Dashboard and alerts

// =====================================================
// DESCRIPTION
// =====================================================
// The MSG Enhanced LEGO System allows you to define up to 4 independent
// MSG (Market Structure Gap) ranges with customizable time periods.
// Each range tracks price action during its specified period and displays
// a colored box on the chart. Ranges can overlap and are processed
// independently, making it easy to identify multiple key trading periods
// throughout the day. The system also includes session boxes for major
// trading sessions (Asia, London, New York) to provide additional market
// context.
//
// Version 3.0 Strategy adds automated trade execution when price breaks out
// of any enabled MSG range. The strategy calculates stop-loss and take-profit
// levels based on the triggering range, with multiple calculation methods
// available. All visual features from the indicator version are maintained
// for analysis and backtesting.
// =====================================================

// =====================================================
// INPUT PARAMETERS - SESSION A
// =====================================================
grp_session_a = "SESSION A - NY"

sessionAEnabled = input.bool(true, title="", group=grp_session_a, inline="session_a_main")
sessionAName = "New York" //input.string("New York", title="", group=grp_session_a, inline="session_a_main")
sessionAStartHour = input.int(13, title="", minval=0, maxval=23, group=grp_session_a, inline="session_a_main")
sessionAStartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_session_a, inline="session_a_main")
sessionAEndHour = input.int(22, title="", minval=0, maxval=23, group=grp_session_a, inline="session_a_main")
sessionAEndMinute = input.int(0, title="", minval=0, maxval=59, group=grp_session_a, inline="session_a_main")
sessionAColor = input.color(color.orange, title="", group=grp_session_a, inline="session_a_display") //session_a_main

sessionAShowRange = input.bool(true, title="Range", group=grp_session_a, inline="session_a_display")
sessionAShowTrendline = input.bool(false, title="Trendline", group=grp_session_a, inline="session_a_display")
sessionAShowMean = input.bool(false, title="Mean", group=grp_session_a, inline="session_a_display")//session_a_display2
sessionAShowVWAP = input.bool(true, title="VWAP", group=grp_session_a, inline="session_a_display")
sessionAShowMaxMin = input.bool(true, title="Max/Min", group=grp_session_a, inline="session_a_display")

// =====================================================
// INPUT PARAMETERS - SESSION B
// =====================================================
grp_session_b = "SESSION B - LON"

sessionBEnabled = input.bool(true, title="", group=grp_session_b, inline="session_b_main")
sessionBName = "London" //input.string("London", title="", group=grp_session_b, inline="session_b_main")
sessionBStartHour = input.int(8, title="", minval=0, maxval=23, group=grp_session_b, inline="session_b_main")
sessionBStartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_session_b, inline="session_b_main")
sessionBEndHour = input.int(17, title="", minval=0, maxval=23, group=grp_session_b, inline="session_b_main")
sessionBEndMinute = input.int(0, title="", minval=0, maxval=59, group=grp_session_b, inline="session_b_main")
sessionBColor = input.color(color.blue, title="", group=grp_session_b, inline="session_b_display") //session_b_main

sessionBShowRange = input.bool(true, title="Range", group=grp_session_b, inline="session_b_display")
sessionBShowTrendline = input.bool(false, title="Trendline", group=grp_session_b, inline="session_b_display")
sessionBShowMean = input.bool(false, title="Mean", group=grp_session_b, inline="session_b_display")//session_b_display2
sessionBShowVWAP = input.bool(false, title="VWAP", group=grp_session_b, inline="session_b_display")
sessionBShowMaxMin = input.bool(false, title="Max/Min", group=grp_session_b, inline="session_b_display")

// =====================================================
// INPUT PARAMETERS - SESSION C
// =====================================================
grp_session_c = "SESSION C - TOK"

sessionCEnabled = input.bool(true, title="", group=grp_session_c, inline="session_c_main")
sessionCName = "Tokyo" //input.string("Tokyo", title="", group=grp_session_c, inline="session_c_main")
sessionCStartHour = input.int(0, title="", minval=0, maxval=23, group=grp_session_c, inline="session_c_main")
sessionCStartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_session_c, inline="session_c_main")
sessionCEndHour = input.int(9, title="", minval=0, maxval=23, group=grp_session_c, inline="session_c_main")
sessionCEndMinute = input.int(0, title="", minval=0, maxval=59, group=grp_session_c, inline="session_c_main")
sessionCColor = input.color(color.fuchsia, title="", group=grp_session_c, inline="session_c_display") //session_c_main

sessionCShowRange = input.bool(true, title="Range", group=grp_session_c, inline="session_c_display")
sessionCShowTrendline = input.bool(false, title="Trendline", group=grp_session_c, inline="session_c_display")
sessionCShowMean = input.bool(false, title="Mean", group=grp_session_c, inline="session_c_display")//session_c_display2
sessionCShowVWAP = input.bool(false, title="VWAP", group=grp_session_c, inline="session_c_display")
sessionCShowMaxMin = input.bool(false, title="Max/Min", group=grp_session_c, inline="session_c_display")

// =====================================================
// INPUT PARAMETERS - MSG RANGE 1
// =====================================================
grp_msg1 = "MSG RANGE 1"

msg1Enabled = input.bool(false, title="", group=grp_msg1, inline="msg1_main")
msg1Name = "MSG1" //input.string("MSG1", title="", group=grp_msg1, inline="msg1_main")
msg1StartHour = input.int(23, title="", minval=0, maxval=23, group=grp_msg1, inline="msg1_main")
msg1StartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg1, inline="msg1_main")
msg1EndHour = input.int(1, title="", minval=0, maxval=23, group=grp_msg1, inline="msg1_main")
msg1EndMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg1, inline="msg1_main")
msg1Color = input.color(color.yellow, title="", group=grp_msg1, inline="msg1_display") //msg1_main

msg1ShowRange = input.bool(false, title="Range", group=grp_msg1, inline="msg1_display")
msg1ShowTrendline = input.bool(false, title="Trendline", group=grp_msg1, inline="msg1_display")
msg1ShowMean = input.bool(false, title="Mean", group=grp_msg1, inline="msg1_display")//msg1_display2
msg1ShowVWAP = input.bool(false, title="VWAP", group=grp_msg1, inline="msg1_display")
msg1ShowMaxMin = input.bool(false, title="Max/Min", group=grp_msg1, inline="msg1_display")

// =====================================================
// INPUT PARAMETERS - MSG RANGE 2
// =====================================================
grp_msg2 = "MSG RANGE 2"

msg2Enabled = input.bool(false, title="", group=grp_msg2, inline="msg2_main")
msg2Name = "MSG2" //input.string("MSG2", title="", group=grp_msg2, inline="msg2_main")
msg2StartHour = input.int(0, title="", minval=0, maxval=23, group=grp_msg2, inline="msg2_main")

msg4Name = "MSG4" //input.string("MSG4", title="", group=grp_msg4, inline="msg4_main")
msg4StartHour = input.int(17, title="", minval=0, maxval=23, group=grp_msg4, inline="msg4_main")
msg4StartMinute = input.int(0, title="", minval=0, maxval=59, group=grp_msg4, inline="msg4_main")

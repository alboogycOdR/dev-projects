        // Draw/update range box in real-time during range period
        if not na(range4High) and not na(range4Low) and not na(range4StartTime)
            if na(range4Box)
                range4Box := box.new(left=range4StartTime, top=range4High, right=time, bottom=range4Low, border_color=msg4Color, border_width=rangeLineWidth, bgcolor=color.new(msg4Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 3, range4Box)
            else
                box.set_right(range4Box, time)
                box.set_top(range4Box, range4High)
                box.set_bottom(range4Box, range4Low)
    
    // Finalize range when period ends
    if wasInRange4 and not inRange4 and not range4Set and not na(range4High) and not na(range4Low) and not na(range4StartTime)
        array.set(msgRangeSet, 3, true)
        range4EndTime := time
        array.set(msgRangeEndTimes, 3, range4EndTime)

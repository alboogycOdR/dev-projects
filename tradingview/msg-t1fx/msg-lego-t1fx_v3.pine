            range4Box := box.new(left=range4StartTime, top=range4High, right=range4EndTime, bottom=range4Low, border_color=msg4Color, border_width=rangeLineWidth, bgcolor=color.new(msg4Color, 85), xloc=xloc.bar_time)
            array.set(msgRangeBoxes, 3, range4Box)
        else
            box.set_right(range4Box, range4EndTime)
            box.set_top(range4Box, range4High)
            box.set_bottom(range4Box, range4Low)
        
        // Create persistent box for historical bars
        if barstate.isconfirmed
            box.new(left=range4StartTime, top=range4High, right=range4EndTime, bottom=range4Low, border_color=msg4Color, border_width=rangeLineWidth, bgcolor=color.new(msg4Color, 85), xloc=xloc.bar_time)
            
            // Create persistent label for historical bars
            if showSessionLabels
                labelX = range4StartTime + (range4EndTime - range4StartTime) / 2
                label.new(x=labelX, y=range4High, text=msg4Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
        
        // Add range label for real-time updates
        if showSessionLabels
            range4Label = array.get(msgRangeLabels, 3)
            if na(range4Label)
                labelX = range4StartTime + (range4EndTime - range4StartTime) / 2
                range4Label := label.new(x=labelX, y=range4High, text=msg4Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
                array.set(msgRangeLabels, 3, range4Label)
    
    // Ensure range box persists after range period ends
    if range4Set and not na(range4High) and not na(range4Low) and not na(range4StartTime)
        range4EndTime = array.get(msgRangeEndTimes, 3)
        if not na(range4EndTime)
            if na(range4Box)
                range4Box := box.new(left=range4StartTime, top=range4High, right=range4EndTime, bottom=range4Low, border_color=msg4Color, border_width=rangeLineWidth, bgcolor=color.new(msg4Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 3, range4Box)
            else
                box.set_left(range4Box, range4StartTime)
                box.set_right(range4Box, range4EndTime)
                box.set_top(range4Box, range4High)
                box.set_bottom(range4Box, range4Low)

// =====================================================
// BREAKOUT DETECTION - For all MSG ranges
// =====================================================
if enableBreakoutSignals
    // MSG Range 1 Breakout Detection
    if msg1Enabled
        range1Set = array.get(msgRangeSet, 0)
        range1BreakoutTriggered = array.get(msgRangeBreakoutTriggered, 0)
        range1SignalExpired = array.get(msgRangeSignalExpired, 0)
        range1SignalExpiryTime = array.get(msgRangeSignalExpiryTimes, 0)
        range1High = array.get(msgRangeHighs, 0)
        range1Low = array.get(msgRangeLows, 0)
        range1Box = array.get(msgRangeBoxes, 0)
        
        if range1Set and not range1BreakoutTriggered and not range1SignalExpired
            // Check if signal window has expired
            if not na(range1SignalExpiryTime) and time > range1SignalExpiryTime and hoursAfterRangeForBreakout > 0
                array.set(msgRangeSignalExpired, 0, true)
                if not na(range1Box)
                    box.set_border_color(range1Box, color.gray)
                    box.set_bgcolor(range1Box, color.new(color.gray, 95))
            
            // Check for breakouts (only if not expired)
            if not array.get(msgRangeSignalExpired, 0)
                // Buy breakout
                if not na(range1High) and close > range1High
                    array.set(msgRangeBreakoutTriggered, 0, true)
                    array.set(msgRangeBreakoutDirection, 0, 1)
                    if not na(range1Box)
                        box.set_border_color(range1Box, buySignalColor)
                        box.set_border_width(range1Box, signalBorderWidth)
                        box.set_bgcolor(range1Box, color.new(buySignalColor, 90))
                
                // Sell breakout
                else if not na(range1Low) and close < range1Low
                    array.set(msgRangeBreakoutTriggered, 0, true)
                    array.set(msgRangeBreakoutDirection, 0, -1)
                    if not na(range1Box)
                        box.set_border_color(range1Box, sellSignalColor)
                        box.set_border_width(range1Box, signalBorderWidth)
                        box.set_bgcolor(range1Box, color.new(sellSignalColor, 90))
    
    // MSG Range 2 Breakout Detection
    if msg2Enabled
        range2Set = array.get(msgRangeSet, 1)
        range2BreakoutTriggered = array.get(msgRangeBreakoutTriggered, 1)
        range2SignalExpired = array.get(msgRangeSignalExpired, 1)
        range2SignalExpiryTime = array.get(msgRangeSignalExpiryTimes, 1)
        range2High = array.get(msgRangeHighs, 1)
        range2Low = array.get(msgRangeLows, 1)
        range2Box = array.get(msgRangeBoxes, 1)
        
        if range2Set and not range2BreakoutTriggered and not range2SignalExpired
            // Check if signal window has expired
            if not na(range2SignalExpiryTime) and time > range2SignalExpiryTime and hoursAfterRangeForBreakout > 0
                array.set(msgRangeSignalExpired, 1, true)
                if not na(range2Box)
                    box.set_border_color(range2Box, color.gray)
                    box.set_bgcolor(range2Box, color.new(color.gray, 95))
            
            // Check for breakouts (only if not expired)
            if not array.get(msgRangeSignalExpired, 1)
                // Buy breakout
                if not na(range2High) and close > range2High
                    array.set(msgRangeBreakoutTriggered, 1, true)
                    array.set(msgRangeBreakoutDirection, 1, 1)
                    if not na(range2Box)
                        box.set_border_color(range2Box, buySignalColor)
                        box.set_border_width(range2Box, signalBorderWidth)
                        box.set_bgcolor(range2Box, color.new(buySignalColor, 90))
                
                // Sell breakout
                else if not na(range2Low) and close < range2Low
                    array.set(msgRangeBreakoutTriggered, 1, true)
                    array.set(msgRangeBreakoutDirection, 1, -1)
                    if not na(range2Box)
                        box.set_border_color(range2Box, sellSignalColor)
                        box.set_border_width(range2Box, signalBorderWidth)
                        box.set_bgcolor(range2Box, color.new(sellSignalColor, 90))
    
    // MSG Range 3 Breakout Detection
    if msg3Enabled
        range3Set = array.get(msgRangeSet, 2)
        range3BreakoutTriggered = array.get(msgRangeBreakoutTriggered, 2)
        range3SignalExpired = array.get(msgRangeSignalExpired, 2)
        range3SignalExpiryTime = array.get(msgRangeSignalExpiryTimes, 2)
        range3High = array.get(msgRangeHighs, 2)
        range3Low = array.get(msgRangeLows, 2)
        range3Box = array.get(msgRangeBoxes, 2)
        
        if range3Set and not range3BreakoutTriggered and not range3SignalExpired
            // Check if signal window has expired
            if not na(range3SignalExpiryTime) and time > range3SignalExpiryTime and hoursAfterRangeForBreakout > 0
                array.set(msgRangeSignalExpired, 2, true)
                if not na(range3Box)
                    box.set_border_color(range3Box, color.gray)
                    box.set_bgcolor(range3Box, color.new(color.gray, 95))
            
            // Check for breakouts (only if not expired)
            if not array.get(msgRangeSignalExpired, 2)
                // Buy breakout
                if not na(range3High) and close > range3High
                    array.set(msgRangeBreakoutTriggered, 2, true)
                    array.set(msgRangeBreakoutDirection, 2, 1)
                    if not na(range3Box)
                        box.set_border_color(range3Box, buySignalColor)
                        box.set_border_width(range3Box, signalBorderWidth)
                        box.set_bgcolor(range3Box, color.new(buySignalColor, 90))
                
                // Sell breakout
                else if not na(range3Low) and close < range3Low
                    array.set(msgRangeBreakoutTriggered, 2, true)
                    array.set(msgRangeBreakoutDirection, 2, -1)
                    if not na(range3Box)
                        box.set_border_color(range3Box, sellSignalColor)
                        box.set_border_width(range3Box, signalBorderWidth)
                        box.set_bgcolor(range3Box, color.new(sellSignalColor, 90))
    
    // MSG Range 4 Breakout Detection
    if msg4Enabled
        range4Set = array.get(msgRangeSet, 3)
        range4BreakoutTriggered = array.get(msgRangeBreakoutTriggered, 3)
        range4SignalExpired = array.get(msgRangeSignalExpired, 3)
        range4SignalExpiryTime = array.get(msgRangeSignalExpiryTimes, 3)
        range4High = array.get(msgRangeHighs, 3)
        range4Low = array.get(msgRangeLows, 3)
        range4Box = array.get(msgRangeBoxes, 3)
        
        if range4Set and not range4BreakoutTriggered and not range4SignalExpired
            // Check if signal window has expired
            if not na(range4SignalExpiryTime) and time > range4SignalExpiryTime and hoursAfterRangeForBreakout > 0
                array.set(msgRangeSignalExpired, 3, true)
                if not na(range4Box)
                    box.set_border_color(range4Box, color.gray)
                    box.set_bgcolor(range4Box, color.new(color.gray, 95))
            
            // Check for breakouts (only if not expired)
            if not array.get(msgRangeSignalExpired, 3)
                // Buy breakout
                if not na(range4High) and close > range4High
                    array.set(msgRangeBreakoutTriggered, 3, true)
                    array.set(msgRangeBreakoutDirection, 3, 1)
                    if not na(range4Box)
                        box.set_border_color(range4Box, buySignalColor)
                        box.set_border_width(range4Box, signalBorderWidth)
                        box.set_bgcolor(range4Box, color.new(buySignalColor, 90))
                
                // Sell breakout
                else if not na(range4Low) and close < range4Low
                    array.set(msgRangeBreakoutTriggered, 3, true)
                    array.set(msgRangeBreakoutDirection, 3, -1)
                    if not na(range4Box)
                        box.set_border_color(range4Box, sellSignalColor)
                        box.set_border_width(range4Box, signalBorderWidth)
                        box.set_bgcolor(range4Box, color.new(sellSignalColor, 90))

// =====================================================
// SIGNAL ARROWS - For all MSG ranges
// =====================================================
if enableBreakoutSignals and showSignalArrows
    arrowSizeValue = arrowSize == "Small" ? size.small : arrowSize == "Large" ? size.large : size.normal
    
    // MSG Range 1 Signals
    if msg1Enabled
        range1Set = array.get(msgRangeSet, 0)
        range1SignalExpired = array.get(msgRangeSignalExpired, 0)
        range1BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 0)[1]
        range1High = array.get(msgRangeHighs, 0)
        range1Low = array.get(msgRangeLows, 0)
        
        if range1Set and not range1SignalExpired and not range1BreakoutTriggeredPrev
            // Buy signal
            if not na(range1High) and close > range1High
                label.new(bar_index, low - (range1High - range1Low) * 0.1, "▲", color=color.new(color.white, 100), textcolor=buySignalColor, style=label.style_label_up, size=arrowSizeValue)
            
            // Sell signal
            else if not na(range1Low) and close < range1Low
                label.new(bar_index, high + (range1High - range1Low) * 0.1, "▼", color=color.new(color.white, 100), textcolor=sellSignalColor, style=label.style_label_down, size=arrowSizeValue)
    
    // MSG Range 2 Signals
    if msg2Enabled
        range2Set = array.get(msgRangeSet, 1)
        range2SignalExpired = array.get(msgRangeSignalExpired, 1)
        range2BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 1)[1]
        range2High = array.get(msgRangeHighs, 1)
        range2Low = array.get(msgRangeLows, 1)
        
        if range2Set and not range2SignalExpired and not range2BreakoutTriggeredPrev
            // Buy signal
            if not na(range2High) and close > range2High
                label.new(bar_index, low - (range2High - range2Low) * 0.1, "▲", color=color.new(color.white, 100), textcolor=buySignalColor, style=label.style_label_up, size=arrowSizeValue)
            
            // Sell signal
            else if not na(range2Low) and close < range2Low
                label.new(bar_index, high + (range2High - range2Low) * 0.1, "▼", color=color.new(color.white, 100), textcolor=sellSignalColor, style=label.style_label_down, size=arrowSizeValue)
    
    // MSG Range 3 Signals
    if msg3Enabled
        range3Set = array.get(msgRangeSet, 2)
        range3SignalExpired = array.get(msgRangeSignalExpired, 2)
        range3BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 2)[1]
        range3High = array.get(msgRangeHighs, 2)
        range3Low = array.get(msgRangeLows, 2)
        
        if range3Set and not range3SignalExpired and not range3BreakoutTriggeredPrev
            // Buy signal
            if not na(range3High) and close > range3High
                label.new(bar_index, low - (range3High - range3Low) * 0.1, "▲", color=color.new(color.white, 100), textcolor=buySignalColor, style=label.style_label_up, size=arrowSizeValue)
            
            // Sell signal
            else if not na(range3Low) and close < range3Low
                label.new(bar_index, high + (range3High - range3Low) * 0.1, "▼", color=color.new(color.white, 100), textcolor=sellSignalColor, style=label.style_label_down, size=arrowSizeValue)
    
    // MSG Range 4 Signals
    if msg4Enabled
        range4Set = array.get(msgRangeSet, 3)
        range4SignalExpired = array.get(msgRangeSignalExpired, 3)
        range4BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 3)[1]
        range4High = array.get(msgRangeHighs, 3)
        range4Low = array.get(msgRangeLows, 3)
        
        if range4Set and not range4SignalExpired and not range4BreakoutTriggeredPrev
            // Buy signal
            if not na(range4High) and close > range4High
                label.new(bar_index, low - (range4High - range4Low) * 0.1, "▲", color=color.new(color.white, 100), textcolor=buySignalColor, style=label.style_label_up, size=arrowSizeValue)
            
            // Sell signal
            else if not na(range4Low) and close < range4Low
                label.new(bar_index, high + (range4High - range4Low) * 0.1, "▼", color=color.new(color.white, 100), textcolor=sellSignalColor, style=label.style_label_down, size=arrowSizeValue)

// =====================================================
// ALERT CONDITIONS - Version 3.0
// =====================================================
// Aggregate breakout signals from all enabled MSG ranges
// These alerts trigger only on confirmed bars to prevent repainting
// Alert messages are formatted as JSON for easy webhook parsing

// Track breakout signals from each range on current bar
var bool buyBreakoutSignal = false
var bool sellBreakoutSignal = false

// Reset signals each bar
buyBreakoutSignal := false
sellBreakoutSignal := false

// Check for new breakouts on current bar (not previously triggered)
// MSG Range 1
if msg1Enabled and enableBreakoutSignals
    range1Set = array.get(msgRangeSet, 0)
    range1SignalExpired = array.get(msgRangeSignalExpired, 0)
    range1BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 0)[1]
    range1High = array.get(msgRangeHighs, 0)
    range1Low = array.get(msgRangeLows, 0)
    if range1Set and not range1SignalExpired and not range1BreakoutTriggeredPrev
        if not na(range1High) and close > range1High
            buyBreakoutSignal := true
        else if not na(range1Low) and close < range1Low
            sellBreakoutSignal := true

// MSG Range 2
if msg2Enabled and enableBreakoutSignals
    range2Set = array.get(msgRangeSet, 1)
    range2SignalExpired = array.get(msgRangeSignalExpired, 1)
    range2BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 1)[1]
    range2High = array.get(msgRangeHighs, 1)
    range2Low = array.get(msgRangeLows, 1)
    if range2Set and not range2SignalExpired and not range2BreakoutTriggeredPrev
        if not na(range2High) and close > range2High
            buyBreakoutSignal := true
        else if not na(range2Low) and close < range2Low
            sellBreakoutSignal := true

// MSG Range 3
if msg3Enabled and enableBreakoutSignals
    range3Set = array.get(msgRangeSet, 2)
    range3SignalExpired = array.get(msgRangeSignalExpired, 2)
    range3BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 2)[1]
    range3High = array.get(msgRangeHighs, 2)
    range3Low = array.get(msgRangeLows, 2)
    if range3Set and not range3SignalExpired and not range3BreakoutTriggeredPrev
        if not na(range3High) and close > range3High
            buyBreakoutSignal := true
        else if not na(range3Low) and close < range3Low
            sellBreakoutSignal := true

// MSG Range 4
if msg4Enabled and enableBreakoutSignals
    range4Set = array.get(msgRangeSet, 3)
    range4SignalExpired = array.get(msgRangeSignalExpired, 3)
    range4BreakoutTriggeredPrev = array.get(msgRangeBreakoutTriggered, 3)[1]
    range4High = array.get(msgRangeHighs, 3)
    range4Low = array.get(msgRangeLows, 3)
    if range4Set and not range4SignalExpired and not range4BreakoutTriggeredPrev
        if not na(range4High) and close > range4High
            buyBreakoutSignal := true
        else if not na(range4Low) and close < range4Low
            sellBreakoutSignal := true

// Alert conditions - only trigger on confirmed bars to prevent repainting
buyAlertCondition = buyBreakoutSignal and barstate.isconfirmed
sellAlertCondition = sellBreakoutSignal and barstate.isconfirmed

// Buy Alert - Triggers when price breaks above any enabled MSG range high
alertcondition(buyAlertCondition, title="MSG LEGO Buy Signal", message='{"action": "BUY", "ticker": "{{ticker}}", "price": "{{close}}", "time": "{{time}}", "timeframe": "{{interval}}", "exchange": "{{exchange}}"}')

// Sell Alert - Triggers when price breaks below any enabled MSG range low
alertcondition(sellAlertCondition, title="MSG LEGO Sell Signal", message='{"action": "SELL", "ticker": "{{ticker}}", "price": "{{close}}", "time": "{{time}}", "timeframe": "{{interval}}", "exchange": "{{exchange}}"}')

// Combined Alert - Triggers on any buy or sell signal (useful for general notifications)
alertcondition(buyAlertCondition or sellAlertCondition, title="MSG LEGO Any Signal", message='{"action": "{{strategy.order.action}}", "ticker": "{{ticker}}", "price": "{{close}}", "time": "{{time}}", "timeframe": "{{interval}}", "exchange": "{{exchange}}"}')

// =====================================================
// ALERT DEBUG VISUALIZATION - For Replay Mode Testing
// =====================================================
// This section provides visual feedback when alerts trigger, useful for testing
// in replay mode where traditional alert popups don't appear
if showAlertDebug and enableBreakoutSignals
    // Determine debug table position
    debugPos = alertDebugPosition == "Top Right" ? position.top_right : alertDebugPosition == "Top Left" ? position.top_left : alertDebugPosition == "Bottom Right" ? position.bottom_right : position.bottom_left
    
    // Track alert triggers for debug display
    var int alertCount = 0
    var string lastAlertType = ""
    var float lastAlertPrice = na
    var int lastAlertTime = na
    
    // Update alert tracking when conditions trigger
    if buyAlertCondition
        alertCount := alertCount + 1
        lastAlertType := "BUY"
        lastAlertPrice := close
        lastAlertTime := time
        
        // Create visual label on chart for buy alert
        label.new(bar_index, high, "🔔 BUY ALERT\n" + str.tostring(close, "#.####"), color=color.new(buySignalColor, 20), textcolor=buySignalColor, style=label.style_label_down, size=size.normal, text_halign=text.align_center)
    
    if sellAlertCondition
        alertCount := alertCount + 1
        lastAlertType := "SELL"
        lastAlertPrice := close
        lastAlertTime := time
        
        // Create visual label on chart for sell alert
        label.new(bar_index, low, "🔔 SELL ALERT\n" + str.tostring(close, "#.####"), color=color.new(sellSignalColor, 20), textcolor=sellSignalColor, style=label.style_label_up, size=size.normal, text_halign=text.align_center)
    
    // Display debug table on last bar (shows current state)
    if barstate.islast
        var table alertDebugTable = table.new(debugPos, 2, 5, bgcolor=color.new(color.black, 80), frame_color=color.yellow, frame_width=2, border_width=1)
        
        // Header
        table.cell(alertDebugTable, 0, 0, "🔔 ALERT DEBUG", text_color=color.yellow, text_size=size.normal, text_halign=text.align_center, bgcolor=color.new(color.black, 50))
        table.cell(alertDebugTable, 1, 0, "Status", text_color=color.yellow, text_size=size.normal, text_halign=text.align_center, bgcolor=color.new(color.black, 50))
        
        // Alert count
        table.cell(alertDebugTable, 0, 1, "Total Alerts", text_color=color.white, text_size=size.small, text_halign=text.align_left)
        table.cell(alertDebugTable, 1, 1, str.tostring(alertCount), text_color=color.white, text_size=size.small, text_halign=text.align_right)
        
        // Last alert type
        table.cell(alertDebugTable, 0, 2, "Last Alert", text_color=color.white, text_size=size.small, text_halign=text.align_left)
        lastAlertText = lastAlertType != "" ? lastAlertType : "None"
        lastAlertColor = lastAlertType == "BUY" ? buySignalColor : lastAlertType == "SELL" ? sellSignalColor : color.gray
        table.cell(alertDebugTable, 1, 2, lastAlertText, text_color=lastAlertColor, text_size=size.small, text_halign=text.align_right)
        
        // Last alert price
        table.cell(alertDebugTable, 0, 3, "Last Price", text_color=color.white, text_size=size.small, text_halign=text.align_left)
        lastPriceText = not na(lastAlertPrice) ? str.tostring(lastAlertPrice, "#.####") : "N/A"
        table.cell(alertDebugTable, 1, 3, lastPriceText, text_color=color.white, text_size=size.small, text_halign=text.align_right)
        
        // Current alert status
        table.cell(alertDebugTable, 0, 4, "Current Status", text_color=color.white, text_size=size.small, text_halign=text.align_left)
        currentStatus = buyAlertCondition ? "BUY Ready" : sellAlertCondition ? "SELL Ready" : "Monitoring"
        currentStatusColor = buyAlertCondition ? buySignalColor : sellAlertCondition ? sellSignalColor : color.gray
        table.cell(alertDebugTable, 1, 4, currentStatus, text_color=currentStatusColor, text_size=size.small, text_halign=text.align_right)

// =====================================================
// SESSION BOXES
// =====================================================
// Session A (New York)
if sessionAEnabled
    inSessionA = isInSession(sessionAStartHour, sessionAEndHour)
    wasInSessionA = isInSession(sessionAStartHour, sessionAEndHour)[1]
    
    if inSessionA
        if na(asiaStart) or not wasInSessionA
            asiaStart := time
            asiaHigh := high
            asiaLow := low
        else
            asiaHigh := math.max(asiaHigh, high)
            asiaLow := math.min(asiaLow, low)
    
    if not inSessionA and wasInSessionA and not na(asiaStart)
        box.new(left=asiaStart, top=asiaHigh, right=time[1], bottom=asiaLow, border_color=sessionAColor, bgcolor=color.new(sessionAColor, 95), border_width=1, xloc=xloc.bar_time)
        if showSessionLabels
            label.new(x=asiaStart, y=asiaHigh, text=sessionAName, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.large, xloc=xloc.bar_time)

// Session B (London)
if sessionBEnabled
    inSessionB = isInSession(sessionBStartHour, sessionBEndHour)
    wasInSessionB = isInSession(sessionBStartHour, sessionBEndHour)[1]
    
    if inSessionB
        if na(londonStart) or not wasInSessionB
            londonStart := time
            londonHigh := high
            londonLow := low
        else
            londonHigh := math.max(londonHigh, high)
            londonLow := math.min(londonLow, low)
    
    if not inSessionB and wasInSessionB and not na(londonStart)
        box.new(left=londonStart, top=londonHigh, right=time[1], bottom=londonLow, border_color=sessionBColor, bgcolor=color.new(sessionBColor, 95), border_width=1, xloc=xloc.bar_time)
        if showSessionLabels
            label.new(x=londonStart, y=londonHigh, text=sessionBName, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.large, xloc=xloc.bar_time)

// Session C (Tokyo/Asia)
if sessionCEnabled
    inSessionC = isInSession(sessionCStartHour, sessionCEndHour)
    wasInSessionC = isInSession(sessionCStartHour, sessionCEndHour)[1]
    
    if inSessionC
        if na(nyStart) or not wasInSessionC
            nyStart := time
            nyHigh := high
            nyLow := low
        else
            nyHigh := math.max(nyHigh, high)
            nyLow := math.min(nyLow, low)
    
    if not inSessionC and wasInSessionC and not na(nyStart)
        box.new(left=nyStart, top=nyHigh, right=time[1], bottom=nyLow, border_color=sessionCColor, bgcolor=color.new(sessionCColor, 95), border_width=1, xloc=xloc.bar_time)
        if showSessionLabels
            label.new(x=nyStart, y=nyHigh, text=sessionCName, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.large, xloc=xloc.bar_time)

// =====================================================
// DASHBOARD
// =====================================================
if showDashboard and barstate.islast
    // Determine position
    dashPos = dashboardPosition == "Top Right" ? position.top_right : dashboardPosition == "Top Left" ? position.top_left : dashboardPosition == "Bottom Right" ? position.bottom_right : position.bottom_left
    
    // Build dashboard text
    var dashText = ""
    dashText := "═══ MSG LEGO SYSTEM ═══\n"
    dashText += "Risk Level: " + riskLevel + "\n"
    
    // Show active ranges
    activeRanges = 0
    if msg1Enabled and array.get(msgRangeSet, 0)
        activeRanges += 1
    if msg2Enabled and array.get(msgRangeSet, 1)
        activeRanges += 1
    if msg3Enabled and array.get(msgRangeSet, 2)
        activeRanges += 1
    if msg4Enabled and array.get(msgRangeSet, 3)
        activeRanges += 1
    
    dashText += "Active Ranges: " + str.tostring(activeRanges) + "\n"
    
    // Current session
    currentSession = isInSession(sessionCStartHour, sessionCEndHour) ? sessionCName : isInSession(sessionBStartHour, sessionBEndHour) ? sessionBName : isInSession(sessionAStartHour, sessionAEndHour) ? sessionAName : "None"
    dashText += "Session: " + currentSession
    
    // Display table
    var table infoTable = table.new(dashPos, 1, 1, bgcolor=color.new(color.black, 70), frame_color=color.white, frame_width=1)
    table.cell(infoTable, 0, 0, dashText, text_color=color.white, text_size=size.small, text_halign=text.align_left)


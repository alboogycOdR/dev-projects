grp_advanced = "ADVANCED SETTINGS"
riskLevel = input.string("Low Risk", title="Risk Level", options=["Low Risk", "Medium Risk", "High Risk", "Very High Risk"], group=grp_advanced)
numberOfOrders = input.int(1, title="Number of Orders (Visual Only)", minval=1, group=grp_advanced)

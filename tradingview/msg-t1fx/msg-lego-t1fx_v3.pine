dashboardPosition = input.string("Top Right", title="Dashboard Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grp_advanced)
arrowSize = input.string("Normal", title="Arrow Size", options=["Small", "Normal", "Large"], group=grp_advanced)
rangeLineWidth = input.int(2, title="Range Line Width", minval=1, maxval=4, group=grp_advanced)
showSessionLabels = input.bool(true, title="Show Session Labels", group=grp_advanced)
showAlertDebug = input.bool(true, title="Show Alert Debug (Replay Mode)", group=grp_advanced, tooltip="Shows visual indicators when alerts trigger - useful for testing in replay mode")
alertDebugPosition = input.string("Top Left", title="Alert Debug Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grp_advanced)

// =====================================================
// FUNCTIONS - TIME CONVERSIONS
// =====================================================
// Convert hours to milliseconds
hoursToMs(hours) => hours * 60 * 60 * 1000

// Get GMT time
getGMTHour() =>
    utcHour = hour(time, "UTC")
    utcHour

getGMTMinute() =>
    utcMinute = minute(time, "UTC")
    utcMinute

// Check if current time is within a session
isInSession(startHour, endHour) =>
    currentHour = getGMTHour()
    if startHour < endHour
        currentHour >= startHour and currentHour < endHour
    else  // Session crosses midnight
        currentHour >= startHour or currentHour < endHour

// Check if we're in a specific MSG range period
isInMsgRange(startHour, startMinute, endHour, endMinute) =>
    currentHour = getGMTHour()
    currentMinute = getGMTMinute()
    rangeStart = startHour * 60 + startMinute
    rangeEnd = endHour * 60 + endMinute
    currentTime = currentHour * 60 + currentMinute
    if rangeEnd > rangeStart
        currentTime >= rangeStart and currentTime < rangeEnd
    else  // Crosses midnight
        currentTime >= rangeStart or currentTime < rangeEnd

// =====================================================
// MSG RANGE TRACKING - Using arrays for multiple ranges
// =====================================================
// Arrays to track all MSG ranges
var array<float> msgRangeHighs = array.new<float>(4, na)
var array<float> msgRangeLows = array.new<float>(4, na)
var array<bool> msgRangeSet = array.new<bool>(4, false)
var array<int> msgRangeStartTimes = array.new<int>(4, na)
var array<int> msgRangeEndTimes = array.new<int>(4, na)
var array<int> msgRangeSignalExpiryTimes = array.new<int>(4, na)
var array<bool> msgRangeBreakoutTriggered = array.new<bool>(4, false)
var array<int> msgRangeBreakoutDirection = array.new<int>(4, 0)  // 1 for buy, -1 for sell
var array<bool> msgRangeSignalExpired = array.new<bool>(4, false)
var array<box> msgRangeBoxes = array.new<box>(4, na)
var array<label> msgRangeLabels = array.new<label>(4, na)

// Session tracking variables
var float asiaHigh = na
var float asiaLow = na
var int asiaStart = na
var float londonHigh = na
var float londonLow = na
var int londonStart = na
var float nyHigh = na
var float nyLow = na
var int nyStart = na

// New day detection
newDay = dayofmonth != dayofmonth[1]

// Reset session variables on new day
if newDay
    asiaHigh := na
    asiaLow := na
    asiaStart := na
    londonHigh := na
    londonLow := na
    londonStart := na
    nyHigh := na
    nyLow := na
    nyStart := na

// =====================================================
// MSG RANGE PROCESSING - Process each range independently
// =====================================================

// MSG Range 1
if msg1Enabled and msg1ShowRange
    inRange1 = isInMsgRange(msg1StartHour, msg1StartMinute, msg1EndHour, msg1EndMinute)
    wasInRange1 = isInMsgRange(msg1StartHour, msg1StartMinute, msg1EndHour, msg1EndMinute)[1]
    range1High = array.get(msgRangeHighs, 0)
    range1Low = array.get(msgRangeLows, 0)
    range1Set = array.get(msgRangeSet, 0)
    range1StartTime = array.get(msgRangeStartTimes, 0)
    range1EndTime = array.get(msgRangeEndTimes, 0)
    range1Box = array.get(msgRangeBoxes, 0)
    
    // Reset when entering new range period
    if inRange1 and not wasInRange1 and range1Set
        array.set(msgRangeSet, 0, false)
        array.set(msgRangeHighs, 0, na)
        array.set(msgRangeLows, 0, na)
        array.set(msgRangeStartTimes, 0, na)
        array.set(msgRangeEndTimes, 0, na)
        array.set(msgRangeSignalExpiryTimes, 0, na)
        array.set(msgRangeBreakoutTriggered, 0, false)
        array.set(msgRangeBreakoutDirection, 0, 0)
        array.set(msgRangeSignalExpired, 0, false)
        if not na(range1Box)
            box.delete(range1Box)
            array.set(msgRangeBoxes, 0, na)
        range1High := na
        range1Low := na
        range1StartTime := na
        range1Box := na
    
    // Update range during the period
    if inRange1 and not range1Set
        if na(range1High) or high > range1High
            range1High := high
        if na(range1Low) or low < range1Low
            range1Low := low
        array.set(msgRangeHighs, 0, range1High)
        array.set(msgRangeLows, 0, range1Low)
        
        if na(range1StartTime)
            range1StartTime := time
            array.set(msgRangeStartTimes, 0, range1StartTime)
        
        // Draw/update range box in real-time during range period
        if not na(range1High) and not na(range1Low) and not na(range1StartTime)
            if na(range1Box)
                range1Box := box.new(left=range1StartTime, top=range1High, right=time, bottom=range1Low, border_color=msg1Color, border_width=rangeLineWidth, bgcolor=color.new(msg1Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 0, range1Box)
            else
                box.set_right(range1Box, time)
                box.set_top(range1Box, range1High)
                box.set_bottom(range1Box, range1Low)
    
    // Finalize range when period ends
    if wasInRange1 and not inRange1 and not range1Set and not na(range1High) and not na(range1Low) and not na(range1StartTime)
        array.set(msgRangeSet, 0, true)
        range1EndTime := time
        array.set(msgRangeEndTimes, 0, range1EndTime)
        array.set(msgRangeSignalExpiryTimes, 0, range1EndTime + hoursToMs(hoursAfterRangeForBreakout))
        
        // Finalize the range box
        if na(range1Box)
            range1Box := box.new(left=range1StartTime, top=range1High, right=range1EndTime, bottom=range1Low, border_color=msg1Color, border_width=rangeLineWidth, bgcolor=color.new(msg1Color, 85), xloc=xloc.bar_time)
            array.set(msgRangeBoxes, 0, range1Box)
        else
            box.set_right(range1Box, range1EndTime)
            box.set_top(range1Box, range1High)
            box.set_bottom(range1Box, range1Low)
        
        // Create persistent box for historical bars
        if barstate.isconfirmed
            box.new(left=range1StartTime, top=range1High, right=range1EndTime, bottom=range1Low, border_color=msg1Color, border_width=rangeLineWidth, bgcolor=color.new(msg1Color, 85), xloc=xloc.bar_time)
            
            // Create persistent label for historical bars
            if showSessionLabels
                labelX = range1StartTime + (range1EndTime - range1StartTime) / 2
                label.new(x=labelX, y=range1High, text=msg1Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
        
        // Add range label for real-time updates
        if showSessionLabels
            range1Label = array.get(msgRangeLabels, 0)
            if na(range1Label)
                labelX = range1StartTime + (range1EndTime - range1StartTime) / 2
                range1Label := label.new(x=labelX, y=range1High, text=msg1Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
                array.set(msgRangeLabels, 0, range1Label)
    
    // Ensure range box persists after range period ends
    if range1Set and not na(range1High) and not na(range1Low) and not na(range1StartTime)
        range1EndTime = array.get(msgRangeEndTimes, 0)
        if not na(range1EndTime)
            if na(range1Box)
                range1Box := box.new(left=range1StartTime, top=range1High, right=range1EndTime, bottom=range1Low, border_color=msg1Color, border_width=rangeLineWidth, bgcolor=color.new(msg1Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 0, range1Box)
            else
                box.set_left(range1Box, range1StartTime)
                box.set_right(range1Box, range1EndTime)
                box.set_top(range1Box, range1High)
                box.set_bottom(range1Box, range1Low)

// MSG Range 2
if msg2Enabled and msg2ShowRange
    inRange2 = isInMsgRange(msg2StartHour, msg2StartMinute, msg2EndHour, msg2EndMinute)
    wasInRange2 = isInMsgRange(msg2StartHour, msg2StartMinute, msg2EndHour, msg2EndMinute)[1]
    range2High = array.get(msgRangeHighs, 1)
    range2Low = array.get(msgRangeLows, 1)
    range2Set = array.get(msgRangeSet, 1)
    range2StartTime = array.get(msgRangeStartTimes, 1)
    range2EndTime = array.get(msgRangeEndTimes, 1)
    range2Box = array.get(msgRangeBoxes, 1)
    
    // Reset when entering new range period
    if inRange2 and not wasInRange2 and range2Set
        array.set(msgRangeSet, 1, false)
        array.set(msgRangeHighs, 1, na)
        array.set(msgRangeLows, 1, na)
        array.set(msgRangeStartTimes, 1, na)
        array.set(msgRangeEndTimes, 1, na)
        array.set(msgRangeSignalExpiryTimes, 1, na)
        array.set(msgRangeBreakoutTriggered, 1, false)
        array.set(msgRangeBreakoutDirection, 1, 0)
        array.set(msgRangeSignalExpired, 1, false)
        if not na(range2Box)
            box.delete(range2Box)
            array.set(msgRangeBoxes, 1, na)
        range2High := na
        range2Low := na
        range2StartTime := na
        range2Box := na
    
    // Update range during the period
    if inRange2 and not range2Set
        if na(range2High) or high > range2High
            range2High := high
        if na(range2Low) or low < range2Low
            range2Low := low
        array.set(msgRangeHighs, 1, range2High)
        array.set(msgRangeLows, 1, range2Low)
        
        if na(range2StartTime)
            range2StartTime := time
            array.set(msgRangeStartTimes, 1, range2StartTime)
        
        // Draw/update range box in real-time during range period
        if not na(range2High) and not na(range2Low) and not na(range2StartTime)
            if na(range2Box)
                range2Box := box.new(left=range2StartTime, top=range2High, right=time, bottom=range2Low, border_color=msg2Color, border_width=rangeLineWidth, bgcolor=color.new(msg2Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 1, range2Box)
            else
                box.set_right(range2Box, time)
                box.set_top(range2Box, range2High)
                box.set_bottom(range2Box, range2Low)
    
    // Finalize range when period ends
    if wasInRange2 and not inRange2 and not range2Set and not na(range2High) and not na(range2Low) and not na(range2StartTime)
        array.set(msgRangeSet, 1, true)
        range2EndTime := time
        array.set(msgRangeEndTimes, 1, range2EndTime)
        array.set(msgRangeSignalExpiryTimes, 1, range2EndTime + hoursToMs(hoursAfterRangeForBreakout))
        
        // Finalize the range box
        if na(range2Box)
            range2Box := box.new(left=range2StartTime, top=range2High, right=range2EndTime, bottom=range2Low, border_color=msg2Color, border_width=rangeLineWidth, bgcolor=color.new(msg2Color, 85), xloc=xloc.bar_time)
            array.set(msgRangeBoxes, 1, range2Box)
        else
            box.set_right(range2Box, range2EndTime)
            box.set_top(range2Box, range2High)
            box.set_bottom(range2Box, range2Low)
        
        // Create persistent box for historical bars
        if barstate.isconfirmed
            box.new(left=range2StartTime, top=range2High, right=range2EndTime, bottom=range2Low, border_color=msg2Color, border_width=rangeLineWidth, bgcolor=color.new(msg2Color, 85), xloc=xloc.bar_time)
            
            // Create persistent label for historical bars
            if showSessionLabels
                labelX = range2StartTime + (range2EndTime - range2StartTime) / 2
                label.new(x=labelX, y=range2High, text=msg2Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
        
        // Add range label for real-time updates
        if showSessionLabels
            range2Label = array.get(msgRangeLabels, 1)
            if na(range2Label)
                labelX = range2StartTime + (range2EndTime - range2StartTime) / 2
                range2Label := label.new(x=labelX, y=range2High, text=msg2Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
                array.set(msgRangeLabels, 1, range2Label)
    
    // Ensure range box persists after range period ends
    if range2Set and not na(range2High) and not na(range2Low) and not na(range2StartTime)
        range2EndTime = array.get(msgRangeEndTimes, 1)
        if not na(range2EndTime)
            if na(range2Box)
                range2Box := box.new(left=range2StartTime, top=range2High, right=range2EndTime, bottom=range2Low, border_color=msg2Color, border_width=rangeLineWidth, bgcolor=color.new(msg2Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 1, range2Box)
            else
                box.set_left(range2Box, range2StartTime)
                box.set_right(range2Box, range2EndTime)
                box.set_top(range2Box, range2High)
                box.set_bottom(range2Box, range2Low)

// MSG Range 3
if msg3Enabled and msg3ShowRange
    inRange3 = isInMsgRange(msg3StartHour, msg3StartMinute, msg3EndHour, msg3EndMinute)
    wasInRange3 = isInMsgRange(msg3StartHour, msg3StartMinute, msg3EndHour, msg3EndMinute)[1]
    range3High = array.get(msgRangeHighs, 2)
    range3Low = array.get(msgRangeLows, 2)
    range3Set = array.get(msgRangeSet, 2)
    range3StartTime = array.get(msgRangeStartTimes, 2)
    range3EndTime = array.get(msgRangeEndTimes, 2)
    range3Box = array.get(msgRangeBoxes, 2)
    
    // Reset when entering new range period
    if inRange3 and not wasInRange3 and range3Set
        array.set(msgRangeSet, 2, false)
        array.set(msgRangeHighs, 2, na)
        array.set(msgRangeLows, 2, na)
        array.set(msgRangeStartTimes, 2, na)
        array.set(msgRangeEndTimes, 2, na)
        array.set(msgRangeSignalExpiryTimes, 2, na)
        array.set(msgRangeBreakoutTriggered, 2, false)
        array.set(msgRangeBreakoutDirection, 2, 0)
        array.set(msgRangeSignalExpired, 2, false)
        if not na(range3Box)
            box.delete(range3Box)
            array.set(msgRangeBoxes, 2, na)
        range3High := na
        range3Low := na
        range3StartTime := na
        range3Box := na
    
    // Update range during the period
    if inRange3 and not range3Set
        if na(range3High) or high > range3High
            range3High := high
        if na(range3Low) or low < range3Low
            range3Low := low
        array.set(msgRangeHighs, 2, range3High)
        array.set(msgRangeLows, 2, range3Low)
        
        if na(range3StartTime)
            range3StartTime := time
            array.set(msgRangeStartTimes, 2, range3StartTime)
        
        // Draw/update range box in real-time during range period
        if not na(range3High) and not na(range3Low) and not na(range3StartTime)
            if na(range3Box)
                range3Box := box.new(left=range3StartTime, top=range3High, right=time, bottom=range3Low, border_color=msg3Color, border_width=rangeLineWidth, bgcolor=color.new(msg3Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 2, range3Box)
            else
                box.set_right(range3Box, time)
                box.set_top(range3Box, range3High)
                box.set_bottom(range3Box, range3Low)
    
    // Finalize range when period ends
    if wasInRange3 and not inRange3 and not range3Set and not na(range3High) and not na(range3Low) and not na(range3StartTime)
        array.set(msgRangeSet, 2, true)
        range3EndTime := time
        array.set(msgRangeEndTimes, 2, range3EndTime)
        array.set(msgRangeSignalExpiryTimes, 2, range3EndTime + hoursToMs(hoursAfterRangeForBreakout))
        
        // Finalize the range box
        if na(range3Box)
            range3Box := box.new(left=range3StartTime, top=range3High, right=range3EndTime, bottom=range3Low, border_color=msg3Color, border_width=rangeLineWidth, bgcolor=color.new(msg3Color, 85), xloc=xloc.bar_time)
            array.set(msgRangeBoxes, 2, range3Box)
        else
            box.set_right(range3Box, range3EndTime)
            box.set_top(range3Box, range3High)
            box.set_bottom(range3Box, range3Low)
        
        // Create persistent box for historical bars
        if barstate.isconfirmed
            box.new(left=range3StartTime, top=range3High, right=range3EndTime, bottom=range3Low, border_color=msg3Color, border_width=rangeLineWidth, bgcolor=color.new(msg3Color, 85), xloc=xloc.bar_time)
            
            // Create persistent label for historical bars
            if showSessionLabels
                labelX = range3StartTime + (range3EndTime - range3StartTime) / 2
                label.new(x=labelX, y=range3High, text=msg3Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
        
        // Add range label for real-time updates
        if showSessionLabels
            range3Label = array.get(msgRangeLabels, 2)
            if na(range3Label)
                labelX = range3StartTime + (range3EndTime - range3StartTime) / 2
                range3Label := label.new(x=labelX, y=range3High, text=msg3Name, color=color.new(color.white, 100), textcolor=color.black, style=label.style_label_down, size=size.small, xloc=xloc.bar_time)
                array.set(msgRangeLabels, 2, range3Label)
    
    // Ensure range box persists after range period ends
    if range3Set and not na(range3High) and not na(range3Low) and not na(range3StartTime)
        range3EndTime = array.get(msgRangeEndTimes, 2)
        if not na(range3EndTime)
            if na(range3Box)
                range3Box := box.new(left=range3StartTime, top=range3High, right=range3EndTime, bottom=range3Low, border_color=msg3Color, border_width=rangeLineWidth, bgcolor=color.new(msg3Color, 85), xloc=xloc.bar_time)
                array.set(msgRangeBoxes, 2, range3Box)
            else
                box.set_left(range3Box, range3StartTime)
                box.set_right(range3Box, range3EndTime)
                box.set_top(range3Box, range3High)
                box.set_bottom(range3Box, range3Low)

// MSG Range 4
if msg4Enabled and msg4ShowRange
    inRange4 = isInMsgRange(msg4StartHour, msg4StartMinute, msg4EndHour, msg4EndMinute)
    wasInRange4 = isInMsgRange(msg4StartHour, msg4StartMinute, msg4EndHour, msg4EndMinute)[1]
    range4High = array.get(msgRangeHighs, 3)
    range4Low = array.get(msgRangeLows, 3)
    range4Set = array.get(msgRangeSet, 3)
    range4StartTime = array.get(msgRangeStartTimes, 3)
    range4EndTime = array.get(msgRangeEndTimes, 3)
    range4Box = array.get(msgRangeBoxes, 3)
    
    // Reset when entering new range period
    if inRange4 and not wasInRange4 and range4Set
        array.set(msgRangeSet, 3, false)
        array.set(msgRangeHighs, 3, na)
        array.set(msgRangeLows, 3, na)
        array.set(msgRangeStartTimes, 3, na)
        array.set(msgRangeEndTimes, 3, na)
        array.set(msgRangeSignalExpiryTimes, 3, na)
        array.set(msgRangeBreakoutTriggered, 3, false)
        array.set(msgRangeBreakoutDirection, 3, 0)
        array.set(msgRangeSignalExpired, 3, false)
        if not na(range4Box)
            box.delete(range4Box)
            array.set(msgRangeBoxes, 3, na)
        range4High := na

        range4StartTime := na
        range4Box := na
    
    // Update range during the period
    if inRange4 and not range4Set
        if na(range4High) or high > range4High
            range4High := high
        if na(range4Low) or low < range4Low
            range4Low := low
        array.set(msgRangeHighs, 3, range4High)
        array.set(msgRangeLows, 3, range4Low)
        

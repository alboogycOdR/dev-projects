//@version=5
indicator("ICT Open Range Breakout (ORB) Strategy", overlay=true, max_bars_back=500)

// ----------------------------------------------------------------------------
// 1. Input Parameters
// ----------------------------------------------------------------------------

// General Configuration
string executionType = input.string("FVG", "Execution Type", options=["FVG", "MSS"], tooltip="Determines the primary entry trigger: Fair Value Gap (FVG) or Market Structure Shift (MSS).")
int mssOffset = input.int(10, "MSS Swing Length", minval=1, tooltip="Swing length for Market Structure Shift (MSS) detection.")
string breakoutMethod = input.string("Close", "Breakout Method", options=["Close", "Wick"], tooltip="Method to determine liquidity/ORB breakout: candle close or wick.")
string fvgBars = input.string("Same Type", "FVG Bar Type", options=["Same Type", "All"], tooltip="Defines how Fair Value Gap (FVG) bars are detected: 'Same Type' (all 3 bars forming FVG must be same type) or 'All' (bar types may vary).")
bool fvgSensEnabled = input.bool(true, "Enable FVG Sensitivity", tooltip="Enables/disables FVG detection sensitivity.")
string fvgSensitivityText = input.string("Extreme", "FVG Sensitivity", options=["Extreme", "High", "Normal", "Low"], tooltip="Sensitivity level for FVG detection.")
string fvgEntry = input.string("Along", "FVG Entry Direction", options=["All", "Along", "Inverse"], tooltip="Defines FVG entry direction. (Debug input)")
bool allowGaps = input.bool(true, "Allow Gaps in FVG", tooltip="Allows FVG detection with gaps.")

// TP / SL Configuration
string tpslMethod = input.string("Dynamic", "TP/SL Method", options=["Dynamic", "Fixed"], tooltip="Method for calculating Take Profit and Stop Loss.")
string riskAmount = input.string("Normal", "Risk Amount (Dynamic TP/SL)", options=["High", "Normal", "Low"], tooltip="Risk amount for Dynamic TP/SL.")
float tpPercent = input.float(0.3, "TP % (Fixed TP/SL)", minval=0.01, tooltip="Take Profit percentage for Fixed TP/SL.")
float slPercent = input.float(0.4, "SL % (Fixed TP/SL)", minval=0.01, tooltip="Stop Loss percentage for Fixed TP/SL.")
bool closePositionAtEndSession = input.bool(true, "Close Position at Session End", tooltip="Closes open positions at the end of the trading session.")

// Debug Configuration (Internal)
float RR = 0.99 // Risk:Reward Ratio
bool requireFVGRetracement = true // Requires FVG retracement for entry
float slATRMult = riskAmount == "High" ? 1.5 : riskAmount == "Normal" ? 2.0 : 2.5 // Stop Loss ATR Multiplier
bool executeInsideSession = true // Must execute inside session
bool ny1Enabled = true // Enables NY Session 1
bool ny2Enabled = true // Enables NY Session 2
bool lnEnabled = true // Enables London Session

// Backtesting Dashboard Configuration (Internal)
bool backtestDisplayEnabled = true
string backtestingLocation = "Top Center"
bool fillBackgrounds = true
color screenerColor = #1B1F2B

// Visuals Configuration
color highColor = input.color(color.green, "Buy Signal Color")
color lowColor = input.color(color.red, "Sell Signal Color")
color textColor = input.color(color.white, "Text Color")

// Alerts Configuration
bool buyAlertEnabled = input.bool(true, "Enable Buy Alerts")
bool sellAlertEnabled = input.bool(true, "Enable Sell Alerts")
bool tpAlertEnabled = input.bool(true, "Enable TP Alerts")
bool slAlertEnabled = input.bool(true, "Enable SL Alerts")

// Improved Strategy Configuration (New Inputs)
string dailyBias = input.string("None", "Daily Bias", options=["None", "Bullish", "Bearish"], tooltip="Sets a directional bias for the day. Only trades aligning with this bias will be considered.")
bool useHigherTFliq = input.bool(true, "Use Higher TF Liquidity", tooltip="Considers previous daily/session highs/lows for liquidity sweeps.")
bool requireDisplacement = input.bool(true, "Require Displacement", tooltip="Requires strong displacement after liquidity sweep/ORB breakout for entry.")
bool requireOBConfluence = input.bool(true, "Require OB Confluence", tooltip="Requires entry within a valid Order Block.")

// New ORB Specific Inputs
string orbSession = input.string("New York", "ORB Session", options=["New York", "London", "Asia"], tooltip="Selects the trading session for Open Range Breakout.")
int orbStartTimeHour = input.int(9, "ORB Start Hour", minval=0, maxval=23, tooltip="Hour (0-23) for Open Range calculation start.")
int orbStartTimeMinute = input.int(30, "ORB Start Minute", minval=0, maxval=59, tooltip="Minute (0-59) for Open Range calculation start.")
int orbEndTimeHour = input.int(9, "ORB End Hour", minval=0, maxval=23, tooltip="Hour (0-23) for Open Range calculation end.")
int orbEndTimeMinute = input.int(45, "ORB End Minute", minval=0, maxval=59, tooltip="Minute (0-59) for Open Range calculation end.")
bool requireORBLiquiditySweep = input.bool(false, "Require ORB Liquidity Sweep", tooltip="Requires a liquidity sweep of the ORB high/low for entry confirmation.")
float slBufferMultiplier = input.float(0.5, "SL Buffer Multiplier (ATR)", minval=0.0, tooltip="Multiplier for ATR to add buffer to Stop Loss from OB/ORB.")

// ----------------------------------------------------------------------------
// 2. Type Definitions
// ----------------------------------------------------------------------------

type FVG
    int startTime
    int endTime
    float top
    float bottom
    bool isBull

type Sweep
    int startTime
    int endTime
    string side
    float price

type OrderBlock
    int startTime
    int endTime
    float high
    float low
    bool isBull

type ORB
    int startTime
    int endTime
    float high
    float low
    bool established

type Trade
    string state // "Waiting For ORB", "Waiting For Breakout", "Waiting For Displacement", "Waiting For OB Retracement", "Entry Taken", "Closed"
    int startTime
    int lastHour
    float lastHourHigh
    float lastHourLow
    Sweep brokenSweep
    float slTarget
    float tpTarget
    string entryType
    int entryTime
    int exitTime
    float entryPrice
    float exitPrice
    int dayEndedBeforeExit
    FVG fvg
    OrderBlock ob
    ORB orbRange

// ----------------------------------------------------------------------------
// 3. Global Variables
// ----------------------------------------------------------------------------

var Trade lastTrade = na
var ORB currentORB = na

// ----------------------------------------------------------------------------
// 4. Helper Functions
// ----------------------------------------------------------------------------

// Function to get session times in milliseconds
getSessionTimes(session) =>
    int startHour = 0
    int startMinute = 0
    int endHour = 0
    int endMinute = 0

    if session == "New York"
        startHour := 13 // 9 AM NY time (UTC-4)
        startMinute := 0
        endHour := 16 // 12 PM NY time (UTC-4)
        endMinute := 0
    else if session == "London"
        startHour := 7 // 3 AM NY time (UTC-4)
        startMinute := 0
        endHour := 10 // 6 AM NY time (UTC-4)
        endMinute := 0
    else if session == "Asia"
        startHour := 0 // 8 PM NY time (UTC-4) previous day
        startMinute := 0
        endHour := 6 // 2 AM NY time (UTC-4)
        endMinute := 0

    [startHour, startMinute, endHour, endMinute]

// Function to check if current bar is within a session
bool insideSession(int startHour, int startMinute, int endHour, int endMinute) =>
    time(timeframe.period, str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", startHour, startMinute, endHour, endMinute), "America/New_York")

// Function to check if a new session has started
bool newSession(int startHour, int startMinute, int endHour, int endMinute) =>
    na(time(timeframe.period, str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", startHour, startMinute, endHour, endMinute), "America/New_York")[1]) and not na(time(timeframe.period, str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", startHour, startMinute, endHour, endMinute), "America/New_York"])) and hour(time("America/New_York")) == startHour and minute(time("America/New_York")) == startMinute

// Function to check if session has ended
bool endSession(int startHour, int startMinute, int endHour, int endMinute) =>
    not na(time(timeframe.period, str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", startHour, startMinute, endHour, endMinute), "America/New_York")[1]) and na(time(timeframe.period, str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", startHour, startMinute, endHour, endMinute), "America/New_York"])) and hour(time("America/New_York")[1]) == endHour and minute(time("America/New_York")[1]) == endMinute

// Function to calculate percentage difference
float diffPercent(float val1, float val2) =>
    math.abs(val1 - val2) / ((val1 + val2) / 2) * 100

// Function to get current position (long/short/flat)
string getPosition() =>
    if strategy.position_size > 0
        "Long"
    else if strategy.position_size < 0
        "Short"
    else
        "Flat"

// Function to detect Fair Value Gap (FVG)
FVG findFVG(int lookback, bool isBullish) =>
    float fvgTop = na
    float fvgBottom = na
    bool fvgFound = false

    for i = 1 to lookback
        if isBullish
            if low[i] > high[i+2]
                fvgTop := low[i]
                fvgBottom := high[i+2]
                fvgFound := true
                break
        else
            if high[i] < low[i+2]
                fvgTop := high[i]
                fvgBottom := low[i+2]
                fvgFound := true
                break

    fvgFound ? FVG.new(time[lookback], time, fvgTop, fvgBottom, isBullish) : na

// Function to detect displacement
bool isDisplacement(int lookback, bool isBullish) =>
    bool displaced = true
    float atr = ta.atr(14)

    for i = 1 to lookback
        if isBullish
            if not (close[i] > open[i] and (close[i] - open[i]) > (0.5 * atr))
                displaced := false
                break
        else
            if not (open[i] > close[i] and (open[i] - close[i]) > (0.5 * atr))
                displaced := false
                break
    displaced

// Function to find Order Block
OrderBlock findOrderBlock(int lookback, bool isBullish) =>
    float obHigh = na
    float obLow = na
    int obStartTime = na
    int obEndTime = na

    for i = 1 to lookback
        if isBullish // Looking for bullish OB (last bearish candle before displacement)
            if close[i] < open[i] // If current candle is bearish
                // Check if the next few candles show displacement
                if isDisplacement(math.min(lookback - i, 3), true) // Check for at least 3 bars of displacement
                    obHigh := high[i]
                    obLow := low[i]
                    obStartTime := time[i]
                    obEndTime := time
                    break
        else // Looking for bearish OB (last bullish candle before displacement)
            if close[i] > open[i] // If current candle is bullish
                // Check if the next few candles show displacement
                if isDisplacement(math.min(lookback - i, 3), false) // Check for at least 3 bars of displacement
                    obHigh := high[i]
                    obLow := low[i]
                    obStartTime := time[i]
                    obEndTime := time
                    break
    
    na(obHigh) ? na : OrderBlock.new(obStartTime, obEndTime, obHigh, obLow, isBullish)

// Function to get higher timeframe liquidity levels
getHigherTFLiquidity(string timeframe, string session, bool isBullish) =>
    float liqLevel = na
    if timeframe == "D"
        liqLevel := isBullish ? request.security(syminfo.tickerid, "D", low[1]) : request.security(syminfo.tickerid, "D", high[1])
    else if timeframe == "60"
        [startH, startM, endH, endM] = getSessionTimes(session)
        string sessionString = str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", startH, startM, endH, endM)
        liqLevel := isBullish ? request.security(syminfo.tickerid, "60", low[1], gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_on, session=sessionString) : request.security(syminfo.tickerid, "60", high[1], gaps=barmerge.gaps_on, lookahead=barmerge.lookahead_on, session=sessionString)
    liqLevel

// ----------------------------------------------------------------------------
// 5. ORB Logic
// ----------------------------------------------------------------------------

// Calculate ORB range
[orbStartH, orbStartM, orbEndH, orbEndM] = getSessionTimes(orbSession)
bool isORBPeriod = time(timeframe.period, str.format("{0,number,#00}:{1,number,#00}-{2,number,#00}:{3,number,#00}", orbStartTimeHour, orbStartTimeMinute, orbEndTimeHour, orbEndTimeMinute), "America/New_York")

var float orbHigh = na
var float orbLow = na
var bool orbEstablished = false

if newSession(orbStartH, orbStartM, orbEndH, orbEndM)
    orbHigh := na
    orbLow := na
    orbEstablished := false

if isORBPeriod
    if na(orbHigh) or high > orbHigh
        orbHigh := high
    if na(orbLow) or low < orbLow
        orbLow := low
else if not orbEstablished[1] and not na(orbHigh)
    orbEstablished := true
    currentORB := ORB.new(time, time, orbHigh, orbLow, true)

// Plot ORB
if orbEstablished
    line.new(x1=currentORB.startTime, y1=currentORB.high, x2=time, y2=currentORB.high, color=color.blue, style=line.style_dashed, width=1)
    line.new(x1=currentORB.startTime, y1=currentORB.low, x2=time, y2=currentORB.low, color=color.blue, style=line.style_dashed, width=1)
    box.new(left=currentORB.startTime, top=currentORB.high, right=time, bottom=currentORB.low, border_color=color.blue, border_width=1, bgcolor=color.new(color.blue, 90))

// ORB Breakout Detection
bool orbBreakoutLong = false
bool orbBreakoutShort = false

if orbEstablished
    if breakoutMethod == "Close"
        orbBreakoutLong := close > orbHigh[1] and close[1] <= orbHigh[1]
        orbBreakoutShort := close < orbLow[1] and close[1] >= orbLow[1]
    else if breakoutMethod == "Wick"
        orbBreakoutLong := high > orbHigh[1] and high[1] <= orbHigh[1]
        orbBreakoutShort := low < orbLow[1] and low[1] >= orbLow[1]

// ----------------------------------------------------------------------------
// 6. Main Strategy Logic (ORB Focused)
// ----------------------------------------------------------------------------

// Reset trade state at the start of a new session
if newSession(orbStartH, orbStartM, orbEndH, orbEndM)
    lastTrade := na

// Initialize trade if not active
if na(lastTrade)
    lastTrade := Trade.new("Waiting For ORB", na, na, na, na, na, na, na, na, na, na, na, na, na, na, na)

// State Machine for ORB Strategy
if executeInsideSession and insideSession(orbStartH, orbStartM, orbEndH, orbEndM)
    if lastTrade.state == "Waiting For ORB"
        if orbEstablished
            lastTrade.state := "Waiting For Breakout"

    if lastTrade.state == "Waiting For Breakout"
        // Apply Daily Bias Filter
        bool biasMatchLong = dailyBias == "None" or dailyBias == "Bullish"
        bool biasMatchShort = dailyBias == "None" or dailyBias == "Bearish"

        if orbBreakoutLong and biasMatchLong
            // Check for ORB Liquidity Sweep (optional)
            bool orbLiqSwept = true
            if requireORBLiquiditySweep
                // Logic to check if price swept below orbLow before breaking above orbHigh
                // This is a simplified check, more robust logic might be needed
                orbLiqSwept := low[1] < orbLow[1] // Check if previous bar wicked below ORB low
            
            if orbLiqSwept
                lastTrade.state := "Waiting For Displacement"
                lastTrade.entryType := "Long"
                lastTrade.orbRange := currentORB

        else if orbBreakoutShort and biasMatchShort
            // Check for ORB Liquidity Sweep (optional)
            bool orbLiqSwept = true
            if requireORBLiquiditySweep
                // Logic to check if price swept above orbHigh before breaking below orbLow
                orbLiqSwept := high[1] > orbHigh[1] // Check if previous bar wicked above ORB high

            if orbLiqSwept
                lastTrade.state := "Waiting For Displacement"
                lastTrade.entryType := "Short"
                lastTrade.orbRange := currentORB

    if lastTrade.state == "Waiting For Displacement"
        bool displaced = false
        if lastTrade.entryType == "Long"
            displaced := isDisplacement(5, true) // Check for bullish displacement in last 5 bars
        else if lastTrade.entryType == "Short"
            displaced := isDisplacement(5, false) // Check for bearish displacement in last 5 bars

        if displaced
            lastTrade.state := "Waiting For OB Retracement"
            // Find Order Block after displacement
            OrderBlock detectedOB = na
            if lastTrade.entryType == "Long"
                detectedOB := findOrderBlock(10, true) // Look for OB in last 10 bars
            else if lastTrade.entryType == "Short"
                detectedOB := findOrderBlock(10, false)
            
            if not na(detectedOB)
                lastTrade.ob := detectedOB
            else
                // If no OB found, revert state or handle as per strategy. For now, reset.
                lastTrade := na // Reset if no OB found after displacement

    if lastTrade.state == "Waiting For OB Retracement" and not na(lastTrade.ob)
        bool priceInOB = false
        if lastTrade.entryType == "Long"
            priceInOB := low >= lastTrade.ob.low and high <= lastTrade.ob.high // Price within bullish OB
        else if lastTrade.entryType == "Short"
            priceInOB := high <= lastTrade.ob.high and low >= lastTrade.ob.low // Price within bearish OB

        if priceInOB
            // Check for FVG within OB or near entry
            FVG detectedFVG = na
            if lastTrade.entryType == "Long"
                detectedFVG := findFVG(3, true) // Look for bullish FVG in last 3 bars
            else if lastTrade.entryType == "Short"
                detectedFVG := findFVG(3, false) // Look for bearish FVG in last 3 bars
            
            // Entry Trigger
            if not na(detectedFVG) // FVG found, confirm entry
                lastTrade.fvg := detectedFVG
                lastTrade.entryPrice := close
                lastTrade.entryTime := time
                lastTrade.state := "Entry Taken"

                // Calculate TP/SL
                float currentATR = ta.atr(14)
                if tpslMethod == "Dynamic"
                    if lastTrade.entryType == "Long"
                        lastTrade.slTarget := lastTrade.ob.low - (currentATR * slBufferMultiplier)
                        // Target higher timeframe liquidity or fixed RR
                        float dailyHigh = getHigherTFLiquidity("D", "", false) // Previous daily high
                        float nyHigh = getHigherTFLiquidity("60", "New York", false) // Previous NY high
                        float lnHigh = getHigherTFLiquidity("60", "London", false) // Previous London high
                        
                        float targetLiq = math.max(dailyHigh, math.max(nyHigh, lnHigh))
                        if not na(targetLiq) and targetLiq > lastTrade.entryPrice
                            lastTrade.tpTarget := targetLiq
                        else
                            lastTrade.tpTarget := lastTrade.entryPrice + (math.abs(lastTrade.entryPrice - lastTrade.slTarget) * RR)
                    else if lastTrade.entryType == "Short"
                        lastTrade.slTarget := lastTrade.ob.high + (currentATR * slBufferMultiplier)
                        // Target higher timeframe liquidity or fixed RR
                        float dailyLow = getHigherTFLiquidity("D", "", true) // Previous daily low
                        float nyLow = getHigherTFLiquidity("60", "New York", true) // Previous NY low
                        float lnLow = getHigherTFLiquidity("60", "London", true) // Previous London low

                        float targetLiq = math.min(dailyLow, math.min(nyLow, lnLow))
                        if not na(targetLiq) and targetLiq < lastTrade.entryPrice
                            lastTrade.tpTarget := targetLiq
                        else
                            lastTrade.tpTarget := lastTrade.entryPrice - (math.abs(lastTrade.entryPrice - lastTrade.slTarget) * RR)
                else // Fixed TP/SL
                    if lastTrade.entryType == "Long"
                        lastTrade.slTarget := lastTrade.entryPrice * (1 - slPercent)
                        lastTrade.tpTarget := lastTrade.entryPrice * (1 + tpPercent)
                    else if lastTrade.entryType == "Short"
                        lastTrade.slTarget := lastTrade.entryPrice * (1 + slPercent)
                        lastTrade.tpTarget := lastTrade.entryPrice * (1 - tpPercent)

                // Execute trade
                if lastTrade.entryType == "Long"
                    strategy.entry("Long", strategy.long)
                    strategy.exit("Exit Long", from_entry="Long", stop=lastTrade.slTarget, limit=lastTrade.tpTarget)
                else if lastTrade.entryType == "Short"
                    strategy.entry("Short", strategy.short)
                    strategy.exit("Exit Short", from_entry="Short", stop=lastTrade.slTarget, limit=lastTrade.tpTarget)

// Close position at session end if enabled
if closePositionAtEndSession and not na(lastTrade) and lastTrade.state == "Entry Taken"
    if endSession(orbStartH, orbStartM, orbEndH, orbEndM)
        strategy.close_all("Session End Close")
        lastTrade.state := "Closed"
        lastTrade.exitTime := time
        lastTrade.exitPrice := close
        lastTrade.dayEndedBeforeExit := time

// Handle TP/SL hit
if not na(lastTrade) and lastTrade.state == "Entry Taken"
    if getPosition() == "Flat" // Position closed by TP/SL
        lastTrade.state := "Closed"
        lastTrade.exitTime := time
        lastTrade.exitPrice := close

// ----------------------------------------------------------------------------
// 7. Visuals
// ----------------------------------------------------------------------------

// Plot FVG
if showFVGs and not na(lastTrade.fvg)
    fvgColor = lastTrade.fvg.isBull ? color.new(color.green, 80) : color.new(color.red, 80)
    box.new(left=lastTrade.fvg.startTime, top=lastTrade.fvg.top, right=lastTrade.fvg.endTime, bottom=lastTrade.fvg.bottom, border_color=fvgColor, bgcolor=fvgColor)

// Plot OB
if requireOBConfluence and not na(lastTrade.ob)
    obColor = lastTrade.ob.isBull ? color.new(color.lime, 80) : color.new(color.fuchsia, 80)
    box.new(left=lastTrade.ob.startTime, top=lastTrade.ob.high, right=lastTrade.ob.endTime, bottom=lastTrade.ob.low, border_color=obColor, bgcolor=obColor)

// Plot TP/SL lines
if showTPSL and not na(lastTrade) and lastTrade.state == "Entry Taken"
    line.new(x1=lastTrade.entryTime, y1=lastTrade.tpTarget, x2=time, y2=lastTrade.tpTarget, color=highColor, style=line.style_dashed, width=1)
    line.new(x1=lastTrade.entryTime, y1=lastTrade.slTarget, x2=time, y2=lastTrade.slTarget, color=lowColor, style=line.style_dashed, width=1)

// Plot entry/exit shapes
if not na(lastTrade) and lastTrade.state == "Entry Taken"
    plotshape(true, style=shape.triangleup, location=location.belowbar, color=highColor, text="Entry", size=size.small, title="Entry Signal")
else if not na(lastTrade) and lastTrade.state == "Closed"
    plotshape(true, style=shape.triangledown, location=location.abovebar, color=lowColor, text="Exit", size=size.small, title="Exit Signal")

// ----------------------------------------------------------------------------
// 8. Backtesting Dashboard
// ----------------------------------------------------------------------------

// Simplified dashboard for demonstration. Full dashboard logic from original can be integrated.
var int totalEntries = 0
var int totalWins = 0
var int totalLosses = 0
var float totalProfit = 0.0

if strategy.closedtrades.size() > totalEntries
    trade = strategy.closedtrades.get(strategy.closedtrades.size() - 1)
    if trade.profit > 0
        totalWins := totalWins + 1
    else
        totalLosses := totalLosses + 1
    totalEntries := totalEntries + 1
    totalProfit := totalProfit + trade.profit

float winRate = totalEntries > 0 ? (float(totalWins) / totalEntries) * 100 : 0.0
float avgProfit = totalEntries > 0 ? totalProfit / totalEntries : 0.0

if backtestDisplayEnabled
    var table dashboardTable = table.new(backtestingLocation == "Top Right" ? position.top_right : backtestingLocation == "Right Center" ? position.right : position.top_center, 1, 6, bgcolor=screenerColor, border_width=1)
    table.cell(dashboardTable, 0, 0, "Total Entries: " + str.tostring(totalEntries), text_color=textColor)
    table.cell(dashboardTable, 0, 1, "Wins: " + str.tostring(totalWins), text_color=textColor)
    table.cell(dashboardTable, 0, 2, "Losses: " + str.tostring(totalLosses), text_color=textColor)
    table.cell(dashboardTable, 0, 3, "Win Rate: " + str.tostring(winRate, "#.##") + "%", text_color=textColor)
    table.cell(dashboardTable, 0, 4, "Avg Profit: " + str.tostring(avgProfit, "#.##"), text_color=textColor)
    table.cell(dashboardTable, 0, 5, "Total Profit: " + str.tostring(totalProfit, "#.##"), text_color=textColor)

// ----------------------------------------------------------------------------
// 9. Alerts
// ----------------------------------------------------------------------------

if buyAlertEnabled and lastTrade.state == "Entry Taken" and lastTrade.entryType == "Long"
    alert("ORB Buy Signal! Entry Price: " + str.tostring(lastTrade.entryPrice), alert.freq_once_per_bar)

if sellAlertEnabled and lastTrade.state == "Entry Taken" and lastTrade.entryType == "Short"
    alert("ORB Sell Signal! Entry Price: " + str.tostring(lastTrade.entryPrice), alert.freq_once_per_bar)

if tpAlertEnabled and lastTrade.state == "Closed" and lastTrade.exitPrice > lastTrade.entryPrice and lastTrade.entryType == "Long"
    alert("ORB Long TP Hit! Exit Price: " + str.tostring(lastTrade.exitPrice), alert.freq_once_per_bar)

if tpAlertEnabled and lastTrade.state == "Closed" and lastTrade.exitPrice < lastTrade.entryPrice and lastTrade.entryType == "Short"
    alert("ORB Short TP Hit! Exit Price: " + str.tostring(lastTrade.exitPrice), alert.freq_once_per_bar)

if slAlertEnabled and lastTrade.state == "Closed" and lastTrade.exitPrice < lastTrade.entryPrice and lastTrade.entryType == "Long"
    alert("ORB Long SL Hit! Exit Price: " + str.tostring(lastTrade.exitPrice), alert.freq_once_per_bar)

if slAlertEnabled and lastTrade.state == "Closed" and lastTrade.exitPrice > lastTrade.entryPrice and lastTrade.entryType == "Short"
    alert("ORB Short SL Hit! Exit Price: " + str.tostring(lastTrade.exitPrice), alert.freq_once_per_bar)





//@version=5
indicator("ICT ORB Manual Trading Companion v3.0 - Enhanced", overlay=true, max_bars_back=500, max_boxes_count=500, max_labels_count=500, max_lines_count=500)
 
// =============================================================================
// 1. INPUT PARAMETERS - REORGANIZED FOR BETTER UX
// =============================================================================

// --- QUICK SETUP ---
string strategyProfile = input.string("Balanced", "🎯 Quick Setup - Strategy Profile", options=["Aggressive", "Balanced", "Conservative", "Custom"], group="⚡ Quick Setup", tooltip="Pre-configured settings for different trading styles")

// --- ORB CONFIGURATION ---
string orbSessionType = input.string("New York", "Session Type", options=["New York", "London", "Asia", "Custom", "714MIDNIGHT", "714AM", "714PM"], group="📊 ORB Settings")
int orbDuration = input.int(15, "ORB Duration (minutes)", minval=5, maxval=60, step=5, group="📊 ORB Settings")
int orbStartTimeHour = input.int(9, "Custom Start Hour", minval=0, maxval=23, group="📊 ORB Settings")
int orbStartTimeMinute = input.int(30, "Custom Start Minute", minval=0, maxval=59, group="📊 ORB Settings")
bool requireORBLiquiditySweep = input.bool(false, "Require ORB Liquidity Sweep", group="📊 ORB Settings")
int maxHistoricalORBs = input.int(10, "Max Historical ORBs", minval=1, maxval=50, group="📊 ORB Settings")

// --- ENTRY TRIGGERS ---
string executionType = input.string("FVG", "Primary Entry Method", options=["FVG", "MSS", "Both"], group="🎯 Entry Triggers", tooltip="Primary entry trigger method")
string breakoutMethod = input.string("Close", "Breakout Method", options=["Close", "Wick", "Body"], group="🎯 Entry Triggers", tooltip="Method to determine ORB breakout")
string fvgBars = input.string("Same Type", "FVG Bar Type", options=["Same Type", "All", "Strong Only"], group="🎯 Entry Triggers", tooltip="Controls the strictness of FVG detection")
int mssOffset = input.int(10, "MSS Swing Length", minval=1, maxval=20, group="🎯 Entry Triggers", tooltip="Swing length for Market Structure Shift detection")

// --- TREND & BIAS ---
bool useHTFBias = input.bool(true, "Use Higher Timeframe Bias", group="📈 Trend & Bias")
string htfTimeframe = input.timeframe("240", "HTF for Bias", group="📈 Trend & Bias")
string dailyBias = input.string("Auto", "Daily Bias", options=["Auto", "None", "Bullish", "Bearish"], group="📈 Trend & Bias", tooltip="Auto uses HTF trend analysis")
bool requireTrendAlignment = input.bool(true, "Require Trend Alignment", group="📈 Trend & Bias")

// --- ICT CONCEPTS ---
bool requireDisplacement = input.bool(true, "Require Displacement", group="🔧 ICT Concepts")
bool requireOBConfluence = input.bool(true, "Require Order Block", group="🔧 ICT Concepts")
bool showBreakerBlocks = input.bool(true, "Show Breaker Blocks", group="🔧 ICT Concepts")
bool showMitigation = input.bool(true, "Show Mitigation Blocks", group="🔧 ICT Concepts")
float displacementATRMultiplier = input.float(0.5, "Displacement ATR Multiplier", minval=0.1, maxval=2.0, group="🔧 ICT Concepts")
int obLookback = input.int(5, "Order Block Lookback", minval=3, maxval=10, group="🔧 ICT Concepts")

// --- RANGE ANALYSIS ---
bool useRangeAnalysis = input.bool(true, "Enable Range Analysis", group="📏 Range Analysis")
bool useATRFilter = input.bool(true, "ATR Range Classification", group="📏 Range Analysis")
float narrowRangeATR = input.float(0.5, "Narrow Range (% of ATR)", minval=0.1, maxval=1.0, group="📏 Range Analysis")
float wideRangeATR = input.float(1.5, "Wide Range (% of ATR)", minval=1.0, maxval=3.0, group="📏 Range Analysis")
bool avoidWideRanges = input.bool(true, "Avoid Wide Ranges", group="📏 Range Analysis")

// --- VOLUME ANALYSIS ---
bool useVolumeAnalysis = input.bool(true, "Enable Volume Analysis", group="📊 Volume Analysis")
bool requireVolumeSpike = input.bool(true, "Require Volume Spike", group="📊 Volume Analysis")
float volumeSpikeMultiplier = input.float(1.5, "Volume Spike Multiplier", minval=1.2, maxval=3.0, group="📊 Volume Analysis")
bool useRVol = input.bool(true, "Use Relative Volume", group="📊 Volume Analysis")
float rvolThreshold = input.float(2.0, "RVol Threshold", minval=1.0, maxval=5.0, group="📊 Volume Analysis")

// --- RISK MANAGEMENT ---
string stopMethod = input.string("Dynamic", "Stop Loss Method", options=["Fixed", "Dynamic", "Structure", "ATR"], group="🛡️ Risk Management")
float slBufferMultiplier = input.float(0.5, "SL Buffer (ATR)", minval=0.0, maxval=2.0, group="🛡️ Risk Management")
float riskRewardRatio = input.float(2.0, "Default R:R Ratio", minval=1.0, maxval=5.0, group="🛡️ Risk Management")
bool useHigherTFliq = input.bool(true, "Use Higher TF Liquidity for TP", group="🛡️ Risk Management")
bool useTrailingStop = input.bool(false, "Enable Trailing Stop", group="🛡️ Risk Management")
float trailingStopATR = input.float(2.0, "Trailing Stop (ATR)", minval=0.5, maxval=5.0, group="🛡️ Risk Management")

// --- VISUAL SETTINGS ---
bool showDashboard = input.bool(true, "Show Dashboard", group="🎨 Visual Settings")
bool showHistoricalORBs = input.bool(true, "Show Historical ORBs", group="🎨 Visual Settings")
bool showICTLevels = input.bool(true, "Show ICT Levels", group="🎨 Visual Settings")
bool showTargetLines = input.bool(true, "Show Target Lines", group="🎨 Visual Settings")

// --- COLOR SCHEME ---
color bullishColor = input.color(#089981, "Bullish Color", group="🎨 Color Scheme")
color bearishColor = input.color(#f23645, "Bearish Color", group="🎨 Color Scheme")
color orbColor = input.color(color.new(color.blue, 70), "ORB Color", group="🎨 Color Scheme")
color fvgColor = input.color(color.new(color.yellow, 85), "FVG Color", group="🎨 Color Scheme")
color obColor = input.color(color.new(color.purple, 85), "OB Color", group="🎨 Color Scheme")
color screenerColor = input.color(#1B1F2B, "Dashboard Background", group="🎨 Color Scheme")
string textSize = input.string("small", "Text Size", options=["tiny", "small", "normal"], group="🎨 Color Scheme")
string dashboardTextSize = input.string("normal", "Dashboard Text Size", options=["tiny", "small", "normal", "large"], group="🎨 Color Scheme")

// =============================================================================
// 2. TYPE DEFINITIONS - ENHANCED
// =============================================================================

type FVG
    int startTime
    float top
    float bottom
    string type  // "bullish" or "bearish"
    bool mitigated

type OrderBlock
    int startTime
    int endTime
    float high
    float low
    string type  // "bullish" or "bearish"
    bool breaker
    bool mitigated

type ORB
    int startTime
    int endTime
    float high
    float low
    float mid
    float width
    string sessionDate
    string rangeType  // "Narrow", "Normal", "Wide"
    float rangeATRRatio

type Trade
    string state
    string direction
    OrderBlock ob
    FVG fvg
    float entryPrice
    float slTarget
    float tpTarget
    float tp2Target
    float tp3Target
    float risk
    int entryBar
    bool trailingActivated

type MarketStructure
    float lastSwingHigh
    float lastSwingLow
    int htfTrend  // 1: Bull, -1: Bear, 0: Neutral
    bool bosDetected
    string bosDirection
    float bosLevel

// =============================================================================
// 3. GLOBAL VARIABLES - ENHANCED
// =============================================================================

var ORB[] historicalORBs = array.new<ORB>(0)
var OrderBlock[] orderBlocks = array.new<OrderBlock>(0)
var FVG[] fvgs = array.new<FVG>(0)
var ORB currentORB = na
var bool orbEstablished = false
var float orbHigh = na
var float orbLow = na
var Trade currentTrade = Trade.new("WAITING_FOR_ORB", na, na, na,  na, na, na, na, na, na, 0, false)
var MarketStructure marketStructure = MarketStructure.new(na, na, 0, false, "None", na)

// Visual elements
var line slLine = na
var line tpLine = na
var line tp2Line = na
var line tp3Line = na
var box currentORBBox = na
var table dashboard = na

// Statistics
var int totalSignals = 0
var int winningSignals = 0
var int losingSignals = 0
var float totalPnL = 0.0

// =============================================================================
// 4. HELPER FUNCTIONS - ENHANCED
// =============================================================================

// Helper function to get text size enum
getTextSize() =>
    textSize == "tiny" ? size.tiny : textSize == "small" ? size.small : textSize == "normal" ? size.normal : size.large

// Helper function to get dashboard text size enum
getDashboardTextSize() =>
    dashboardTextSize == "tiny" ? size.tiny : dashboardTextSize == "small" ? size.small : dashboardTextSize == "normal" ? size.normal : size.large

// Calculate ATR
currentATR = ta.atr(14)
dailyATR = request.security(syminfo.tickerid, "D", ta.atr(14))

// Get previous day levels
[prevDayHigh, prevDayLow, prevDayClose] = request.security(syminfo.tickerid, "D",     [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)

// Calculate Relative Volume
calcRVol() =>
    avgVol = ta.sma(volume, 20)
    currentVol = volume
    rvol = avgVol > 0 ? currentVol / avgVol : 1.0
    rvol

// HTF Trend Analysis
getHTFTrend() =>
    htfClose = request.security(syminfo.tickerid, htfTimeframe, close)
    htfHigh = request.security(syminfo.tickerid, htfTimeframe, high)
    htfLow = request.security(syminfo.tickerid, htfTimeframe, low)
    
    trend = 0
    if htfClose > htfClose[1] and htfLow > htfLow[1]
        trend := 1  // Bullish
    else if htfClose < htfClose[1] and htfHigh < htfHigh[1]
        trend := -1  // Bearish
    trend

// Enhanced FVG Detection
findFVG(isBullish) =>
    FVG result = na
    
    if isBullish
        // Bullish FVG: Gap up between candle 3 high and candle 1 low
        if low[1] > high[3]
            gapSize = low[1] - high[3]
            if gapSize > currentATR * 0.2  // Minimum gap size
                validBars = true
                
                if fvgBars == "Same Type"
                    validBars := close[1] > open[1] and close[2] > open[2] and close[3] > open[3]
                else if fvgBars == "Strong Only"
                    body1 = math.abs(close[1] - open[1])
                    body2 = math.abs(close[2] - open[2])
                    body3 = math.abs(close[3] - open[3])
                    validBars := body2 > body1 and body2 > body3  // Middle candle is strongest
                
                if validBars
                    result := FVG.new(time[3], low[1], high[3], "bullish", false)
    else
        // Bearish FVG: Gap down between candle 3 low and candle 1 high
        if high[1] < low[3]
            gapSize = low[3] - high[1]
            if gapSize > currentATR * 0.2
                validBars = true
                
                if fvgBars == "Same Type"
                    validBars := close[1] < open[1] and close[2] < open[2] and close[3] < open[3]
                else if fvgBars == "Strong Only"
                    body1 = math.abs(close[1] - open[1])
                    body2 = math.abs(close[2] - open[2])
                    body3 = math.abs(close[3] - open[3])
                    validBars := body2 > body1 and body2 > body3
                
                if validBars
                    result := FVG.new(time[3], high[1], low[3], "bearish", false)
    result

// Enhanced Displacement Detection
isDisplacement(lookback, isBullish) =>
    strongCount = 0
    totalMove = 0.0
    
    for i = 0 to lookback - 1
        if isBullish
            isStrong = close[i] > open[i] and (close[i] - open[i]) > (displacementATRMultiplier * currentATR)
            if isStrong
                strongCount += 1
                totalMove += (close[i] - open[i])
        else
            isStrong = open[i] > close[i] and (open[i] - close[i]) > (displacementATRMultiplier * currentATR)
            if isStrong
                strongCount += 1
                totalMove += (open[i] - close[i])
    
    // Require majority of candles to be strong and total move > ATR
    strongCount >= math.ceil(lookback * 0.66) and totalMove > currentATR

// Enhanced Order Block Detection
findOrderBlock(lookback, isBullish) =>
    OrderBlock ob = na
    
    for i = 1 to math.min(lookback, obLookback)
        if isBullish
            // Bullish OB: Last bearish candle before bullish move
            if close[i] < open[i] and close[i-1] > open[i-1]
                // Check if followed by displacement
                if isDisplacement(3, true)
                    ob := OrderBlock.new(time[i], time[i-1], high[i], low[i], "bullish", false, false)
                    break
        else
            // Bearish OB: Last bullish candle before bearish move
            if close[i] > open[i] and close[i-1] < open[i-1]
                if isDisplacement(3, false)
                    ob := OrderBlock.new(time[i], time[i-1], high[i], low[i], "bearish", false, false)
                    break
    ob

// Market Structure Analysis
updateMarketStructure() =>
    // Find swing points
    swingHighBar = ta.pivothigh(high, mssOffset, mssOffset)
    swingLowBar = ta.pivotlow(low, mssOffset, mssOffset)
    
    if not na(swingHighBar)
        marketStructure.lastSwingHigh := swingHighBar
    if not na(swingLowBar)
        marketStructure.lastSwingLow := swingLowBar
    
    // Check for BOS
    if not na(marketStructure.lastSwingHigh) and close > marketStructure.lastSwingHigh
        marketStructure.bosDetected := true
        marketStructure.bosDirection := "Bullish"
        marketStructure.bosLevel := marketStructure.lastSwingHigh
    else if not na(marketStructure.lastSwingLow) and close < marketStructure.lastSwingLow
        marketStructure.bosDetected := true
        marketStructure.bosDirection := "Bearish"
        marketStructure.bosLevel := marketStructure.lastSwingLow
    
    // Update HTF trend
    if useHTFBias
        marketStructure.htfTrend := getHTFTrend()

// Calculate position size based on risk
calcPositionSize(entryPrice, stopLoss, riskAmount) =>
    riskPerShare = math.abs(entryPrice - stopLoss)
    positionSize = riskPerShare > 0 ? riskAmount / riskPerShare : 0
    math.round(positionSize)

// =============================================================================
// 5. ORB & SESSION LOGIC - ENHANCED
// =============================================================================

// Get session times based on selection
getSessionTimes() =>
    startHour = 0
    startMinute = 0
    endHour = 0
    endMinute = 0
    
    if orbSessionType == "New York"
        startHour := 9
        startMinute := 30
        endHour := startHour
        endMinute := startMinute + orbDuration
    else if orbSessionType == "London"
        startHour := 3
        startMinute := 0
        endHour := startHour
        endMinute := startMinute + orbDuration
    else if orbSessionType == "Asia"
        startHour := 0
        startMinute := 0
        endHour := startHour
        endMinute := startMinute + orbDuration
    else if orbSessionType == "Custom"
        startHour := orbStartTimeHour
        startMinute := orbStartTimeMinute
        endHour := startHour
        endMinute := startMinute + orbDuration
    else if orbSessionType == "714MIDNIGHT"
        startHour := 1
        startMinute := 0
        endHour := startHour
        endMinute := startMinute + orbDuration
    else if orbSessionType == "714AM"
        startHour := 7
        startMinute := 0
        endHour := startHour
        endMinute := startMinute + orbDuration
    else if orbSessionType == "714PM"
        startHour := 10
        startMinute := 0
        endHour := startHour
        endMinute := startMinute + orbDuration
    
    // Handle minute overflow
    if endMinute >= 60
        endHour := endHour + math.floor(endMinute / 60)
        endMinute := endMinute % 60
    
    [startHour, startMinute, endHour, endMinute]

[sH, sM, eH, eM] = getSessionTimes()

// Calculate timestamps using session time
orbStartTimestamp = timestamp(syminfo.timezone, year, month, dayofmonth, sH, sM)
orbEndTimestamp = timestamp(syminfo.timezone, year, month, dayofmonth, eH, eM)

// Check if current time is within ORB period
isORBPeriod = time >= orbStartTimestamp and time < orbEndTimestamp

// Daily reset
if ta.change(time("D"))
    orbHigh := na
    orbLow := na
    orbEstablished := false
    currentORB := na
    currentTrade.state := "WAITING_FOR_ORB"
    currentTrade.direction := na
    marketStructure.bosDetected := false
    
    // Clean up visual elements
    line.delete(slLine)
    line.delete(tpLine)
    line.delete(tp2Line)
    line.delete(tp3Line)
    box.delete(currentORBBox)
    slLine := na
    tpLine := na
    tp2Line := na
    tp3Line := na
    currentORBBox := na

// ORB Formation
if isORBPeriod and not orbEstablished
    orbHigh := na(orbHigh) ? high : math.max(high, orbHigh)
    orbLow := na(orbLow) ? low : math.min(low, orbLow)
    
    // Update ORB box during formation
    if na(currentORBBox)
        currentORBBox := box.new(orbStartTimestamp, orbHigh, orbEndTimestamp, orbLow, border_color=orbColor, bgcolor=color.new(orbColor, 90), xloc=xloc.bar_time)
    else
        box.set_top(currentORBBox, orbHigh)
        box.set_bottom(currentORBBox, orbLow)

// ORB Completion
else if time >= orbEndTimestamp and not orbEstablished and not na(orbHigh)
    orbEstablished := true
    
    // Calculate ORB metrics
    orbMid = (orbHigh + orbLow) / 2
    orbWidth = orbHigh - orbLow
    rangeATRRatio = dailyATR > 0 ? orbWidth / dailyATR : 0
    
    // Classify range type
    rangeType = "Normal"
    if useRangeAnalysis and useATRFilter
        rangeType := rangeATRRatio < narrowRangeATR ? "Narrow" :  rangeATRRatio > wideRangeATR ? "Wide" : "Normal"
    
    // Create ORB object
    currentORB := ORB.new(orbStartTimestamp, orbEndTimestamp, orbHigh, orbLow, orbMid, orbWidth, str.format("{0,date,MM/dd}", orbStartTimestamp), rangeType, rangeATRRatio)
    
    // Add to historical array
    array.unshift(historicalORBs, currentORB)
    if array.size(historicalORBs) > maxHistoricalORBs
        array.pop(historicalORBs)
    
    // Update trade state
    currentTrade.state := "WAITING_FOR_BREAKOUT"
    
    // Finalize ORB box
    box.set_right(currentORBBox, orbEndTimestamp)

// =============================================================================
// 6. MAIN TRADING LOGIC (STATE MACHINE) - ENHANCED
// =============================================================================

// Update market structure
updateMarketStructure()

// Volume analysis
currentRVol = useRVol ? calcRVol() : 1.0
avgVolume = ta.sma(volume, 20)
volumeSpike = volume > avgVolume * volumeSpikeMultiplier

// Determine effective bias
effectiveBias = dailyBias
if dailyBias == "Auto" and useHTFBias
    effectiveBias := marketStructure.htfTrend == 1 ? "Bullish" :     marketStructure.htfTrend == -1 ? "Bearish" : "None"

if orbEstablished
    // State: WAITING_FOR_BREAKOUT
    if currentTrade.state == "WAITING_FOR_BREAKOUT"
        // Check for range type filter
        rangeOK = not avoidWideRanges or currentORB.rangeType != "Wide"
        
        // Volume confirmation
        volumeOK = not requireVolumeSpike or volumeSpike
        rvolOK = not useRVol or currentRVol >= rvolThreshold
        
        // Long breakout
        isLongBreakout = false
        if breakoutMethod == "Close"
            isLongBreakout := close > orbHigh and close[1] <= orbHigh
        else if breakoutMethod == "Wick"
            isLongBreakout := high > orbHigh
        else  // Body
            isLongBreakout := math.max(open, close) > orbHigh
        
        liquiditySweepOK = not requireORBLiquiditySweep or low[1] < orbLow
        biasOK = effectiveBias == "None" or effectiveBias == "Bullish"
        trendOK = not requireTrendAlignment or marketStructure.htfTrend >= 0
        
        if isLongBreakout and liquiditySweepOK and biasOK and trendOK and rangeOK and volumeOK and rvolOK
            currentTrade.state := "WAITING_FOR_DISPLACEMENT"
            currentTrade.direction := "Long"
            totalSignals += 1
        
        // Short breakout
        isShortBreakout = false
        if breakoutMethod == "Close"
            isShortBreakout := close < orbLow and close[1] >= orbLow
        else if breakoutMethod == "Wick"
            isShortBreakout := low < orbLow
        else  // Body
            isShortBreakout := math.min(open, close) < orbLow
        
        liquiditySweepOK := not requireORBLiquiditySweep or high[1] > orbHigh
        biasOK := effectiveBias == "None" or effectiveBias == "Bearish"
        trendOK := not requireTrendAlignment or marketStructure.htfTrend <= 0
        
        if isShortBreakout and liquiditySweepOK and biasOK and trendOK and rangeOK and volumeOK and rvolOK
            currentTrade.state := "WAITING_FOR_DISPLACEMENT"
            currentTrade.direction := "Short"
            totalSignals += 1
    
    // State: WAITING_FOR_DISPLACEMENT
    if currentTrade.state == "WAITING_FOR_DISPLACEMENT"
        displaced = currentTrade.direction == "Long" ? isDisplacement(3, true) : isDisplacement(3, false)
        
        if (displaced and requireDisplacement) or not requireDisplacement
            // Find Order Block
            detectedOB = currentTrade.direction == "Long" ? findOrderBlock(obLookback, true) : findOrderBlock(obLookback, false)
            
            if not na(detectedOB) or not requireOBConfluence
                currentTrade.ob := detectedOB
                if not na(detectedOB)
                    array.unshift(orderBlocks, detectedOB)
                    if array.size(orderBlocks) > 10
                        array.pop(orderBlocks)
                currentTrade.state := "WAITING_FOR_RETRACEMENT"
    
    // State: WAITING_FOR_RETRACEMENT
    if currentTrade.state == "WAITING_FOR_RETRACEMENT"
        entryConditionMet = false
        
        if currentTrade.direction == "Long"
            // Check if price is within Order Block
            isWithinOB = not na(currentTrade.ob) ?    (low <= currentTrade.ob.high and high >= currentTrade.ob.low) : false
            inOB = not requireOBConfluence or isWithinOB
            
            if inOB
                // Check execution type
                if executionType == "FVG" or executionType == "Both"
                    detectedFVG = findFVG(true)
                    if not na(detectedFVG)
                        entryConditionMet := true
                        currentTrade.fvg := detectedFVG
                        array.unshift(fvgs, detectedFVG)
                        if array.size(fvgs) > 10
                            array.pop(fvgs)
                
                if (executionType == "MSS" or executionType == "Both") and not entryConditionMet
                    // Check for MSS
                    recentHigh = ta.highest(high, mssOffset)
                    if high > recentHigh[1]
                        entryConditionMet := true
            
            if entryConditionMet
                currentTrade.entryPrice := close
                currentTrade.entryBar := bar_index
                
                // Calculate Stop Loss
                if stopMethod == "Fixed"
                    currentTrade.slTarget := orbLow - (currentATR * slBufferMultiplier)
                else if stopMethod == "Dynamic"
                    obLow = not na(currentTrade.ob) ? currentTrade.ob.low : orbLow
                    currentTrade.slTarget := math.min(obLow, orbLow) - (currentATR * slBufferMultiplier)
                else if stopMethod == "Structure"
                    currentTrade.slTarget := marketStructure.lastSwingLow - (currentATR * slBufferMultiplier)
                else  // ATR
                    currentTrade.slTarget := close - (currentATR * (1 + slBufferMultiplier))
                
                // Calculate Targets
                currentTrade.risk := currentTrade.entryPrice - currentTrade.slTarget
                
                // Primary target
                if useHigherTFliq and not na(prevDayHigh) and prevDayHigh > close
                    currentTrade.tpTarget := prevDayHigh
                else
                    currentTrade.tpTarget := currentTrade.entryPrice + (currentTrade.risk * riskRewardRatio)
                
                // Additional targets
                currentTrade.tp2Target := currentTrade.entryPrice + (currentTrade.risk * (riskRewardRatio + 1))
                currentTrade.tp3Target := currentTrade.entryPrice + (currentTrade.risk * (riskRewardRatio + 2))
                
                currentTrade.state := "ENTRY_TAKEN"
                
                // Create visual lines
                if showTargetLines
                    line.delete(slLine)
                    line.delete(tpLine)
                    line.delete(tp2Line)
                    line.delete(tp3Line)
                    
                    slLine := line.new(bar_index-1, currentTrade.slTarget, bar_index, currentTrade.slTarget, 
                                      color=bearishColor, style=line.style_dashed, width=2, extend=extend.right)
                    tpLine := line.new(bar_index-1, currentTrade.tpTarget, bar_index, currentTrade.tpTarget, 
                                      color=bullishColor, style=line.style_dashed, width=2, extend=extend.right)
                    tp2Line := line.new(bar_index-1, currentTrade.tp2Target, bar_index, currentTrade.tp2Target, 
                                       color=color.new(bullishColor, 30), style=line.style_dotted, width=1, extend=extend.right)
                    tp3Line := line.new(bar_index-1, currentTrade.tp3Target, bar_index, currentTrade.tp3Target, 
                                       color=color.new(bullishColor, 50), style=line.style_dotted, width=1, extend=extend.right)
        
        else if currentTrade.direction == "Short"
            // Check if price is within Order Block
            isWithinOB = not na(currentTrade.ob) ?    (high >= currentTrade.ob.low and low <= currentTrade.ob.high) : false
            inOB = not requireOBConfluence or isWithinOB
            
            if inOB
                // Check execution type
                if executionType == "FVG" or executionType == "Both"
                    detectedFVG = findFVG(false)
                    if not na(detectedFVG)
                        entryConditionMet := true
                        currentTrade.fvg := detectedFVG
                        array.unshift(fvgs, detectedFVG)
                        if array.size(fvgs) > 10
                            array.pop(fvgs)
                
                if (executionType == "MSS" or executionType == "Both") and not entryConditionMet
                    // Check for MSS
                    recentLow = ta.lowest(low, mssOffset)
                    if low < recentLow[1]
                        entryConditionMet := true
            
            if entryConditionMet
                currentTrade.entryPrice := close
                currentTrade.entryBar := bar_index
                
                // Calculate Stop Loss
                if stopMethod == "Fixed"
                    currentTrade.slTarget := orbHigh + (currentATR * slBufferMultiplier)
                else if stopMethod == "Dynamic"
                    obHigh = not na(currentTrade.ob) ? currentTrade.ob.high : orbHigh
                    currentTrade.slTarget := math.max(obHigh, orbHigh) + (currentATR * slBufferMultiplier)
                else if stopMethod == "Structure"
                    currentTrade.slTarget := marketStructure.lastSwingHigh + (currentATR * slBufferMultiplier)
                else  // ATR
                    currentTrade.slTarget := close + (currentATR * (1 + slBufferMultiplier))
                
                // Calculate Targets
                currentTrade.risk := currentTrade.slTarget - currentTrade.entryPrice
                
                // Primary target
                if useHigherTFliq and not na(prevDayLow) and prevDayLow < close
                    currentTrade.tpTarget := prevDayLow
                else
                    currentTrade.tpTarget := currentTrade.entryPrice - (currentTrade.risk * riskRewardRatio)
                
                // Additional targets
                currentTrade.tp2Target := currentTrade.entryPrice - (currentTrade.risk * (riskRewardRatio + 1))
                currentTrade.tp3Target := currentTrade.entryPrice - (currentTrade.risk * (riskRewardRatio + 2))
                
                currentTrade.state := "ENTRY_TAKEN"
                
                // Create visual lines
                if showTargetLines
                    line.delete(slLine)
                    line.delete(tpLine)
                    line.delete(tp2Line)
                    line.delete(tp3Line)
                    
                    slLine := line.new(bar_index-1, currentTrade.slTarget, bar_index, currentTrade.slTarget, 
                                      color=bearishColor, style=line.style_dashed, width=2, extend=extend.right)
                    tpLine := line.new(bar_index-1, currentTrade.tpTarget, bar_index, currentTrade.tpTarget, 
                                      color=bullishColor, style=line.style_dashed, width=2, extend=extend.right)
                    tp2Line := line.new(bar_index-1, currentTrade.tp2Target, bar_index, currentTrade.tp2Target, 
                                       color=color.new(bullishColor, 30), style=line.style_dotted, width=1, extend=extend.right)
                    tp3Line := line.new(bar_index-1, currentTrade.tp3Target, bar_index, currentTrade.tp3Target, 
                                       color=color.new(bullishColor, 50), style=line.style_dotted, width=1, extend=extend.right)
    
    // State: ENTRY_TAKEN (Trade Management)
    if currentTrade.state == "ENTRY_TAKEN"
        // Check for stop loss hit
        if currentTrade.direction == "Long" and low <= currentTrade.slTarget
            currentTrade.state := "TRADE_CLOSED"
            losingSignals += 1
            totalPnL -= currentTrade.risk
        else if currentTrade.direction == "Short" and high >= currentTrade.slTarget
            currentTrade.state := "TRADE_CLOSED"
            losingSignals += 1
            totalPnL -= currentTrade.risk
        
        // Check for take profit hit
        else if currentTrade.direction == "Long" and high >= currentTrade.tpTarget
            currentTrade.state := "TRADE_CLOSED"
            winningSignals += 1
            totalPnL += (currentTrade.tpTarget - currentTrade.entryPrice)
        else if currentTrade.direction == "Short" and low <= currentTrade.tpTarget
            currentTrade.state := "TRADE_CLOSED"
            winningSignals += 1
            totalPnL += (currentTrade.entryPrice - currentTrade.tpTarget)
        
        // Trailing stop logic
        if useTrailingStop and not currentTrade.trailingActivated
            if currentTrade.direction == "Long" and high >= currentTrade.entryPrice + currentTrade.risk
                currentTrade.trailingActivated := true
                currentTrade.slTarget := currentTrade.entryPrice  // Move to breakeven
            else if currentTrade.direction == "Short" and low <= currentTrade.entryPrice - currentTrade.risk
                currentTrade.trailingActivated := true
                currentTrade.slTarget := currentTrade.entryPrice  // Move to breakeven
        
        if currentTrade.trailingActivated
            if currentTrade.direction == "Long"
                trailStop = high - (currentATR * trailingStopATR)
                if trailStop > currentTrade.slTarget
                    currentTrade.slTarget := trailStop
                    line.set_y1(slLine, currentTrade.slTarget)
                    line.set_y2(slLine, currentTrade.slTarget)
            else
                trailStop = low + (currentATR * trailingStopATR)
                if trailStop < currentTrade.slTarget
                    currentTrade.slTarget := trailStop
                    line.set_y1(slLine, currentTrade.slTarget)
                    line.set_y2(slLine, currentTrade.slTarget)

// =============================================================================
// 7. VISUALS & DASHBOARD - ENHANCED
// =============================================================================

// Draw historical ORBs
if barstate.islast and showHistoricalORBs and array.size(historicalORBs) > 0
    for i = 0 to math.min(array.size(historicalORBs) - 1, maxHistoricalORBs - 1)
        orb = array.get(historicalORBs, i)
        if na(currentORB) or (not na(currentORB) ? orb.startTime != currentORB.startTime : false)
            historicalBox = box.new(orb.startTime, orb.high, orb.endTime, orb.low, border_color=color.new(orbColor, 50), bgcolor=color.new(orbColor, 95), xloc=xloc.bar_time)
            
            // Add label with ORB info
            labelText = orb.sessionDate + "\n" + orb.rangeType
            label.new(orb.startTime, orb.high, labelText, xloc=xloc.bar_time, style=label.style_label_down, size=size.tiny, color=color.new(orbColor, 90), textcolor=color.black)

// Draw ICT levels
if showICTLevels
    // Draw Order Blocks
    if array.size(orderBlocks) > 0
        for i = 0 to math.min(array.size(orderBlocks) - 1, 5)
            ob = array.get(orderBlocks, i)
            if not ob.mitigated
                obBox = box.new(ob.startTime, ob.high, ob.endTime, ob.low, border_color=color.new(obColor, 50), bgcolor=obColor, xloc=xloc.bar_time)
    
    // Draw FVGs
    if array.size(fvgs) > 0
        for i = 0 to math.min(array.size(fvgs) - 1, 5)
            fvg = array.get(fvgs, i)
            if not fvg.mitigated
                fvgBox = box.new(fvg.startTime, fvg.top, time, fvg.bottom, border_color=color.new(fvgColor, 50), bgcolor=fvgColor, xloc=xloc.bar_time)

// Entry signals
isSignalBar = currentTrade.state[1] != "ENTRY_TAKEN" and currentTrade.state == "ENTRY_TAKEN"
longSignal = isSignalBar and currentTrade.direction == "Long"
shortSignal = isSignalBar and currentTrade.direction == "Short"

plotshape(longSignal, "Long Entry", shape.triangleup, location.belowbar, bullishColor, size=size.normal)
plotshape(shortSignal, "Short Entry", shape.triangledown, location.abovebar, bearishColor, size=size.normal)

// Add entry labels with details
if longSignal
    entryLabel = "LONG\n" + "Entry: " + str.tostring(currentTrade.entryPrice, "#.##") + "\n" +  "SL: " + str.tostring(currentTrade.slTarget, "#.##") + "\n" +              "TP: " + str.tostring(currentTrade.tpTarget, "#.##")
    label.new(bar_index, low - currentATR, entryLabel, style=label.style_label_up, color=bullishColor, textcolor=color.black, size=getTextSize())

if shortSignal
    entryLabel = "SHORT\n" +                 "Entry: " + str.tostring(currentTrade.entryPrice, "#.##") + "\n" +                "SL: " + str.tostring(currentTrade.slTarget, "#.##") + "\n" +                "TP: " + str.tostring(currentTrade.tpTarget, "#.##")
    label.new(bar_index, high + currentATR, entryLabel, style=label.style_label_down, color=bearishColor, textcolor=color.black, size=getTextSize())

// Dashboard
if showDashboard
    dashboard := table.new(position.top_right, 2, 20,                           bgcolor=screenerColor,                          frame_width=2, frame_color=color.black, border_width=1, border_color=color.black)
    
    if barstate.islast
        row = 0
        
        // Header
        table.cell(dashboard, 0, row, "ICT ORB System v3.0", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
        table.merge_cells(dashboard, 0, row, 1, row)
        row += 1
        
        // Current State
        table.cell(dashboard, 0, row, "State", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
        stateColor = currentTrade.state == "ENTRY_TAKEN" ? bullishColor : color.yellow
        table.cell(dashboard, 1, row, currentTrade.state, text_color=stateColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
        row += 1
        
        // Direction
        if not na(currentTrade.direction)
            table.cell(dashboard, 0, row, "Direction", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            dirColor = currentTrade.direction == "Long" ? bullishColor : bearishColor
            table.cell(dashboard, 1, row, currentTrade.direction, text_color=dirColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
        
        // ORB Info
        if orbEstablished
            table.cell(dashboard, 0, row, "ORB High", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.cell(dashboard, 1, row, str.tostring(orbHigh, "#.##"), text_color=bullishColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
            
            table.cell(dashboard, 0, row, "ORB Low", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.cell(dashboard, 1, row, str.tostring(orbLow, "#.##"), text_color=bearishColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
            
            if not na(currentORB)
                table.cell(dashboard, 0, row, "Range Type", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
                rangeColor = currentORB.rangeType == "Narrow" ? bullishColor : currentORB.rangeType == "Wide" ? bearishColor : color.yellow
                table.cell(dashboard, 1, row, currentORB.rangeType, text_color=rangeColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
                row += 1
                
                table.cell(dashboard, 0, row, "Range/ATR", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
                table.cell(dashboard, 1, row, str.tostring(currentORB.rangeATRRatio, "#.##"), text_color=color.purple, bgcolor=screenerColor, text_size=getDashboardTextSize())
                row += 1
        
        // Volume Analysis
        if useVolumeAnalysis
            table.cell(dashboard, 0, row, "RVol", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            rvolColor = currentRVol >= rvolThreshold ? bullishColor : bearishColor
            table.cell(dashboard, 1, row, str.tostring(currentRVol, "#.#") + "x", text_color=rvolColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
        
        // Market Structure
        table.cell(dashboard, 0, row, "HTF Trend", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
        trendText = marketStructure.htfTrend == 1 ? "↑ Bull" : marketStructure.htfTrend == -1 ? "↓ Bear" : "→ Neutral"
        trendColor = marketStructure.htfTrend == 1 ? bullishColor : marketStructure.htfTrend == -1 ? bearishColor : color.yellow
        table.cell(dashboard, 1, row, trendText, text_color=trendColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
        row += 1
        
        if marketStructure.bosDetected
            table.cell(dashboard, 0, row, "BOS", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            bosColor = marketStructure.bosDirection == "Bullish" ? bullishColor : bearishColor
            table.cell(dashboard, 1, row, marketStructure.bosDirection, text_color=bosColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
        
        // Trade Stats
        table.cell(dashboard, 0, row, "--- Stats ---", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
        table.merge_cells(dashboard, 0, row, 1, row)
        row += 1
        
        table.cell(dashboard, 0, row, "Signals", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
        table.cell(dashboard, 1, row, str.tostring(totalSignals), text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
        row += 1
        
        if totalSignals > 0
            winRate = (winningSignals / totalSignals) * 100
            table.cell(dashboard, 0, row, "Win Rate", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            wrColor = winRate >= 60 ? bullishColor : winRate >= 40 ? color.yellow : bearishColor
            table.cell(dashboard, 1, row, str.tostring(winRate, "#.#") + "%", text_color=wrColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
        
        // Risk Management
        if currentTrade.state == "ENTRY_TAKEN"
            table.cell(dashboard, 0, row, "--- Trade ---", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.merge_cells(dashboard, 0, row, 1, row)
            row += 1
            
            table.cell(dashboard, 0, row, "Entry", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.cell(dashboard, 1, row, str.tostring(currentTrade.entryPrice, "#.##"), text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
            
            table.cell(dashboard, 0, row, "Stop", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.cell(dashboard, 1, row, str.tostring(currentTrade.slTarget, "#.##"), text_color=bearishColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
            
            table.cell(dashboard, 0, row, "Target", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.cell(dashboard, 1, row, str.tostring(currentTrade.tpTarget, "#.##"), text_color=bullishColor, bgcolor=screenerColor, text_size=getDashboardTextSize())
            row += 1
            
            // Calculate position size
            riskAmount = 1000  // Example: $1000 risk per trade
            posSize = calcPositionSize(currentTrade.entryPrice, currentTrade.slTarget, riskAmount)
            table.cell(dashboard, 0, row, "Pos Size", text_color=color.white, bgcolor=screenerColor, text_size=getDashboardTextSize())
            table.cell(dashboard, 1, row, str.tostring(posSize), text_color=color.orange, bgcolor=screenerColor, text_size=getDashboardTextSize())

// Alert conditions
alertcondition(longSignal, "ICT ORB Long Signal", "Long entry signal detected")
alertcondition(shortSignal, "ICT ORB Short Signal", "Short entry signal detected")
alertcondition((not na(currentORB) ? currentORB.rangeType == "Narrow" : false) and orbEstablished, "Narrow Range Alert", "Narrow range detected - potential explosive move")
alertcondition(marketStructure.bosDetected, "BOS Alert", "Break of Structure detected")
alertcondition(currentRVol >= rvolThreshold, "High RVol Alert", "High relative volume detected")
//@version=6
indicator('Forever Model', overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500, max_bars_back = 501)

// HTF Settings
autoMode = input.bool(true, 'Auto Mode', tooltip = 'Automatically select HTF based on current chart timeframe.', group = 'HTF Settings')
manualHTF = input.timeframe('D', 'Manual HTF', tooltip = 'Manual HTF selection (only used when Auto Mode is disabled)', group = 'HTF Settings')

// Indicator Settings
showConfirmationLines = input.bool(true, 'Show Confirmation Lines', group = 'Indicator')
extendOnlyLatestConfirmation = input.bool(true, 'Extend Only Latest Confirmation', tooltip = 'If enabled, only the latest confirmation line extends to current bar. If disabled, all confirmation lines extend to current bar.', group = 'Indicator')
showLabels = input.bool(false, 'Show Labels', tooltip = 'Show labels for FVGs and ERLs', group = 'Indicator')
showFVGBoxes = input.bool(true, 'Show FVG Boxes', tooltip = 'Show FVG boxes on chart', group = 'Indicator')
bias = input.string('No Bias', 'Bias', options = ['No Bias', 'Bullish Bias', 'Bearish Bias'], tooltip = 'When biased, only detect FVGs for that bias. No Bias detects both.', group = 'Indicator')

// Dashboard Settings
showDashboard = input.bool(true, 'Show Dashboard', group = 'Dashboard')
dashboardPosition = input.string('Top Right', 'Dashboard Position', options = ['Top Left', 'Top Center', 'Top Right', 'Middle Left', 'Middle Center', 'Middle Right', 'Bottom Left', 'Bottom Center', 'Bottom Right'], group = 'Dashboard')
dashboardBgColor = input.color(color.new(color.gray, 100), 'Dashboard Background', group = 'Dashboard')
dashboardBorderColor = input.color(color.black, 'Dashboard Border', group = 'Dashboard')
dashboardTextColor = input.color(color.black, 'Dashboard Text', group = 'Dashboard')
dashboardSize = input.string(size.small, 'Dashboard Text Size', options = [size.tiny, size.small, size.normal, size.large, size.huge], group = 'Dashboard')
dashboardBorderWidth = input.int(1, 'Dashboard Border Width', minval = 0, maxval = 5, group = 'Dashboard')
dashboardFrameColor = input.color(color.black, 'Dashboard Frame Color', group = 'Dashboard')
dashboardFrameWidth = input.int(1, 'Dashboard Frame Width', minval = 0, maxval = 5, group = 'Dashboard')

// Position Sizing Settings
showPositionSize = input.bool(false, 'Show Position Size for Latest Signal', group = 'Position Sizing')
accountBalance = input.float(10000.0, 'Account Balance (USD)', minval = 0.0, group = 'Position Sizing')
riskType = input.string('Percentage', 'Risk Type', options = ['Percentage', 'Fixed Amount'], group = 'Position Sizing')
riskAmount = input.float(1.0, 'Risk Amount (% or USD)', minval = 0.0, group = 'Position Sizing')
usingProp = input.bool(false, 'Using Prop Firm', group = 'Position Sizing', tooltip = 'Use prop firm contract size calculations')
abbreviatePositionInfo = input.bool(false, 'Abbreviate Position Info', group = 'Position Sizing', tooltip = 'Shorten position sizing text (Size, Entry, Stop, contracts, units)')

// SMT Settings
enableSMT = input.bool(false, 'Enable SMT Detection', group = 'SMT Settings')
smtAutoMode = input.bool(true, 'SMT Auto Pair', tooltip = 'Automatically select SMT pair based on symbol. For crypto: BTC↔ETH, others→ETH. For stocks/futures: related pairs.', group = 'SMT Settings')
smtManualPair = input.symbol('', 'SMT Manual Pair', tooltip = 'Manual SMT pair selection (only used when Auto Pair is disabled)', group = 'SMT Settings')
smtLineWidth = input.int(2, 'SMT Line Width', minval = 1, group = 'SMT Settings')
smtOnlyInFVG = input.bool(false, 'Only Display SMTs in FVG', tooltip = 'Only display SMTs that have at least one extreme within an FVG range (not fully mitigated)', group = 'SMT Settings')
smtRequiredForSignal = input.bool(false, 'Require SMT for Signal Confirmation', tooltip = 'Only allow signal confirmation if there is an SMT of that direction that occurred after the initial touch point of the FVG and has at least one extreme within the FVG', group = 'SMT Settings')
smtKeepOnlyLatest = input.bool(false, 'Keep Only Latest SMTs', tooltip = 'When enabled, only the latest bearish and latest bullish SMTs are kept. Older SMTs of the same type are removed.', group = 'SMT Settings')


// OI-based special range settings
useOIForSpecialRanges = input.bool(false, 'Use OI for Special Ranges', group = 'Range Detection', tooltip = 'Detect special ranges based on OI pivot detection')
oiPivotLookLeft = input.int(1, 'OI Pivot Look Left', minval = 1, group = 'Range Detection')
oiPivotLookRight = input.int(1, 'OI Pivot Look Right', minval = 1, group = 'Range Detection')

// iFVG Settings
showInversionFVGs = input.bool(false, 'Show Inversion FVGs', group = 'iFVG Settings', tooltip = 'Display inversion FVG boxes on confirmation lines')

// Get HTF Period function - around 15-16x multiples (except fixed ones)
getHTFPeriod() =>
    switch timeframe.period
        '1'   => '15'      // 1m → 15m (15x) - fixed
        '3'   => '30'      // 3m → 30m (10x) - fixed
        '5'   => '60'      // 5m → 1h (12x) - fixed
        '10'  => '150'     // 10m → 150m (15x) = 2.5h
        '15'  => '240'     // 15m → 4h (16x) - fixed
        '30'  => '1D'      // 30m → 1D (48x) - fixed
        '45'  => '720'     // 45m → 12h (16x)
        '60'  => '1D'      // 1h → 1D (24x) - fixed, same as 30m
        '120' => '2D'      // 2h → 2D (24x) - closest standard timeframe (30h not available)
        '240' => '1W'      // 4h → 1W (42x) - fixed
        '360' => '4D'      // 6h → 4D (16x)
        '720' => '1W'      // 12h → 1W (14x) - closest to 1W
        '1D'  => '15D'      // 1D → 15D (15x)
        '3D'  => '45D'      // 3D → 45D (15x)
        '1W'  => '15W'      // 1W → 15W (15x)
        '1M'  => '15M'      // 1M → 15M (15x)
        '3M'  => '45M'      // 3M → 45M (15x)
        => '1D'            // Default

// Helper function to format timeframe name
formatTimeframe(string tf) =>
    seconds = timeframe.in_seconds(tf)
    if seconds < 60
        str.tostring(seconds) + "S"
    else if (seconds / 60) < 60
        str.tostring((seconds/60)) + "M"
    else if (seconds/60/60) < 24
        str.tostring((seconds/60/60)) + "H"
    else if (seconds/60/60/24) < 7
        str.tostring((seconds/60/60/24)) + "D"
    else if (seconds/60/60/24/7) < 4
        str.tostring((seconds/60/60/24/7)) + "W"
    else if (seconds/60/60/24/30) < 12
        str.tostring((seconds/60/60/24/30)) + "M"
    else
        str.tostring((seconds/60/60/24/365)) + "Y"

// Helper function to get current timeframe string
getCurrentTimeframe() =>
    current_seconds = timeframe.in_seconds()
    if current_seconds < 60
        str.tostring(current_seconds) + "S"
    else if (current_seconds / 60) < 60
        str.tostring((current_seconds/60)) + "M"
    else if (current_seconds/60/60) < 24
        str.tostring((current_seconds/60/60)) + "H"
    else if (current_seconds/60/60/24) < 7
        str.tostring((current_seconds/60/60/24)) + "D"
    else if (current_seconds/60/60/24/7) < 4
        str.tostring((current_seconds/60/60/24/7)) + "W"
    else if (current_seconds/60/60/24/30) < 12
        str.tostring((current_seconds/60/60/24/30)) + "M"
    else
        str.tostring((current_seconds/60/60/24/365)) + "Y"

// Helper function to get remaining time until next HTF candle
getRemainingTime(string htf) =>
    if barstate.isrealtime
        timeRemaining = (time_close(htf) - timenow)/1000
        days = math.floor(timeRemaining / 86400)
        hours = math.floor((timeRemaining - (days*86400)) / 3600)
        minutes = math.floor((timeRemaining - (days*86400) - (hours*3600))/ 60)
        seconds = math.floor(timeRemaining - (days*86400) - (hours*3600) - (minutes*60))
        
        r = str.tostring(seconds, "00")
        if minutes > 0 or hours > 0 or days > 0
            r := str.tostring(minutes, "00") + ":" + r
        if hours > 0 or days > 0
            r := str.tostring(hours, "00") + ":" + r
        if days > 0
            r := str.tostring(days) + "D " + r
        r
    else
        "n/a"

// Helper function to get table position
getTablePosition(string position) =>
    switch position
        'Top Left' => position.top_left
        'Top Center' => position.top_center
        'Top Right' => position.top_right
        'Middle Left' => position.middle_left
        'Middle Center' => position.middle_center
        'Middle Right' => position.middle_right
        'Bottom Left' => position.bottom_left
        'Bottom Center' => position.bottom_center
        'Bottom Right' => position.bottom_right
        => position.top_right


// Function to calculate position size based on risk parameters
calculatePositionSize(float entry, float stop, float riskUsd) =>
    riskPerUnit = math.abs(entry - stop)
    positionSize = riskPerUnit != 0 ? riskUsd / riskPerUnit : 0
    
    // Format based on market type
    detectedMarket = syminfo.type
    if detectedMarket == "forex"
        ticker = syminfo.ticker
        needsConversion = not (str.contains(ticker, "USD") and str.endswith(ticker, "USD")) or str.contains(ticker, "6")
        if needsConversion
            positionSize := (positionSize * entry) / 100000.0
        else
            positionSize := positionSize / 100000.0
    else if detectedMarket == "futures" or detectedMarket == "future" or detectedMarket == "cfd" or detectedMarket == "index"
        contractSize = getContractSize()
        positionSize := positionSize / contractSize
    else if detectedMarket == "crypto" or detectedMarket == "stock" or detectedMarket == "other"
        positionSize := positionSize
    else
        positionSize := positionSize
    
    positionSize

// Function to format position size based on market type
formatPositionSize(float size) =>
    detectedMarket = syminfo.type
    sizeText = ""
    if detectedMarket == "forex"
        sizeText := str.tostring(size, '#.##') + (abbreviatePositionInfo ? ' lt' : ' lots')
    else if detectedMarket == "futures" or detectedMarket == "future" or detectedMarket == "cfd" or detectedMarket == "index"
        sizeText := str.tostring(size, '#.##') + (abbreviatePositionInfo ? ' ct' : ' contracts')
    else if detectedMarket == "crypto" or detectedMarket == "stock"
        sizeText := str.tostring(size, '#.####') + (abbreviatePositionInfo ? ' un' : ' units')
    else
        sizeText := str.tostring(size, '#.####')
    sizeText

// Function to get precision string (e.g., "#####" for 5 decimals)
getPrecisionString() =>
    int decimals = int(math.log10(1 / syminfo.mintick))
    string precisionString = ''
    for i = 0 to decimals - 1 by 1
        precisionString := precisionString + '#'
    precisionString



// Helper function to check if SMT extreme is within an FVG range (not fully mitigated)
isSMTInFVG(string smtType, float prevChartHigh, float currChartHigh, float prevChartLow, float currChartLow, float rangeHigh, float rangeLow, bool highMitigated, bool lowMitigated) =>
    // Check if range is not fully mitigated
    bool notFullyMitigated = (na(rangeHigh) or not highMitigated) or (na(rangeLow) or not lowMitigated)
    if not notFullyMitigated
        false
    else
        // Determine min and max of range (rangeHigh might be less than rangeLow for FVGs)
        float rangeMin = math.min(rangeHigh, rangeLow)
        float rangeMax = math.max(rangeHigh, rangeLow)
        
        // For bearish SMT: check if at least one high is within FVG range
        if smtType == "BEARISH"
            bool prevHighInRange = not na(prevChartHigh) and not na(rangeHigh) and not na(rangeLow) and prevChartHigh >= rangeMin and prevChartHigh <= rangeMax
            bool currHighInRange = not na(currChartHigh) and not na(rangeHigh) and not na(rangeLow) and currChartHigh >= rangeMin and currChartHigh <= rangeMax
            prevHighInRange or currHighInRange
        // For bullish SMT: check if at least one low is within FVG range
        else
            bool prevLowInRange = not na(prevChartLow) and not na(rangeHigh) and not na(rangeLow) and prevChartLow >= rangeMin and prevChartLow <= rangeMax
            bool currLowInRange = not na(currChartLow) and not na(rangeHigh) and not na(rangeLow) and currChartLow >= rangeMin and currChartLow <= rangeMax
            prevLowInRange or currLowInRange

// Helper function to check if SMT is within a specific FVG range (for signal confirmation)
isSMTInFVGRange(string smtType, float prevChartHigh, float currChartHigh, float prevChartLow, float currChartLow, float fvgHigh, float fvgLow) =>
    if na(fvgHigh) or na(fvgLow)
        false
    else
        // For bearish SMT: check if at least one high is within FVG range
        if smtType == "BEARISH"
            bool prevHighInRange = not na(prevChartHigh) and prevChartHigh >= fvgLow and prevChartHigh <= fvgHigh
            bool currHighInRange = not na(currChartHigh) and currChartHigh >= fvgLow and currChartHigh <= fvgHigh
            prevHighInRange or currHighInRange
        // For bullish SMT: check if at least one low is within FVG range
        else
            bool prevLowInRange = not na(prevChartLow) and prevChartLow >= fvgLow and prevChartLow <= fvgHigh
            bool currLowInRange = not na(currChartLow) and currChartLow >= fvgLow and currChartLow <= fvgHigh
            prevLowInRange or currLowInRange

// Get SMT Pair function - auto-detection based on symbol
getSMTPair() =>
    string ticker = syminfo.ticker
    string baseTicker = syminfo.tickerid
    
    // Check if crypto (BTC, ETH, etc.)
    if str.contains(ticker, "BTC") or str.contains(baseTicker, "BTC")
        "ETHUSD"  // BTC's pair is ETH
    else if str.contains(ticker, "ETH") or str.contains(baseTicker, "ETH")
        "BTCUSD"  // ETH's pair is BTC
    else if str.contains(ticker, "USD") or str.contains(baseTicker, "USD")
        "ETHUSD"  // Other cryptos pair with ETH
    // Futures pairs
    else if str.contains(ticker, "ES1!") or str.contains(baseTicker, "ES1!")
        "NQ1!"    // ES pairs with NQ
    else if str.contains(ticker, "NQ1!") or str.contains(baseTicker, "NQ1!")
        "ES1!"    // NQ pairs with ES
    else if str.contains(ticker, "YM1!") or str.contains(baseTicker, "YM1!")
        "ES1!"    // YM pairs with ES
    else if str.contains(ticker, "RTY1!") or str.contains(baseTicker, "RTY1!")
        "ES1!"    // RTY pairs with ES
    else if str.contains(ticker, "CL1!") or str.contains(baseTicker, "CL1!")
        "NG1!"    // CL pairs with NG
    else if str.contains(ticker, "NG1!") or str.contains(baseTicker, "NG1!")
        "CL1!"    // NG pairs with CL
    else if str.contains(ticker, "GC1!") or str.contains(baseTicker, "GC1!")
        "SI1!"    // GC pairs with SI
    else if str.contains(ticker, "SI1!") or str.contains(baseTicker, "SI1!")
        "GC1!"    // SI pairs with GC
    // Forex pairs
    else if str.contains(ticker, "EURUSD") or str.contains(baseTicker, "EURUSD")
        "GBPUSD"  // EUR pairs with GBP
    else if str.contains(ticker, "GBPUSD") or str.contains(baseTicker, "GBPUSD")
        "EURUSD"  // GBP pairs with EUR
    else if str.contains(ticker, "USDJPY") or str.contains(baseTicker, "USDJPY")
        "EURJPY"  // USDJPY pairs with EURJPY
    else if str.contains(ticker, "EURJPY") or str.contains(baseTicker, "EURJPY")
        "USDJPY"  // EURJPY pairs with USDJPY
    else if str.contains(ticker, "AUDUSD") or str.contains(baseTicker, "AUDUSD")
        "NZDUSD"  // AUD pairs with NZD
    else if str.contains(ticker, "NZDUSD") or str.contains(baseTicker, "NZDUSD")
        "AUDUSD"  // NZD pairs with AUD
    else if str.contains(ticker, "USDCAD") or str.contains(baseTicker, "USDCAD")
        "USDCHF"  // USDCAD pairs with USDCHF
    else if str.contains(ticker, "USDCHF") or str.contains(baseTicker, "USDCHF")
        "USDCAD"  // USDCHF pairs with USDCAD
    else if str.contains(ticker, "EUR") or str.contains(baseTicker, "EUR")
        "GBPUSD"  // Other EUR pairs with GBP
    else if str.contains(ticker, "GBP") or str.contains(baseTicker, "GBP")
        "EURUSD"  // Other GBP pairs with EUR
    else if str.contains(ticker, "JPY") or str.contains(baseTicker, "JPY")
        "EURJPY"  // Other JPY pairs with EURJPY
    else
        "ES1!"    // Default fallback

// ══════════════════════════════════════════════════════════════════════════════
// GLOBAL VARIABLES (Must be declared before functions that use them)
// ══════════════════════════════════════════════════════════════════════════════
// ERL (External Range Liquidity) - tracks latest HTF pivots (one high, one low)
var float erlHighLevel = na  // Latest HTF pivot high
var int erlHighTime = na     // Time when pivot high was formed
var bool erlHighMitigated = false  // True if pivot high ERL has been mitigated
var int erlHighMitigationTime = na  // Time when pivot high ERL was mitigated
var line erlHighLine = na   // Line object for pivot high ERL
var label erlHighLabel = na  // Label for pivot high ERL

var float erlLowLevel = na  // Latest HTF pivot low
var int erlLowTime = na     // Time when pivot low was formed
var bool erlLowMitigated = false  // True if pivot low ERL has been mitigated
var int erlLowMitigationTime = na  // Time when pivot low ERL was mitigated
var line erlLowLine = na   // Line object for pivot low ERL
var label erlLowLabel = na  // Label for pivot low ERL

// Strategy signal tracking variables (used in helper functions)
var float latestBearishStopPrice = na  // Stop price for latest bearish signal
var float latestBullishStopPrice = na  // Stop price for latest bullish signal
var float latestBearishPositionSize = na  // Position size for latest bearish signal
var float latestBullishPositionSize = na  // Position size for latest bullish signal

// SMT Structure (must be declared before functions that use it)
type SMT
    string smtType        // "BEARISH" or "BULLISH"
    string detectionMode  // "HTF" or "PIVOT"
    string smtPair        // SMT pair symbol (for labels)
    // For HTF: prev and curr swing points; For Pivot: prev and curr pivots
    float prevChartHigh   // Previous chart high (HTF swing or pivot)
    float currChartHigh   // Current chart high (HTF swing or pivot)
    int prevChartHighTime // Previous chart high time
    int currChartHighTime // Current chart high time
    float prevChartLow    // Previous chart low (HTF swing or pivot)
    float currChartLow   // Current chart low (HTF swing or pivot)
    int prevChartLowTime  // Previous chart low time
    int currChartLowTime  // Current chart low time
    bool confirmed        // True if confirmed (HTF: on new bar, Pivot: on opposing pivot)
    int creationBar       // Bar where SMT was created
    line smtLine          // Line object for SMT
    label smtLabel        // Label object for SMT

// SMT Variables (must be declared before functions that use them)
var array<SMT> smtArray = array.new<SMT>()  // Array to store all SMT instances

// ══════════════════════════════════════════════════════════════════════════════
// STRATEGY HELPER FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════
// Contract size adjustment for strategy
adjustForContractSize(float rawSize) =>
    float adjustedSize = rawSize
    if syminfo.type == "forex"
        adjustedSize := rawSize / 100000
    else if syminfo.type == "futures" or syminfo.type == "future"
        contractSize = getContractSize()
        adjustedSize := rawSize / contractSize
    adjustedSize

// Strategy position size calculation
calculateStrategyPositionSize(float entryPrice, float stopPrice) =>
    float posSize = 0.0
    float riskPerUnit = math.abs(entryPrice - stopPrice)
    switch positionSizeType
        'Percent of Equity' =>
            posSize := (strategy.equity * positionSizeValue / 100) / entryPrice
        'Fixed Contracts' =>
            posSize := positionSizeValue
        'Fixed USD' =>
            posSize := positionSizeValue / entryPrice
        'Risk-Based' =>
            float riskAmount = strategy.equity * positionSizeValue / 100
            if riskPerUnit > 0
                posSize := riskAmount / riskPerUnit
            else
                posSize := 0
    posSize := adjustForContractSize(posSize)
    posSize := math.max(posSize, syminfo.mintick)
    posSize

// Stop loss calculation
calculateStrategyStopLoss(bool isLong, float entryPrice, float signalStop, PendingSignal signal = na) =>
    float stopPrice = na
    if not useStopLoss
        stopPrice := na
    else
        switch stopLossType
            'Signal-Based' =>
                stopPrice := signalStop
            'Swing-Based' =>
                // v4.0: Use swing high/low (ERL levels)
                if isLong
                    stopPrice := not na(erlLowLevel) and not erlLowMitigated ? erlLowLevel : signalStop
                else
                    stopPrice := not na(erlHighLevel) and not erlHighMitigated ? erlHighLevel : signalStop
            'Manipulation Candle' =>
                // v4.0: Use manipulation candle wick
                if not na(signal)
                    if isLong
                        stopPrice := signal.manipulationCandleLow
                    else
                        stopPrice := signal.manipulationCandleHigh
                else
                    stopPrice := signalStop
            'Fixed Points' =>
                stopPrice := isLong ? entryPrice - fixedStopPoints * syminfo.mintick : entryPrice + fixedStopPoints * syminfo.mintick
            'Fixed Percent' =>
                stopPrice := isLong ? entryPrice * (1 - fixedStopPercent / 100) : entryPrice * (1 + fixedStopPercent / 100)
            'ATR-Based' =>
                float atrValue = ta.atr(atrStopLength)
                stopPrice := isLong ? entryPrice - atrValue * atrStopMultiplier : entryPrice + atrValue * atrStopMultiplier
    stopPrice

// Take profit calculation
calculateStrategyTakeProfit(bool isLong, float entryPrice, float stopPrice) =>
    float tpPrice = na
    if not useTakeProfit
        tpPrice := na
    else
        float riskDistance = math.abs(entryPrice - stopPrice)
        switch takeProfitType
            'Risk:Reward' =>
                float rewardDistance = riskDistance * riskRewardRatio
                tpPrice := isLong ? entryPrice + rewardDistance : entryPrice - rewardDistance
            'Fixed Points' =>
                tpPrice := isLong ? entryPrice + fixedTPPoints * syminfo.mintick : entryPrice - fixedTPPoints * syminfo.mintick
            'Fixed Percent' =>
                tpPrice := isLong ? entryPrice * (1 + fixedTPPercent / 100) : entryPrice * (1 - fixedTPPercent / 100)
            'ATR-Based' =>
                float atrValue = ta.atr(atrStopLength)
                tpPrice := isLong ? entryPrice + atrValue * atrTPMultiplier : entryPrice - atrValue * atrTPMultiplier
            'ERL Target' =>
                if isLong and not na(erlHighLevel) and erlHighLevel > entryPrice
                    tpPrice := erlHighLevel
                else if not isLong and not na(erlLowLevel) and erlLowLevel < entryPrice
                    tpPrice := erlLowLevel
                else
                    tpPrice := isLong ? entryPrice + riskDistance * riskRewardRatio : entryPrice - riskDistance * riskRewardRatio
    tpPrice

// Partial take profit calculation
calculatePartialTP(bool isLong, float entryPrice, float stopPrice) =>
    float partialPrice = na
    if usePartialTP
        float riskDistance = math.abs(entryPrice - stopPrice)
        float partialReward = riskDistance * partialTPRatio
        partialPrice := isLong ? entryPrice + partialReward : entryPrice - partialReward
    partialPrice

// Stop loss management
manageStrategyStopLoss(bool isLong, float entryPrice, float stopPrice, float currentStop) =>
    float newStop = stopPrice
    if not na(currentStop)
        float currentProfit = isLong ? close - entryPrice : entryPrice - close
        float initialRisk = math.abs(entryPrice - stopPrice)
        float rMultiple = initialRisk > 0 ? currentProfit / initialRisk : 0
        if useBreakEven and rMultiple >= breakEvenTriggerRR
            newStop := isLong ? entryPrice + breakEvenOffset * syminfo.mintick : entryPrice - breakEvenOffset * syminfo.mintick
        if useTrailingStop and rMultiple >= trailingStopActivation
            float trailDistance = 0.0
            switch trailingStopType
                'Fixed Points' =>
                    trailDistance := trailingStopDistance * syminfo.mintick
                'Fixed Percent' =>
                    trailDistance := close * trailingStopDistance / 100
                'ATR-Based' =>
                    trailDistance := ta.atr(atrStopLength) * trailingStopDistance
            float trailStop = isLong ? close - trailDistance : close + trailDistance
            if isLong
                newStop := math.max(nz(currentStop, stopPrice), trailStop)
            else
                newStop := math.min(nz(currentStop, stopPrice), trailStop)
        if isLong
            newStop := math.max(newStop, nz(currentStop, 0))
        else
            newStop := math.min(newStop, nz(currentStop, 999999999))
    newStop

// Time filter
isWithinTradingHours() =>
    int currentMinutes = hour * 60 + minute
    int startMinutes = tradingStartHour * 60 + tradingStartMinute
    int endMinutes = tradingEndHour * 60 + tradingEndMinute
    if startMinutes < endMinutes
        currentMinutes >= startMinutes and currentMinutes < endMinutes
    else
        currentMinutes >= startMinutes or currentMinutes < endMinutes

// Day filter
isDayAllowed() =>
    int dow = dayofweek
    bool allowed = true
    if dow == dayofweek.monday and not tradeMon
        allowed := false
    else if dow == dayofweek.tuesday and not tradeTue
        allowed := false
    else if dow == dayofweek.wednesday and not tradeWed
        allowed := false
    else if dow == dayofweek.thursday and not tradeThu
        allowed := false
    else if dow == dayofweek.friday and not tradeFri
        allowed := false
    allowed

// Volatility filter
isVolatilityAcceptable() =>
    float atrValue = ta.atr(14)
    bool acceptable = true
    if minATR > 0 and atrValue < minATR
        acceptable := false
    if maxATR > 0 and atrValue > maxATR
        acceptable := false
    acceptable

// SMT check functions
hasBullishSMT() =>
    bool found = false
    if enableSMT and array.size(smtArray) > 0
        for i = array.size(smtArray) - 1 to 0
            smt = array.get(smtArray, i)
            if smt.smtType == "BULLISH" and smt.confirmed
                found := true
                break
    found

hasBearishSMT() =>
    bool found = false
    if enableSMT and array.size(smtArray) > 0
        for i = array.size(smtArray) - 1 to 0
            smt = array.get(smtArray, i)
            if smt.smtType == "BEARISH" and smt.confirmed
                found := true
                break
    found

// HTF bias
getHTFBias() =>
    int bias = 0
    switch htfBiasMethod
        'Candle Direction' =>
            [htfO, htfC] = request.security(syminfo.tickerid, htfBiasTimeframe, [open, close])
            bias := htfC > htfO ? 1 : htfC < htfO ? -1 : 0
        'EMA Trend' =>
            htfEMA = request.security(syminfo.tickerid, htfBiasTimeframe, ta.ema(close, 20))
            htfClose = request.security(syminfo.tickerid, htfBiasTimeframe, close)
            bias := htfClose > htfEMA ? 1 : htfClose < htfEMA ? -1 : 0
        'Price vs VWAP' =>
            htfVWAP = request.security(syminfo.tickerid, htfBiasTimeframe, ta.vwap)
            htfClose = request.security(syminfo.tickerid, htfBiasTimeframe, close)
            bias := htfClose > htfVWAP ? 1 : htfClose < htfVWAP ? -1 : 0
    bias

// v4.0: HTF Context Validation - Check if price is at HTF POI
isAtHTFPOI() =>
    bool atPOI = false
    // Check if price is inside any active HTF FVG
    if array.size(ranges) > 0
        for i = 0 to array.size(ranges) - 1
            r = array.get(ranges, i)
            if not r.isSpecial and not r.highMitigated and not r.lowMitigated
                float fvgMin = math.min(r.rangeHigh, r.rangeLow)
                float fvgMax = math.max(r.rangeHigh, r.rangeLow)
                if low <= fvgMax and high >= fvgMin
                    atPOI := true
                    break
    // Check if price has swept HTF ERL (liquidity)
    if not atPOI
        if not na(erlHighLevel) and not erlHighMitigated and high >= erlHighLevel
            atPOI := true
        if not atPOI and not na(erlLowLevel) and not erlLowMitigated and low <= erlLowLevel
            atPOI := true
    atPOI

// v4.0: Violent Rejection Validation - Check if iFVG was created with strong rejection
hasViolentRejection(int pivotBar, int confirmationBar) =>
    bool violent = false
    if confirmationBar > pivotBar
        // Check for large candle body at confirmation
        float bodySize = math.abs(close[bar_index - confirmationBar] - open[bar_index - confirmationBar])
        float atrValue = ta.atr(14)
        float bodyATR = atrValue > 0 ? bodySize / atrValue : 0
        // Check for high volume
        float avgVolume = ta.sma(volume, 20)
        float volumeRatio = avgVolume > 0 ? volume[bar_index - confirmationBar] / avgVolume : 0
        // Violent if: large body (>1.5 ATR) OR high volume (>2x average)
        violent := bodyATR > 1.5 or volumeRatio > 2.0
    violent

// v4.0: Displacement Check - Verify manipulation leg lacks displacement
lacksDisplacement(int manipulationBar) =>
    bool lacksDisp = false
    if manipulationBar >= 0 and bar_index >= manipulationBar
        int offset = bar_index - manipulationBar
        if offset >= 0
            float candleBody = math.abs(close[offset] - open[offset])
            float candleWick = 0.0
            if close[offset] > open[offset]
                candleWick := high[offset] - close[offset] + open[offset] - low[offset]
            else
                candleWick := high[offset] - open[offset] + close[offset] - low[offset]
            // Lacks displacement if wick is larger than body (sluggish move)
            lacksDisp := candleWick > candleBody
    lacksDisp

// v4.0: Find iFVG floor/ceiling for Mode A entry
findIFVGEntryPrice(string signalType, int pivotBar, int confirmationBar) =>
    float entryPrice = na
    array<InversionFVG> sourceArray = signalType == "BEARISH" ? bearInvArray : bullInvArray
    if array.size(sourceArray) > 0
        for i = array.size(sourceArray) - 1 to 0
            inv = array.get(sourceArray, i)
            if not inv.mitigated and not na(inv.creationBar) and not na(inv.inversionBar)
                if inv.creationBar > pivotBar and inv.inversionBar <= confirmationBar
                    // For bearish: entry at iFVG ceiling (top)
                    // For bullish: entry at iFVG floor (bot)
                    entryPrice := signalType == "BEARISH" ? inv.top : inv.bot
                    break
    entryPrice

// v4.0: Find swing high/low for Mode A stop loss
findSwingStopPrice(string signalType) =>
    float stopPrice = na
    // Use ERL levels as swing stops
    if signalType == "BEARISH" and not na(erlHighLevel) and not erlHighMitigated
        stopPrice := erlHighLevel
    else if signalType == "BULLISH" and not na(erlLowLevel) and not erlLowMitigated
        stopPrice := erlLowLevel
    stopPrice

// Pending Signal Structure
type PendingSignal
    string signalType       // "BEARISH" or "BULLISH"
    float confirmationLevel // Pivot level that needs to be crossed
    int creationBar         // Bar where signal was created
    int pivotBarIndex       // Bar index where the pivot was formed
    float maxPrice          // Max price from creation to confirmation (for bearish)
    float minPrice          // Min price from creation to confirmation (for bullish)
    float mitigatedLevel    // The range level that was mitigated (rangeHigh for bearish, rangeLow for bullish)
    float fvgRangeHigh      // FVG range high (for SMT checking)
    float fvgRangeLow       // FVG range low (for SMT checking)
    int fvgTouchBar         // Bar where FVG was initially touched (for SMT checking)
    // v4.0: Manipulation candle tracking
    float manipulationCandleOpen    // Open price of manipulation candle (for Mode B entry)
    float manipulationCandleHigh   // High of manipulation candle (for short stops)
    float manipulationCandleLow    // Low of manipulation candle (for long stops)
    int manipulationCandleBar       // Bar index of manipulation candle
    // v4.0: Signal quality
    bool hasViolentRejection       // True if iFVG was created with violent rejection
    bool lacksDisplacement          // True if manipulation leg lacks displacement
    bool hasSMTDivergence          // True if SMT divergence is present (A++ grade)
    string signalGrade              // "A", "A+", or "A++"

// FVG quality check
checkFVGQuality(PendingSignal signal) =>
    bool passed = true
    if not na(signal) and not na(signal.fvgRangeHigh) and not na(signal.fvgRangeLow)
        float fvgSize = math.abs(signal.fvgRangeLow - signal.fvgRangeHigh)
        float fvgSizePoints = fvgSize / syminfo.mintick
        float atrValue = ta.atr(14)
        float fvgSizeATR = atrValue > 0 ? fvgSize / atrValue : 0
        if minFVGSize > 0 and fvgSizePoints < minFVGSize
            passed := false
        if maxFVGSize > 0 and fvgSizePoints > maxFVGSize
            passed := false
        if minFVGSizeATR > 0 and fvgSizeATR < minFVGSizeATR
            passed := false
        if maxFVGSizeATR > 0 and fvgSizeATR > maxFVGSizeATR
            passed := false
    passed

// Confirmation timing check
checkConfirmationTiming(PendingSignal signal) =>
    bool passed = true
    if not na(signal)
        int barsSinceCreation = bar_index - signal.creationBar
        if maxBarsToConfirm > 0 and barsSinceCreation > maxBarsToConfirm
            passed := false
        if minBarsToConfirm > 0 and barsSinceCreation < minBarsToConfirm
            passed := false
    passed

// Determine HTF
string selectedHTF = manualHTF

if autoMode
    // In auto mode: automatically select HTF based on chart timeframe
    selectedHTF := getHTFPeriod()
else
    // Manual mode: use manual HTF input
    selectedHTF := manualHTF

// v2.0: HTF candle counter for time decay - MUST be declared before first use
var int htfCandleCount = 0

// Input parameters
maxRangesToDisplay = input.int(10, 'Max Ranges to Display', minval = 1, maxval = 100)
rangeFilter = input.bool(false, 'Range Filter', tooltip = "Filter Fvg Keep Only Those Outside Ranges")

// Detect new HTF candle
bool newPeriod = timeframe.change(selectedHTF)

// v2.0: Update HTF candle counter for time decay
if newPeriod
    htfCandleCount += 1

// ========================================
// TYPES
// ========================================
type HTFPivotPoint
    float price
    string pType // "HIGH" or "LOW"
    int time
    int barIndex

type HTFInsideSwing
    float high    // Outer High
    float low     // Outer Low
    int time      // Time when the pattern completed (4th pivot time)
    int startBar  // Start bar of the pattern
    int endBar    // End bar of the pattern

// ========================================
// GLOBAL STORAGE
// ========================================
var allHtfPivots = array.new<HTFPivotPoint>()
var activeSwingHistory = array.new<HTFInsideSwing>()

// ========================================
// HTF DATA & PIVOT DETECTION
// ========================================
// Function to detect HTF pivots based on candle direction
detectHTFPivots() =>
    bool hasPivotHigh = false
    bool hasPivotLow = false
    float pivotHighPrice = na
    float pivotLowPrice = na
    int pivotHighTime = na
    int pivotLowTime = na
    
    if barstate.isconfirmed
        // Get HTF data
        float htfHigh = high[0]
        float htfLow = low[0]
        float htfHigh1 = high[1]
        float htfLow1 = low[1]
        float htfOpen = open[0]
        float htfClose = close[0]
        float htfOpen1 = open[1]
        float htfClose1 = close[1]
        int htfTime = time[0]
        
        bool currentHtfIsBullish = htfClose > htfOpen
        bool prevHtfWasBullishCheck = htfClose1 > htfOpen1
        
        // Bullish HTF candle after bearish → new HTF pivot low
        if currentHtfIsBullish and not prevHtfWasBullishCheck and not na(htfLow) and not na(htfLow1)
            hasPivotLow := true
            pivotLowPrice := math.min(htfLow, htfLow1)
            pivotLowTime := htfTime
        
        // Bearish HTF candle after bullish → new HTF pivot high
        if not currentHtfIsBullish and prevHtfWasBullishCheck and not na(htfHigh) and not na(htfHigh1)
            hasPivotHigh := true
            pivotHighPrice := math.max(htfHigh, htfHigh1)
            pivotHighTime := htfTime
    
    [hasPivotHigh, hasPivotLow, pivotHighPrice, pivotLowPrice, pivotHighTime, pivotLowTime]

// Fetch HTF data
[htfHasPivotHigh, htfHasPivotLow, htfPivotHighPrice, htfPivotLowPrice, htfPivotHighTime, htfPivotLowTime] = request.security(syminfo.tickerid, selectedHTF, detectHTFPivots())
// Detect new HTF candle

// ========================================
// PIVOT STORAGE & PATTERN LOGIC
// ========================================
// Only process on new HTF pivots
if htfHasPivotHigh and newPeriod
    newPivot = HTFPivotPoint.new(htfPivotHighPrice, "HIGH", htfPivotHighTime, bar_index)
    array.push(allHtfPivots, newPivot)

if htfHasPivotLow and newPeriod
    newPivot = HTFPivotPoint.new(htfPivotLowPrice, "LOW", htfPivotLowTime, bar_index)
    array.push(allHtfPivots, newPivot)

// Detect Inside Swings (Run whenever we have enough pivots)
if (htfHasPivotHigh or htfHasPivotLow) and array.size(allHtfPivots) >= 4 and newPeriod
    // Get last 4 pivots
    p4 = array.get(allHtfPivots, array.size(allHtfPivots) - 1) // Latest
    p3 = array.get(allHtfPivots, array.size(allHtfPivots) - 2)
    p2 = array.get(allHtfPivots, array.size(allHtfPivots) - 3)
    p1 = array.get(allHtfPivots, array.size(allHtfPivots) - 4) // Oldest
    
    HTFInsideSwing newSwing = na
    
    // HLHL Pattern: High(1) -> Low(1) -> High(2) -> Low(2)
    if p1.pType == "HIGH" and p2.pType == "LOW" and p3.pType == "HIGH" and p4.pType == "LOW"
        // Outer High (H1) > Inner High (H2) AND Outer Low (L1) < Inner Low (L2)
        if p1.price > p3.price and p2.price < p4.price
            newSwing := HTFInsideSwing.new(p1.price, p2.price, p4.time, p1.barIndex, p4.barIndex)

    // LHLH Pattern: Low(1) -> High(1) -> Low(2) -> High(2)
    if p1.pType == "LOW" and p2.pType == "HIGH" and p3.pType == "LOW" and p4.pType == "HIGH"
        // Outer Low (L1) < Inner Low (L2) AND Outer High (H1) > Inner High (H2)
        if p1.price < p3.price and p2.price > p4.price
            newSwing := HTFInsideSwing.new(p2.price, p1.price, p4.time, p1.barIndex, p4.barIndex)
            
    // Nesting Logic
    if not na(newSwing)
        // Check against current active swing
        HTFInsideSwing activeSwing = na
        if array.size(activeSwingHistory) > 0
            activeSwing := array.get(activeSwingHistory, array.size(activeSwingHistory) - 1)
        
        bool isNested = false
        if not na(activeSwing)
            // Check if new swing is contained within active swing
            // New High <= Active High AND New Low >= Active Low
            if newSwing.high <= activeSwing.high and newSwing.low >= activeSwing.low
                isNested := true
        
        if not isNested
            array.push(activeSwingHistory, newSwing)

// ========================================
// FILTERING FUNCTION
// ========================================
// Function to check if FVG passes the Inside Swing filter
// Returns true if filter is disabled OR if FVG meets the criteria
fvgPassesFilter(bool isBullish, float fvgTop, float fvgBottom, int fvgTime) =>
    bool passed = false
    
    if not rangeFilter
        passed := true
    else
        // Find the active swing that was valid BEFORE this FVG formed
        HTFInsideSwing relevantSwing = na
        if array.size(activeSwingHistory) > 0
            for i = array.size(activeSwingHistory) - 1 to 0
                s = array.get(activeSwingHistory, i)
                if s.time < fvgTime
                    relevantSwing := s
                    break
        
        if na(relevantSwing)
            passed := true // No active swing to filter against
        else
            if isBullish
                // Bullish FVG Top must be > Active Swing High (Break Out Up)
                passed := fvgTop > relevantSwing.high
            else
                // Bearish FVG Bottom must be < Active Swing Low (Break Out Down)
                passed := fvgBottom < relevantSwing.low
    
    passed


// Color settings
bullishFVGColor = input.color(color.green, 'Bullish FVG Color')
bearishFVGColor = input.color(color.red, 'Bearish FVG Color')
erlColor = input.color(color.yellow, 'ERL Color')

// Structure for ranges - track high and low mitigation separately
type Range
    float rangeHigh
    float rangeLow
    int highStartTime     // Time when the high was formed
    int lowStartTime      // Time when the low was formed
    bool highMitigated
    bool lowMitigated
    int highMitigationTime
    int lowMitigationTime
    bool isSpecial        // Flag to mark special ranges (only one extreme)
    int creationBar       // Bar index where the range was created (for special ranges)
    bool isOIBased        // Flag to mark OI-based special ranges
    bool isSignalBased    // Flag to mark signal-based special ranges
    int signalCreationBar      // Bar index where signal was created (for signal-based ranges)
    int signalConfirmationBar  // Bar index where signal was confirmed (for signal-based ranges)
    bool canCreateSignalFromHigh  // True if high mitigation can create a signal
    bool canCreateSignalFromLow   // True if low mitigation can create a signal
    array<box> fvgBoxes           // Array of boxes for FVG segments
    array<int> fvgBoxEndTimes     // Array of end times for each box segment (na = still extending)
    // v2.0: OTE Levels
    array<line> oteLines      // Array of OTE level lines
    array<label> oteLabels    // Array of OTE level labels
    box oteZoneBox            // OTE zone highlight box (61.8-79%)
    // v2.0: Time Decay
    int lastRetestBar         // Bar index of last retest (for decay pause)
    int htfCandleAtCreation   // HTF candle count at creation
    float currentDecayLevel   // 0.0 = no decay, 1.0 = fully decayed

// Helper function to cleanup FVG boxes when range is deleted
cleanupFVGBoxes(Range r) =>
    if array.size(r.fvgBoxes) > 0
        for i = array.size(r.fvgBoxes) - 1 to 0
            box.delete(array.get(r.fvgBoxes, i))
        array.clear(r.fvgBoxes)
    if array.size(r.fvgBoxEndTimes) > 0
        array.clear(r.fvgBoxEndTimes)

// iFVG Structure (chart timeframe inversion FVG - stored in arrays only)
type InversionFVG
    int left                // Left time of the FVG
    float top               // Top of the FVG gap
    int right               // Right time of the FVG (na = still extending)
    float bot               // Bottom of the FVG gap
    float mid               // Midline of the FVG
    int dir                 // 1 for bullish iFVG, -1 for bearish iFVG
    int state               // 0 = just inverted, 1 = confirmed
    int creationBar         // Bar where FVG was created
    int inversionBar        // Bar where FVG was inverted
    box invBox              // Box object for display (only created when drawing)
    label invLabel          // Label object for display (only created when drawing)
    bool mitigated          // True if fully mitigated (gap filled)
    int mitigationTime      // Time when iFVG was mitigated (na if not mitigated)

// Killzone box type (v2.0)
type KillzoneBox
    box kzBox                 // The box object
    label kzLabel             // Session label
    string sessionName        // 'Asian', 'London', 'NY Open', etc.
    int sessionStartTime      // Session start timestamp
    int sessionEndTime        // Session end timestamp (na if ongoing)
    float sessionHigh         // Highest price during session
    float sessionLow          // Lowest price during session
    bool isComplete           // True if session has ended

// Confirmation Line Structure
type ConfirmationLine
    line confLine           // The confirmation line
    label confLabel         // The label for the confirmation line
    string signalType       // "BEARISH" or "BULLISH"
    float confirmationLevel // The confirmation level
    int startTime           // Time where line starts
    int confirmationTime    // Time when signal was confirmed (line stops here for older ones)
    float stopPrice         // Stop price for this signal
    float entryPrice        // Entry price for this signal
    float positionSize      // Position size for this signal
    float fvgRangeHigh      // FVG range high (for OB breach detection)
    float fvgRangeLow       // FVG range low (for OB breach detection)
    int fvgTouchBar         // Bar where FVG was initially touched
    int pivotBar            // Bar index where pivot was formed
    array<InversionFVG> iFVGs  // Array of inversion FVGs between pivot and confirmation bars

// Initialize arrays
var ranges = array.new<Range>()
var mitigatedRanges = array.new<Range>()  // Separate array for fully mitigated ranges
var array<line> rangeLines = array.new_line()
var array<label> fvgLabels = array.new<label>()  // Global array for all FVG labels (recreated every bar)

// Confirmation lines array
var confirmationLines = array.new<ConfirmationLine>()

// Track latest signal info (for dashboard and position sizing)
var float latestBearishEntryPrice = na  // Entry price for latest bearish signal
var float latestBullishEntryPrice = na  // Entry price for latest bullish signal

// Pivot tracking (always one high and one low)
var float pivotHigh = na
var float pivotLow = na
var int pivotHighBar = na
var int pivotLowBar = na
var bool wasBullish = true  // Initialize to true to track changes

// Pending signals (max one of each type)
var PendingSignal pendingBearish = na
var PendingSignal pendingBullish = na

// Chart timeframe FVG arrays (for iFVG detection - arrays only, no boxes)
var array<InversionFVG> bullFVGArray = array.new<InversionFVG>()  // Bullish FVGs (not yet inverted)
var array<InversionFVG> bearFVGArray = array.new<InversionFVG>()  // Bearish FVGs (not yet inverted)
var array<InversionFVG> bullInvArray = array.new<InversionFVG>()  // Bullish iFVGs (inverted bearish FVGs)
var array<InversionFVG> bearInvArray = array.new<InversionFVG>()  // Bearish iFVGs (inverted bullish FVGs)

// Dashboard table
var table dashboardTable = na

// v2.0: Killzone arrays
var array<KillzoneBox> asianKZBoxes = array.new<KillzoneBox>()
var array<KillzoneBox> londonKZBoxes = array.new<KillzoneBox>()
var array<KillzoneBox> nyOpenKZBoxes = array.new<KillzoneBox>()
var array<KillzoneBox> nyLunchKZBoxes = array.new<KillzoneBox>()
var array<KillzoneBox> nyCloseKZBoxes = array.new<KillzoneBox>()

// v2.0: Killzone session state tracking
var bool wasInAsian = false
var bool wasInLondon = false
var bool wasInNYOpen = false
var bool wasInNYLunch = false
var bool wasInNYClose = false

// ========================================
// v2.0: SESSION FILTERING FUNCTIONS
// ========================================
// Returns true if current bar is within any enabled session
isInSession() =>
    if not enableSessionFilter
        true
    else
        int currentHour = hour(time, sessionTimezone)
        int currentMinute = minute(time, sessionTimezone)
        int currentTimeMinutes = currentHour * 60 + currentMinute
        bool inSession = false
        int dow = dayofweek(time, sessionTimezone)
        bool isWeekday = dow >= dayofweek.monday and dow <= dayofweek.friday
        if not isWeekday
            false
        else
            if asianSessionEnabled
                int asianStart = 20 * 60  // 1200 minutes (8 PM)
                // Asian session: 20:00-00:00 (8 PM to midnight)
                // Covers 20:00 (1200) to 23:59 (1439), ends at 00:00
                if currentTimeMinutes >= asianStart
                    inSession := true
            if londonSessionEnabled
                int londonStart = 2 * 60
                int londonEnd = 5 * 60
                if currentTimeMinutes >= londonStart and currentTimeMinutes < londonEnd
                    inSession := true
            if nyAmSessionEnabled
                int nyAmStart = 7 * 60
                int nyAmEnd = 10 * 60
                if currentTimeMinutes >= nyAmStart and currentTimeMinutes < nyAmEnd
                    inSession := true
            if nyLunchEnabled
                int nyLunchStart = 12 * 60
                int nyLunchEnd = 13 * 60
                if currentTimeMinutes >= nyLunchStart and currentTimeMinutes < nyLunchEnd
                    inSession := true
            if nyPmSessionEnabled
                int nyPmStart = 13 * 60 + 30
                int nyPmEnd = 16 * 60
                if currentTimeMinutes >= nyPmStart and currentTimeMinutes < nyPmEnd
                    inSession := true
            if useCustomSession
                inSession := inSession or not na(time(timeframe.period, customSessionStart, sessionTimezone))
            inSession

// Check if in specific named session (for killzone coloring)
isInSpecificSession(string sessionName) =>
    int currentHour = hour(time, sessionTimezone)
    int currentMinute = minute(time, sessionTimezone)
    int currentTimeMinutes = currentHour * 60 + currentMinute
    switch sessionName
        'Asian' => currentTimeMinutes >= 1200  // 20:00 (8 PM) onwards until midnight
        'London' => currentTimeMinutes >= 120 and currentTimeMinutes < 300
        'NY AM' => currentTimeMinutes >= 420 and currentTimeMinutes < 600
        'NY Lunch' => currentTimeMinutes >= 720 and currentTimeMinutes < 780
        'NY PM' => currentTimeMinutes >= 810 and currentTimeMinutes < 960
        => false

// ========================================
// v2.0: KILLZONE FUNCTIONS
// ========================================
// Detect session boundaries
detectSessionTransitions() =>
    bool inAsian = not na(time(timeframe.period, asianKZStart, sessionTimezone))
    bool inLondon = not na(time(timeframe.period, londonKZStart, sessionTimezone))
    bool inNYOpen = not na(time(timeframe.period, nyOpenKZStart, sessionTimezone))
    bool inNYLunch = not na(time(timeframe.period, nyLunchKZStart, sessionTimezone))
    bool inNYClose = not na(time(timeframe.period, nyCloseKZStart, sessionTimezone))
    bool asianStart = inAsian and not wasInAsian
    bool londonStart = inLondon and not wasInLondon
    bool nyOpenStart = inNYOpen and not wasInNYOpen
    bool nyLunchStart = inNYLunch and not wasInNYLunch
    bool nyCloseStart = inNYClose and not wasInNYClose
    bool asianEnd = not inAsian and wasInAsian
    bool londonEnd = not inLondon and wasInLondon
    bool nyOpenEnd = not inNYOpen and wasInNYOpen
    bool nyLunchEnd = not inNYLunch and wasInNYLunch
    bool nyCloseEnd = not inNYClose and wasInNYClose
    [asianStart, asianEnd, inAsian, londonStart, londonEnd, inLondon, nyOpenStart, nyOpenEnd, inNYOpen, nyLunchStart, nyLunchEnd, inNYLunch, nyCloseStart, nyCloseEnd, inNYClose]

// Create a new killzone box
createKillzoneBox(array<KillzoneBox> kzArray, string sessionName, color kzColor) =>
    if array.size(kzArray) >= kzMaxBoxes
        KillzoneBox oldest = array.shift(kzArray)
        if not na(oldest.kzBox)
            box.delete(oldest.kzBox)
        if not na(oldest.kzLabel)
            label.delete(oldest.kzLabel)
    KillzoneBox newKZ = KillzoneBox.new()
    newKZ.sessionName := sessionName
    newKZ.sessionStartTime := time
    newKZ.sessionEndTime := na
    newKZ.sessionHigh := high
    newKZ.sessionLow := low
    newKZ.isComplete := false
    color bgColor = killzoneDisplayMode == 'Border Only' ? na : kzColor
    color borderColor = killzoneDisplayMode == 'Background' ? na : color.new(kzColor, 50)
    newKZ.kzBox := box.new(time, high, time, low, border_color = borderColor, border_width = kzBorderWidth, bgcolor = bgColor, xloc = xloc.bar_time)
    if showKZLabels
        labelStyle = switch kzLabelPosition
            'Top Left' => label.style_label_lower_right
            'Top Right' => label.style_label_lower_left
            'Bottom Left' => label.style_label_upper_right
            'Bottom Right' => label.style_label_upper_left
            => label.style_label_lower_left
        float labelY = str.contains(kzLabelPosition, 'Top') ? high : low
        int labelX = str.contains(kzLabelPosition, 'Left') ? time : time
        newKZ.kzLabel := label.new(labelX, labelY, sessionName, xloc = xloc.bar_time, style = labelStyle, color = color.new(color.white, 100), textcolor = color.new(kzColor, 30), size = size.tiny)
    array.push(kzArray, newKZ)

// Update an active (incomplete) killzone box
updateKillzoneBox(KillzoneBox kz) =>
    if not kz.isComplete
        if high > kz.sessionHigh
            kz.sessionHigh := high
        if low < kz.sessionLow
            kz.sessionLow := low
        if not na(kz.kzBox)
            box.set_top(kz.kzBox, kz.sessionHigh)
            box.set_bottom(kz.kzBox, kz.sessionLow)
            box.set_right(kz.kzBox, time)
        if showKZLabels and not na(kz.kzLabel)
            float labelY = str.contains(kzLabelPosition, 'Top') ? kz.sessionHigh : kz.sessionLow
            int labelX = str.contains(kzLabelPosition, 'Right') ? time : kz.sessionStartTime
            label.set_xy(kz.kzLabel, labelX, labelY)

// Finalize a killzone box when session ends
completeKillzoneBox(KillzoneBox kz) =>
    kz.isComplete := true
    kz.sessionEndTime := time
    if not na(kz.kzBox)
        box.set_right(kz.kzBox, time)

// ========================================
// v2.0: OTE LEVEL FUNCTIONS
// ========================================
// Calculate OTE levels for an FVG
calculateOTELevel(float fvgBottom, float fvgTop, float level, bool isBullishFVG) =>
    float fvgRange = math.abs(fvgTop - fvgBottom)
    float price = na
    if isBullishFVG
        price := fvgBottom + (fvgRange * level)
    else
        price := fvgTop - (fvgRange * level)
    price

// Create OTE lines for a range
createOTELines(Range r, bool isBullishFVG) =>
    if showOTELevels and not r.isSpecial
        if na(r.oteLines)
            r.oteLines := array.new<line>()
        if na(r.oteLabels)
            r.oteLabels := array.new<label>()
        float fvgBottom = r.rangeHigh
        float fvgTop = r.rangeLow
        string lineStyle = switch oteLevelStyle
            'Solid' => line.style_solid
            'Dotted' => line.style_dotted
            'Dashed' => line.style_dashed
            => line.style_dotted
        int startTime = isBullishFVG ? r.highStartTime : r.lowStartTime
        array<float> levels = array.new<float>()
        array<string> levelNames = array.new<string>()
        if useCustomOTELevels
            array.push(levels, customOTELevel1)
            array.push(levelNames, str.tostring(customOTELevel1 * 100, '#.#') + '%')
            array.push(levels, customOTELevel2)
            array.push(levelNames, str.tostring(customOTELevel2 * 100, '#.#') + '%')
            array.push(levels, customOTELevel3)
            array.push(levelNames, str.tostring(customOTELevel3 * 100, '#.#') + '%')
        else
            if showOTE_0
                array.push(levels, 0.0)
                array.push(levelNames, '0%')
            if showOTE_50
                array.push(levels, 0.5)
                array.push(levelNames, '50%')
            if showOTE_618
                array.push(levels, 0.618)
                array.push(levelNames, '61.8%')
            if showOTE_705
                array.push(levels, 0.705)
                array.push(levelNames, '70.5%')
            if showOTE_79
                array.push(levels, 0.79)
                array.push(levelNames, '79%')
            if showOTE_100
                array.push(levels, 1.0)
                array.push(levelNames, '100%')
        color baseColor = isBullishFVG ? bullishFVGColor : bearishFVGColor
        color levelColor = color.new(baseColor, oteTransparency)
        for i = 0 to array.size(levels) - 1
            float level = array.get(levels, i)
            string levelName = array.get(levelNames, i)
            float price = calculateOTELevel(fvgBottom, fvgTop, level, isBullishFVG)
            bool isFullyMitigated = r.highMitigated and r.lowMitigated
            int endTime = isFullyMitigated ? math.max(nz(r.highMitigationTime, time), nz(r.lowMitigationTime, time)) : time
            line newLine = line.new(startTime, price, endTime, price, xloc = xloc.bar_time, color = levelColor, style = lineStyle, width = oteLevelWidth)
            array.push(r.oteLines, newLine)
            if oteShowLabels
                label newLabel = label.new(endTime, price, levelName, xloc = xloc.bar_time, style = label.style_label_left, color = color.new(color.white, 100), textcolor = levelColor, size = oteLabelSize)
                array.push(r.oteLabels, newLabel)
        if highlightOTEZone
            float oteZoneStart = calculateOTELevel(fvgBottom, fvgTop, 0.618, isBullishFVG)
            float oteZoneEnd = calculateOTELevel(fvgBottom, fvgTop, 0.79, isBullishFVG)
            int zoneEndTime = (r.highMitigated and r.lowMitigated) ? math.max(nz(r.highMitigationTime, time), nz(r.lowMitigationTime, time)) : time
            r.oteZoneBox := box.new(startTime, math.max(oteZoneStart, oteZoneEnd), zoneEndTime, math.min(oteZoneStart, oteZoneEnd), border_color = na, bgcolor = oteZoneColor, xloc = xloc.bar_time)

// Update OTE lines for a range (called each bar)
updateOTELines(Range r, bool isBullishFVG) =>
    if showOTELevels and not r.isSpecial and array.size(r.oteLines) > 0
        bool isFullyMitigated = r.highMitigated and r.lowMitigated
        int endTime = isFullyMitigated ? math.max(nz(r.highMitigationTime, time), nz(r.lowMitigationTime, time)) : time
        for i = 0 to array.size(r.oteLines) - 1
            line l = array.get(r.oteLines, i)
            line.set_x2(l, endTime)
        if oteShowLabels and array.size(r.oteLabels) > 0
            for i = 0 to array.size(r.oteLabels) - 1
                label lbl = array.get(r.oteLabels, i)
                label.set_x(lbl, endTime)
        if highlightOTEZone and not na(r.oteZoneBox)
            box.set_right(r.oteZoneBox, endTime)

// Clean up OTE lines when range is deleted
cleanupOTELines(Range r) =>
    if array.size(r.oteLines) > 0
        for i = array.size(r.oteLines) - 1 to 0
            line.delete(array.get(r.oteLines, i))
        array.clear(r.oteLines)
    if array.size(r.oteLabels) > 0
        for i = array.size(r.oteLabels) - 1 to 0
            label.delete(array.get(r.oteLabels, i))
        array.clear(r.oteLabels)
    if not na(r.oteZoneBox)
        box.delete(r.oteZoneBox)
        r.oteZoneBox := na

// ========================================
// v2.0: TIME DECAY FUNCTIONS
// ========================================
// Calculate elapsed time units since FVG creation
getElapsedTimeUnits(Range r) =>
    float elapsed = 0.0
    switch decayTimeUnit
        'HTF Candles' =>
            elapsed := htfCandleCount - r.htfCandleAtCreation
        'Chart Bars' =>
            elapsed := bar_index - r.creationBar
        'Hours' =>
            elapsed := (time - r.highStartTime) / (1000 * 60 * 60)
        'Days' =>
            elapsed := (time - r.highStartTime) / (1000 * 60 * 60 * 24)
    elapsed

// Calculate current decay level (0.0 to 1.0)
calculateDecayLevel(Range r) =>
    if not enableTimeDecay
        0.0
    else
        float elapsed = getElapsedTimeUnits(r)
        bool decayPaused = false
        if pauseDecayOnRetest and not na(r.lastRetestBar)
            elapsed := bar_index - r.lastRetestBar
        if pauseDecayInSession and enableSessionFilter and isInSession()
            decayPaused := true
        if decayPaused
            r.currentDecayLevel
        else
            float decayLevel = 0.0
            if elapsed < fadeStartTime
                decayLevel := 0.0
            else if elapsed >= invalidateTime and invalidateTime > 0
                decayLevel := 1.0
            else if elapsed >= fullFadeTime
                decayLevel := 0.99
            else
                decayLevel := (elapsed - fadeStartTime) / (fullFadeTime - fadeStartTime)
            decayLevel

// Apply decay transparency to FVG elements
applyDecayTransparency(Range r, float decayLevel) =>
    int baseTransparency = 85
    int targetTransparency = maxFadeTransparency
    int currentTransparency = int(baseTransparency + (targetTransparency - baseTransparency) * decayLevel)
    if array.size(r.fvgBoxes) > 0
        bool isBullishFVG = r.canCreateSignalFromLow
        color baseColor = isBullishFVG ? bullishFVGColor : bearishFVGColor
        color fadedColor = color.new(baseColor, currentTransparency)
        for i = 0 to array.size(r.fvgBoxes) - 1
            box b = array.get(r.fvgBoxes, i)
            box.set_bgcolor(b, fadedColor)
    if showOTELevels and array.size(r.oteLines) > 0
        color baseColor = r.canCreateSignalFromLow ? bullishFVGColor : bearishFVGColor
        color fadedColor = color.new(baseColor, int(oteTransparency + (100 - oteTransparency) * decayLevel))
        for i = 0 to array.size(r.oteLines) - 1
            line l = array.get(r.oteLines, i)
            line.set_color(l, fadedColor)

// Helper function to check if SMT should be created (based on smtOnlyInFVG filter)
shouldCreateSMT(string smtType, float prevChartHigh, float currChartHigh, float prevChartLow, float currChartLow) =>
    if not smtOnlyInFVG
        true  // No filter, create all SMTs
    else
        // Only create if within pending signal FVG range
        bool shouldCreate = false
        // For bearish SMT, check against pending bearish signal FVG
        if smtType == "BEARISH" and not na(pendingBearish) and not na(pendingBearish.fvgRangeHigh) and not na(pendingBearish.fvgRangeLow)
            // More lenient check: any of the highs is greater than FVG bottom (rangeHigh)
            bool prevHighAboveBottom = not na(prevChartHigh) and prevChartHigh > pendingBearish.fvgRangeHigh
            bool currHighAboveBottom = not na(currChartHigh) and currChartHigh > pendingBearish.fvgRangeHigh
            shouldCreate := prevHighAboveBottom or currHighAboveBottom
        // For bullish SMT, check against pending bullish signal FVG
        else if smtType == "BULLISH" and not na(pendingBullish) and not na(pendingBullish.fvgRangeHigh) and not na(pendingBullish.fvgRangeLow)
            // More lenient check: any of the lows is less than FVG top (rangeLow)
            bool prevLowBelowTop = not na(prevChartLow) and prevChartLow < pendingBullish.fvgRangeLow
            bool currLowBelowTop = not na(currChartLow) and currChartLow < pendingBullish.fvgRangeLow
            shouldCreate := prevLowBelowTop or currLowBelowTop
        shouldCreate


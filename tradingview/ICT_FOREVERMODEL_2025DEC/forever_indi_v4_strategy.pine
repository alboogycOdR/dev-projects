// Clear previous drawings
while array.size(rangeLines) > 0
    line.delete(array.pop(rangeLines))

// Clean up old confirmation lines (keep only last 50 by confirmation time)
// Only run cleanup on confirmed bars to avoid replay vs live discrepancies
if barstate.isconfirmed and array.size(confirmationLines) > maxRangesToDisplay
    // Find the 50th oldest confirmation time (threshold)
    array<int> confirmationTimes = array.new<int>()
    for i = 0 to array.size(confirmationLines) - 1
        conf = array.get(confirmationLines, i)
        array.push(confirmationTimes, conf.confirmationTime)
    array.sort(confirmationTimes, order = order.ascending)
    int thresholdTime = array.get(confirmationTimes, array.size(confirmationLines) - maxRangesToDisplay)
    
    // Remove all lines with confirmation time less than threshold
    for i = array.size(confirmationLines) - 1 to 0
        conf = array.get(confirmationLines, i)
        if conf.confirmationTime < thresholdTime
            line.delete(conf.confLine)
            label.delete(conf.confLabel)
            array.remove(confirmationLines, i)


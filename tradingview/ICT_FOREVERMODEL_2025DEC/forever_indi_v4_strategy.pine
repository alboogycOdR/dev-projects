// Get HTF Period function - around 15-16x multiples (except fixed ones)
getHTFPeriod() =>
    switch timeframe.period
        '1'   => '15'      // 1m → 15m (15x) - fixed
        '3'   => '30'      // 3m → 30m (10x) - fixed
        '5'   => '60'      // 5m → 1h (12x) - fixed
        '10'  => '150'     // 10m → 150m (15x) = 2.5h
        '15'  => '240'     // 15m → 4h (16x) - fixed
        '30'  => '1D'      // 30m → 1D (48x) - fixed
        '45'  => '720'     // 45m → 12h (16x)
        '60'  => '1D'      // 1h → 1D (24x) - fixed, same as 30m
        '120' => '2D'      // 2h → 2D (24x) - closest standard timeframe (30h not available)
        '240' => '1W'      // 4h → 1W (42x) - fixed
        '360' => '4D'      // 6h → 4D (16x)
        '720' => '1W'      // 12h → 1W (14x) - closest to 1W
        '1D'  => '15D'      // 1D → 15D (15x)
        '3D'  => '45D'      // 3D → 45D (15x)
        '1W'  => '15W'      // 1W → 15W (15x)
        '1M'  => '15M'      // 1M → 15M (15x)
        '3M'  => '45M'      // 3M → 45M (15x)
        => '1D'            // Default

// Helper function to format timeframe name
formatTimeframe(string tf) =>
    seconds = timeframe.in_seconds(tf)
    if seconds < 60
        str.tostring(seconds) + "S"
    else if (seconds / 60) < 60
        str.tostring((seconds/60)) + "M"
    else if (seconds/60/60) < 24
        str.tostring((seconds/60/60)) + "H"
    else if (seconds/60/60/24) < 7
        str.tostring((seconds/60/60/24)) + "D"
    else if (seconds/60/60/24/7) < 4
        str.tostring((seconds/60/60/24/7)) + "W"
    else if (seconds/60/60/24/30) < 12
        str.tostring((seconds/60/60/24/30)) + "M"
    else
        str.tostring((seconds/60/60/24/365)) + "Y"

// Helper function to get current timeframe string
getCurrentTimeframe() =>
    current_seconds = timeframe.in_seconds()
    if current_seconds < 60
        str.tostring(current_seconds) + "S"
    else if (current_seconds / 60) < 60
        str.tostring((current_seconds/60)) + "M"
    else if (current_seconds/60/60) < 24
        str.tostring((current_seconds/60/60)) + "H"
    else if (current_seconds/60/60/24) < 7
        str.tostring((current_seconds/60/60/24)) + "D"
    else if (current_seconds/60/60/24/7) < 4
        str.tostring((current_seconds/60/60/24/7)) + "W"
    else if (current_seconds/60/60/24/30) < 12
        str.tostring((current_seconds/60/60/24/30)) + "M"
    else
        str.tostring((current_seconds/60/60/24/365)) + "Y"

// Helper function to get remaining time until next HTF candle
getRemainingTime(string htf) =>
    if barstate.isrealtime
        timeRemaining = (time_close(htf) - timenow)/1000
        days = math.floor(timeRemaining / 86400)
        hours = math.floor((timeRemaining - (days*86400)) / 3600)
        minutes = math.floor((timeRemaining - (days*86400) - (hours*3600))/ 60)
        seconds = math.floor(timeRemaining - (days*86400) - (hours*3600) - (minutes*60))
        
        r = str.tostring(seconds, "00")
        if minutes > 0 or hours > 0 or days > 0
            r := str.tostring(minutes, "00") + ":" + r
        if hours > 0 or days > 0
            r := str.tostring(hours, "00") + ":" + r
        if days > 0
            r := str.tostring(days) + "D " + r
        r
    else
        "n/a"

// Helper function to get table position
getTablePosition(string position) =>
    switch position
        'Top Left' => position.top_left
        'Top Center' => position.top_center
        'Top Right' => position.top_right
        'Middle Left' => position.middle_left
        'Middle Center' => position.middle_center
        'Middle Right' => position.middle_right
        'Bottom Left' => position.bottom_left
        'Bottom Center' => position.bottom_center
        'Bottom Right' => position.bottom_right
        => position.top_right

// Get contract size for common futures
getContractSize() =>
    if usingProp
        ticker = syminfo.ticker
        if syminfo.type == "forex" or str.contains(ticker,"6")
            100000.0

[oi_d1a, oi_c1a, oi_o1a, oi_h1a, oi_l1a] = request.security('BINANCE' + ':' + oi_base_alt + 'USDT.P_OI', timeframe.period, [close - close[1], close, open, high, low], ignore_invalid_symbol = true)
[oi_d2, oi_c2, oi_o2, oi_h2, oi_l2] = request.security('BINANCE' + ':' + oi_base + 'USD.P_OI', timeframe.period, [close - close[1], close, open, high, low], ignore_invalid_symbol = true)
[oi_d2a, oi_c2a, oi_o2a, oi_h2a, oi_l2a] = request.security('BINANCE' + ':' + oi_base_alt + 'USD.P_OI', timeframe.period, [close - close[1], close, open, high, low], ignore_invalid_symbol = true)
[oi_d3, oi_c3, oi_o3, oi_h3, oi_l3] = request.security('BINANCE' + ':' + oi_base + 'BUSD.P_OI', timeframe.period, [close - close[1], close, open, high, low], ignore_invalid_symbol = true)
[oi_d3a, oi_c3a, oi_o3a, oi_h3a, oi_l3a] = request.security('BINANCE' + ':' + oi_base_alt + 'BUSD.P_OI', timeframe.period, [close - close[1], close, open, high, low], ignore_invalid_symbol = true)

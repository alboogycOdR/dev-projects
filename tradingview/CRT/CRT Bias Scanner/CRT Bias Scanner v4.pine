var string G_PERFORMANCE = "⚡ Performance & Alerts"
i_scan_freq = input.int(5, "↻ Scan Frequency", minval=1, maxval=60, step=1, group=G_PERFORMANCE, 
     tooltip="Minutes between scans. Lower = more frequent updates but higher resource usage")
i_enable_scan = input.bool(true, "🟢 Scanner Active", group=G_PERFORMANCE)
i_enable_alerts = input.bool(false, "🔔 Enable Alerts", group=G_PERFORMANCE, 
     tooltip="Get alerts when assets show strong bias signals")
i_alert_bull_only = input.bool(false, "↗ Bull Signals Only", group=G_PERFORMANCE)
i_alert_bear_only = input.bool(false, "↘ Bear Signals Only", group=G_PERFORMANCE)
i_show_stats = input.bool(true, "📊 Show Statistics", group=G_PERFORMANCE)

// ═══════════════════════════════════════════════════════════════════════════
// ║                          SYMBOL CONFIGURATION                            ║
// ═══════════════════════════════════════════════════════════════════════════

var string G_SYMBOLS = "💱 Symbol Configuration"
symbol_group = input.string("Forex Majors", "Preset Groups", 
     options=["Forex Majors", "Indices", "Crypto", "Commodities", "Custom"], 
     group=G_SYMBOLS, tooltip="Quick symbol presets or choose Custom")

// Default symbol inputs
sym1  = input.symbol("OANDA:EURUSD", "Slot 1", group=G_SYMBOLS)
sym2  = input.symbol("OANDA:GBPUSD", "Slot 2", group=G_SYMBOLS)
sym3  = input.symbol("OANDA:USDJPY", "Slot 3", group=G_SYMBOLS)
sym4  = input.symbol("OANDA:USDCAD", "Slot 4", group=G_SYMBOLS)
sym5  = input.symbol("OANDA:AUDUSD", "Slot 5", group=G_SYMBOLS)
sym6  = input.symbol("OANDA:NZDUSD", "Slot 6", group=G_SYMBOLS)
sym7  = input.symbol("OANDA:USDCHF", "Slot 7", group=G_SYMBOLS)
sym8  = input.symbol("OANDA:EURJPY", "Slot 8", group=G_SYMBOLS)
sym9  = input.symbol("OANDA:GBPJPY", "Slot 9", group=G_SYMBOLS)
sym10 = input.symbol("OANDA:XAUUSD", "Slot 10", group=G_SYMBOLS)
sym11 = input.symbol("OANDA:XAGUSD", "Slot 11", group=G_SYMBOLS)
sym12 = input.symbol("OANDA:NAS100USD", "Slot 12", group=G_SYMBOLS)
sym13 = input.symbol("OANDA:US30USD", "Slot 13", group=G_SYMBOLS)
sym14 = input.symbol("OANDA:SPX500USD", "Slot 14", group=G_SYMBOLS)
sym15 = input.symbol("BITSTAMP:BTCUSD", "Slot 15", group=G_SYMBOLS)
sym16 = input.symbol("BITSTAMP:ETHUSD", "Slot 16", group=G_SYMBOLS)

// ═══════════════════════════════════════════════════════════════════════════
// ║                         VISUAL CUSTOMIZATION                             ║
// ═══════════════════════════════════════════════════════════════════════════

var string G_VISUAL = "🎨 Visual Settings"
i_theme = input.string("Dark Pro", "Color Theme", 
     options=["Dark Pro", "Light Pro", "Matrix", "Ocean", "Monochrome"], 
     group=G_VISUAL)
i_table_pos = input.string("Top Right", "Scanner Position", 
     options=["Top Right", "Top Left", "Middle Right", "Middle Left", "Bottom Right", "Bottom Left"], 
     group=G_VISUAL)
i_table_size = input.string("Normal", "Table Size", 
     options=["Compact", "Normal", "Large"], group=G_VISUAL)
i_show_header = input.bool(true, "Show Header", group=G_VISUAL)
i_show_legend = input.bool(true, "Show Legend", group=G_VISUAL)
i_compact_mode = input.bool(false, "Compact Mode", group=G_VISUAL, 
     tooltip="Removes asset names, shows only symbols")

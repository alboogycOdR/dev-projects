// ═══════════════════════════════════════════════════════════════════════════
// ║                          SESSION SETTINGS                                ║
// ═══════════════════════════════════════════════════════════════════════════

var string G_SESSIONS = "🕐 Trading Sessions"
show_sessions = input.bool(true, "Show Sessions on Chart", group=G_SESSIONS)
session1_active = input.bool(true, "🗽 New York", inline="s1", group=G_SESSIONS)
session1_time = input.session("1300-2200", "", inline="s1", group=G_SESSIONS)
session1_color = input.color(#ff5d00, "", inline="s1", group=G_SESSIONS)

session2_active = input.bool(true, "🏰 London", inline="s2", group=G_SESSIONS)
session2_time = input.session("0700-1600", "", inline="s2", group=G_SESSIONS)
session2_color = input.color(#2157f3, "", inline="s2", group=G_SESSIONS)

session3_active = input.bool(true, "🗾 Tokyo", inline="s3", group=G_SESSIONS)
session3_time = input.session("0000-0900", "", inline="s3", group=G_SESSIONS)
session3_color = input.color(#e91e63, "", inline="s3", group=G_SESSIONS)

session4_active = input.bool(true, "🏖 Sydney", inline="s4", group=G_SESSIONS)
session4_time = input.session("2100-0600", "", inline="s4", group=G_SESSIONS)
session4_color = input.color(#ffeb3b, "", inline="s4", group=G_SESSIONS)

session_transparency = input.int(92, "Session Box Transparency", minval=0, maxval=100, group=G_SESSIONS)

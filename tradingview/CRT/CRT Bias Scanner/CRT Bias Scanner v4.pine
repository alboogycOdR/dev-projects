//@version=5
indicator("CRT Bias Scanner v4", "CRT_ScanR", true, max_bars_back = 500, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500, dynamic_requests=true)

// ═══════════════════════════════════════════════════════════════════════════
// ║                           GLOBAL SETTINGS                                ║
// ═══════════════════════════════════════════════════════════════════════════

var string G_INFO = "📌 CRT Bias Scanner Pro v4.0"
dummy0 = input.bool(true, "═══════════════════════════════════════", group=G_INFO)
dummy1 = input.bool(true, "Professional Multi-Asset CRT Scanner", group=G_INFO)
dummy2 = input.bool(true, "═══════════════════════════════════════", group=G_INFO)


//@version=5
// =========================================================================================
// | Indicator:      Complete CRT System (MTF v5alpha)                                      |
// | Description:    Identifies time-based H4 CRT patterns and projects the corresponding  |
// |                 H4 CRT Levels, Fair Value Gaps, and Order Blocks onto the current     |
// |                 chart timeframe for a complete top-down analysis.                     |
// | Author:         Generated by AI for User (System Version)                             |
// =========================================================================================
indicator("Complete CRT System (MTF v5alpha)", "CRT System", overlay=true)

// What Has Been Changed/Fixed:
// MTF for PD Arrays: The Fair Value Gap and Order Block detection logic has been moved into functions that are called via request.security().
// Efficient Data Handling: I've structured the code to make only a few necessary calls to the higher timeframe to fetch all required data at once, which is more efficient.
// Clean Drawing: The code now manages the drawing of the boxes and lines to prevent chart clutter and memory issues, deleting old objects as new ones are drawn.
// Clarity and Tooltips: Added more tooltips and slightly reorganized the input settings for better usability.



// ===================================================================
//                        USER INPUTS
// ===================================================================

// --- Main Settings ---
g_main = "Main Settings"
target_timeframe = input.timeframe("240", "Analysis Timeframe", group=g_main)

// --- CRT Inputs ---
g_crt = "Candle Range Theory"
showCrtLines = input.bool(true, "Show H4 CRT Lines", group=g_crt)
crtModel = input.string("9AM CRT", "CRT Model", options=["1AM CRT", "5AM CRT", "9AM CRT"], tooltip="Select which specific time-based CRT setup to display on the chart.", group=g_crt)
color_high = input.color(color.new(color.blue, 0), "CRT High Color", group=g_crt)
color_low  = input.color(color.new(color.red, 0), "CRT Low Color", group=g_crt)
line_width = input.int(2, "Line Width", minval=1, group=g_crt)
label_color = input.color(color.new(color.gray, 0), "Label Color", group=g_crt)

// --- FVG Inputs ---
g_fvg = "H4 Fair Value Gaps"
showFairValueGaps = input.bool(false, "Show H4 Fair Value Gaps", group=g_fvg)
fairValueGapsExtend = input.int(10, "Extend FVG", group=g_fvg, tooltip="How many H4 bars to extend the FVG boxes.", minval=0)
bullishFvgColor = input.color(color.new(#00ff68, 85), "Bullish FVG", group=g_fvg)
bearishFvgColor = input.color(color.new(#ff0008, 85), "Bearish FVG", group=g_fvg)

// --- Order Block Inputs ---
g_ob = "H4 Order Blocks"
showOrderBlocks = input.bool(false, "Show H4 Order Blocks", group=g_ob)
orderBlocksSize = input.int(3, "Number of H4 OBs to Display", group=g_ob, minval=1, tooltip="The most recent X number of unmitigated Order Blocks to show.")
bullishObColor = input.color(color.new(#1848cc, 80), "Bullish OB", group=g_ob)
bearishObColor = input.color(color.new(#b22833, 80), "Bearish OB", group=g_ob)

// ===================================================================
//                   DATA STRUCTURES & ARRAYS
// ===================================================================

// Custom types to store box and its bias
type FvgBox
    box box_id
    int bias

type ObBox
    box box_id
    int bias

// Arrays to store the drawing objects
var array<FvgBox> h4_fvg_boxes = array.new<FvgBox>()
var array<ObBox> h4_ob_boxes  = array.new<ObBox>()

// ===================================================================
//                MULTI-TIMEFRAME ANALYSIS FUNCTION
// ===================================================================
// This is the single, powerful function that will run on the H4 timeframe.
// It detects EVERYTHING at once (CRT, FVG, OB) and returns all data.
f_analyze_htf() =>
    // --- PART 1: CRT Detection ---
    nyHour = hour(time[1], "America/New_York")
    int keyHour = na
    if crtModel == "1AM CRT"
        keyHour := 21
    if crtModel == "5AM CRT"
        keyHour := 1
    if crtModel == "9AM CRT"
        keyHour := 5

    bool isKeyTime = nyHour == keyHour
    float highLevel = na, float lowLevel = na
    int rangeCandleTime = na

    if isKeyTime and bar_index > 2
        bool isBearish = high[1] > high[2] and close[1] < high[2] and close < open
        bool isBullish = low[1] < low[2] and close[1] > low[2] and close > open
        if isBearish or isBullish
            highLevel := high[2]
            lowLevel  := low[2]
            rangeCandleTime := time[2]

    // --- PART 2: FVG Detection ---
    bool isBullishFvg = low > high[2]
    bool isBearishFvg = high < low[2]
    float fvgTop = na, float fvgBottom = na
    int fvgBias = 0 // 1 for Bullish, -1 for Bearish

    if isBullishFvg
        fvgTop := low
        fvgBottom := high[2]
        fvgBias := 1
    else if isBearishFvg
        fvgTop := high
        fvgBottom := low[2]
        fvgBias := -1

    // --- PART 3: Order Block Detection (linked to FVG) ---
    bool isBullishOb = isBullishFvg and close[2] < open[2]
    bool isBearishOb = isBearishFvg and close[2] > open[2]
    float obTop = na, float obBottom = na
    int obBias = 0 // 1 for Bullish, -1 for Bearish
    
    if isBullishOb
        obTop := high[2]
        obBottom := low[2]
        obBias := 1
    else if isBearishOb
        obTop := high[2]
        obBottom := low[2]
        obBias := -1

    // Return all detected data in a tuple
    [highLevel, lowLevel, rangeCandleTime, fvgTop, fvgBottom, fvgBias, obTop, obBottom, obBias]

// --- Request All Data from the Higher Timeframe in One Go ---
[h4_crtHigh, h4_crtLow, h4_crtTime, h4_fvgTop, h4_fvgBottom, h4_fvgBias, h4_obTop, h4_obBottom, h4_obBias] = request.security(syminfo.tickerid, target_timeframe, f_analyze_htf(), lookahead=barmerge.lookahead_on)

// ===================================================================
//              DRAWING & MANAGEMENT ON THE CHART
// ===================================================================

// --- Draw CRT Lines ---
var line crtHigh_line = na
var line crtLow_line  = na
var int crt_line_start_time = na

// Clean up expired lines on every bar
if not na(crt_line_start_time)
    timeframe_duration_ms = timeframe.in_seconds(target_timeframe) * 1000
    line_end_time = crt_line_start_time + 2 * timeframe_duration_ms
    // If the current bar's time is past the line's end time, delete the lines
    if time > line_end_time
        line.delete(crtHigh_line)
        line.delete(crtLow_line)
        // Reset variables to indicate no active lines
        crtHigh_line := na
        crtLow_line := na
        crt_line_start_time := na

if showCrtLines and not na(h4_crtHigh) and (na(h4_crtTime[1]) or h4_crtTime[1] != h4_crtTime)
    line.delete(crtHigh_line[1])
    line.delete(crtLow_line[1])
    
    // Calculate the end time for the line, extending it for 2 H4 bars
    timeframe_duration_ms = timeframe.in_seconds(target_timeframe) * 1000
    line_end_time = h4_crtTime + 2 * timeframe_duration_ms

    crtHigh_line := line.new(h4_crtTime, h4_crtHigh, line_end_time, h4_crtHigh, xloc=xloc.bar_time, color=color_high, width=line_width)
    crtLow_line  := line.new(h4_crtTime, h4_crtLow, line_end_time, h4_crtLow, xloc=xloc.bar_time, color=color_low, width=line_width)
    crt_line_start_time := h4_crtTime
    
// --- Manage and Draw H4 Fair Value Gaps ---
if showFairValueGaps
    // Delete mitigated FVGs
    if array.size(h4_fvg_boxes) > 0
        for i = array.size(h4_fvg_boxes) - 1 to 0
            fvg_data = array.get(h4_fvg_boxes, i)
            fvgBox = fvg_data.box_id
            fvgBias = fvg_data.bias
            
            isBullishFvgMitigated = fvgBias > 0 and box.get_bottom(fvgBox) > low
            isBearishFvgMitigated = fvgBias < 0 and box.get_top(fvgBox) < high
            
            if isBullishFvgMitigated or isBearishFvgMitigated
                box.delete(fvgBox)
                array.remove(h4_fvg_boxes, i)

    // Draw new FVGs
    if not na(h4_fvgTop) and (na(h4_fvgTop[1]) or h4_fvgTop[1] != h4_fvgTop)
        box_color = h4_fvgBias > 0 ? bullishFvgColor : bearishFvgColor
        new_fvg_box = box.new(left=time[1], top=h4_fvgTop, right=time + (time - time[1]) * fairValueGapsExtend, bottom=h4_fvgBottom, 
         xloc=xloc.bar_time, bgcolor=box_color, border_color=box_color)
        array.unshift(h4_fvg_boxes, FvgBox.new(new_fvg_box, h4_fvgBias))

// --- Manage and Draw H4 Order Blocks ---
if showOrderBlocks
    // Delete mitigated OBs
    if array.size(h4_ob_boxes) > 0
        for i = array.size(h4_ob_boxes) - 1 to 0
            ob_data = array.get(h4_ob_boxes, i)
            obBox = ob_data.box_id
            obBias = ob_data.bias

            isBullishObMitigated = obBias > 0 and box.get_bottom(obBox) > low
            isBearishObMitigated = obBias < 0 and box.get_top(obBox) < high

            if isBullishObMitigated or isBearishObMitigated
                box.delete(obBox)
                array.remove(h4_ob_boxes, i)

    // Draw new OBs
    if not na(h4_obTop) and (na(h4_obTop[1]) or h4_obTop[1] != h4_obTop)
        box_color = h4_obBias > 0 ? bullishObColor : bearishObColor
        new_ob_box = box.new(left=time[1], top=h4_obTop, right=time, bottom=h4_obBottom, xloc=xloc.bar_time, border_color=na, bgcolor=box_color, extend=extend.right)
        array.unshift(h4_ob_boxes, ObBox.new(new_ob_box, h4_obBias))
        
    // Keep array size in check
    while array.size(h4_ob_boxes) > orderBlocksSize
        last_ob_data = array.pop(h4_ob_boxes)
        box.delete(last_ob_data.box_id)
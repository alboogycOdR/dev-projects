//@version=5
// Name: CRT Mapper with Turtle Soup Entry System v3.0
// This module adds Turtle Soup pattern detection for precise entries after CRT range establishment
indicator("3-Candle Time Pattern - Pro v3.0 Turtle Soup", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=100)

// ═══════════════════════════════════════════════════════════════════════
// ADVANCED TURTLE SOUP FEATURES
// ═══════════════════════════════════════════════════════════════════════

// Time-based Turtle Soup filtering
timeFilterGroup = "⏰ Turtle Time Filter"
useTimeFilter = input.bool(true, "Use Time Filter", group=timeFilterGroup)
londonStart = input.int(8, "London Start Hour (UTC)", minval=0, maxval=23, group=timeFilterGroup)
londonEnd = input.int(16, "London End Hour (UTC)", minval=0, maxval=23, group=timeFilterGroup)
nyStart = input.int(13, "NY Start Hour (UTC)", minval=0, maxval=23, group=timeFilterGroup)
nyEnd = input.int(21, "NY End Hour (UTC)", minval=0, maxval=23, group=timeFilterGroup)
avoidNewsTime = input.bool(true, "Avoid 30min Before/After News", group=timeFilterGroup)

// Check if current time is optimal for Turtle Soup
isOptimalTime() =>
    if not useTimeFilter
        true
    else
        currentHour = hour(time, "UTC")
        inLondon = currentHour >= londonStart and currentHour <= londonEnd
        inNY = currentHour >= nyStart and currentHour <= nyEnd
        inLondon or inNY

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP VARIATIONS
// ═══════════════════════════════════════════════════════════════════════

// Detect Inverse Turtle Soup (continuation pattern)
detectInverseTurtle() =>
    if not enableTurtleSoup or not crtRangeActive
        false
    
    // Inverse Turtle: Price breaks and continues instead of reversing
    // Used as a filter to avoid false Turtle Soup signals
    [bullishBreak, bearishBreak, prevLow, prevHigh, _] = checkBreakout(turtleLookback)
    
    // Check if price continues after break (inverse of Turtle Soup)
    if bullishBreak and close < prevLow - atr * 0.5
        // Continuation down - NOT a Turtle Soup
        label.new(bar_index, high, "⚠️ INVERSE", color=color.orange, 
                 textcolor=color.white, style=label.style_label_down, size=size.tiny)
        false
    else if bearishBreak and close > prevHigh + atr * 0.5
        // Continuation up - NOT a Turtle Soup
        label.new(bar_index, low, "⚠️ INVERSE", color=color.orange, 
                 textcolor=color.white, style=label.style_label_up, size=size.tiny)
        false
    else
        true  // Not an inverse pattern, safe to proceed

// Detect Double Turtle Soup (two failed breaks in same direction)
detectDoubleTurtle() =>
    if not enableTurtleSoup or not crtRangeActive or array.size(historicalTurtles) < 1
        false
    
    // Check if previous Turtle Soup was recent and in same direction
    if array.size(historicalTurtles) > 0
        lastTurtle = array.get(historicalTurtles, array.size(historicalTurtles) - 1)
        barsAgo = bar_index - lastTurtle.startBar
        
        if barsAgo < 20  // Recent pattern
            [bullishSetup, bearishSetup, _, _, _] = checkBreakout(turtleLookback)
            
            // Same direction as previous = Double Turtle (stronger signal)
            if (bullishSetup and lastTurtle.isBullish) or (bearishSetup and not lastTurtle.isBullish)
                turtle = TurtleSoup.new()
                turtle.patternType := "DOUBLE"
                turtle.confluenceScore := 5.0  // Maximum confluence for double pattern
                // ... rest of turtle setup with enhanced targets
                true
            else
                false
        else
            false
    else
        false

// ═══════════════════════════════════════════════════════════════════════
// ENHANCED ENTRY OPTIMIZATION
// ═══════════════════════════════════════════════════════════════════════

// Calculate optimal entry using market profile concepts
calculateOptimalEntry(turtle) =>
    if na(turtle)
        na
    else
        // Find the Point of Control (POC) within the fake break range
        priceRange = turtle.isBullish ? 
                    turtle.breakLevel - turtle.fakeBreakExtreme : 
                    turtle.fakeBreakExtreme - turtle.breakLevel
        
        // Divide range into levels and find highest volume level
        levels = 10
        stepSize = priceRange / levels
        maxVolLevel = turtle.breakLevel
        maxVol = 0.0
        
        for i = 0 to levels - 1
            levelPrice = turtle.isBullish ? 
                        turtle.fakeBreakExtreme + (stepSize * i) : 
                        turtle.breakLevel + (stepSize * i)
            
            // Count volume at this level in recent bars
            volAtLevel = 0.0
            for j = 1 to 20
                if high[j] >= levelPrice and low[j] <= levelPrice
                    volAtLevel += volume[j]
            
            if volAtLevel > maxVol
                maxVol := volAtLevel
                maxVolLevel := levelPrice
        
        // Optimal entry is near the POC
        optimalEntry = turtle.isBullish ? 
                      math.max(maxVolLevel, turtle.breakLevel + atr * 0.05) :
                      math.min(maxVolLevel, turtle.breakLevel - atr * 0.05)
        
        optimalEntry

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP SCANNING & RANKING
// ═══════════════════════════════════════════════════════════════════════

// Scan multiple timeframes for Turtle setups
type TurtleScan
    string timeframe
    bool hasSetup
    float quality
    string direction

scanTimeframes() =>
    scans = array.new<TurtleScan>()
    
    // Scan 5m
    [setup5m, dir5m, quality5m] = request.security(syminfo.tickerid, "5", 
        [turtleSetupActive, currentTurtle.isBullish ? "BULL" : "BEAR", 
         not na(currentTurtle) ? currentTurtle.confluenceScore : 0])
    if setup5m
        scan5m = TurtleScan.new("5m", true, quality5m, dir5m)
        array.push(scans, scan5m)
    
    // Scan 15m
    [setup15m, dir15m, quality15m] = request.security(syminfo.tickerid, "15", 
        [turtleSetupActive, currentTurtle.isBullish ? "BULL" : "BEAR",
         not na(currentTurtle) ? currentTurtle.confluenceScore : 0])
    if setup15m
        scan15m = TurtleScan.new("15m", true, quality15m, dir15m)
        array.push(scans, scan15m)
    
    // Scan 30m
    [setup30m, dir30m, quality30m] = request.security(syminfo.tickerid, "30", 
        [turtleSetupActive, currentTurtle.isBullish ? "BULL" : "BEAR",
         not na(currentTurtle) ? currentTurtle.confluenceScore : 0])
    if setup30m
        scan30m = TurtleScan.new("30m", true, quality30m, dir30m)
        array.push(scans, scan30m)
    
    scans

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP HEAT MAP
// ═══════════════════════════════════════════════════════════════════════

// Create heat map of Turtle Soup zones
createTurtleHeatMap() =>
    if showTurtleBox and barstate.islast
        // Define heat zones based on historical patterns
        heatZones = array.new<float>()
        heatIntensity = array.new<int>()
        
        // Analyze historical patterns
        for i = 0 to math.min(array.size(historicalTurtles) - 1, 50)
            turtle = array.get(historicalTurtles, i)
            
            // Add break level to heat zones
            zoneExists = false
            for j = 0 to array.size(heatZones) - 1
                if math.abs(array.get(heatZones, j) - turtle.breakLevel) < atr * 0.1
                    array.set(heatIntensity, j, array.get(heatIntensity, j) + 1)
                    zoneExists := true
                    break
            
            if not zoneExists
                array.push(heatZones, turtle.breakLevel)
                array.push(heatIntensity, 1)
        
        // Draw heat map
        for i = 0 to math.min(array.size(heatZones) - 1, 10)
            level = array.get(heatZones, i)
            intensity = array.get(heatIntensity, i)
            
            // Color based on intensity
            heatColor = intensity >= 3 ? color.new(color.red, 70) :
                       intensity >= 2 ? color.new(color.orange, 80) :
                       color.new(color.yellow, 90)
            
            // Draw heat zone
            line.new(bar_index - 100, level, bar_index, level,
                    color=heatColor, style=line.style_solid, width=intensity)
            
            label.new(bar_index, level, "🔥 " + str.tostring(intensity),
                     color=color.new(color.black, 100), textcolor=heatColor,
                     style=label.style_label_left, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════
// AUTOMATED TRADE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

type TradeManager
    float entryPrice
    float currentStop
    float currentTarget
    bool isTrailing
    float trailOffset
    int entryBar
    float maxProfit
    float maxLoss

var TradeManager currentTrade = na

// Manage active Turtle Soup trade
manageTurtleTrade() =>
    if not na(currentTurtle) and currentTurtle.isConfirmed and currentTurtle.isActive
        // Initialize trade if not exists
        if na(currentTrade)
            currentTrade := TradeManager.new()
            currentTrade.entryPrice := currentTurtle.entryLevel
            currentTrade.currentStop := currentTurtle.stopLoss
            currentTrade.currentTarget := currentTurtle.target1
            currentTrade.isTrailing := false
            currentTrade.trailOffset := atr * 0.5
            currentTrade.entryBar := bar_index
            currentTrade.maxProfit := 0
            currentTrade.maxLoss := 0
        
        // Update max profit/loss
        if currentTurtle.isBullish
            profit = high - currentTrade.entryPrice
            loss = currentTrade.entryPrice - low
        else
            profit = currentTrade.entryPrice - low
            loss = high - currentTrade.entryPrice
        
        currentTrade.maxProfit := math.max(currentTrade.maxProfit, profit)
        currentTrade.maxLoss := math.max(currentTrade.maxLoss, loss)
        
        // Trailing stop logic
        if currentTrade.maxProfit > atr * 1.5
            currentTrade.isTrailing := true
            
            if currentTurtle.isBullish
                newStop = high - currentTrade.trailOffset
                currentTrade.currentStop := math.max(currentTrade.currentStop, newStop)
            else
                newStop = low + currentTrade.trailOffset
                currentTrade.currentStop := math.min(currentTrade.currentStop, newStop)
        
        // Move stop to breakeven at first target
        if currentTurtle.isBullish
            if high >= currentTurtle.target1
                currentTrade.currentStop := math.max(currentTrade.entryPrice, currentTrade.currentStop)
                currentTrade.currentTarget := currentTurtle.target2
        else
            if low <= currentTurtle.target1
                currentTrade.currentStop := math.min(currentTrade.entryPrice, currentTrade.currentStop)
                currentTrade.currentTarget := currentTurtle.target2
        
        // Draw current trade status
        if barstate.islast
            statusText = (currentTurtle.isBullish ? "🟢 LONG" : "🔴 SHORT") + "\n" +
                        "Entry: " + str.tostring(currentTrade.entryPrice, "#.##") + "\n" +
                        "Stop: " + str.tostring(currentTrade.currentStop, "#.##") + "\n" +
                        "Target: " + str.tostring(currentTrade.currentTarget, "#.##") + "\n" +
                        "P&L: " + str.tostring(currentTrade.maxProfit - currentTrade.maxLoss, "#.##") + "\n" +
                        (currentTrade.isTrailing ? "TRAILING ✓" : "FIXED")
            
            label.new(bar_index + 3, close, statusText,
                     color=currentTurtle.isBullish ? color.green : color.red,
                     textcolor=color.white, style=label.style_label_left, size=size.small)

// ═══════════════════════════════════════════════════════════════════════
// FINAL EXECUTION & PLOTTING
// ═══════════════════════════════════════════════════════════════════════

// Main execution flow
if crtRangeActive and isOptimalTime()
    // Check for inverse pattern first (filter)
    if detectInverseTurtle()
        // Check for double turtle (strongest signal)
        if detectDoubleTurtle()
            if not na(currentTurtle)
                currentTurtle.entryLevel := calculateOptimalEntry(currentTurtle)
                drawTurtleSoup(currentTurtle)
        else
            // Standard pattern detection
            plusDetected = detectTurtleSoupPlus()
            if not plusDetected
                classicDetected = detectClassicTurtleSoup()
                if classicDetected and not na(currentTurtle)
                    currentTurtle.entryLevel := calculateOptimalEntry(currentTurtle)
    
    // Confirm and manage
    if turtleSetupActive
        confirmed = confirmTurtleSoup()
        if confirmed
            drawTurtleSoup(currentTurtle)
            generateTurtleAlerts()
            manageTurtleTrade()

// Create heat map
createTurtleHeatMap()

// Manage active patterns and trades
manageActiveTurtles()
if not na(currentTrade)
    manageTurtleTrade()

// Display statistics
displayTurtleStats()

// Multi-timeframe scan display
if barstate.islast
    scans = scanTimeframes()
    if array.size(scans) > 0
        scanText = "🔍 MTF SCAN\n"
        for i = 0 to array.size(scans) - 1
            scan = array.get(scans, i)
            scanText += scan.timeframe + ": " + scan.direction + " (" + str.tostring(scan.quality, "#.#") + ")\n"
        
        label.new(bar_index - 50, high + atr * 2, scanText,
                 color=color.new(color.blue, 80), textcolor=color.white,
                 style=label.style_label_down, size=size.small)

// Plot key levels
plot(crtRangeActive ? rangeHigh : na, "CRT High", color=color.new(color.gray, 50), linewidth=2, style=plot.style_circles)
plot(crtRangeActive ? rangeLow : na, "CRT Low", color=color.new(color.gray, 50), linewidth=2, style=plot.style_circles)
plot(crtRangeActive ? rangeMid : na, "CRT Mid", color=color.new(color.gray, 70), linewidth=1, style=plot.style_cross)

// Background coloring for sessions
bgcolor(isOptimalTime() ? color.new(color.blue, 95) : na, title="Optimal Trading Time")

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP PATTERN DETECTION MODULE
// ═══════════════════════════════════════════════════════════════════════

// Turtle Soup Settings
turtleGroup = "🐢 Turtle Soup Configuration"
enableTurtleSoup = input.bool(true, "Enable Turtle Soup Detection", group=turtleGroup)
turtleLookback = input.int(20, "Lookback Period (bars)", minval=10, maxval=50, group=turtleGroup)
minBreakDistance = input.float(0.1, "Min Break Distance (ATR)", minval=0.05, maxval=0.5, step=0.05, group=turtleGroup)
maxBreakDistance = input.float(2.0, "Max Break Distance (ATR)", minval=0.5, maxval=5.0, step=0.5, group=turtleGroup)
turtleConfirmBars = input.int(3, "Confirmation Bars", minval=1, maxval=5, group=turtleGroup)
showTurtleLabels = input.bool(true, "Show Turtle Soup Labels", group=turtleGroup)
showTurtleBox = input.bool(true, "Show Turtle Soup Box", group=turtleGroup)

// Advanced Turtle Settings
advTurtleGroup = "🐢 Advanced Turtle Settings"
use15mDetection = input.bool(true, "Force 15m Detection", group=advTurtleGroup, tooltip="Always use 15m data for Turtle Soup regardless of chart timeframe")
requireVolumeSpike = input.bool(true, "Require Volume Spike", group=advTurtleGroup)
volumeSpikeMultiplier = input.float(1.3, "Volume Spike Multiplier", minval=1.1, maxval=3.0, group=advTurtleGroup)
requireMomentum = input.bool(true, "Require Momentum Shift", group=advTurtleGroup)
turtleRiskReward = input.float(3.0, "Turtle Soup R:R Target", minval=1.0, maxval=10.0, group=advTurtleGroup)

// Turtle Soup Color Scheme
turtleColorGroup = "🎨 Turtle Soup Colors"
bullishTurtleColor = input.color(color.new(#00E676, 80), "Bullish Turtle Soup", group=turtleColorGroup)
bearishTurtleColor = input.color(color.new(#FF1744, 80), "Bearish Turtle Soup", group=turtleColorGroup)
turtleBoxColor = input.color(color.new(#2196F3, 90), "Turtle Box", group=turtleColorGroup)
turtleFailColor = input.color(color.new(#FF9800, 80), "Failed Turtle", group=turtleColorGroup)

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════

type TurtleSoup
    float breakLevel        // The level that was broken (previous high/low)
    float fakeBreakExtreme  // The extreme of the fake breakout
    float entryLevel        // Optimal entry level
    float stopLoss          // Stop loss level
    float target1           // First target
    float target2           // Second target
    int startBar            // Bar where pattern started
    int confirmBar          // Bar where pattern confirmed
    bool isBullish          // Direction
    bool isConfirmed        // Confirmation status
    bool isActive           // Still active for entry
    float volumeRatio       // Volume at breakout vs average
    string patternType      // "CLASSIC", "PLUS", "FAILED"
    float confluenceScore   // Confluence with CRT

type TurtleStats
    int totalPatterns
    int successfulPatterns
    int failedPatterns
    float avgRR
    float winRate

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP VARIABLES
// ═══════════════════════════════════════════════════════════════════════

// Arrays to store Turtle Soup patterns
var array<TurtleSoup> activeTurtles = array.new<TurtleSoup>()
var array<TurtleSoup> historicalTurtles = array.new<TurtleSoup>()
var TurtleStats turtleStats = TurtleStats.new(0, 0, 0, 0, 0)

// Current pattern tracking
var TurtleSoup currentTurtle = na
var bool turtleSetupActive = false
var int turtleSetupBar = na

// Multi-timeframe variables for 15m detection
var float mtf15mHigh = na
var float mtf15mLow = na
var float mtf15mVolume = na
var bool mtf15mDataReady = false

// ═══════════════════════════════════════════════════════════════════════
// EXISTING CRT VARIABLES (from previous implementation)
// ═══════════════════════════════════════════════════════════════════════

// Add these to your existing CRT variables
var float rangeHigh = na
var float rangeLow = na
var float rangeMid = na
var int rangeStartBar = na
var bool crtRangeActive = false
var int crtBias = 0  // 1 = bullish, -1 = bearish

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP DETECTION FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════

// Get 15m data if enabled
get15mData() =>
    if use15mDetection and timeframe.period != "15"
        [h, l, v] = request.security(syminfo.tickerid, "15", [high, low, volume], lookahead=barmerge.lookahead_off)
        mtf15mHigh := h
        mtf15mLow := l
        mtf15mVolume := v
        mtf15mDataReady := true
    else
        mtf15mHigh := high
        mtf15mLow := low
        mtf15mVolume := volume
        mtf15mDataReady := true

// Calculate ATR for dynamic levels
atr = ta.atr(14)

// Function to find previous significant high/low
findPreviousExtreme(isHigh, lookback) =>
    extreme = isHigh ? ta.highest(high, lookback) : ta.lowest(low, lookback)
    extremeBar = isHigh ? ta.highestbars(high, lookback) : ta.lowestbars(low, lookback)
    [extreme, extremeBar]

// Check if price has broken a significant level
checkBreakout(lookback) =>
    [prevHigh, prevHighBar] = findPreviousExtreme(true, lookback)
    [prevLow, prevLowBar] = findPreviousExtreme(false, lookback)
    
    bullishBreak = low < prevLow and close > prevLow  // Failed breakdown
    bearishBreak = high > prevHigh and close < prevHigh  // Failed breakout
    
    breakDistance = 0.0
    if bullishBreak
        breakDistance := (prevLow - low) / atr
    else if bearishBreak
        breakDistance := (high - prevHigh) / atr
    
    // Check if break distance is within acceptable range
    validDistance = breakDistance >= minBreakDistance and breakDistance <= maxBreakDistance
    
    [bullishBreak and validDistance, bearishBreak and validDistance, prevLow, prevHigh, breakDistance]

// Check volume confirmation
checkVolumeConfirmation() =>
    avgVolume = ta.sma(volume, 20)
    volumeRatio = volume / avgVolume
    
    if requireVolumeSpike
        volumeRatio >= volumeSpikeMultiplier
    else
        true

// Check momentum shift (using RSI and MACD)
checkMomentumShift(isBullish) =>
    rsi = ta.rsi(close, 14)
    [macdLine, signalLine, _] = ta.macd(close, 12, 26, 9)
    
    if not requireMomentum
        true
    else if isBullish
        rsi < 70 and macdLine > macdLine[1]  // Not overbought and MACD turning up
    else
        rsi > 30 and macdLine < macdLine[1]  // Not oversold and MACD turning down

// Calculate Turtle Soup confluence with CRT
calculateTurtleConfluence(turtle, crtHigh, crtLow, crtMid, bias) =>
    score = 0.0
    
    // Check if Turtle Soup aligns with CRT bias
    if (turtle.isBullish and bias > 0) or (not turtle.isBullish and bias < 0)
        score += 2.0
    
    // Check if entry is near CRT levels
    if turtle.isBullish
        if math.abs(turtle.entryLevel - crtLow) < atr * 0.5
            score += 1.5  // Entry near CRT low support
        if turtle.entryLevel < crtMid
            score += 0.5  // Entry below midpoint
    else
        if math.abs(turtle.entryLevel - crtHigh) < atr * 0.5
            score += 1.5  // Entry near CRT high resistance
        if turtle.entryLevel > crtMid
            score += 0.5  // Entry above midpoint
    
    // Check if stop loss is beyond CRT range
    if turtle.isBullish
        if turtle.stopLoss < crtLow
            score += 1.0  // Stop protected by CRT low
    else
        if turtle.stopLoss > crtHigh
            score += 1.0  // Stop protected by CRT high
    
    score

// Detect Classic Turtle Soup pattern
detectClassicTurtleSoup() =>
    if not enableTurtleSoup or not crtRangeActive
        false
    
    [bullishSetup, bearishSetup, prevLow, prevHigh, breakDist] = checkBreakout(turtleLookback)
    
    if bullishSetup and checkVolumeConfirmation() and checkMomentumShift(true)
        // Bullish Turtle Soup (failed breakdown)
        turtle = TurtleSoup.new()
        turtle.breakLevel := prevLow
        turtle.fakeBreakExtreme := low
        turtle.entryLevel := prevLow + (atr * 0.1)  // Entry slightly above broken level
        turtle.stopLoss := low - (atr * 0.5)
        turtle.target1 := rangeMid  // CRT midpoint
        turtle.target2 := rangeHigh  // CRT high
        turtle.startBar := bar_index
        turtle.isBullish := true
        turtle.isConfirmed := false
        turtle.isActive := true
        turtle.volumeRatio := volume / ta.sma(volume, 20)
        turtle.patternType := "CLASSIC"
        turtle.confluenceScore := calculateTurtleConfluence(turtle, rangeHigh, rangeLow, rangeMid, crtBias)
        
        currentTurtle := turtle
        turtleSetupActive := true
        turtleSetupBar := bar_index
        true
        
    else if bearishSetup and checkVolumeConfirmation() and checkMomentumShift(false)
        // Bearish Turtle Soup (failed breakout)
        turtle = TurtleSoup.new()
        turtle.breakLevel := prevHigh
        turtle.fakeBreakExtreme := high
        turtle.entryLevel := prevHigh - (atr * 0.1)  // Entry slightly below broken level
        turtle.stopLoss := high + (atr * 0.5)
        turtle.target1 := rangeMid  // CRT midpoint
        turtle.target2 := rangeLow  // CRT low
        turtle.startBar := bar_index
        turtle.isBullish := false
        turtle.isConfirmed := false
        turtle.isActive := true
        turtle.volumeRatio := volume / ta.sma(volume, 20)
        turtle.patternType := "CLASSIC"
        turtle.confluenceScore := calculateTurtleConfluence(turtle, rangeHigh, rangeLow, rangeMid, crtBias)
        
        currentTurtle := turtle
        turtleSetupActive := true
        turtleSetupBar := bar_index
        true
    else
        false

// Detect Turtle Soup Plus pattern (stronger version with multiple tests)
detectTurtleSoupPlus() =>
    if not enableTurtleSoup or not crtRangeActive
        false
    
    // Look for multiple tests of the same level before final break
    multipleTests = false
    testCount = 0
    
    // Check if level was tested multiple times
    for i = 1 to turtleLookback
        if math.abs(high[i] - high) < atr * 0.1 or math.abs(low[i] - low) < atr * 0.1
            testCount += 1
    
    multipleTests := testCount >= 2
    
    if multipleTests
        [bullishSetup, bearishSetup, prevLow, prevHigh, breakDist] = checkBreakout(turtleLookback)
        
        if bullishSetup or bearishSetup
            turtle = TurtleSoup.new()
            
            if bullishSetup
                turtle.breakLevel := prevLow
                turtle.fakeBreakExtreme := low
                turtle.entryLevel := prevLow + (atr * 0.15)
                turtle.stopLoss := low - (atr * 0.3)  // Tighter stop for Plus pattern
                turtle.target1 := rangeMid
                turtle.target2 := rangeHigh + (rangeHigh - rangeMid) * 0.5  // Extended target
                turtle.isBullish := true
            else
                turtle.breakLevel := prevHigh
                turtle.fakeBreakExtreme := high
                turtle.entryLevel := prevHigh - (atr * 0.15)
                turtle.stopLoss := high + (atr * 0.3)
                turtle.target1 := rangeMid
                turtle.target2 := rangeLow - (rangeMid - rangeLow) * 0.5  // Extended target
                turtle.isBullish := false
            
            turtle.startBar := bar_index
            turtle.isConfirmed := false
            turtle.isActive := true
            turtle.volumeRatio := volume / ta.sma(volume, 20)
            turtle.patternType := "PLUS"
            turtle.confluenceScore := calculateTurtleConfluence(turtle, rangeHigh, rangeLow, rangeMid, crtBias) + 1.0  // Bonus for Plus pattern
            
            currentTurtle := turtle
            turtleSetupActive := true
            turtleSetupBar := bar_index
            true
        else
            false
    else
        false

// Confirm Turtle Soup pattern
confirmTurtleSoup() =>
    if turtleSetupActive and not na(currentTurtle)
        barsElapsed = bar_index - turtleSetupBar
        
        if barsElapsed <= turtleConfirmBars
            // Check if price has moved in expected direction
            if currentTurtle.isBullish
                if close > currentTurtle.breakLevel and close > close[1]
                    currentTurtle.isConfirmed := true
                    currentTurtle.confirmBar := bar_index
                    array.push(activeTurtles, currentTurtle)
                    turtleStats.totalPatterns += 1
                    true
                else if close < currentTurtle.stopLoss
                    // Pattern failed
                    currentTurtle.isActive := false
                    currentTurtle.patternType := "FAILED"
                    array.push(historicalTurtles, currentTurtle)
                    turtleStats.failedPatterns += 1
                    turtleSetupActive := false
                    false
                else
                    false
            else
                if close < currentTurtle.breakLevel and close < close[1]
                    currentTurtle.isConfirmed := true
                    currentTurtle.confirmBar := bar_index
                    array.push(activeTurtles, currentTurtle)
                    turtleStats.totalPatterns += 1
                    true
                else if close > currentTurtle.stopLoss
                    // Pattern failed
                    currentTurtle.isActive := false
                    currentTurtle.patternType := "FAILED"
                    array.push(historicalTurtles, currentTurtle)
                    turtleStats.failedPatterns += 1
                    turtleSetupActive := false
                    false
                else
                    false
        else
            // Timeout - pattern not confirmed in time
            turtleSetupActive := false
            currentTurtle := na
            false
    else
        false

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP VISUALIZATION
// ═══════════════════════════════════════════════════════════════════════

// Draw Turtle Soup pattern
drawTurtleSoup(turtle) =>
    if not na(turtle) and showTurtleBox
        // Draw the fake breakout box
        boxColor = turtle.isBullish ? bullishTurtleColor : bearishTurtleColor
        box.new(turtle.startBar, turtle.fakeBreakExtreme, turtle.confirmBar, turtle.breakLevel,
                border_color=color.new(color.white, 70), bgcolor=boxColor, border_width=1)
    
    if not na(turtle) and showTurtleLabels
        // Entry level line
        line.new(turtle.confirmBar, turtle.entryLevel, turtle.confirmBar + 20, turtle.entryLevel,
                color=turtle.isBullish ? color.green : color.red, style=line.style_solid, width=2)
        
        // Stop loss line
        line.new(turtle.confirmBar, turtle.stopLoss, turtle.confirmBar + 20, turtle.stopLoss,
                color=color.red, style=line.style_dashed, width=1)
        
        // Target lines
        line.new(turtle.confirmBar, turtle.target1, turtle.confirmBar + 20, turtle.target1,
                color=color.green, style=line.style_dotted, width=1)
        line.new(turtle.confirmBar, turtle.target2, turtle.confirmBar + 20, turtle.target2,
                color=color.green, style=line.style_dotted, width=1)
        
        // Pattern label
        patternText = turtle.patternType + " TURTLE\n" +
                     "Entry: " + str.tostring(turtle.entryLevel, "#.##") + "\n" +
                     "SL: " + str.tostring(turtle.stopLoss, "#.##") + "\n" +
                     "Score: " + str.tostring(turtle.confluenceScore, "#.#")
        
        labelStyle = turtle.isBullish ? label.style_label_up : label.style_label_down
        labelColor = turtle.isBullish ? color.green : color.red
        
        label.new(turtle.confirmBar, turtle.isBullish ? turtle.stopLoss : turtle.stopLoss,
                 patternText, color=labelColor, textcolor=color.white,
                 style=labelStyle, size=size.small)
        
        // Add turtle emoji for confirmed patterns
        if turtle.isConfirmed
            label.new(turtle.confirmBar, turtle.entryLevel, "🐢",
                     color=color.new(color.blue, 100), textcolor=color.white,
                     style=label.style_none, size=size.large)

// ═══════════════════════════════════════════════════════════════════════
// TURTLE SOUP MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════

// Manage active Turtle Soup patterns
manageActiveTurtles() =>
    if array.size(activeTurtles) > 0
        for i = array.size(activeTurtles) - 1 to 0
            turtle = array.get(activeTurtles, i)
            
            // Check if targets hit or stop loss hit
            if turtle.isBullish
                if high >= turtle.target2
                    // Full target hit
                    turtle.isActive := false
                    array.remove(activeTurtles, i)
                    array.push(historicalTurtles, turtle)
                    turtleStats.successfulPatterns += 1
                    
                    // Calculate R:R
                    risk = turtle.entryLevel - turtle.stopLoss
                    reward = turtle.target2 - turtle.entryLevel
                    rr = reward / risk
                    turtleStats.avgRR := (turtleStats.avgRR * (turtleStats.successfulPatterns - 1) + rr) / turtleStats.successfulPatterns
                    
                else if low <= turtle.stopLoss
                    // Stop loss hit
                    turtle.isActive := false
                    array.remove(activeTurtles, i)
                    array.push(historicalTurtles, turtle)
                    turtleStats.failedPatterns += 1
                    
            else  // Bearish
                if low <= turtle.target2
                    // Full target hit
                    turtle.isActive := false
                    array.remove(activeTurtles, i)
                    array.push(historicalTurtles, turtle)
                    turtleStats.successfulPatterns += 1
                    
                    // Calculate R:R
                    risk = turtle.stopLoss - turtle.entryLevel
                    reward = turtle.entryLevel - turtle.target2
                    rr = reward / risk
                    turtleStats.avgRR := (turtleStats.avgRR * (turtleStats.successfulPatterns - 1) + rr) / turtleStats.successfulPatterns
                    
                else if high >= turtle.stopLoss
                    // Stop loss hit
                    turtle.isActive := false
                    array.remove(activeTurtles, i)
                    array.push(historicalTurtles, turtle)
                    turtleStats.failedPatterns += 1
            
            // Clean up old patterns (older than 50 bars)
            if bar_index - turtle.startBar > 50
                turtle.isActive := false
                array.remove(activeTurtles, i)
                array.push(historicalTurtles, turtle)
    
    // Limit historical array size
    while array.size(historicalTurtles) > 50
        array.shift(historicalTurtles)

// ═══════════════════════════════════════════════════════════════════════
// INTEGRATION WITH CRT SYSTEM
// ═══════════════════════════════════════════════════════════════════════

// Update CRT range status (integrate with your existing CRT code)
updateCRTStatus() =>
    // This should be integrated with your existing CRT detection
    // For demonstration, using simplified logic
    if hour(time, "UTC") == 3 and hour(time[1], "UTC") != 3  // Example: 3 AM UTC start
        crtRangeActive := true
        rangeHigh := high
        rangeLow := low
        rangeMid := (high + low) / 2
        rangeStartBar := bar_index
        
        // Determine bias based on previous price action
        if close > open
            crtBias := 1  // Bullish
        else if close < open
            crtBias := -1  // Bearish
        else
            crtBias := 0  // Neutral

// ═══════════════════════════════════════════════════════════════════════
// ALERTS FOR TURTLE SOUP
// ═══════════════════════════════════════════════════════════════════════

// Generate Turtle Soup alerts
generateTurtleAlerts() =>
    if not na(currentTurtle) and currentTurtle.isConfirmed
        direction = currentTurtle.isBullish ? "BULLISH" : "BEARISH"
        alertMessage = "🐢 TURTLE SOUP " + direction + " CONFIRMED\n" +
                      "Pattern: " + currentTurtle.patternType + "\n" +
                      "Entry: " + str.tostring(currentTurtle.entryLevel, "#.##") + "\n" +
                      "Stop: " + str.tostring(currentTurtle.stopLoss, "#.##") + "\n" +
                      "Target 1: " + str.tostring(currentTurtle.target1, "#.##") + "\n" +
                      "Target 2: " + str.tostring(currentTurtle.target2, "#.##") + "\n" +
                      "Confluence: " + str.tostring(currentTurtle.confluenceScore, "#.#") + "/5\n" +
                      "Volume Ratio: " + str.tostring(currentTurtle.volumeRatio, "#.#") + "x"
        
        alert(alertMessage, alert.freq_once_per_bar)
    
    // Alert when approaching entry
    if not na(currentTurtle) and currentTurtle.isActive
        if currentTurtle.isBullish and close <= currentTurtle.entryLevel * 1.001
            alert("🐢 Approaching Bullish Turtle Entry: " + str.tostring(currentTurtle.entryLevel), alert.freq_once_per_bar)
        else if not currentTurtle.isBullish and close >= currentTurtle.entryLevel * 0.999
            alert("🐢 Approaching Bearish Turtle Entry: " + str.tostring(currentTurtle.entryLevel), alert.freq_once_per_bar)

// ═══════════════════════════════════════════════════════════════════════
// STATISTICS DISPLAY
// ═══════════════════════════════════════════════════════════════════════

// Display Turtle Soup statistics
displayTurtleStats() =>
    if barstate.islast
        var table turtleTable = table.new(position.bottom_right, 2, 8,
                                         bgcolor=color.new(color.black, 85),
                                         border_color=color.gray, border_width=1)
        
        // Calculate win rate
        totalCompleted = turtleStats.successfulPatterns + turtleStats.failedPatterns
        winRate = totalCompleted > 0 ? (turtleStats.successfulPatterns / totalCompleted) * 100 : 0
        
        // Header
        table.cell(turtleTable, 0, 0, "🐢 Turtle Soup", text_color=color.white, bgcolor=color.new(#2196F3, 50))
        table.cell(turtleTable, 1, 0, "Stats", text_color=color.white, bgcolor=color.new(#2196F3, 50))
        
        // Stats
        table.cell(turtleTable, 0, 1, "Total Patterns", text_color=color.white)
        table.cell(turtleTable, 1, 1, str.tostring(turtleStats.totalPatterns), text_color=color.white)
        
        table.cell(turtleTable, 0, 2, "Active", text_color=color.white)
        table.cell(turtleTable, 1, 2, str.tostring(array.size(activeTurtles)), text_color=color.yellow)
        
        table.cell(turtleTable, 0, 3, "Successful", text_color=color.white)
        table.cell(turtleTable, 1, 3, str.tostring(turtleStats.successfulPatterns), text_color=color.green)
        
        table.cell(turtleTable, 0, 4, "Failed", text_color=color.white)
        table.cell(turtleTable, 1, 4, str.tostring(turtleStats.failedPatterns), text_color=color.red)
        
        table.cell(turtleTable, 0, 5, "Win Rate", text_color=color.white)
        table.cell(turtleTable, 1, 5, str.tostring(winRate, "#.#") + "%", 
                  text_color=winRate > 60 ? color.green : winRate > 40 ? color.yellow : color.red)
        
        table.cell(turtleTable, 0, 6, "Avg R:R", text_color=color.white)
        table.cell(turtleTable, 1, 6, str.tostring(turtleStats.avgRR, "#.#"), 
                  text_color=turtleStats.avgRR > 2 ? color.green : color.yellow)
        
        table.cell(turtleTable, 0, 7, "Best Setup", text_color=color.white)
        bestSetup = "None"
        if not na(currentTurtle)
            if currentTurtle.confluenceScore >= 4
                bestSetup = "HIGH"
            else if currentTurtle.confluenceScore >= 2.5
                bestSetup = "MEDIUM"
            else
                bestSetup = "LOW"
        table.cell(turtleTable, 1, 7, bestSetup, 
                  text_color=bestSetup == "HIGH" ? color.green : bestSetup == "MEDIUM" ? color.yellow : color.gray)

// ═══════════════════════════════════════════════════════════════════════
// MAIN EXECUTION
// ═══════════════════════════════════════════════════════════════════════

// Update CRT status (integrate with your existing CRT code)
updateCRTStatus()

// Get 15m data if needed
if use15mDetection
    get15mData()

// Detect Turtle Soup patterns
if crtRangeActive
    // Try to detect Plus pattern first (higher quality)
    plusDetected = detectTurtleSoupPlus()
    
    // If no Plus pattern, try Classic
    if not plusDetected
        classicDetected = detectClassicTurtleSoup()
    
    // Confirm any active setup
    if turtleSetupActive
        confirmed = confirmTurtleSoup()
        if confirmed
            drawTurtleSoup(currentTurtle)
            generateTurtleAlerts()

// Manage active patterns
manageActiveTurtles()

// Display statistics
if showTurtleLabels
    displayTurtleStats()

// ═══════════════════════════════════════════════════════════════
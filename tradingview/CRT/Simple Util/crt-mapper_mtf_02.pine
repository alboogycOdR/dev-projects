//@version=5
// Name: 3-Candle Time Pattern - Enhanced Multi-Timeframe (Fixed)
indicator("3-Candle Time Pattern - Enhanced - v1.1", overlay=true, max_lines_count=500, max_labels_count=500)
//author: https://t.me/NuburoFx (NuburoFX)
//version: 1.1.0
//date: 2025-09-04
//description: A simple indicator that detects 3-candle time patterns on the chart.
//license: MIT
//tags: 3-candle, time pattern, mtf, fixed

// --- User Inputs ---
startHourSAST = input.int(3, title="Range Candle Start Hour (SAST)", minval=0, maxval=23, tooltip="Enter the start hour for the first candle in SAST (UTC+2). The script will handle UTC conversion.")
endAtHourSAST = (startHourSAST + 8) % 24  // Auto-calculated: always 8 hours after start
showDebug = input.bool(true, title="Show Debug Information", tooltip="Display debug information on the chart")
historyDays = input.int(5, title="History Window (days)", minval=1, maxval=30, tooltip="Limit drawing to the last N days on lower timeframes")
redrawLastBarOnly = input.bool(true, title="Draw historical only on last bar", tooltip="Greatly reduces CPU by rebuilding past objects only on the last bar")

// --- Constants and Variables ---
// Convert SAST input to UTC for reliable checking
var int startHourUTC = (startHourSAST - 2 + 24) % 24
var int endHourUTC = (startHourUTC + 4) % 24  // End of 4-hour period
var int endAtHourUTC = (endAtHourSAST - 2 + 24) % 24  // Target end hour in UTC
var int hoursSpanStartToEndAt = ((endAtHourUTC - startHourUTC + 24) % 24)
if hoursSpanStartToEndAt == 0
    hoursSpanStartToEndAt := 24

// Original 4H logic variables
var float rangeHigh = na
var float rangeLow = na
var int patternState = 0 // 0: Searching for Range, 1: Range Found, 2: Manipulation Found
var int tradeBias = 0    // 1 for Bullish, -1 for Bearish, 0 for Neutral, 2 for Both Rejected

// Variables for drawing lines - use arrays to handle multiple patterns
var array<line> lineHighArray = array.new<line>()
var array<line> lineLowArray = array.new<line>()
var array<line> lineMidArray = array.new<line>()

// Debug variable
var label debugLabel = na

// Variables to track all patterns for historical display
var array<float> allRangeHighs = array.new<float>()
var array<float> allRangeLows = array.new<float>()
var array<int> allPatternBars = array.new<int>()

// Variables for rejection detection
var bool bearishRejection = false
var bool bullishRejection = false

// Variables for temporary line creation
var line newLineHigh = na
var line newLineLow = na
var line newLineMid = na

// Variables for line cleanup
var line oldLineHigh = na
var line oldLineLow = na
var line oldLineMid = na

// --- NEW: Multi-timeframe variables ---
var float mtfPeriodHigh = na
var float mtfPeriodLow = na
var bool mtfPeriodActive = false
var int mtfPeriodStartBar = na
var line mtfHighLine = na
var line mtfLowLine = na
var line mtfMidLine = na
var label mtfHighLabel = na
var label mtfLowLabel = na
var label mtfMidLabel = na
var array<int> cacheDayKeys = array.new<int>()
var array<int> cacheDayCounts = array.new<int>()
var bool mtfPeriodProcessed = false
var int mtfPeriodStartTime = na
var int barsToExtend = 0

// --- Helper Functions ---
// Function to check if current time is within the 4-hour period
isWithinMTFPeriod() =>
    currentHourUTC = hour(time, "UTC")
    if startHourUTC < endHourUTC
        currentHourUTC >= startHourUTC and currentHourUTC < endHourUTC
    else  // Handle day boundary crossing (e.g., 22:00 to 02:00)
        currentHourUTC >= startHourUTC or currentHourUTC < endHourUTC

// Function to check if we're at the start of the 4-hour period
isStartOfMTFPeriod() =>
    currentHour = hour(time, "UTC")
    prevHour = hour(time[1], "UTC")
    // Check if we just entered the start hour or loading historical data
    (currentHour == startHourUTC and prevHour != startHourUTC) or (currentHour == startHourUTC and (na(prevHour) or hour(time, "UTC") != hour(time[1], "UTC")))

// Function to check if the 4-hour period just ended
isMTFPeriodJustEnded() =>
    currentHour = hour(time, "UTC")
    prevHour = hour(time[1], "UTC")
    // Check if we just entered the end hour or loading historical data
    (currentHour == endHourUTC and prevHour != endHourUTC) or (currentHour == endHourUTC and (na(prevHour) or hour(time, "UTC") != hour(time[1], "UTC")))

// --- Logic ---
// Detect the start of a new Range Candle (every 4 hours at the specified time)
isNewRangeCandle = timeframe.period == "240" and hour(time, "UTC") == startHourUTC

// Check if we're on a lower timeframe (not 4H)
isLowerTimeframe = timeframe.period != "240"

// --- ORIGINAL 4H LOGIC (unchanged) ---
if (isNewRangeCandle)
    // --- 1. A New Range Candle is Found ---
    
    // Store the high and low of the range
    rangeHigh := high
    rangeLow := low
    
    // Set the state to indicate we have the range and are waiting for the manipulation candle
    patternState := 1
    tradeBias := 0
    
    // Store pattern data for historical display
    array.push(allRangeHighs, high)
    array.push(allRangeLows, low)
    array.push(allPatternBars, bar_index)
    
    // Draw new horizontal lines for the range, extending for the next 3 bars (12 hours) to cover all 3 candles
    newLineHigh := line.new(bar_index, high, bar_index + 3, high, color=color.new(color.black, 0), style=line.style_solid, width=2)
    newLineLow := line.new(bar_index, low, bar_index + 3, low, color=color.new(color.black, 0), style=line.style_solid, width=2)
    // Midpoint (TP1) dotted line on 4H
    midVal = (high + low) / 2.0
    newLineMid := line.new(bar_index, midVal, bar_index + 3, midVal, color=color.new(color.black, 0), style=line.style_dotted, width=2)
    
    // Add new lines to arrays for management
    array.push(lineHighArray, newLineHigh)
    array.push(lineLowArray, newLineLow)
    array.push(lineMidArray, newLineMid)

else if (patternState == 1)
    // --- 2. This is the Manipulation Candle ---
    
    // Check for a bearish rejection of the high
    bearishRejection := high > rangeHigh and close < rangeHigh

    // Check for a bullish rejection of the low
    bullishRejection := low < rangeLow and close > rangeLow

    // Note: Both can be true simultaneously, indicating market indecision
    
    if (bearishRejection and bullishRejection)
        tradeBias := 2  // Set bias to Both Rejected (Neutral) - Purple Circle
    else if (bearishRejection)
        tradeBias := -1 // Set bias to Bearish - Red Down Arrow
    else if (bullishRejection)
        tradeBias := 1  // Set bias to Bullish - Green Up Arrow
    
    // Move to the next state, ready for the distribution candle
    patternState := 2

else if (patternState == 2)
    // --- 3. This is the Distribution Candle ---
    
    // Reset the pattern state to search for the next one
    patternState := 0

// Define arrays for CRT patterns
var array<int> crtStartBars = array.new<int>()
var array<int> crtStartTimes = array.new<int>()
var array<float> crtHighs = array.new<float>()
var array<float> crtLows = array.new<float>()
var array<int> crtEndBars = array.new<int>()

// --- NEW: Multi-timeframe logic for lower timeframes ---
if (isLowerTimeframe)
    
    // Debug output
    if barstate.islast and showDebug
        debugText = "TF: " + timeframe.period + "\nCurrent UTC: " + str.tostring(hour(time, "UTC")) + ":" + str.tostring(minute(time, "UTC")) + "\nStart: " + str.tostring(startHourUTC) + " UTC, End Period: " + str.tostring(endHourUTC) + " UTC" + "\nEnd At: " + str.tostring(endAtHourUTC) + " UTC (" + str.tostring(endAtHourSAST) + " SAST)" + "\nActive: " + str.tostring(mtfPeriodActive) + "\nProcessed: " + str.tostring(mtfPeriodProcessed) + "\nWithin Period: " + str.tostring(isWithinMTFPeriod()) + "\nHigh: " + str.tostring(mtfPeriodHigh) + "\nLow: " + str.tostring(mtfPeriodLow) + "\nCRT Patterns: " + str.tostring(array.size(crtStartBars))
        
        if na(debugLabel)
            debugLabel := label.new(bar_index, high + (ta.atr(14) * 3), text=debugText, color=color.new(color.gray, 50), textcolor=color.white, style=label.style_label_down, size=size.normal)
        else
            label.set_xy(debugLabel, bar_index, high + (ta.atr(14) * 3))
            label.set_text(debugLabel, debugText)
    
    // Check if we're starting a new 4-hour period
    if (isStartOfMTFPeriod())
        // Reset for new period
        mtfPeriodActive := true
        mtfPeriodProcessed := false
        mtfPeriodStartBar := bar_index
        mtfPeriodStartTime := time
        mtfPeriodHigh := high
        mtfPeriodLow := low
        
        // Clean up previous lines
        // Keep previous period lines on lower TFs for historical visibility
        if not na(mtfHighLine)
            mtfHighLine := na
        if not na(mtfLowLine)
            mtfLowLine := na
        if not na(mtfMidLine)
            mtfMidLine := na
    
    // Update highs and lows during the active period
    if (mtfPeriodActive and isWithinMTFPeriod())
        mtfPeriodHigh := math.max(mtfPeriodHigh, high)
        mtfPeriodLow := math.min(mtfPeriodLow, low)
    
    // Check if the 4-hour period just ended
    if (isMTFPeriodJustEnded() and mtfPeriodActive and not mtfPeriodProcessed)
        mtfPeriodActive := false
        mtfPeriodProcessed := true
        
        // Compute target x2 from start bar using fixed span 03:00→endAtHour
        tfSeconds = timeframe.in_seconds(timeframe.period)
        barsTotalToTarget = na(tfSeconds) ? 0 : math.round((hoursSpanStartToEndAt * 3600) / tfSeconds)
        extendToBar = mtfPeriodStartBar + barsTotalToTarget
        
        // Store CRT pattern data
        if not na(mtfPeriodStartBar) and not na(mtfPeriodHigh) and not na(mtfPeriodLow)
            array.push(crtStartBars, mtfPeriodStartBar)
            array.push(crtStartTimes, mtfPeriodStartTime)
            array.push(crtHighs, mtfPeriodHigh)
            array.push(crtLows, mtfPeriodLow)
            array.push(crtEndBars, extendToBar)
            
            // Draw CRT-H line (high)
            mtfHighLine := line.new(x1=mtfPeriodStartBar, y1=mtfPeriodHigh, x2=extendToBar, y2=mtfPeriodHigh, color=color.new(color.black, 0), style=line.style_solid, width=2)
            
            // Draw CRT-L line (low)
            mtfLowLine := line.new(x1=mtfPeriodStartBar, y1=mtfPeriodLow, x2=extendToBar, y2=mtfPeriodLow, color=color.new(color.black, 0), style=line.style_solid, width=2)
            
            // Midpoint dotted line and label
            midY = (mtfPeriodHigh + mtfPeriodLow) / 2.0
            mtfMidLine := line.new(x1=mtfPeriodStartBar, y1=midY, x2=extendToBar, y2=midY, color=color.new(color.black, 0), style=line.style_dotted, width=2)
            mtfMidLabel := label.new(x=extendToBar, y=midY, text="tp1", color=color.new(color.black, 0), textcolor=color.white, style=label.style_label_left, size=size.normal)

            // Add labels for identification
            mtfHighLabel := label.new(x=extendToBar, y=mtfPeriodHigh, text="CRT-H", color=color.new(color.black, 0), textcolor=color.white, style=label.style_label_left, size=size.normal)
            
            mtfLowLabel := label.new(x=extendToBar, y=mtfPeriodLow, text="CRT-L", color=color.new(color.black, 0), textcolor=color.white, style=label.style_label_left, size=size.normal)

// --- ORIGINAL PLOTTING AND VISUALS (unchanged) ---

// Plot arrows/circles ONLY on the first bar of the Distribution Candle, fixed to price levels with offset
// Smaller, cleaner arrows on 4H timeframe
arrowSize = timeframe.period == "240" ? size.tiny : size.small
if tradeBias[1] == 1 and patternState == 0 and patternState[1] == 2
    label.new(bar_index[1], low[1] - (ta.atr(14) * 0.25), "▲", color=color.new(color.green, 0), textcolor=color.white, style=label.style_triangleup, size=arrowSize, yloc=yloc.price)
if tradeBias[1] == -1 and patternState == 0 and patternState[1] == 2
    label.new(bar_index[1], high[1] + (ta.atr(14) * 0.25), "▼", color=color.new(color.red, 0), textcolor=color.white, style=label.style_triangledown, size=arrowSize, yloc=yloc.price)
if tradeBias[1] == 2 and patternState == 0 and patternState[1] == 2
    label.new(bar_index[1], close[1] - (ta.atr(14) * 0.2), "●", color=color.new(color.purple, 0), textcolor=color.white, style=label.style_circle, size=arrowSize, yloc=yloc.price)

// Color the background for the Distribution Candle based on the bias
bgcolor(patternState == 0 and tradeBias[1] == 1 ? color.new(color.green, 85) : na, title="Bullish Bias BG")
bgcolor(patternState == 0 and tradeBias[1] == -1 ? color.new(color.red, 85) : na, title="Bearish Bias BG")
bgcolor(patternState == 0 and tradeBias[1] == 2 ? color.new(color.purple, 85) : na, title="Neutral Bias BG")

// --- Historical Pattern Lines ---
// Draw trendlines for all historical patterns to ensure visibility (only for 4H timeframe)
if barstate.islast and array.size(allPatternBars) > 0 and not isLowerTimeframe
    for i = 0 to array.size(allPatternBars) - 1
        if array.size(allPatternBars) > i and array.size(allRangeHighs) > i and array.size(allRangeLows) > i
            patternBar = array.get(allPatternBars, i)
            patternHigh = array.get(allRangeHighs, i)
            patternLow = array.get(allRangeLows, i)
            
            // Only draw if not already drawn (check if within visible range)
            if bar_index - patternBar <= 100  // Show last 100 bars of patterns
                // Draw high line
                line.new(patternBar, patternHigh, patternBar + 3, patternHigh, color=color.new(color.gray, 25), style=line.style_dashed)
                // Draw low line  
                line.new(patternBar, patternLow, patternBar + 3, patternLow, color=color.new(color.gray, 25), style=line.style_dashed)

// --- Line Management ---
// Clean up old lines to prevent memory issues (keep last 50 patterns)
if array.size(lineHighArray) > 50
    oldLineHigh := array.shift(lineHighArray)
    oldLineLow := array.shift(lineLowArray)
    line.delete(oldLineHigh)
    line.delete(oldLineLow)
    if array.size(lineMidArray) > 50
        oldLineMid := array.shift(lineMidArray)
        line.delete(oldLineMid)

// Draw historical CRT patterns
// Draw only within the configured history window to limit resource usage
if isLowerTimeframe and array.size(crtStartBars) > 0 and array.size(crtHighs) > 0 and array.size(crtLows) > 0 and array.size(crtEndBars) > 0 and (not redrawLastBarOnly or barstate.islast)
    // Build per-day counts for current window
    tmpKeys = array.new<int>()
    tmpCounts = array.new<int>()
    cutoffTime = timenow - historyDays * 24 * 60 * 60 * 1000
    for i = 0 to array.size(crtStartBars) - 1
        if i < array.size(crtStartBars) and i < array.size(crtHighs) and i < array.size(crtLows) and i < array.size(crtEndBars)
            sb = array.get(crtStartBars, i)
            st = array.get(crtStartTimes, i)
            if not na(st) and st >= cutoffTime
                dk = year(st) * 10000 + month(st) * 100 + dayofmonth(st)
                idx = array.indexof(tmpKeys, dk)
                if idx == -1
                    array.push(tmpKeys, dk)
                    array.push(tmpCounts, 1)
                else
                    array.set(tmpCounts, idx, array.get(tmpCounts, idx) + 1)
    // Compare with cache
    changed = array.size(tmpKeys) != array.size(cacheDayKeys)
    if not changed
        for k = 0 to array.size(tmpKeys) - 1
            keyK = array.get(tmpKeys, k)
            idxC = array.indexof(cacheDayKeys, keyK)
            if idxC == -1 or array.get(cacheDayCounts, idxC) != array.get(tmpCounts, k)
                changed := true
    // Update cache and draw only if changed
    if changed
        array.clear(cacheDayKeys)
        array.clear(cacheDayCounts)
        for k2 = 0 to array.size(tmpKeys) - 1
            array.push(cacheDayKeys, array.get(tmpKeys, k2))
            array.push(cacheDayCounts, array.get(tmpCounts, k2))
        for i2 = 0 to array.size(crtStartBars) - 1
            if i2 < array.size(crtStartBars) and i2 < array.size(crtHighs) and i2 < array.size(crtLows) and i2 < array.size(crtEndBars)
                startBar = array.get(crtStartBars, i2)
                highValue = array.get(crtHighs, i2)
                lowValue = array.get(crtLows, i2)
                endBar = array.get(crtEndBars, i2)
                st2 = array.get(crtStartTimes, i2)
                startTimeOk = not na(st2) and st2 >= cutoffTime
                if startBar != mtfPeriodStartBar and startBar >= 0 and startBar <= bar_index and bar_index - startBar <= 2800 and endBar >= startBar and startTimeOk
                    line.new(x1=startBar, y1=highValue, x2=endBar, y2=highValue, color=color.new(color.black, 0), style=line.style_solid, width=2)
                    line.new(x1=startBar, y1=lowValue, x2=endBar, y2=lowValue, color=color.new(color.black, 0), style=line.style_solid, width=2)
                    midHV = (highValue + lowValue) / 2.0
                    line.new(x1=startBar, y1=midHV, x2=endBar, y2=midHV, color=color.new(color.black, 0), style=line.style_dotted, width=2)
                    label.new(x=endBar, y=highValue, text="CRT-H", color=color.new(color.black, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)
                    label.new(x=endBar, y=lowValue, text="CRT-L", color=color.new(color.black, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)
                    label.new(x=endBar, y=midHV, text="tp1", color=color.new(color.black, 0), textcolor=color.white, style=label.style_label_left, size=size.tiny)

// Clean up old CRT data to prevent memory issues (keep last 30 CRT patterns)
if array.size(crtStartBars) > 30
    array.shift(crtStartBars)
    array.shift(crtStartTimes)
    array.shift(crtHighs)
    array.shift(crtLows)
    array.shift(crtEndBars)
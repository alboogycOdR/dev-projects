// ┌─────────────────────────────────────────────────────────────────────────────┐
// │  WED & MIDNIGHT DST System v0.7.4 – Complete with Wick-Reaction Alerts    │
// │  & Level Optimization                                                      │
// │  © 2024 – Free to use & modify (Corrected by AI)                           │
// └─────────────────────────────────────────────────────────────────────────────┘
//
//BEFORE FIX OF ALERT SYSTEM  IN -0801.4.DST_ALERTS.pine
//
//
// ───── DESCRIPTION ─────────────────────────────────────────────────────────────────
//
// This script is designed to identify and visualize specific, recurring price levels
// based on two distinct time-based systems: Wednesday SAST (South African Standard Time)
// and Midnight (UTC+2) levels. These features are intended to highlight potentially
// significant support and resistance zones for technical analysis.
//
// -----------------------------------------------------------------------------
// │ KEY FEATURES (Corrected Version)                                            │
// -----------------------------------------------------------------------------
//
// 1. Wednesday SAST Lines:
//    - Identifies the high, low, and open of the first five Wednesdays of each month.
//    - The specific time for capturing the high/low is 20:30 SAST, which the
//      script automatically adjusts for US Daylight Saving Time changes by calculating
//      the correct UTC time generically for any year.
//    - Uses request.security() to always fetch data from the 15-minute timeframe,
//      ensuring consistent line placement across all chart timeframes.
//
// 2. Midnight Levels (UTC+2):
//    - Plots the high and low of the 00:00 candle (15-minute timeframe) for each
//      day, based on the UTC+2 timezone.
//    - Users can specify a lookback period (in days) to display these historical levels.
//
// 3. Wick Interaction Visuals:
//    - Displays a visual marker on any candle that wicks into an active price line.
//    - Marker's color automatically matches the color of the line it interacts with.
//
// 4. Alert System:
//    - Real-time alerts when price wicks touch Wednesday or Midnight levels.
//    - Alert cooldown system prevents spam notifications. Alert mechanism now correctly
//      uses Pine Script's event-driven system without misleading inputs.
//
// 5. Code Quality & Performance:
//    - Full Pine Script v5 compliance with corrected syntax (e.g., arrow functions for
//      sorting, correct array manipulation, valid variable assignments).
//    - Robust array management to prevent runtime errors.
//    - Optimized and logically sound code structure.
//
// 6. Level Optimization:
//    - Dynamic filtering to show only the most relevant X levels above and below
//      the current price, reducing chart noise.
//
// 7. General Settings:
//    - All drawing logic has been reviewed for multi-timeframe compatibility and
//      efficient, non-repainting behavior where appropriate.
//    - Corrected label positioning logic for future projections.
//
// -----------------------------------------------------------------------------
// -----------------------------------------------------------------------------
//@version=5

indicator(
     title   = "WED & MIDNIGHT DST System v0.7.4 (Alerts + Optimization)",
     overlay = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     dynamic_requests = true)

// ───── ALERT SWITCHES ────────────────────────────────────────────────────────
GROUP_ALERT = "Alerts"
sendEmail   = input.bool(true,  "Send Email",         group=GROUP_ALERT)
sendPush    = input.bool(true,  "Send Push",          group=GROUP_ALERT)
alertCooldown = input.int(30,    "Cooldown (sec)", minval=5, group=GROUP_ALERT,
                       tooltip="Seconds between duplicate alerts")

// ───── WEDNESDAY LINES ───────────────────────────────────────────────────────
GROUP_WEDNESDAY = "Wednesday SAST Lines"
showWednesdays = input.bool(true, "Show Wednesday High/Low Lines", group=GROUP_WEDNESDAY, tooltip="Master switch to show/hide Wednesday High/Low lines.")
showWednesdayOpen = input.bool(true, "Show Wednesday Open Line", group=GROUP_WEDNESDAY, tooltip="Toggles the visibility of the Wednesday Open line.")

showW1 = input.bool(true, "Show 1st Wednesday", group=GROUP_WEDNESDAY, inline="W1")
hiC1 = input.color(color.new(color.red, 0), "", inline="1H", group=GROUP_WEDNESDAY)
loC1 = input.color(color.new(color.blue, 0), "", inline="1L", group=GROUP_WEDNESDAY)
opC1 = input.color(color.new(color.gray, 0), "", inline="1O", group=GROUP_WEDNESDAY)
hiW1 = input.int(2, "Width", minval=1, maxval=10, inline="1H", group=GROUP_WEDNESDAY)
loW1 = input.int(2, "Width", minval=1, maxval=10, inline="1L", group=GROUP_WEDNESDAY)
opW1 = input.int(2, "Width", minval=1, maxval=10, inline="1O", group=GROUP_WEDNESDAY)

showW2 = input.bool(true, "Show 2nd Wednesday", group=GROUP_WEDNESDAY, inline="W2")
hiC2 = input.color(color.new(color.orange, 0), "", inline="2H", group=GROUP_WEDNESDAY)
loC2 = input.color(color.new(color.aqua, 0), "", inline="2L", group=GROUP_WEDNESDAY)
opC2 = input.color(color.new(color.gray, 0), "", inline="2O", group=GROUP_WEDNESDAY)
hiW2 = input.int(2, "Width", minval=1, maxval=10, inline="2H", group=GROUP_WEDNESDAY)
loW2 = input.int(2, "Width", minval=1, maxval=10, inline="2L", group=GROUP_WEDNESDAY)
opW2 = input.int(2, "Width", minval=1, maxval=10, inline="2O", group=GROUP_WEDNESDAY)

showW3 = input.bool(true, "Show 3rd Wednesday", group=GROUP_WEDNESDAY, inline="W3")
hiC3 = input.color(color.new(color.green, 0), "", inline="3H", group=GROUP_WEDNESDAY)
loC3 = input.color(color.new(color.fuchsia, 0), "", inline="3L", group=GROUP_WEDNESDAY)
opC3 = input.color(color.new(color.gray, 0), "", inline="3O", group=GROUP_WEDNESDAY)
hiW3 = input.int(2, "Width", minval=1, maxval=10, inline="3H", group=GROUP_WEDNESDAY)
loW3 = input.int(2, "Width", minval=1, maxval=10, inline="3L", group=GROUP_WEDNESDAY)
opW3 = input.int(2, "Width", minval=1, maxval=10, inline="3O", group=GROUP_WEDNESDAY)

showW4 = input.bool(true, "Show 4th Wednesday", group=GROUP_WEDNESDAY, inline="W4")
hiC4 = input.color(color.new(color.purple, 0), "", inline="4H", group=GROUP_WEDNESDAY)
loC4 = input.color(color.new(color.lime, 0), "", inline="4L", group=GROUP_WEDNESDAY)
opC4 = input.color(color.new(color.gray, 0), "", inline="4O", group=GROUP_WEDNESDAY)
hiW4 = input.int(2, "Width", minval=1, maxval=10, inline="4H", group=GROUP_WEDNESDAY)
loW4 = input.int(2, "Width", minval=1, maxval=10, inline="4L", group=GROUP_WEDNESDAY)
opW4 = input.int(2, "Width", minval=1, maxval=10, inline="4O", group=GROUP_WEDNESDAY)

showW5 = input.bool(false, "Show 5th Wednesday", group=GROUP_WEDNESDAY, inline="W5")
hiC5 = input.color(color.new(color.gray, 0), "", inline="5H", group=GROUP_WEDNESDAY)
loC5 = input.color(color.new(color.black, 0), "", inline="5L", group=GROUP_WEDNESDAY)
opC5 = input.color(color.new(color.gray, 0), "", inline="5O", group=GROUP_WEDNESDAY)
hiW5 = input.int(2, "Width", minval=1, maxval=10, inline="5H", group=GROUP_WEDNESDAY)
loW5 = input.int(2, "Width", minval=1, maxval=10, inline="5L", group=GROUP_WEDNESDAY)
opW5 = input.int(2, "Width", minval=1, maxval=10, inline="5O", group=GROUP_WEDNESDAY)

// ───── MIDNIGHT LEVELS ───────────────────────────────────────────────────────
GROUP_MIDNIGHT = "Midnight Levels"
showMidnightLevelsInput = input.bool(true, 'Show Midnight Levels', group=GROUP_MIDNIGHT, tooltip='Shows the high and low of the 00:00 (UTC+2) candle on the 15m timeframe.')
midnightLookbackDaysInput = input.int(21, 'Lookback (Days)', group=GROUP_MIDNIGHT, minval=1, tooltip='Number of past days to show the midnight levels for.')
midnightHighColorInput = input.color(color.new(color.orange, 50), 'High Color', group=GROUP_MIDNIGHT, inline='mlHigh')
midnightHighStyleInput = input.string("Solid", 'High Style', group=GROUP_MIDNIGHT, options=["Solid", "Dashed", "Dotted"], inline='mlHigh')
midnightHighWidthInput = input.int(1, 'High Width', group=GROUP_MIDNIGHT, minval=1, maxval=4, inline='mlHigh')
midnightLowColorInput = input.color(color.new(color.purple, 50), 'Low Color', group=GROUP_MIDNIGHT, inline='mlLow')
midnightLowStyleInput = input.string("Solid", 'Low Style', group=GROUP_MIDNIGHT, options=["Solid", "Dashed", "Dotted"], inline='mlLow')
midnightLowWidthInput = input.int(1, 'Low Width', group=GROUP_MIDNIGHT, minval=1, maxval=4, inline='mlLow')
midnightHighLabelColorInput = input.color(color.new(color.orange, 0), 'High Label Color', group=GROUP_MIDNIGHT)
midnightLowLabelColorInput = input.color(color.new(color.purple, 0), 'Low Label Color', group=GROUP_MIDNIGHT)
midnightLabelSizeInput = input.string("Tiny", 'Label Text Size', group=GROUP_MIDNIGHT, options=["Tiny","Small","Normal","Large","Huge"])

// ───── INTERACTION VISUALS ───────────────────────────────────────────────────
GROUP_INTERACTION = "Interaction Visuals"
showWickInteractions = input.bool(true, "Show Wick Interactions", group=GROUP_INTERACTION, tooltip="Master switch to show/hide all wick interaction markers.")
interactionMarkerStyle = input.string("Circle", "Marker Style", options=["Circle", "Square", "Diamond", "Triangle Up", "Triangle Down"], group=GROUP_INTERACTION)
interactionMarkerSize = input.string("Tiny", "Marker Size", options=["Tiny", "Small", "Normal", "Large", "Huge"], group=GROUP_INTERACTION)

// ───── GENERAL SETTINGS ──────────────────────────────────────────────────────
GROUP_GENERAL = "General Settings"
extendRight = input.bool(true, "Extend Lines into Future", group=GROUP_GENERAL)
labelText   = input.bool(true, "Show Date Labels", group=GROUP_GENERAL)
labelSize   = input.string("Tiny", "Label Size", options=["Tiny","Small","Normal","Large","Huge"], group=GROUP_GENERAL)
wednesdayLabelOffset = input.int(5, "Wednesday Label Offset", group=GROUP_GENERAL, tooltip="Number of bars to offset the Wednesday labels to the right.", minval=0)

// ───── LEVEL OPTIMIZATION ────────────────────────────────────────────────────
GROUP_OPTIMIZATION = "Level Optimization"
enableLevelFiltering = input.bool(false, "Enable Level Filtering", group=GROUP_OPTIMIZATION, tooltip="Show only X levels above and below current price to reduce chart noise")
levelsAbovePrice = input.int(3, "Levels Above Price", group=GROUP_OPTIMIZATION, minval=1, maxval=20, tooltip="Number of levels to show above current ASK price")
levelsBelowPrice = input.int(3, "Levels Below Price", group=GROUP_OPTIMIZATION, minval=1, maxval=20, tooltip="Number of levels to show below current ASK price")

// ───── CONSTANTS ─────────────────────────────────────────────────────────────
TARGET_TIMEZONE = "UTC+2"
DAYOFWED        = 4 // 1=Sun, 2=Mon, 3=Tue, 4=Wed, 5=Thu, 6=Fri, 7=Sat
MS_IN_DAY       = 24 * 60 * 60 * 1000

// ───── HELPER FUNCTIONS ──────────────────────────────────────────────────────
f_size_str_to_const(size_str) =>
    switch size_str
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge
        => size.auto

getStyle(string style) =>
    switch style
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid
      
getMarkerStyle(string style) =>
    switch style
        "Circle"        => label.style_circle
        "Square"        => label.style_square
        "Diamond"       => label.style_diamond
        "Triangle Up"   => label.style_triangleup
        "Triangle Down" => label.style_triangledown
        => label.style_circle

// ───── DATA STRUCTURES ───────────────────────────────────────────────────────
type midnightLevel
    float high
    float low
    int barTime

type indexDistance
    int idx
    float dist

type wedIndexDistance
    int idx
    float dist

// ───── STORAGE ───────────────────────────────────────────────────────────────
var float[] hiPrice  = array.new_float()
var float[] loPrice  = array.new_float()
var float[] opPrice  = array.new_float()
var int[]   eventTimes = array.new_int()
var int[]   wedRank  = array.new_int()
var string[] dateLbl = array.new_string()

// Midnight Levels Storage
var array<midnightLevel> midnightLevels = array.new<midnightLevel>()
var array<line> midnightHighLines = array.new<line>()
var array<line> midnightLowLines = array.new<line>()
var array<label> midnightHighLabels = array.new<label>()
var array<label> midnightLowLabels = array.new<label>()

// Wednesday Lines Storage
var array<line> wednesdayHighLines = array.new<line>()
var array<line> wednesdayLowLines = array.new<line>()
var array<line> wednesdayOpenLines = array.new<line>()
var array<label> wednesdayHighLabels = array.new<label>()
var array<label> wednesdayLowLabels = array.new<label>()
var array<label> wednesdayOpenLabels = array.new<label>()

// ───── COMMON VARIABLES ──────────────────────────────────────────────────────
actualLabelSize = f_size_str_to_const(labelSize)
actualMarkerSize = f_size_str_to_const(interactionMarkerSize)
actualMarkerStyle = getMarkerStyle(interactionMarkerStyle)
actualMidnightLabelSize = f_size_str_to_const(midnightLabelSizeInput)

// ───── ALERT COOLDOWN ────────────────────────────────────────────────────────
var int lastAlertTime = 0

// ───── WEDNESDAY LOGIC ───────────────────────────────────────────────────────
f_getTargetTime(int ts) =>
    _year = year(ts, "UTC")
    
    start_dst_day = 8 
    for i = 0 to 6
        if dayofweek(timestamp("UTC", _year, 3, 8 + i, 2, 0)) == dayofweek.sunday
            start_dst_day := 8 + i
            break
    start_dst = timestamp("UTC", _year, 3, start_dst_day, 2, 0)

    end_dst_day = 1
    for i = 0 to 6
        if dayofweek(timestamp("UTC", _year, 11, 1 + i, 2, 0)) == dayofweek.sunday
            end_dst_day := 1 + i
            break
    end_dst = timestamp("UTC", _year, 11, end_dst_day, 2, 0)
    
    _targetHour = (ts >= start_dst and ts < end_dst) ? 19 : 20
    _targetMin = 30
    [_targetHour, _targetMin]

varip float wednesdayHigh_15m = na
varip float wednesdayLow_15m = na
varip float wednesdayOpen_15m = na
varip int wednesdayTime_15m = na
varip int wednesdayCount_15m = na

[targetHour, targetMin] = f_getTargetTime(time)
isWednesday_15m = timeframe.isintraday and timeframe.multiplier == 15 and dayofweek(time, TARGET_TIMEZONE) == DAYOFWED and hour(time, TARGET_TIMEZONE) == targetHour and minute(time, TARGET_TIMEZONE) == targetMin

if isWednesday_15m and barstate.isconfirmed
    currentDay = dayofmonth(time, TARGET_TIMEZONE)
    currentMonth = month(time, TARGET_TIMEZONE)
    currentYear = year(time, TARGET_TIMEZONE)
    wedCount = 0
    for d = 1 to currentDay
        testTime = timestamp(TARGET_TIMEZONE, currentYear, currentMonth, d, 12, 0)
        if month(testTime, TARGET_TIMEZONE) == currentMonth and dayofweek(testTime, TARGET_TIMEZONE) == DAYOFWED
            wedCount += 1
    if wedCount <= 5
        wednesdayHigh_15m := high, wednesdayLow_15m := low, wednesdayOpen_15m := open
        wednesdayTime_15m := time, wednesdayCount_15m := wedCount

[wed_high, wed_low, wed_open, wed_time, wed_count] = request.security(syminfo.tickerid, "15", [wednesdayHigh_15m[1], wednesdayLow_15m[1], wednesdayOpen_15m[1], wednesdayTime_15m[1], wednesdayCount_15m[1]], lookahead=barmerge.lookahead_off)

isNewWednesdayData = not na(wed_high) and not na(wed_count) and (array.size(eventTimes) > 0 ? wed_time != array.last(eventTimes) : true)

if isNewWednesdayData
    array.push(hiPrice, wed_high), array.push(loPrice, wed_low), array.push(opPrice, wed_open)
    array.push(eventTimes, wed_time), array.push(wedRank, wed_count)
    
    currentDay = dayofmonth(wed_time, TARGET_TIMEZONE)
    currentMonth = month(wed_time, TARGET_TIMEZONE)
    
    string monthStr = switch currentMonth
        1 => "Jan"
        2 => "Feb"
        3 => "Mar"
        4 => "Apr"
        5 => "May"
        6 => "Jun"
        7 => "Jul"
        8 => "Aug"
        9 => "Sep"
        10 => "Oct"
        11 => "Nov"
        => "Dec"

    dateStr = str.format("{0} {1}", currentDay, monthStr)
    array.push(dateLbl, dateStr)

// ───── REVISED MIDNIGHT LEVEL LOGIC (Non-Repainting & Efficient) ───────────
varip float midnightHigh_15m = na
varip float midnightLow_15m = na

isMidnightCandle = timeframe.isintraday and timeframe.multiplier == 15 and hour(time, TARGET_TIMEZONE) == 0 and minute(time, TARGET_TIMEZONE) == 0
if isMidnightCandle
    midnightHigh_15m := high
    midnightLow_15m := low

[h_req, l_req] = request.security(syminfo.tickerid, "15", [midnightHigh_15m[1], midnightLow_15m[1]], lookahead=barmerge.lookahead_off)

isNewDataPoint = not na(h_req) and (array.size(midnightLevels) > 0 ? h_req != array.last(midnightLevels).high : true)

if isNewDataPoint
    dayTimestamp = timestamp(TARGET_TIMEZONE, year(time_close[1], TARGET_TIMEZONE), month(time_close[1], TARGET_TIMEZONE), dayofmonth(time_close[1], TARGET_TIMEZONE), 0, 0)
    array.push(midnightLevels, midnightLevel.new(h_req, l_req, dayTimestamp))

    if showMidnightLevelsInput
        x2_time = extendRight ? time_close + 50 * (time_close - nz(time_close[1], time_close)) : dayTimestamp + MS_IN_DAY - 1

        array.push(midnightHighLines, line.new(dayTimestamp, h_req, x2_time, h_req, xloc=xloc.bar_time))
        array.push(midnightLowLines, line.new(dayTimestamp, l_req, x2_time, l_req, xloc=xloc.bar_time))
        
        if labelText
            dateString = str.format_time(dayTimestamp, "yyyy.MM.dd", TARGET_TIMEZONE)
            highLabelText = str.format("Midnight High {0} {1}", str.tostring(h_req, format.mintick), dateString)
            lowLabelText  = str.format("Midnight Low {0} {1}", str.tostring(l_req, format.mintick), dateString)

            array.push(midnightHighLabels, label.new(x2_time, h_req, highLabelText, xloc=xloc.bar_time, color=color(na), style=label.style_label_left, size=actualMidnightLabelSize, textalign=text.align_left))
            array.push(midnightLowLabels, label.new(x2_time, l_req, lowLabelText, xloc=xloc.bar_time, color=color(na), style=label.style_label_left, size=actualMidnightLabelSize, textalign=text.align_left))

    while array.size(midnightLevels) > midnightLookbackDaysInput
        array.shift(midnightLevels)
        if array.size(midnightHighLines) > 0
            line.delete(array.shift(midnightHighLines))
            line.delete(array.shift(midnightLowLines))
        if array.size(midnightHighLabels) > 0
            label.delete(array.shift(midnightHighLabels))
            label.delete(array.shift(midnightLowLabels))

// --- Midnight Drawing & Updates ---
if barstate.islast and array.size(midnightLevels) > 0
    visibleMidnightIndices = array.new_int()
    
    if enableLevelFiltering
        currentPrice = close
        
        // Create array of indices with their minimum distances
        array<indexDistance> midnightDistances = array.new<indexDistance>()
        
        for i = 0 to array.size(midnightLevels) - 1
            levelData = array.get(midnightLevels, i)
            minDist = math.min(math.abs(levelData.high - currentPrice), math.abs(levelData.low - currentPrice))
            array.push(midnightDistances, indexDistance.new(i, minDist))
        
        // Sort by distance using a simple bubble sort
        n = array.size(midnightDistances)
        for i = 0 to n - 2
            for j = 0 to n - i - 2
                if array.get(midnightDistances, j).dist > array.get(midnightDistances, j + 1).dist
                    temp = array.get(midnightDistances, j)
                    array.set(midnightDistances, j, array.get(midnightDistances, j + 1))
                    array.set(midnightDistances, j + 1, temp)
        
        // Separate into above and below
        aboveMidnightIndices = array.new_int()
        belowMidnightIndices = array.new_int()
        
        for i = 0 to array.size(midnightDistances) - 1
            item = array.get(midnightDistances, i)
            levelData = array.get(midnightLevels, item.idx)
            if levelData.high >= currentPrice or levelData.low >= currentPrice
                array.push(aboveMidnightIndices, item.idx)
            if levelData.high <= currentPrice or levelData.low <= currentPrice
                array.push(belowMidnightIndices, item.idx)
        
        // Take the required number of levels
        if array.size(aboveMidnightIndices) > 0
            for i = 0 to math.min(array.size(aboveMidnightIndices) - 1, levelsAbovePrice - 1)
                array.push(visibleMidnightIndices, array.get(aboveMidnightIndices, i))
        
        if array.size(belowMidnightIndices) > 0
            for i = 0 to math.min(array.size(belowMidnightIndices) - 1, levelsBelowPrice - 1)
                idx = array.get(belowMidnightIndices, i)
                if not array.includes(visibleMidnightIndices, idx)
                    array.push(visibleMidnightIndices, idx)
    else
        for i = 0 to array.size(midnightLevels) - 1
            array.push(visibleMidnightIndices, i)
    
    if array.size(midnightHighLines) > 0
        for i = 0 to array.size(midnightHighLines) - 1
            isVisible = array.includes(visibleMidnightIndices, i)
            
            highLine = array.get(midnightHighLines, i)
            if i < array.size(midnightLowLines)
                lowLine = array.get(midnightLowLines, i)
                highLine.set_color(showMidnightLevelsInput and isVisible ? midnightHighColorInput : color(na))
                highLine.set_style(getStyle(midnightHighStyleInput))
                highLine.set_width(midnightHighWidthInput)
                
                lowLine.set_color(showMidnightLevelsInput and isVisible ? midnightLowColorInput : color(na))
                lowLine.set_style(getStyle(midnightLowStyleInput))
                lowLine.set_width(midnightLowWidthInput)

            if labelText and i < array.size(midnightHighLabels) and i < array.size(midnightLowLabels)
                array.get(midnightHighLabels, i).set_textcolor(showMidnightLevelsInput and isVisible ? midnightHighLabelColorInput : color(na))
                array.get(midnightLowLabels, i).set_textcolor(showMidnightLevelsInput and isVisible ? midnightLowLabelColorInput : color(na))

if extendRight and showMidnightLevelsInput and array.size(midnightHighLines) > 0
    bar_width_ms = time - nz(time[1], time)
    if array.size(midnightHighLines) > 0
        for i = 0 to array.size(midnightHighLines) - 1
            if i < array.size(midnightHighLines)
                array.get(midnightHighLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(midnightLowLines)
                array.get(midnightLowLines, i).set_x2(time_close + 50 * bar_width_ms)
            if labelText and i < array.size(midnightHighLabels) and i < array.size(midnightLowLabels)
                array.get(midnightHighLabels, i).set_x(time_close + 50 * bar_width_ms)
                array.get(midnightLowLabels, i).set_x(time_close + 50 * bar_width_ms)

// ───── WICK-REACTION ALERT ENGINE ────────────────────────────────────────────
if barstate.isconfirmed
    min_oc = math.min(open, close)
    max_oc = math.max(open, close)
    canSend = timenow - lastAlertTime >= alertCooldown * 1000
    sent = false

    if array.size(eventTimes) > 0
        for i = 0 to array.size(eventTimes) - 1
            w = array.get(wedRank, i)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h = array.get(hiPrice, i)
            l = array.get(loPrice, i)
            o = array.get(opPrice, i)
            dStr = array.get(dateLbl, i)

            if showWednesdays and (high >= h and low <= h) and (h > max_oc or h < min_oc)
                hiCol = switch w
                    1 => hiC1
                    2 => hiC2
                    3 => hiC3
                    4 => hiC4
                    5 => hiC5
                    => na
                if showWickInteractions
                    label.new(time, h, "", xloc=xloc.bar_time, yloc=yloc.price, style=actualMarkerStyle, color=hiCol, size=actualMarkerSize)
                if canSend
                    sent := true, msg = str.format("WICK TOUCH – {0} Wednesday HIGH ({1})", dStr, syminfo.ticker)
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

            if showWednesdays and (high >= l and low <= l) and (l > max_oc or l < min_oc)
                loCol = switch w
                    1 => loC1
                    2 => loC2
                    3 => loC3
                    4 => loC4
                    5 => loC5
                    => na
                if showWickInteractions
                    label.new(time, l, "", xloc=xloc.bar_time, yloc=yloc.price, style=actualMarkerStyle, color=loCol, size=actualMarkerSize)
                if canSend
                    sent := true, msg = str.format("WICK TOUCH – {0} Wednesday LOW ({1})", dStr, syminfo.ticker)
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

            if showWednesdayOpen and (high >= o and low <= o) and (o > max_oc or o < min_oc)
                opCol = switch w
                    1 => opC1
                    2 => opC2
                    3 => opC3
                    4 => opC4
                    5 => opC5
                    => na
                if showWickInteractions
                    label.new(time, o, "", xloc=xloc.bar_time, yloc=yloc.price, style=actualMarkerStyle, color=opCol, size=actualMarkerSize)
                if canSend
                    sent := true, msg = str.format("WICK TOUCH – {0} Wednesday OPEN ({1})", dStr, syminfo.ticker)
                    if sendEmail 
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush 
                        alert(msg, alert.freq_once_per_bar)

    // Midnight lines
    if array.size(midnightLevels) > 0 and showMidnightLevelsInput
        for i = 0 to array.size(midnightLevels) - 1
            levelData = array.get(midnightLevels, i)
            h = levelData.high, l = levelData.low
            if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                sent := true, msg = "WICK TOUCH – Midnight HIGH (" + syminfo.ticker + ")"
                if sendEmail 
                    alert(msg, alert.freq_once_per_bar)
                if sendPush 
                    alert(msg, alert.freq_once_per_bar)
            if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                sent := true, msg = "WICK TOUCH – Midnight LOW (" + syminfo.ticker + ")"
                if sendEmail 
                    alert(msg, alert.freq_once_per_bar)
                if sendPush 
                    alert(msg, alert.freq_once_per_bar)

    if sent
        lastAlertTime := timenow

// ───── EXECUTION & DRAWING ───────────────────────────────────────────────────
if barstate.islast
    // --- Cleanup previous drawings ---
    for id in wednesdayHighLines
        line.delete(id)
    for id in wednesdayLowLines
        line.delete(id)
    for id in wednesdayOpenLines
        line.delete(id)
    for id in wednesdayHighLabels
        label.delete(id)
    for id in wednesdayLowLabels
        label.delete(id)
    for id in wednesdayOpenLabels
        label.delete(id)

    array.clear(wednesdayHighLines), array.clear(wednesdayLowLines), array.clear(wednesdayOpenLines)
    array.clear(wednesdayHighLabels), array.clear(wednesdayLowLabels), array.clear(wednesdayOpenLabels)

    if (showWednesdays or showWednesdayOpen) and array.size(eventTimes) > 0
        filteredIndices = array.new_int()

        if enableLevelFiltering
            currentPrice = close
            
            // Create array of indices with their minimum distances
            array<wedIndexDistance> wednesdayDistances = array.new<wedIndexDistance>()
            
            for i = 0 to array.size(eventTimes) - 1
                h = array.get(hiPrice, i)
                l = array.get(loPrice, i)
                o = array.get(opPrice, i)
                minDist = math.min(math.abs(h - currentPrice), math.abs(l - currentPrice), math.abs(o - currentPrice))
                array.push(wednesdayDistances, wedIndexDistance.new(i, minDist))
            
            // Sort by distance using bubble sort
            n = array.size(wednesdayDistances)
            for i = 0 to n - 2
                for j = 0 to n - i - 2
                    if array.get(wednesdayDistances, j).dist > array.get(wednesdayDistances, j + 1).dist
                        temp = array.get(wednesdayDistances, j)
                        array.set(wednesdayDistances, j, array.get(wednesdayDistances, j + 1))
                        array.set(wednesdayDistances, j + 1, temp)
            
            // Separate into above and below
            aboveIndices = array.new_int()
            belowIndices = array.new_int()
            
            for i = 0 to array.size(wednesdayDistances) - 1
                item = array.get(wednesdayDistances, i)
                h = array.get(hiPrice, item.idx)
                l = array.get(loPrice, item.idx)
                o = array.get(opPrice, item.idx)
                if h >= currentPrice or l >= currentPrice or o >= currentPrice
                    array.push(aboveIndices, item.idx)
                if h <= currentPrice or l <= currentPrice or o <= currentPrice
                    array.push(belowIndices, item.idx)

            // Take the required number of levels
            if array.size(aboveIndices) > 0
                for i = 0 to math.min(array.size(aboveIndices) - 1, levelsAbovePrice - 1)
                    array.push(filteredIndices, array.get(aboveIndices, i))
            
            if array.size(belowIndices) > 0
                for i = 0 to math.min(array.size(belowIndices) - 1, levelsBelowPrice - 1)
                    idx = array.get(belowIndices, i)
                    if not array.includes(filteredIndices, idx)
                        array.push(filteredIndices, idx)
        else
            for i = 0 to array.size(eventTimes) - 1
                array.push(filteredIndices, i)

        bar_width_ms = time - nz(time[1], time)
        for i = 0 to array.size(filteredIndices) - 1
            originalIndex = array.get(filteredIndices, i)
            w = array.get(wedRank, originalIndex)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h = array.get(hiPrice, originalIndex), l = array.get(loPrice, originalIndex), o = array.get(opPrice, originalIndex)
            t = array.get(eventTimes, originalIndex), dStr = array.get(dateLbl, originalIndex)

            hiCol = switch w
                1 => hiC1
                2 => hiC2
                3 => hiC3
                4 => hiC4
                5 => hiC5
                => na
            loCol = switch w
                1 => loC1
                2 => loC2
                3 => loC3
                4 => loC4
                5 => loC5
                => na
            opCol = switch w
                1 => opC1
                2 => opC2
                3 => opC3
                4 => opC4
                5 => opC5
                => na
            hiW = switch w
                1 => hiW1
                2 => hiW2
                3 => hiW3
                4 => hiW4
                5 => hiW5
                => na
            loW = switch w
                1 => loW1
                2 => loW2
                3 => loW3
                4 => loW4
                5 => loW5
                => na
            opW = switch w
                1 => opW1
                2 => opW2
                3 => opW3
                4 => opW4
                5 => opW5
                => na
            
            x2 = extendRight ? t + 50 * bar_width_ms : t + MS_IN_DAY - 1
            label_x_position = extendRight ? t + (wednesdayLabelOffset + 50) * bar_width_ms : x2
            
            if showWednesdays
                array.push(wednesdayHighLines, line.new(t, h, x2, h, xloc=xloc.bar_time, color=hiCol, width=hiW))
                array.push(wednesdayLowLines, line.new(t, l, x2, l, xloc=xloc.bar_time, color=loCol, width=loW))
            if showWednesdayOpen
                array.push(wednesdayOpenLines, line.new(t, o, x2, o, xloc=xloc.bar_time, color=opCol, width=opW))
            
            if labelText
                highLabelText = str.format("{0} High {1}", dStr, str.tostring(h, format.mintick))
                lowLabelText  = str.format("{0} Low {1}", dStr, str.tostring(l, format.mintick))
                openLabelText = str.format("{0} Open {1}", dStr, str.tostring(o, format.mintick))
                if showWednesdays
                    array.push(wednesdayHighLabels, label.new(label_x_position, h, highLabelText, xloc=xloc.bar_time, color=color(na), textcolor=hiCol, style=label.style_label_right, size=actualLabelSize, textalign=text.align_left))
                    array.push(wednesdayLowLabels, label.new(label_x_position, l, lowLabelText, xloc=xloc.bar_time, color=color(na), textcolor=loCol, style=label.style_label_right, size=actualLabelSize, textalign=text.align_left))
                if showWednesdayOpen
                    array.push(wednesdayOpenLabels, label.new(label_x_position, o, openLabelText, xloc=xloc.bar_time, color=color(na), textcolor=opCol, style=label.style_label_right, size=actualLabelSize, textalign=text.align_left))

if extendRight and (showWednesdays or showWednesdayOpen)
    bar_width_ms = time - nz(time[1], time)
    if array.size(wednesdayHighLines) > 0
        for i = 0 to array.size(wednesdayHighLines) - 1
            if i < array.size(wednesdayHighLines)
                array.get(wednesdayHighLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(wednesdayHighLabels)
                array.get(wednesdayHighLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)
    if array.size(wednesdayLowLines) > 0
        for i = 0 to array.size(wednesdayLowLines) - 1
            if i < array.size(wednesdayLowLines)
                array.get(wednesdayLowLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(wednesdayLowLabels)
                array.get(wednesdayLowLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)
    if array.size(wednesdayOpenLines) > 0
        for i = 0 to array.size(wednesdayOpenLines) - 1
            if i < array.size(wednesdayOpenLines)
                array.get(wednesdayOpenLines, i).set_x2(time_close + 50 * bar_width_ms)
            if i < array.size(wednesdayOpenLabels)
                array.get(wednesdayOpenLabels, i).set_x(time_close + (wednesdayLabelOffset + 50) * bar_width_ms)
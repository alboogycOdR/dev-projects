// ┌─────────────────────────────────────────────────────────────────────────────┐
// │  WED & MIDNIGHT DST System v0.4 – TEST VERSION (Enhanced Alert Testing)    │
// │  © 2024 – Free to use & modify                                             │
// └─────────────────────────────────────────────────────────────────────────────┘
// ───── DESCRIPTION ─────────────────────────────────────────────────────────────────
//
// TEST VERSION - Enhanced for Alert System Testing
// This version includes:
// - Reduced alert cooldowns for faster testing
// - Additional test alerts for easier verification
// - Enhanced visual feedback for testing
// - Simulated wick interactions for testing
//
//🚀 HOW TO TEST:
//Quick Start Test:
//Load the test script on any chart
//Enable "Test Alerts" in the settings
//Set cooldown to 1 second
//Enable both Email and Push
//Watch for test alerts every 10 bars
//Wednesday Line Testing:
//Go to a Wednesday (like January 2025)
//Enable all Wednesday lines (showW1, showW2, etc.)
//Look for candles with wicks touching the lines
//Verify both visual markers and alerts
//Midnight Level Testing:
//Enable midnight levels
//Look for wick interactions with midnight lines
//Check for midnight-specific alerts
// TEST CHECKLIST:
//[ ] Test Alerts: Should trigger every 10 bars
//[ ] Wednesday Alerts: Trigger when wicks touch Wednesday lines
//[ ] Midnight Alerts: Trigger when wicks touch midnight levels
//[ ] Visual Markers: Appear at interaction points
//[ ] Email Delivery: Check email notifications
//[ ] Push Notifications: Check mobile/desktop alerts
//[ ] Cooldown System: Alerts respect the 1-second cooldown
// -----------------------------------------------------------------------------
// │ KEY FEATURES                                                                │
// -----------------------------------------------------------------------------
//
// 1. Wednesday SAST Lines:
//    - Identifies the high, low, and open of the first five Wednesdays of each month.
//    - The specific time for capturing the high/low is 20:30 SAST, which the
//      script automatically adjusts to account for US Daylight Saving Time changes,
//      switching between 19:30 and 20:30 UTC as needed.
//    - Each of the five Wednesdays has its own customizable display settings,
//      allowing users to toggle visibility, and set unique colors and line widths
//      for the high, low, and open lines.
//    - This feature helps traders track monthly price ranges based on a consistent
//      weekly event.
//
// 2. Midnight Levels (UTC+2):
//    - Plots the high and low of the 00:00 candle (15-minute timeframe) for each
//      day, based on the UTC+2 timezone.
//    - Users can specify a lookback period (in days) to display these historical
//      midnight levels on the chart.
//    - The appearance of the high and low lines (color, style, width) is fully
//      customizable.
//    - This is useful for strategies that focus on the opening range of the
//      European sessions.
//
// 3. Wick Interaction Visuals:
//    - Displays a visual marker (e.g., a small circle) on any candle that wicks
//      into one of the active Wednesday price lines (High, Low, or Open).
//    - This feature is fully customizable, allowing users to enable or disable the
//      markers and adjust their size and style. The marker's color automatically
//      matches the color of the line it interacts with.
//    - This provides immediate visual feedback on how price is reacting to the
//      key Wednesday levels.
//
// 4. Enhanced Alert System (TEST VERSION):
//    - Real-time alerts when price wicks touch Wednesday lines (High, Low, or Open).
//    - Real-time alerts when price wicks touch Midnight levels (High or Low).
//    - Configurable alert delivery: Email and/or Push notifications.
//    - REDUCED alert cooldown for faster testing (1 second default).
//    - Detailed alert messages include the specific line type and symbol information.
//    - TEST FEATURE: Additional test alerts for easier verification.
//    - TEST FEATURE: Enhanced visual feedback for alert testing.
//
// 5. General Settings:
//    - Line Extension: All lines can be configured to either extend indefinitely
//      into the future or stop at the end of their respective day.
//    - Date Labels: Optional labels can be displayed to mark the specific date
//      and type of each line (e.g., "DD Mon High", "Midnight Low").
//    - Dynamic Updates: The script is built to handle drawing a large number of
//      lines and labels efficiently without causing chart lag.
//    - Multi-timeframe compatibility: Works on any timeframe without restrictions.
//
// -----------------------------------------------------------------------------
//@version=5
indicator(
     title   = "WED & MIDNIGHT DST System v0.4 (TEST VERSION)",
     overlay = true,
     max_lines_count  = 500,
     max_labels_count = 500,
     dynamic_requests = true)

// ───── TEST ALERT SWITCHES ────────────────────────────────────────────────────────
GROUP_ALERT = "Alerts (TEST VERSION)"
sendEmail     = input.bool(true,  "Send Email",        group=GROUP_ALERT)
sendPush      = input.bool(true,  "Send Push",         group=GROUP_ALERT)
alertCooldown = input.int(1,     "Cooldown (sec)", minval=1, group=GROUP_ALERT,
                          tooltip="TEST VERSION: Reduced to 1 second for faster testing")
enableTestAlerts = input.bool(true, "Enable Test Alerts", group=GROUP_ALERT,
                              tooltip="TEST FEATURE: Additional alerts for testing")

// ───── WEDNESDAY LINES ───────────────────────────────────────────────────────
GROUP_WEDNESDAY = "Wednesday SAST Lines"
showWednesdays = input.bool(true, "Show Wednesday High/Low Lines", group=GROUP_WEDNESDAY, tooltip="Master switch to show/hide Wednesday High/Low lines.")
showWednesdayOpen = input.bool(true, "Show Wednesday Open Line", group=GROUP_WEDNESDAY, tooltip="Toggles the visibility of the Wednesday Open line.")

showW1 = input.bool(true, "Show 1st Wednesday", group=GROUP_WEDNESDAY)
hiC1 = input.color(color.new(color.red, 0), "", inline="1H", group=GROUP_WEDNESDAY)
loC1 = input.color(color.new(color.blue, 0), "", inline="1L", group=GROUP_WEDNESDAY)
opC1 = input.color(color.new(color.yellow, 0), "", inline="1O", group=GROUP_WEDNESDAY)
hiW1 = input.int(2, "Width", minval=1, maxval=10, inline="1H", group=GROUP_WEDNESDAY)
loW1 = input.int(2, "Width", minval=1, maxval=10, inline="1L", group=GROUP_WEDNESDAY)
opW1 = input.int(2, "Width", minval=1, maxval=10, inline="1O", group=GROUP_WEDNESDAY)

showW2 = input.bool(true, "Show 2nd Wednesday", group=GROUP_WEDNESDAY)
hiC2 = input.color(color.new(color.orange, 0), "", inline="2H", group=GROUP_WEDNESDAY)
loC2 = input.color(color.new(color.aqua, 0), "", inline="2L", group=GROUP_WEDNESDAY)
opC2 = input.color(color.new(color.yellow, 0), "", inline="2O", group=GROUP_WEDNESDAY)
hiW2 = input.int(2, "Width", minval=1, maxval=10, inline="2H", group=GROUP_WEDNESDAY)
loW2 = input.int(2, "Width", minval=1, maxval=10, inline="2L", group=GROUP_WEDNESDAY)
opW2 = input.int(2, "Width", minval=1, maxval=10, inline="2O", group=GROUP_WEDNESDAY)

showW3 = input.bool(true, "Show 3rd Wednesday", group=GROUP_WEDNESDAY)
hiC3 = input.color(color.new(color.green, 0), "", inline="3H", group=GROUP_WEDNESDAY)
loC3 = input.color(color.new(color.fuchsia, 0), "", inline="3L", group=GROUP_WEDNESDAY)
opC3 = input.color(color.new(color.yellow, 0), "", inline="3O", group=GROUP_WEDNESDAY)
hiW3 = input.int(2, "Width", minval=1, maxval=10, inline="3H", group=GROUP_WEDNESDAY)
loW3 = input.int(2, "Width", minval=1, maxval=10, inline="3L", group=GROUP_WEDNESDAY)
opW3 = input.int(2, "Width", minval=1, maxval=10, inline="3O", group=GROUP_WEDNESDAY)

showW4 = input.bool(true, "Show 4th Wednesday", group=GROUP_WEDNESDAY)
hiC4 = input.color(color.new(color.purple, 0), "", inline="4H", group=GROUP_WEDNESDAY)
loC4 = input.color(color.new(color.lime, 0), "", inline="4L", group=GROUP_WEDNESDAY)
opC4 = input.color(color.new(color.yellow, 0), "", inline="4O", group=GROUP_WEDNESDAY)
hiW4 = input.int(2, "Width", minval=1, maxval=10, inline="4H", group=GROUP_WEDNESDAY)
loW4 = input.int(2, "Width", minval=1, maxval=10, inline="4L", group=GROUP_WEDNESDAY)
opW4 = input.int(2, "Width", minval=1, maxval=10, inline="4O", group=GROUP_WEDNESDAY)

showW5 = input.bool(false, "Show 5th Wednesday", group=GROUP_WEDNESDAY)
hiC5 = input.color(color.new(color.gray, 0), "", inline="5H", group=GROUP_WEDNESDAY)
loC5 = input.color(color.new(color.black, 0), "", inline="5L", group=GROUP_WEDNESDAY)
opC5 = input.color(color.new(color.yellow, 0), "", inline="5O", group=GROUP_WEDNESDAY)
hiW5 = input.int(2, "Width", minval=1, maxval=10, inline="5H", group=GROUP_WEDNESDAY)
loW5 = input.int(2, "Width", minval=1, maxval=10, inline="5L", group=GROUP_WEDNESDAY)
opW5 = input.int(2, "Width", minval=1, maxval=10, inline="5O", group=GROUP_WEDNESDAY)

// ───── MIDNIGHT LEVELS ───────────────────────────────────────────────────────
GROUP_MIDNIGHT = "Midnight Levels"
showMidnightLevelsInput = input.bool(true, 'Show Midnight Levels', group=GROUP_MIDNIGHT, tooltip='Shows the high and low of the 00:00 (UTC+2) candle on the 15m timeframe.')
midnightLookbackDaysInput = input.int(21, 'Lookback (Days)', group=GROUP_MIDNIGHT, minval=1, tooltip='Number of past days to show the midnight levels for.')
midnightHighColorInput = input.color(color.new(color.orange, 50), 'High Color', group=GROUP_MIDNIGHT, inline='mlHigh')
midnightHighStyleInput = input.string("Solid", 'High Style', group=GROUP_MIDNIGHT, options=["Solid", "Dashed", "Dotted"], inline='mlHigh')
midnightHighWidthInput = input.int(1, 'High Width', group=GROUP_MIDNIGHT, minval=1, maxval=4, inline='mlHigh')
midnightLowColorInput = input.color(color.new(color.purple, 50), 'Low Color', group=GROUP_MIDNIGHT, inline='mlLow')
midnightLowStyleInput = input.string("Solid", 'Low Style', group=GROUP_MIDNIGHT, options=["Solid", "Dashed", "Dotted"], inline='mlLow')
midnightLowWidthInput = input.int(1, 'Low Width', group=GROUP_MIDNIGHT, minval=1, maxval=4, inline='mlLow')

// ───── INTERACTION VISUALS ───────────────────────────────────────────────────
GROUP_INTERACTION = "Interaction Visuals"
showWickInteractions = input.bool(true, "Show Wick Interactions", group=GROUP_INTERACTION, tooltip="Master switch to show/hide all wick interaction markers.")
interactionMarkerStyle = input.string("Circle", "Marker Style", options=["Circle", "Square", "Diamond", "Triangle Up", "Triangle Down"], group=GROUP_INTERACTION)
interactionMarkerSize = input.string("Tiny", "Marker Size", options=["Tiny", "Small", "Normal", "Large", "Huge"], group=GROUP_INTERACTION)

// ───── GENERAL SETTINGS ──────────────────────────────────────────────────────
GROUP_GENERAL = "General Settings"
extendRight = input.bool(true, "Extend Lines into Future", group=GROUP_GENERAL)
labelText   = input.bool(true, "Show Date Labels", group=GROUP_GENERAL)
labelSize   = input.string("Tiny", "Label Size", options=["Tiny","Small","Normal","Large","Huge"], group=GROUP_GENERAL)

// ───── CONSTANTS & HELPERS ───────────────────────────────────────────────────
TARGET_TZ = "UTC+2"
DAY_WED   = 4

f_style(style) =>
    style == "Solid"  ? line.style_solid :
      style == "Dashed" ? line.style_dashed :
      style == "Dotted" ? line.style_dotted : line.style_solid

f_marker(style) =>
    style == "Circle"        ? label.style_circle :
      style == "Square"      ? label.style_square :
      style == "Diamond"     ? label.style_diamond :
      style == "Triangle Up" ? label.style_triangleup :
      style == "Triangle Down" ? label.style_triangledown : label.style_circle

f_size(sizeStr) =>
    sizeStr == "Tiny"   ? size.tiny :
      sizeStr == "Small" ? size.small :
      sizeStr == "Normal" ? size.normal :
      sizeStr == "Large" ? size.large :
      sizeStr == "Huge" ? size.huge : size.auto

// ───── STORAGE ───────────────────────────────────────────────────────────────
// Wednesday Lines Storage
var float[] hiPrice = array.new<float>()
var float[] loPrice = array.new<float>()
var float[] opPrice = array.new<float>()
var int[] eventTimes = array.new<int>()
var int[] wedRank = array.new<int>()
var string[] dateLbl = array.new<string>()

// Midnight Levels Storage
var int[] midDays = array.new<int>()
var float[] midHighs = array.new<float>()
var float[] midLows = array.new<float>()

// ───── ALERT COOLDOWN ────────────────────────────────────────────────────────
var int lastAlertTime = 0

// ───── WEDNESDAY CAPTURE LOGIC ───────────────────────────────────────────────
f_getTargetHour(y, m, d) =>
    isDst = (y == 2025 and ((m > 3 and m < 11) or (m == 3 and d >= 9) or (m == 11 and d < 2))) or (y == 2026 and ((m > 3 and m < 11) or (m == 3 and d >= 8) or (m == 11 and d < 1)))
    hour = isDst ? 19 : 20
    [hour, 30]

isWednesday = dayofweek(time, TARGET_TZ) == DAY_WED
if isWednesday and barstate.isconfirmed
    y = year(time, TARGET_TZ)
    m = month(time, TARGET_TZ)
    d = dayofmonth(time, TARGET_TZ)

    wedCount = 0
    for i = 1 to d
        cand = timestamp(TARGET_TZ, y, m, i, 12, 0)
        if month(cand, TARGET_TZ) == m and dayofweek(cand, TARGET_TZ) == DAY_WED
            wedCount += 1

    if wedCount <= 5
        [h, targetMin] = f_getTargetHour(y, m, d)
        isTargetTime = hour(time, TARGET_TZ) == h and minute(time, TARGET_TZ) == targetMin
        
        if isTargetTime
            array.push(hiPrice, high)
            array.push(loPrice, low)
            array.push(opPrice, open)
            array.push(eventTimes, time)
            array.push(wedRank, wedCount)
            array.push(dateLbl, str.format("{0} {1}", d,
               m == 1 ? "Jan" : m == 2 ? "Feb" : m == 3 ? "Mar" : m == 4 ? "Apr" :
               m == 5 ? "May" : m == 6 ? "Jun" : m == 7 ? "Jul" : m == 8 ? "Aug" :
               m == 9 ? "Sep" : m == 10 ? "Oct" : m == 11 ? "Nov" : "Dec"))

// ───── MIDNIGHT LEVEL CAPTURE ────────────────────────────────────────────────
if showMidnightLevelsInput and barstate.isconfirmed
    y = year(time, TARGET_TZ)
    m = month(time, TARGET_TZ)
    d = dayofmonth(time, TARGET_TZ)
    newDay = y != year[1] or m != month[1] or d != dayofmonth[1]
    if newDay
        h = request.security(syminfo.tickerid, "15", high[1], lookahead=barmerge.lookahead_on)
        l = request.security(syminfo.tickerid, "15", low[1],  lookahead=barmerge.lookahead_on)
        if not na(h) and not na(l)
            array.push(midDays,  timestamp(TARGET_TZ, y, m, d, 0, 0))
            array.push(midHighs, h)
            array.push(midLows,  l)
    while array.size(midDays) > midnightLookbackDaysInput
        array.shift(midDays)
        array.shift(midHighs)
        array.shift(midLows)

// ───── TEST ALERT ENGINE ─────────────────────────────────────────────────────
if barstate.isconfirmed
    min_oc = math.min(open, close)
    max_oc = math.max(open, close)
    bool canSend = timenow - lastAlertTime >= alertCooldown * 1000
    bool sent = false

    // TEST FEATURE: Additional test alerts every 10 bars
    if enableTestAlerts and canSend and bar_index % 10 == 0
        sent := true
        testMsg = str.format("TEST ALERT - Bar {0} ({1})", bar_index, syminfo.ticker)
        if sendEmail
            alert(testMsg, alert.freq_once_per_bar)
        if sendPush
            alert(testMsg, alert.freq_once_per_bar)

    // Wednesday lines
    if array.size(eventTimes) > 0
        for i = 0 to array.size(eventTimes) - 1
            w = array.get(wedRank, i)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h = array.get(hiPrice, i)
            l = array.get(loPrice, i)
            o = array.get(opPrice, i)
            dStr = array.get(dateLbl, i)

            // Check High Line Interaction (wick only)
            if showWednesdays and (high >= h and low <= h) and (h > max_oc or h < min_oc)
                hiCol = switch w
                    1 => hiC1
                    2 => hiC2
                    3 => hiC3
                    4 => hiC4
                    5 => hiC5
                    => na
                if showWickInteractions
                    label.new(time, h, "", xloc=xloc.bar_time, yloc=yloc.price, style=f_marker(interactionMarkerStyle), color=hiCol, size=f_size(interactionMarkerSize))
                if canSend
                    sent := true
                    msg = str.format("WICK TOUCH – {0} Wednesday HIGH ({1})", dStr, syminfo.ticker)
                    if sendEmail
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush
                        alert(msg, alert.freq_once_per_bar)

            // Check Low Line Interaction (wick only)
            if showWednesdays and (high >= l and low <= l) and (l > max_oc or l < min_oc)
                loCol = switch w
                    1 => loC1
                    2 => loC2
                    3 => loC3
                    4 => loC4
                    5 => loC5
                    => na
                if showWickInteractions
                    label.new(time, l, "", xloc=xloc.bar_time, yloc=yloc.price, style=f_marker(interactionMarkerStyle), color=loCol, size=f_size(interactionMarkerSize))
                if canSend
                    sent := true
                    msg = str.format("WICK TOUCH – {0} Wednesday LOW ({1})", dStr, syminfo.ticker)
                    if sendEmail
                        alert(msg, alert.freq_once_per_bar)
                    if sendPush
                        alert(msg, alert.freq_once_per_bar)

            // Check Open Line Interaction (wick only)
            if showWednesdayOpen and (high >= o and low <= o) and (o > max_oc or o < min_oc)
                opCol = switch w
                    1 => opC1
                    2 => opC2
                    3 => opC3
                    4 => opC4
                    5 => opC5
                    => na
                if showWickInteractions
                    label.new(time, o, "", xloc=xloc.bar_time, yloc=yloc.price, style=f_marker(interactionMarkerStyle), color=opCol, size=f_size(interactionMarkerSize))
                if canSend
                    sent := true
                    msg = str.format("WICK TOUCH – {0} Wednesday OPEN ({1})", dStr, syminfo.ticker)
                    if sendPush
                        alert(msg, alert.freq_once_per_bar)
                    if sendEmail
                        alert(msg, alert.freq_once_per_bar)

    // Midnight lines
    if array.size(midDays) > 0
        for i = 0 to array.size(midDays) - 1
            h = array.get(midHighs, i)
            l = array.get(midLows,  i)

            if canSend and high >= h and low <= h and (h > max_oc or h < min_oc)
                sent := true
                msg = "WICK TOUCH – Midnight HIGH (" + syminfo.ticker + ")"
                if sendEmail
                    alert(msg, alert.freq_once_per_bar)
                if sendPush
                    alert(msg, alert.freq_once_per_bar)

            if canSend and high >= l and low <= l and (l > max_oc or l < min_oc)
                sent := true
                msg = "WICK TOUCH – Midnight LOW (" + syminfo.ticker + ")"
                if sendEmail
                    alert(msg, alert.freq_once_per_bar)
                if sendPush
                    alert(msg, alert.freq_once_per_bar)

    if sent
        lastAlertTime := timenow

// ───── DRAW LINES & LABELS ───────────────────────────────────────────────────
if barstate.islast
    // Wednesday lines
    if (showWednesdays or showWednesdayOpen) and array.size(eventTimes) > 0
        for i = 0 to array.size(eventTimes) - 1
            w = array.get(wedRank, i)
            show = switch w
                1 => showW1
                2 => showW2
                3 => showW3
                4 => showW4
                5 => showW5
                => false
            if not show
                continue
            h   = array.get(hiPrice, i)
            l   = array.get(loPrice, i)
            o   = array.get(opPrice, i)
            t   = array.get(eventTimes, i)
            dStr= array.get(dateLbl, i)

            hiCol = switch w
                1 => hiC1  
                2 => hiC2  
                3 => hiC3  
                4 => hiC4  
                5 => hiC5
            loCol = switch w
                1 => loC1  
                2 => loC2  
                3 => loC3  
                4 => loC4  
                5 => loC5
            opCol = switch w
                1 => opC1  
                2 => opC2  
                3 => opC3  
                4 => opC4  
                5 => opC5
            hiW = switch w
                1 => hiW1  
                2 => hiW2  
                3 => hiW3  
                4 => hiW4  
                5 => hiW5
            loW = switch w
                1 => loW1  
                2 => loW2  
                3 => loW3  
                4 => loW4  
                5 => loW5
            opW = switch w
                1 => opW1  
                2 => opW2  
                3 => opW3  
                4 => opW4  
                5 => opW5

            x2 = extendRight ? time : t + 24*60*60*1000

            if showWednesdays
                line.new(t, h, x2, h, xloc=xloc.bar_time, color=hiCol, width=hiW, style=line.style_solid)
                line.new(t, l, x2, l, xloc=xloc.bar_time, color=loCol, width=loW, style=line.style_solid)
            if showWednesdayOpen
                line.new(t, o, x2, o, xloc=xloc.bar_time, color=opCol, width=opW, style=line.style_solid)
            if labelText
                if showWednesdays
                    label.new(x2, h, dStr + " High", xloc=xloc.bar_time, color=hiCol, textcolor=color.white, style=label.style_label_down, size=f_size(labelSize))
                    label.new(x2, l, dStr + " Low",  xloc=xloc.bar_time, color=loCol, textcolor=color.white, style=label.style_label_up,   size=f_size(labelSize))
                if showWednesdayOpen
                    label.new(x2, o, dStr + " Open", xloc=xloc.bar_time, color=opCol, textcolor=color.white, style=label.style_label_right,size=f_size(labelSize))

    // Midnight lines
    if array.size(midDays) > 0
        for i = 0 to array.size(midDays) - 1
            t   = array.get(midDays, i)
            h   = array.get(midHighs, i)
            l   = array.get(midLows,  i)
            x2  = extendRight ? time : t + 24*60*60*1000
            line.new(t, h, x2, h, xloc=xloc.bar_time, color=midnightHighColorInput, width=midnightHighWidthInput, style=f_style(midnightHighStyleInput))
            line.new(t, l, x2, l, xloc=xloc.bar_time, color=midnightLowColorInput,  width=midnightLowWidthInput,  style=f_style(midnightLowStyleInput))
            if labelText
                label.new(x2, h, "Midnight High", xloc=xloc.bar_time, color=midnightHighColorInput, textcolor=color.white, style=label.style_label_down, size=f_size(labelSize))
                label.new(x2, l, "Midnight Low",  xloc=xloc.bar_time, color=midnightLowColorInput,  textcolor=color.white, style=label.style_label_up,   size=f_size(labelSize)) 
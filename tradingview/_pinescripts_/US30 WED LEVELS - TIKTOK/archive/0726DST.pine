//@version=5
indicator("Wednesday SAST Lines with Custom Time Logic",
          overlay=true,
          max_lines_count=500,
          max_labels_count=500)

// ───── INPUTS ────────────────────────────────────────────────────────────────
// 1st Wednesday
showW1 = input.bool(true, "Show 1st Wednesday")
hiC1 = input.color(color.new(color.red, 0), "", inline="1H")
loC1 = input.color(color.new(color.blue, 0), "", inline="1L")
hiW1 = input.int(2, "Width", minval=1, maxval=10, inline="1H")
loW1 = input.int(2, "Width", minval=1, maxval=10, inline="1L")

// 2nd Wednesday
showW2 = input.bool(true, "Show 2nd Wednesday")
hiC2 = input.color(color.new(color.orange, 0), "", inline="2H")
loC2 = input.color(color.new(color.aqua, 0), "", inline="2L")
hiW2 = input.int(2, "Width", minval=1, maxval=10, inline="2H")
loW2 = input.int(2, "Width", minval=1, maxval=10, inline="2L")

// 3rd Wednesday
showW3 = input.bool(true, "Show 3rd Wednesday")
hiC3 = input.color(color.new(color.green, 0), "", inline="3H")
loC3 = input.color(color.new(color.fuchsia, 0), "", inline="3L")
hiW3 = input.int(2, "Width", minval=1, maxval=10, inline="3H")
loW3 = input.int(2, "Width", minval=1, maxval=10, inline="3L")

// 4th Wednesday
showW4 = input.bool(true, "Show 4th Wednesday")
hiC4 = input.color(color.new(color.purple, 0), "", inline="4H")
loC4 = input.color(color.new(color.lime, 0), "", inline="4L")
hiW4 = input.int(2, "Width", minval=1, maxval=10, inline="4H")
loW4 = input.int(2, "Width", minval=1, maxval=10, inline="4L")

// 5th Wednesday
showW5 = input.bool(false, "Show 5th Wednesday")
hiC5 = input.color(color.new(color.gray, 0), "", inline="5H")
loC5 = input.color(color.new(color.black, 0), "", inline="5L")
hiW5 = input.int(2, "Width", minval=1, maxval=10, inline="5H")
loW5 = input.int(2, "Width", minval=1, maxval=10, inline="5L")

extendRight = input.bool(true, "Extend Lines into Future")
labelText = input.bool(true, "Show Date Labels")
labelSize = input.string("Tiny", "Label Size", options = ["Tiny", "Small", "Normal", "Large", "Huge"])

// ───── CONSTANTS ─────────────────────────────────────────────────────────────
TARGET_TIMEZONE = "UTC+2"
DAYOFWED        = 4     // 1=Sun, 2=Mon, 3=Tue, 4=Wed, 5=Thu, 6=Fri, 7=Sat

// ───── CUSTOM TIME LOGIC ─────────────────────────────────────────────────────
f_getTargetTime(ts) =>
    _year = year(ts, "UTC")
    _month = month(ts, "UTC")
    _day = dayofmonth(ts, "UTC")

    _targetHour = 20 // Default to 20:30
    _targetMin = 30

    // Period 1: 9 March 2025 to 2 November 2025 -> Use 19:30
    isPeriod1 = false
    if _year == 2025 and ((_month > 3 and _month < 11) or (_month == 3 and _day >= 9) or (_month == 11 and _day < 2))
        isPeriod1 := true
    
    // Period 2: 3 November 2025 to 8 March 2026 -> Use 20:30
    isPeriod2 = false
    if (_year == 2025 and (_month > 11 or (_month == 11 and _day >= 3))) or (_year == 2026 and (_month < 3 or (_month == 3 and _day < 8)))
        isPeriod2 := true
        
    if isPeriod1
        _targetHour := 19
    else if isPeriod2
        _targetHour := 20
        
    [_targetHour, _targetMin]

[targetHour, targetMin] = f_getTargetTime(time)

f_size_str_to_const(size_str) =>
    size_str == "Tiny" ? size.tiny :
      size_str == "Small" ? size.small :
      size_str == "Normal" ? size.normal :
      size_str == "Large" ? size.large :
      size_str == "Huge" ? size.huge : size.auto

actualLabelSize = f_size_str_to_const(labelSize)

// ───── STORAGE ───────────────────────────────────────────────────────────────
var float[] hiPrice = array.new<float>()
var float[] loPrice = array.new<float>()
var int[] eventTimes = array.new<int>()
var int[] wedRank = array.new<int>() // 1..5
var string[] dates = array.new<string>()

// ───── DETECT WEDNESDAY TARGET TIME IN SAST ─────────────────────────────────
isWednesday = dayofweek(time, TARGET_TIMEZONE) == DAYOFWED
isTargetTime = hour(time, TARGET_TIMEZONE) == targetHour and minute(time, TARGET_TIMEZONE) == targetMin

if isWednesday and isTargetTime and barstate.isconfirmed
    // Calculate which Wednesday of the month this is
    currentDay = dayofmonth(time, TARGET_TIMEZONE)
    currentMonth = month(time, TARGET_TIMEZONE)
    currentYear = year(time, TARGET_TIMEZONE)
    
    wedCount = 0
    for d = 1 to currentDay
        testTime = timestamp(TARGET_TIMEZONE, currentYear, currentMonth, d, 12, 0)
        if month(testTime, TARGET_TIMEZONE) == currentMonth and dayofweek(testTime, TARGET_TIMEZONE) == DAYOFWED
            wedCount += 1
    
    if wedCount <= 5
        // Store the data
        array.push(hiPrice, high)
        array.push(loPrice, low)
        array.push(eventTimes, time)
        array.push(wedRank, wedCount)
        dateStr = str.format("{0} {1}", currentDay,
           currentMonth == 1 ? "Jan" :
           currentMonth == 2 ? "Feb" :
           currentMonth == 3 ? "Mar" :
           currentMonth == 4 ? "Apr" :
           currentMonth == 5 ? "May" :
           currentMonth == 6 ? "Jun" :
           currentMonth == 7 ? "Jul" :
           currentMonth == 8 ? "Aug" :
           currentMonth == 9 ? "Sep" :
           currentMonth == 10 ? "Oct" :
           currentMonth == 11 ? "Nov" : "Dec")
        array.push(dates, dateStr)

// ───── DRAWING LOGIC ─────────────────────────────────────────────────────────
if barstate.islast and array.size(eventTimes) > 0
    for i = 0 to array.size(eventTimes) - 1
        eventTime = array.get(eventTimes, i)
        hPrice = array.get(hiPrice, i)
        lPrice = array.get(loPrice, i)
        wRank = array.get(wedRank, i)
        dStr = array.get(dates, i)
        
        // Check if this Wednesday type should be shown
        show = switch wRank
            1 => showW1,
            2 => showW2,
            3 => showW3,
            4 => showW4,
            5 => showW5,
            => false
        
        if show
            // Get colors and widths
            hiCol = switch wRank
                1 => hiC1,
                2 => hiC2,
                3 => hiC3,
                4 => hiC4,
                5 => hiC5
            loCol = switch wRank
                1 => loC1,
                2 => loC2,
                3 => loC3,
                4 => loC4,
                5 => loC5
            hiW = switch wRank
                1 => hiW1,
                2 => hiW2,
                3 => hiW3,
                4 => hiW4,
                5 => hiW5
            loW = switch wRank
                1 => loW1,
                2 => loW2,
                3 => loW3,
                4 => loW4,
                5 => loW5

            // Draw lines
            line.new(eventTime, hPrice, time, hPrice, xloc=xloc.bar_time,
                 color=hiCol, width=hiW, style=line.style_solid)
            line.new(eventTime, lPrice, time, lPrice, xloc=xloc.bar_time,
                 color=loCol, width=loW, style=line.style_solid)

            // Draw labels
            if labelText
                label.new(time, hPrice, dStr + " High", xloc=xloc.bar_time,
                      color=hiCol, textcolor=color.white, style=label.style_label_down, size=actualLabelSize,
                      textalign=text.align_left)
                label.new(time, lPrice, dStr + " Low", xloc=xloc.bar_time,
                      color=loCol, textcolor=color.white, style=label.style_label_up, size=actualLabelSize,
                      textalign=text.align_left) 
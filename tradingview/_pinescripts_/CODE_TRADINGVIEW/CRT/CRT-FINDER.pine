//@version=5
// =========================================================================================
// | Indicator:      Time-Filtered MTF CRT Detector v2                                     |
// | Description:    CORRECTED - Identifies specific 1AM, 5AM, or 9AM H4 CRT patterns.     |
// |                 Draws extending horizontal lines FROM THE CORRECT H4 RANGE CANDLE.    |
// |                 Adds labels to lines for clarity.                                     |
// | Author:         Generated by AI for User (Final Corrected Version)                    |
// =========================================================================================

 
indicator("Complete CRT System (MTF v2)", "CRT System2", overlay=true, max_lines_count=100)
// --- User Inputs ---
crtModel = input.string("5AM CRT", "CRT Model", options=["1AM CRT", "5AM CRT", "9AM CRT"], tooltip="Select which specific time-based CRT setup to display on the chart.")
target_timeframe = input.timeframe("240", "Analysis Timeframe") 
color_high = input.color(color.new(color.blue, 0), title="CRT High Color")
color_low  = input.color(color.new(color.red, 0), title="CRT Low Color")
line_width = input.int(2, title="Line Width", minval=1)
label_color = input.color(color.new(color.gray, 0), title="Label Color")


// --- CRT Detection Function ---
// This function contains the core logic to be run on the target timeframe.
f_getCrtLevels() =>
    // --- TIME FILTER: Get the hour of the MANIPULATION CANDLE (bar at index [1]) ---
    nyHour = hour(time[1], "America/New_York")
    
    // Determine the hour to look for based on user's selected model
    int keyHour = na
    string modelText = ""
    int rangeCandleIndex = na

    if crtModel == "1AM CRT"
        keyHour := 21 // 9 PM Manipulation candle is checked
        modelText := "H4 CRT (from 5PM)" // The range is the 5PM candle
        rangeCandleIndex := 3
    else if crtModel == "5AM CRT"
        keyHour := 1 // 1 AM Manipulation candle is checked
        modelText := "H4 CRT (from 9PM)" // The range is the 9PM candle
        rangeCandleIndex := 3
    else if crtModel == "9AM CRT"
        keyHour := 5 // 5 AM Manipulation candle is checked
        modelText := "H4 CRT (from 1AM)" // The range is the 1AM candle
        rangeCandleIndex := 3
        
    bool isKeyTime = nyHour == keyHour

    // --- PATTERN LOGIC: Only proceeds if it's the correct time ---
    float highLevel = na
    float lowLevel = na
    int rangeCandleTime = na
    string highLabelText = na
    string lowLabelText = na

    // Make sure we have enough bars to look back for the range candle
    if isKeyTime and not na(rangeCandleIndex) and bar_index > rangeCandleIndex
        // The indices are relative to the MANIPULATION candle [1]
        bool isBearish = high[1] > high[rangeCandleIndex - 1] and close[1] < high[rangeCandleIndex - 1] and close < open
        bool isBullish = low[1] < low[rangeCandleIndex - 1] and close[1] > low[rangeCandleIndex - 1] and close > open
            
        if isBearish or isBullish
            highLevel := high[rangeCandleIndex-1] 
            lowLevel  := low[rangeCandleIndex-1]  
            rangeCandleTime := time[rangeCandleIndex-1] 
            highLabelText := modelText + " High"
            lowLabelText := modelText + " Low"
    
    [highLevel, lowLevel, rangeCandleTime, highLabelText, lowLabelText] 

// --- Request Data from the Higher Timeframe ---
[h4_high, h4_low, h4_time, h4_high_text, h4_low_text] = request.security(syminfo.tickerid, target_timeframe, f_getCrtLevels(), lookahead=barmerge.lookahead_on)

// --- State Variables for Drawing ---
var line crtHigh_line = na
var line crtLow_line  = na
var label crtHigh_label = na
var label crtLow_label = na

// --- Draw when a new, valid signal is received from the H4 timeframe ---
if not na(h4_high) and (na(h4_time[1]) or h4_time[1] != h4_time)
    line.delete(crtHigh_line[1])
    line.delete(crtLow_line[1])
    label.delete(crtHigh_label[1])
    label.delete(crtLow_label[1])
    crtHigh_line := line.new(h4_time, h4_high, time, h4_high, xloc=xloc.bar_time, extend=extend.right, color=color_high, width=line_width)
    crtLow_line  := line.new(h4_time, h4_low, time, h4_low, xloc=xloc.bar_time, extend=extend.right, color=color_low, width=line_width)
    crtHigh_label := label.new(h4_time, h4_high, text=h4_high_text, xloc=xloc.bar_time, style=label.style_label_right, textcolor=label_color, color=color.new(color.white, 100))
    crtLow_label  := label.new(h4_time, h4_low, text=h4_low_text, xloc=xloc.bar_time, style=label.style_label_right, textcolor=label_color, color=color.new(color.white, 100))
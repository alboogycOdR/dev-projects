//@version=5
// =========================================================================================
// | Indicator:      Time-Filtered MTF CRT Detector v3                                     |
// | Description:    CORRECTED - Identifies specific 1AM, 5AM, or 9AM H4 CRT patterns.     |
// |                 Draws extending horizontal lines FROM THE CORRECT H4 RANGE CANDLE.    |
// |                 Adds labels to lines for clarity.                                     |
// | Author:         Generated by AI for User (Final Corrected Version)                    |
// =========================================================================================

indicator("Time-Filtered MTF CRT Detector v3", overlay=true, max_lines_count=100)

// --- User Inputs ---
crtModel = input.string("5AM CRT", "CRT Model", options=["1AM CRT", "5AM CRT", "9AM CRT"], tooltip="Select which specific time-based CRT setup to display on the chart.")
target_timeframe = input.timeframe("240", "Analysis Timeframe") 
color_high = input.color(color.new(color.blue, 0), title="CRT High Color")
color_low  = input.color(color.new(color.red, 0), title="CRT Low Color")
line_width = input.int(2, title="Line Width", minval=1)
label_color = input.color(color.new(color.gray, 0), title="Label Color")

// --- FVG Inputs ---
fvg_group = "Fair Value Gaps"
showFairValueGaps = input.bool(true, "Show Fair Value Gaps", group=fvg_group, tooltip="Display Fair Value Gaps on the chart.")
fairValueGapsBullColor = input.color(color.new(#00ff68, 70), "Bullish FVG", group=fvg_group)
fairValueGapsBearColor = input.color(color.new(#ff0008, 70), "Bearish FVG", group=fvg_group)
fairValueGapsExtend = input.int(5, "Extend FVG", group=fvg_group, tooltip="How many bars to extend the FVG boxes.", minval=0)
fairValueGapsThreshold = input.bool(true, "Auto Threshold", group=fvg_group, tooltip="Filter out non-significant Fair Value Gaps.")

// --- Order Block Inputs ---
ob_group = "Order Blocks"
showOrderBlocks = input.bool(true, "Show Order Blocks", group=ob_group)
orderBlocksSize = input.int(5, "Number of OBs to Display", group=ob_group, minval=1)
bullishObColor = input.color(color.new(#1848cc, 80), "Bullish OB", group=ob_group)
bearishObColor = input.color(color.new(#b22833, 80), "Bearish OB", group=ob_group)
orderBlockMitigation = input.string("High/Low", "Mitigation by", group=ob_group, options=["High/Low", "Close"])

// --- Constants ---
BULLISH = 1
BEARISH = -1

// --- FVG Data Structures ---
type fairValueGap
    float top
    float bottom
    int bias
    box fvgBox

var array<fairValueGap> fairValueGaps = array.new<fairValueGap>()

// --- Order Block Data Structures ---
type orderBlock
    float top
    float bottom
    int barTime
    int bias
    box obBox

var array<orderBlock> orderBlocks = array.new<orderBlock>()

// --- FVG Functions ---
f_manageFVGs() =>
    // Delete mitigated FVGs
    if array.size(fairValueGaps) > 0
        for i = array.size(fairValueGaps) - 1 to 0
            eachFairValueGap = array.get(fairValueGaps, i)
            if (low < eachFairValueGap.bottom and eachFairValueGap.bias == BULLISH) or (high > eachFairValueGap.top and eachFairValueGap.bias == BEARISH)
                box.delete(eachFairValueGap.fvgBox)
                array.remove(fairValueGaps, i)

    // Detect new FVGs
    barDeltaPercent = close[1] != 0 and open[1] !=0 ? (close[1] - open[1]) / open[1] : 0
    threshold = fairValueGapsThreshold and bar_index > 0 ? ta.cum(math.abs(barDeltaPercent)) / bar_index * 2 : 0

    bool bullishFairValueGap = low > high[2] and barDeltaPercent > threshold
    bool bearishFairValueGap = high < low[2] and -barDeltaPercent > threshold

    if bullishFairValueGap
        fvgBox = box.new(left=time[1], top=low, right=time + fairValueGapsExtend * (time-time[1]), bottom=high[2], 
         xloc=xloc.bar_time, border_color=na, bgcolor=fairValueGapsBullColor)
        array.unshift(fairValueGaps, fairValueGap.new(low, high[2], BULLISH, fvgBox))
        
    if bearishFairValueGap
        fvgBox = box.new(left=time[1], top=high, right=time + fairValueGapsExtend * (time-time[1]), bottom=low[2], 
         xloc=xloc.bar_time, border_color=na, bgcolor=fairValueGapsBearColor)
        array.unshift(fairValueGaps, fairValueGap.new(high, low[2], BEARISH, fvgBox))

// --- Order Block Functions ---
f_manageOrderBlocks() =>
    // --- Mitigation ---
    bearishMitigationSource = orderBlockMitigation == "Close" ? close : high
    bullishMitigationSource = orderBlockMitigation == "Close" ? close : low
    if array.size(orderBlocks) > 0
        for i = array.size(orderBlocks) - 1 to 0
            eachOrderBlock = array.get(orderBlocks, i)
            bool mitigated = false
            if eachOrderBlock.bias == BULLISH and bullishMitigationSource < eachOrderBlock.bottom
                mitigated := true
            else if eachOrderBlock.bias == BEARISH and bearishMitigationSource > eachOrderBlock.top
                mitigated := true
            
            if mitigated
                box.delete(eachOrderBlock.obBox)
                array.remove(orderBlocks, i)

    // --- Detection (linked to FVG formation) ---
    barDeltaPercent = close[1] != 0 and open[1] !=0 ? (close[1] - open[1]) / open[1] : 0
    threshold = fairValueGapsThreshold and bar_index > 0 ? ta.cum(math.abs(barDeltaPercent)) / bar_index * 2 : 0

    bool bullishFairValueGap = low > high[2] and barDeltaPercent > threshold
    bool bearishFairValueGap = high < low[2] and -barDeltaPercent > threshold

    // A bullish OB is the last down-candle before an up-move that creates an FVG
    if bullishFairValueGap and close[2] < open[2]
        obBox = box.new(left=time[2], top=high[2], right=time, bottom=low[2], xloc=xloc.bar_time, border_color=na, bgcolor=bullishObColor, extend=extend.right)
        array.unshift(orderBlocks, orderBlock.new(high[2], low[2], time[2], BULLISH, obBox))

    // A bearish OB is the last up-candle before a down-move that creates an FVG
    if bearishFairValueGap and close[2] > open[2]
        obBox = box.new(left=time[2], top=high[2], right=time, bottom=low[2], xloc=xloc.bar_time, border_color=na, bgcolor=bearishObColor, extend=extend.right)
        array.unshift(orderBlocks, orderBlock.new(high[2], low[2], time[2], BEARISH, obBox))

    // --- Drawing & Cleanup ---
    // Ensure we only keep the desired number of OBs
    while array.size(orderBlocks) > orderBlocksSize
        lastOb = array.pop(orderBlocks)
        box.delete(lastOb.obBox)

// --- CRT Detection Function ---
// This function contains the core logic to be run on the target timeframe.
f_getCrtLevels() =>
    // --- TIME FILTER: Get the hour of the MANIPULATION CANDLE (bar at index [1]) ---
    nyHour = hour(time[1], "America/New_York")
    
    // Determine the hour to look for based on user's selected model
    int keyHour = na
    string modelText = ""
    int rangeCandleIndex = na

    if crtModel == "1AM CRT"
        keyHour := 21 // 9 PM Manipulation candle is checked
        modelText := "H4 CRT (from 5PM)" // The range is the 5PM candle
        rangeCandleIndex := 3
    else if crtModel == "5AM CRT"
        keyHour := 1 // 1 AM Manipulation candle is checked
        modelText := "H4 CRT (from 9PM)" // The range is the 9PM candle
        rangeCandleIndex := 3
    else if crtModel == "9AM CRT"
        keyHour := 5 // 5 AM Manipulation candle is checked
        modelText := "H4 CRT (from 1AM)" // The range is the 1AM candle
        rangeCandleIndex := 3
        
    bool isKeyTime = nyHour == keyHour

    // --- PATTERN LOGIC: Only proceeds if it's the correct time ---
    float highLevel = na
    float lowLevel = na
    int rangeCandleTime = na
    string highLabelText = na
    string lowLabelText = na

    // Make sure we have enough bars to look back for the range candle
    if isKeyTime and not na(rangeCandleIndex) and bar_index > rangeCandleIndex
        // The indices are relative to the MANIPULATION candle [1]
        bool isBearish = high[1] > high[rangeCandleIndex - 1] and close[1] < high[rangeCandleIndex - 1] and close < open
        bool isBullish = low[1] < low[rangeCandleIndex - 1] and close[1] > low[rangeCandleIndex - 1] and close > open
            
        if isBearish or isBullish
            highLevel := high[rangeCandleIndex-1] 
            lowLevel  := low[rangeCandleIndex-1]  
            rangeCandleTime := time[rangeCandleIndex-1] 
            highLabelText := modelText + " High"
            lowLabelText := modelText + " Low"
    
    [highLevel, lowLevel, rangeCandleTime, highLabelText, lowLabelText] 

// --- Request Data from the Higher Timeframe ---
[h4_high, h4_low, h4_time, h4_high_text, h4_low_text] = request.security(syminfo.tickerid, target_timeframe, f_getCrtLevels(), lookahead=barmerge.lookahead_on)

// --- State Variables for Drawing ---
var line crtHigh_line = na
var line crtLow_line  = na
var label crtHigh_label = na
var label crtLow_label = na

// --- Draw when a new, valid signal is received from the H4 timeframe ---
if not na(h4_high) and (na(h4_time[1]) or h4_time[1] != h4_time)
    line.delete(crtHigh_line[1])
    line.delete(crtLow_line[1])
    label.delete(crtHigh_label[1])
    label.delete(crtLow_label[1])
    crtHigh_line := line.new(x1=h4_time, y1=h4_high, x2=time + 2 * timeframe.in_seconds(), y2=h4_high, xloc=xloc.bar_time, color=color_high, width=line_width)
    crtLow_line  := line.new(x1=h4_time, y1=h4_low,  x2=time + 2 * timeframe.in_seconds(), y2=h4_low,  xloc=xloc.bar_time, color=color_low,  width=line_width)
    crtHigh_label := label.new(h4_time, h4_high, text=h4_high_text, xloc=xloc.bar_time, style=label.style_label_right, textcolor=label_color, color=color.new(color.white, 100))
    crtLow_label  := label.new(h4_time, h4_low, text=h4_low_text, xloc=xloc.bar_time, style=label.style_label_right, textcolor=label_color, color=color.new(color.white, 100))

// --- FVG Execution ---
if showFairValueGaps
    f_manageFVGs()

// --- Order Block Execution ---
if showOrderBlocks
    f_manageOrderBlocks()
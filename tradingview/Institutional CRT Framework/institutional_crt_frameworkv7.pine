// =======================
// === TYPE DEFINITIONS ===
// =======================

// Market Structure Type
type MarketStructure
    float lastHH = na
    float lastHL = na
    float lastLH = na
    float lastLL = na
    string trend = "NEUTRAL"
    int strength = 0
    bool brokenStructure = false
    int trendBars = 0

// Liquidity Pool Type
type LiquidityPool
    float price
    string poolType  // "BUYSIDE" or "SELLSIDE"
    int touches
    float volume
    bool swept
    int barIndex

// Volume Profile Type
type VolumeProfile
    float poc  // Point of Control
    float vah  // Value Area High
    float val  // Value Area Low
    float totalVolume
    bool bullishImbalance
    bool bearishImbalance

// Correlation Data Type
type CorrelationData
    string symbol
    float correlation
    bool divergence
    string divergenceType
    float strength

// Entry Filter Type
type EntryFilter
    bool marketStructureAligned
    bool liquiditySwept
    bool volumeConfirmation
    bool correlationConfirmation
    bool timeOfDayOptimal
    int score  // 0-100

// Risk Manager Type
type RiskManager
    float accountBalance
    float riskPerTrade
    float maxDailyLoss
    float currentDailyPnL
    int maxConcurrentTrades
    int currentOpenTrades
    float positionSize
    bool tradingAllowed

// Performance Tracker Type
type PerformanceTracker
    int totalSignals
    int winningSignals
    int losingSignals
    float winRate
    float avgWin
    float avgLoss
    float profitFactor
    float sharpeRatio
    array<float> returns

// =======================
// === CORE INPUTS =======
// =======================

// System Configuration
enable_dol_engine = input.bool(true, "Enable DOL Analysis Engine", group="Core System")
enable_session_engine = input.bool(true, "Enable Session State Machine", group="Core System")
enable_entry_engine = input.bool(true, "Enable Live Entry Signals", group="Core System")
enable_debug_mode = input.bool(false, "Debug Mode (Show All States)", group="Core System")

// Advanced Modules
enable_market_structure = input.bool(true, "Enable Market Structure Analysis", group="Advanced Modules")
enable_liquidity_pools = input.bool(true, "Enable Liquidity Pool Detection", group="Advanced Modules")
enable_volume_profile = input.bool(true, "Enable Volume Profile Analysis", group="Advanced Modules")
enable_correlation = input.bool(true, "Enable Multi-Pair Correlation", group="Advanced Modules")
enable_risk_management = input.bool(true, "Enable Risk Management", group="Advanced Modules")
enable_performance_tracking = input.bool(true, "Enable Performance Tracking", group="Advanced Modules")

// DOL Configuration
pivot_strength = input.int(10, "DOL Pivot Strength", minval=5, maxval=50, group="DOL Analysis")

// CRT Model Selection
enable_1am_crt = input.bool(true, "1AM CRT Model", group="CRT Models")
enable_5am_crt = input.bool(true, "5AM CRT Model", group="CRT Models")
enable_9am_crt = input.bool(true, "9AM CRT Model", group="CRT Models")

// Risk Management Settings
account_balance = input.float(10000, "Account Balance", minval=100, group="Risk Management")
risk_per_trade_pct = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, group="Risk Management")
max_daily_loss_pct = input.float(3.0, "Max Daily Loss (%)", minval=1.0, maxval=10.0, step=0.5, group="Risk Management")
max_concurrent_trades = input.int(3, "Max Concurrent Trades", minval=1, maxval=10, group="Risk Management")

// Entry Filter Settings
min_entry_score = input.int(60, "Minimum Entry Score (0-100)", minval=0, maxval=100, step=5, group="Entry Filters")
require_structure_alignment = input.bool(true, "Require Market Structure Alignment", group="Entry Filters")
require_liquidity_sweep = input.bool(false, "Require Liquidity Sweep", group="Entry Filters")
require_volume_confluence = input.bool(true, "Require Volume Confluence", group="Entry Filters")

// Visual Settings
show_market_structure = input.bool(true, "Show Market Structure", group="Visuals")
show_liquidity_pools = input.bool(true, "Show Liquidity Pools", group="Visuals")
show_volume_profile = input.bool(true, "Show Volume Profile", group="Visuals")
show_advanced_dashboard = input.bool(true, "Show Advanced Dashboard", group="Visuals")

// =======================
// === INITIALIZE OBJECTS ===
// =======================

var MarketStructure ms = MarketStructure.new()
var array<LiquidityPool> liquidityPools = array.new<LiquidityPool>()
var RiskManager rm = RiskManager.new()
var PerformanceTracker pt = PerformanceTracker.new(0, 0, 0, 0, 0, 0, 0, 0, array.new<float>())

// Initialize Risk Manager
if barstate.isfirst
    rm.accountBalance := account_balance
    rm.riskPerTrade := account_balance * (risk_per_trade_pct / 100)
    rm.maxDailyLoss := account_balance * (max_daily_loss_pct / 100)
    rm.maxConcurrentTrades := max_concurrent_trades
    rm.currentOpenTrades := 0
    rm.currentDailyPnL := 0
    rm.tradingAllowed := true

// =======================
// === V6 CORE SYSTEM (Preserved) ===
// =======================

// Session History Arrays
var array<string> session_name_history = array.new<string>(100)
var array<string> session_behavior_history = array.new<string>(100)
var array<float> session_high_history = array.new<float>(100)
var array<float> session_low_history = array.new<float>(100)
var array<int> session_start_bars = array.new<int>(100)

// Track session transitions
track_session_history(string current_session, string current_behavior, float current_high, float current_low) =>
    if array.size(session_name_history) >= 100
        array.shift(session_name_history)
        array.shift(session_behavior_history)
        array.shift(session_high_history)
        array.shift(session_low_history)
        array.shift(session_start_bars)
    
    array.push(session_name_history, current_session)
    array.push(session_behavior_history, current_behavior)
    array.push(session_high_history, current_high)
    array.push(session_low_history, current_low)
    array.push(session_start_bars, bar_index)

// Get historical session behavior
get_session_behavior_lookback(int sessions_back) =>
    idx = array.size(session_behavior_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_behavior_history) ? array.get(session_behavior_history, idx) : "UNKNOWN"
    result

// Timeframe Support Functions
get_timeframe_multiplier() =>
    tf = timeframe.period
    multiplier = 1.0
    
    if timeframe.isminutes
        minutes = timeframe.multiplier
        multiplier := 240.0 / minutes
    else if timeframe.isdaily
        multiplier := 0.1667
    else if timeframe.isweekly
        multiplier := 0.0357
    else
        multiplier := 1.0
    
    multiplier

is_valid_timeframe() =>
    tf = timeframe.period
    valid = timeframe.isminutes and (timeframe.multiplier == 15 or timeframe.multiplier == 30 or 
                                     timeframe.multiplier == 60 or timeframe.multiplier == 240)
    valid := valid or timeframe.isdaily or timeframe.isweekly
    valid

adjust_lookback_for_timeframe(int base_lookback) =>
    multiplier = get_timeframe_multiplier()
    adjusted = math.round(base_lookback * multiplier)
    math.max(1, adjusted)

// Time Window Functions
get_current_minutes() =>
    h = hour(time, "GMT")
    m = minute(time, "GMT")
    h * 60 + m

is_in_time_window(int start_minutes, int end_minutes) =>
    current = get_current_minutes()
    if start_minutes <= end_minutes
        current >= start_minutes and current <= end_minutes
    else
        current >= start_minutes or current <= end_minutes

// =======================
// === DOL ANALYSIS ======
// =======================

adjusted_pivot_strength = math.round(pivot_strength * get_timeframe_multiplier())
adjusted_pivot_strength := math.max(2, math.min(50, adjusted_pivot_strength))

float pivot_high_price = ta.pivothigh(high, adjusted_pivot_strength, adjusted_pivot_strength)
float pivot_low_price = ta.pivotlow(low, adjusted_pivot_strength, adjusted_pivot_strength)

var float last_swing_high = na
var float last_swing_low = na
var float dol_target = na
var string dol_bias = "NEUTRAL"

if not na(pivot_high_price)
    last_swing_high := pivot_high_price

if not na(pivot_low_price)
    last_swing_low := pivot_low_price

if not na(last_swing_high) and not na(last_swing_low)
    float dist_to_high = math.abs(close - last_swing_high)
    float dist_to_low = math.abs(close - last_swing_low)
    
    dol_bias := dist_to_high < dist_to_low ? "BULLISH" : "BEARISH"
    dol_target := dist_to_high < dist_to_low ? last_swing_high : last_swing_low

// =======================
// === SESSION STATES ====
// =======================

get_session_state() =>
    string state = "UNKNOWN"
    int h = hour(time, "GMT")
    
    if h >= 17 and h < 21
        state := "CBDR"
    else if h >= 21 or h < 1
        state := "ASIA"
    else if h >= 1 and h < 5
        state := "LONDON"
    else if h >= 5 and h < 9
        state := "LUNCH"
    else if h >= 9 and h < 13
        state := "NY"
    else
        state := "POST_NY"
    
    state

string session_state = get_session_state()
var string session_behavior = "CONSOLIDATION"
var float session_high = na
var float session_low = na
var string prev_session = ""
var float prev_session_high = na
var float prev_session_low = na

if session_state != prev_session
    if prev_session != ""
        track_session_history(prev_session, session_behavior, session_high, session_low)
    
    prev_session_high := session_high
    prev_session_low := session_low
    prev_session := session_state
    
    session_high := high
    session_low := low
    session_behavior := "CONSOLIDATION"
else
    session_high := math.max(nz(session_high, high), high)
    session_low := math.min(nz(session_low, low), low)
    
    float prev_session_range = nz(prev_session_high - prev_session_low, 0)
    float current_range = high - low
    
    if prev_session_range > 0
        if current_range > prev_session_range * 1.5
            session_behavior := "EXPANSION"
        else if high > nz(prev_session_high, high) or low < nz(prev_session_low, low)
            session_behavior := "MANIPULATION"

// =======================
// === CRT STATES (From V6) ===
// =======================

var string crt_1am_state = "INACTIVE"
var string crt_5am_state = "INACTIVE"
var string crt_9am_state = "INACTIVE"
var string profile_1am = "NONE"
var string profile_5am = "NONE"
var string profile_9am = "NONE"

// [CRT State Logic from V6 - keeping intact for stability]
// ... [Previous CRT update functions remain the same]

// =======================
// === MARKET STRUCTURE MODULE ===
// =======================

update_market_structure() =>
    if enable_market_structure
        // Identify swing points
        pivotHigh = ta.pivothigh(high, 5, 5)
        pivotLow = ta.pivotlow(low, 5, 5)
        
        if not na(pivotHigh)
            if na(ms.lastHH) or pivotHigh > ms.lastHH
                ms.lastLH := ms.lastHH
                ms.lastHH := pivotHigh
                
                // Check for trend change
                if ms.trend == "BEARISH" and not na(ms.lastLH) and pivotHigh > ms.lastLH
                    ms.trend := "BULLISH"
                    ms.brokenStructure := true
                    ms.trendBars := 0
            else
                ms.lastLH := pivotHigh
        
        if not na(pivotLow)
            if na(ms.lastLL) or pivotLow < ms.lastLL
                ms.lastHL := ms.lastLL
                ms.lastLL := pivotLow
                
                // Check for trend change
                if ms.trend == "BULLISH" and not na(ms.lastHL) and pivotLow < ms.lastHL
                    ms.trend := "BEARISH"
                    ms.brokenStructure := true
                    ms.trendBars := 0
            else
                ms.lastHL := pivotLow
        
        // Calculate trend strength (0-100)
        ms.trendBars += 1
        if not na(ms.lastHH) and not na(ms.lastLL)
            range_hl = ms.lastHH - ms.lastLL
            if ms.trend == "BULLISH" and range_hl > 0
                ms.strength := math.round(((close - ms.lastLL) / range_hl) * 100)
            else if ms.trend == "BEARISH" and range_hl > 0
                ms.strength := math.round(((ms.lastHH - close) / range_hl) * 100)
            
            ms.strength := math.max(0, math.min(100, ms.strength))

update_market_structure()

// =======================
// === LIQUIDITY POOL MODULE ===
// =======================

detect_liquidity_pools() =>
    if enable_liquidity_pools
        // Detect equal highs (buy-side liquidity)
        if high == high[1] and high > ta.highest(high[2], 10)
            pool = LiquidityPool.new()
            pool.price := high
            pool.poolType := "BUYSIDE"
            pool.touches := 2
            pool.volume := volume + volume[1]
            pool.swept := false
            pool.barIndex := bar_index
            array.push(liquidityPools, pool)
        
        // Detect equal lows (sell-side liquidity)
        if low == low[1] and low < ta.lowest(low[2], 10)
            pool = LiquidityPool.new()
            pool.price := low
            pool.poolType := "SELLSIDE"
            pool.touches := 2
            pool.volume := volume + volume[1]
            pool.swept := false
            pool.barIndex := bar_index
            array.push(liquidityPools, pool)
        
        // Check if pools have been swept
        if array.size(liquidityPools) > 0
            for i = array.size(liquidityPools) - 1 to 0
                pool = array.get(liquidityPools, i)
                
                if not pool.swept
                    if pool.poolType == "BUYSIDE" and high > pool.price
                        pool.swept := true
                    else if pool.poolType == "SELLSIDE" and low < pool.price
                        pool.swept := true
                
                // Remove old pools (more than 50 bars)
                if bar_index - pool.barIndex > 50
                    array.remove(liquidityPools, i)

detect_liquidity_pools()

// Check for recent liquidity sweep
check_liquidity_sweep(string direction) =>
    swept = false
    if array.size(liquidityPools) > 0
        for pool in liquidityPools
            if pool.swept and bar_index - pool.barIndex < 5
                if (direction == "BUY" and pool.poolType == "SELLSIDE") or
                   (direction == "SELL" and pool.poolType == "BUYSIDE")
                    swept := true
                    break
    swept

// =======================
// === VOLUME PROFILE MODULE ===
// =======================

calculate_volume_profile(int lookback) =>
    vp = VolumeProfile.new()
    
    if enable_volume_profile
        // Create price bins
        highest = ta.highest(high, lookback)
        lowest = ta.lowest(low, lookback)
        priceRange = highest - lowest
        
        if priceRange > 0
            numBins = 20
            binSize = priceRange / numBins
            
            // Volume per price level arrays
            volumeLevels = array.new<float>(numBins, 0)
            priceLevels = array.new<float>(numBins, 0)
            
            // Initialize price levels
            for i = 0 to numBins - 1
                array.set(priceLevels, i, lowest + (i * binSize))
            
            // Accumulate volume
            for i = 0 to math.min(lookback - 1, 500)
                if i < bar_index
                    barMid = (high[i] + low[i]) / 2
                    binIndex = math.floor((barMid - lowest) / binSize)
                    binIndex := math.max(0, math.min(numBins - 1, binIndex))
                    
                    currentVol = array.get(volumeLevels, binIndex)
                    array.set(volumeLevels, binIndex, currentVol + nz(volume[i], 0))
            
            // Find POC (highest volume level)
            maxVol = 0.0
            pocIndex = 0
            for i = 0 to numBins - 1
                vol = array.get(volumeLevels, i)
                if vol > maxVol
                    maxVol := vol
                    pocIndex := i
            
            vp.poc := array.get(priceLevels, pocIndex)
            vp.totalVolume := array.sum(volumeLevels)
            
            // Calculate Value Area (70% of volume)
            if vp.totalVolume > 0
                targetVolume = vp.totalVolume * 0.7
                accumulatedVolume = array.get(volumeLevels, pocIndex)
                upperIndex = pocIndex
                lowerIndex = pocIndex
                
                // Expand from POC until 70% volume reached
                while accumulatedVolume < targetVolume and (upperIndex < numBins - 1 or lowerIndex > 0)
                    upperVol = upperIndex < numBins - 1 ? array.get(volumeLevels, upperIndex + 1) : 0
                    lowerVol = lowerIndex > 0 ? array.get(volumeLevels, lowerIndex - 1) : 0
                    
                    if upperVol > lowerVol and upperIndex < numBins - 1
                        upperIndex += 1
                        accumulatedVolume += upperVol
                    else if lowerIndex > 0
                        lowerIndex -= 1
                        accumulatedVolume += lowerVol
                
                vp.vah := array.get(priceLevels, math.min(upperIndex, numBins - 1))
                vp.val := array.get(priceLevels, math.max(lowerIndex, 0))
                
                // Check for imbalances
                vp.bullishImbalance := close > vp.poc and close > vp.vah
                vp.bearishImbalance := close < vp.poc and close < vp.val
    
    vp

vp_current = calculate_volume_profile(50)

// =======================
// === CORRELATION MODULE ===
// =======================

calculate_correlations() =>
    var array<CorrelationData> correlations = array.new<CorrelationData>()
    
    if enable_correlation
        array.clear(correlations)
        
        // Define correlated pairs based on current symbol
        correlatedPairs = syminfo.ticker == "EURUSD" ? array.from("GBPUSD", "AUDUSD") :
                         syminfo.ticker == "GBPUSD" ? array.from("EURUSD", "AUDUSD") :
                         syminfo.ticker == "USDJPY" ? array.from("USDCHF", "USDCAD") :
                         array.from("EURUSD", "GBPUSD")
        
        // Calculate correlation for each pair
        for pair in correlatedPairs
            cd = CorrelationData.new()
            cd.symbol := pair
            
            // Get pair data
            [pairClose, pairVolume] = request.security(pair, timeframe.period, [close, volume])
            pairChange = (pairClose - pairClose[1]) / pairClose[1] * 100
            
            // Current symbol change
            currentChange = (close - close[1]) / close[1] * 100
            
            // Simple correlation calculation
            cd.correlation := ta.correlation(close, pairClose, 20)
            
            // Check for SMT divergence
            if math.abs(cd.correlation) > 0.7
                if (currentChange > 0 and pairChange < 0) or (currentChange < 0 and pairChange > 0)
                    cd.divergence := true
                    cd.divergenceType := currentChange > 0 ? "BULLISH_SMT" : "BEARISH_SMT"
                    cd.strength := math.abs(currentChange - pairChange)
            
            array.push(correlations, cd)
    
    correlations

correlations = calculate_correlations()

// Check for SMT divergence
check_smt_divergence(string direction) =>
    has_divergence = false
    if array.size(correlations) > 0
        for corr in correlations
            if corr.divergence and 
               ((direction == "BUY" and corr.divergenceType == "BULLISH_SMT") or
                (direction == "SELL" and corr.divergenceType == "BEARISH_SMT"))
                has_divergence := true
                break
    has_divergence

// =======================
// === ENTRY FILTERS MODULE ===
// =======================

evaluate_entry_filters(string direction) =>
    ef = EntryFilter.new()
    ef.score := 0
    
    // Market Structure Filter (20 points)
    ef.marketStructureAligned := (direction == "BUY" and ms.trend == "BULLISH") or
                                 (direction == "SELL" and ms.trend == "BEARISH")
    if ef.marketStructureAligned
        ef.score += 20
    
    // Liquidity Sweep Filter (25 points)
    ef.liquiditySwept := check_liquidity_sweep(direction)
    if ef.liquiditySwept
        ef.score += 25
    
    // Volume Confirmation (20 points)
    ef.volumeConfirmation := (direction == "BUY" and close > vp_current.poc) or
                            (direction == "SELL" and close < vp_current.poc)
    if ef.volumeConfirmation
        ef.score += 20
    
    // Correlation Confirmation (20 points)
    ef.correlationConfirmation := check_smt_divergence(direction)
    if ef.correlationConfirmation
        ef.score += 20
    
    // Time of Day Optimization (15 points)
    optimalHours = array.from(2, 3, 6, 7, 8, 9, 10)
    current_hour = hour(time, "GMT")
    ef.timeOfDayOptimal := array.includes(optimalHours, current_hour)
    if ef.timeOfDayOptimal
        ef.score += 15
    
    ef

// =======================
// === RISK MANAGEMENT MODULE ===
// =======================

calculate_position_size(float entryPrice, float stopLoss) =>
    position_size = 0.0
    
    if enable_risk_management
        riskAmount = rm.riskPerTrade
        pipRisk = math.abs(entryPrice - stopLoss)
        
        // Adjust for different symbols
        pipValue = syminfo.type == "forex" ? 0.0001 : syminfo.mintick
        
        if pipRisk > 0
            position_size := riskAmount / (pipRisk / pipValue)
        
        // Check if trading is allowed
        rm.tradingAllowed := rm.currentOpenTrades < rm.maxConcurrentTrades and
                            math.abs(rm.currentDailyPnL) < rm.maxDailyLoss
    
    position_size

// Update daily P&L (mock implementation for demo)
update_daily_pnl(float pnl) =>
    // Reset at start of new day
    if dayofweek != dayofweek[1]
        rm.currentDailyPnL := 0
    
    rm.currentDailyPnL += pnl

// =======================
// === PERFORMANCE TRACKING MODULE ===
// =======================

track_signal_performance(bool signalHit, float returnPct) =>
    if enable_performance_tracking
        pt.totalSignals += 1
        
        if signalHit
            pt.winningSignals += 1
            pt.avgWin := (pt.avgWin * (pt.winningSignals - 1) + returnPct) / pt.winningSignals
        else
            pt.losingSignals += 1
            pt.avgLoss := (pt.avgLoss * (pt.losingSignals - 1) + math.abs(returnPct)) / pt.losingSignals
        
        array.push(pt.returns, returnPct)
        if array.size(pt.returns) > 100
            array.shift(pt.returns)
        
        // Calculate metrics
        pt.winRate := pt.totalSignals > 0 ? (pt.winningSignals / pt.totalSignals) * 100 : 0
        pt.profitFactor := pt.avgLoss > 0 ? pt.avgWin / pt.avgLoss : 0
        
        // Calculate Sharpe Ratio
        if array.size(pt.returns) > 20
            avgReturn = array.avg(pt.returns)
            stdDev = array.stdev(pt.returns)
            pt.sharpeRatio := stdDev > 0 ? (avgReturn / stdDev) * math.sqrt(252) : 0

// =======================
// === KEY LEVEL DETECTION ===
// =======================

detect_order_block() =>
    bool is_ob = false
    string ob_type = "NONE"
    
    if bar_index >= 3
        bool bullish_imbalance = low[1] < low[2] and low[1] < low[3] and close > high[1]
        bool bullish_structure = close > open and close[1] < open[1]
        
        if bullish_imbalance and bullish_structure
            is_ob := true
            ob_type := "BULLISH"
        
        bool bearish_imbalance = high[1] > high[2] and high[1] > high[3] and close < low[1]
        bool bearish_structure = close < open and close[1] > open[1]
        
        if bearish_imbalance and bearish_structure
            is_ob := true
            ob_type := "BEARISH"
    
    [is_ob, ob_type]

[is_order_block, ob_type] = detect_order_block()

// =======================
// === ENHANCED ENTRY SIGNALS ===
// =======================

var string entry_signal = "NONE"
var float entry_price = na
var float stop_loss = na
var float take_profit = na
var float position_size = na
var int entry_score = 0

generate_advanced_entry_signal() =>
    string signal = "NONE"
    float price = na
    float sl = na
    float tp = na
    float size = na
    int score = 0
    
    // Check if any CRT model is in D_READY state
    bool crt_active = (crt_1am_state == "D_READY") or 
                     (crt_5am_state == "D_READY") or 
                     (crt_9am_state == "D_READY")
    
    if crt_active and enable_entry_engine
        current_minutes = get_current_minutes()
        bool in_entry_window = false
        
        // Check entry windows
        if crt_1am_state == "D_READY" and is_in_time_window(120, 180)
            in_entry_window := true
        else if crt_5am_state == "D_READY" and is_in_time_window(360, 510)
            in_entry_window := true
        else if crt_9am_state == "D_READY" and is_in_time_window(570, 660)
            in_entry_window := true
        
        if in_entry_window
            // Determine direction based on DOL
            direction = dol_bias == "BULLISH" ? "BUY" : "SELL"
            
            // Apply advanced filters
            filters = evaluate_entry_filters(direction)
            score := filters.score
            
            // Only proceed if score meets minimum threshold
            if score >= min_entry_score
                // Check for order block confirmation
                if (direction == "BUY" and is_order_block and ob_type == "BULLISH") or
                   (direction == "SELL" and is_order_block and ob_type == "BEARISH")
                    
                    signal := direction
                    price := close
                    
                    // Dynamic stop loss with ATR
                    atr = ta.atr(14)
                    sl := direction == "BUY" ? 
                          low[1] - (atr * 0.5) : 
                          high[1] + (atr * 0.5)
                    
                    // Calculate position size
                    size := calculate_position_size(price, sl)
                    
                    // Dynamic take profit based on market structure
                    if not na(ms.lastHH) and not na(ms.lastLL)
                        tp := direction == "BUY" ? 
                              math.min(ms.lastHH, price + ((price - sl) * 3)) :
                              math.max(ms.lastLL, price - ((sl - price) * 3))
                    else
                        tp := direction == "BUY" ?
                              price + ((price - sl) * 2) :
                              price - ((sl - price) * 2)
    
    [signal, price, sl, tp, size, score]

[temp_signal, temp_price, temp_sl, temp_tp, temp_size, temp_score] = generate_advanced_entry_signal()

if temp_signal != "NONE"
    entry_signal := temp_signal
    entry_price := temp_price
    stop_loss := temp_sl
    take_profit := temp_tp
    position_size := temp_size
    entry_score := temp_score
else if entry_signal != "NONE"
    current_minutes = get_current_minutes()
    should_clear = true
    
    if crt_1am_state == "D_READY" and is_in_time_window(120, 180)
        should_clear := false
    else if crt_5am_state == "D_READY" and is_in_time_window(360, 510)
        should_clear := false
    else if crt_9am_state == "D_READY" and is_in_time_window(570, 660)
        should_clear := false
    
    if should_clear
        entry_signal := "NONE"
        entry_price := na
        stop_loss := na
        take_profit := na
        position_size := na
        entry_score := 0

// =======================
// === VISUALIZATIONS ====
// =======================

// Market Structure Visualization
if show_market_structure and not na(ms.lastHH)
    line.new(bar_index-20, ms.lastHH, bar_index, ms.lastHH, 
             color=color.new(color.blue, 50), style=line.style_dotted)
    label.new(bar_index-10, ms.lastHH, "HH", color=color.blue, 
              style=label.style_label_down, size=size.tiny)

if show_market_structure and not na(ms.lastLL)
    line.new(bar_index-20, ms.lastLL, bar_index, ms.lastLL, 
             color=color.new(color.blue, 50), style=line.style_dotted)
    label.new(bar_index-10, ms.lastLL, "LL", color=color.blue, 
              style=label.style_label_up, size=size.tiny)

// Liquidity Pool Visualization
if show_liquidity_pools and array.size(liquidityPools) > 0
    for pool in liquidityPools
        if not pool.swept and bar_index - pool.barIndex < 50
            poolColor = pool.poolType == "BUYSIDE" ? 
                       color.new(color.red, 70) : color.new(color.green, 70)
            line.new(pool.barIndex, pool.price, bar_index, pool.price, 
                    color=poolColor, width=2, style=line.style_dotted)

// Volume Profile Visualization
if show_volume_profile and barstate.islast
    // POC Line
    if not na(vp_current.poc)
        line.new(bar_index-50, vp_current.poc, bar_index, vp_current.poc, 
                color=color.new(color.orange, 30), width=3)
        label.new(bar_index, vp_current.poc, "POC", 
                 color=color.orange, style=label.style_label_left, size=size.small)
    
    // Value Area
    if not na(vp_current.vah) and not na(vp_current.val)
        box.new(bar_index-50, vp_current.vah, bar_index, vp_current.val, 
               bgcolor=color.new(color.blue, 90), border_width=1)

// Entry Signals with Advanced Info
if entry_signal != "NONE" and barstate.isconfirmed
    signal_color = entry_signal == "BUY" ? color.green : color.red
    signal_text = entry_signal + " (Score: " + str.tostring(entry_score) + "/100)\n"
    signal_text += "Entry: " + str.tostring(entry_price, "#.####") + "\n"
    signal_text += "SL: " + str.tostring(stop_loss, "#.####") + "\n"
    signal_text += "TP: " + str.tostring(take_profit, "#.####") + "\n"
    signal_text += "Size: " + str.tostring(position_size, "#.##") + " lots"
    
    label.new(bar_index, entry_signal == "BUY" ? low : high, signal_text,
              yloc = entry_signal == "BUY" ? yloc.belowbar : yloc.abovebar,
              style=label.style_label_center, size=size.normal,
              color=signal_color, textcolor=color.white)

// =======================
// === ADVANCED DASHBOARD ===
// =======================

if show_advanced_dashboard
    var table dashboard = table.new(position.top_right, 4, 15, border_width=1)
    
    if barstate.islast
        row = 0
        
        // Header
        table.merge_cells(dashboard, 0, row, 3, row)
        table.cell(dashboard, 0, row, "CRT ENGINE V7 PROFESSIONAL", 
                  bgcolor=color.new(color.blue, 70), text_color=color.white)
        
        // System Status Section
        row += 1
        table.merge_cells(dashboard, 0, row, 3, row)
        table.cell(dashboard, 0, row, "[ SYSTEM STATUS ]", 
                  bgcolor=color.gray, text_color=color.white)
        
        // Timeframe & Time
        row += 1
        tf_valid = is_valid_timeframe()
        table.cell(dashboard, 0, row, "Timeframe", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, timeframe.period, 
                  bgcolor=tf_valid ? color.green : color.red)
        table.cell(dashboard, 2, row, "GMT", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 3, row, str.format("{0,time,HH:mm}", time), 
                  bgcolor=color.new(color.gray, 90))
        
        // Market Analysis Section
        row += 1
        table.merge_cells(dashboard, 0, row, 3, row)
        table.cell(dashboard, 0, row, "[ MARKET ANALYSIS ]", 
                  bgcolor=color.gray, text_color=color.white)
        
        // DOL Status
        row += 1
        dol_color = dol_bias == "BULLISH" ? color.green : 
                   dol_bias == "BEARISH" ? color.red : color.gray
        table.cell(dashboard, 0, row, "DOL Bias", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, dol_bias, bgcolor=dol_color)
        table.cell(dashboard, 2, row, "Target", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 3, row, str.tostring(dol_target, "#.####"), bgcolor=dol_color)
        
        // Market Structure
        row += 1
        ms_color = ms.trend == "BULLISH" ? color.green : 
                  ms.trend == "BEARISH" ? color.red : color.gray
        table.cell(dashboard, 0, row, "Structure", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, ms.trend, bgcolor=ms_color)
        table.cell(dashboard, 2, row, "Strength", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 3, row, str.tostring(ms.strength) + "%", 
                  bgcolor=color.new(ms_color, 70))
        
        // Volume Profile
        row += 1
        vp_status = vp_current.bullishImbalance ? "Bull Imbal" : 
                   vp_current.bearishImbalance ? "Bear Imbal" : "Balanced"
        vp_color = vp_current.bullishImbalance ? color.green : 
                  vp_current.bearishImbalance ? color.red : color.gray
        table.cell(dashboard, 0, row, "Volume", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, vp_status, bgcolor=vp_color)
        table.cell(dashboard, 2, row, "POC", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 3, row, str.tostring(vp_current.poc, "#.####"), 
                  bgcolor=color.new(color.orange, 70))
        
        // CRT Models Section
        row += 1
        table.merge_cells(dashboard, 0, row, 3, row)
        table.cell(dashboard, 0, row, "[ CRT MODELS ]", 
                  bgcolor=color.gray, text_color=color.white)
        
        // Model States
        row += 1
        table.cell(dashboard, 0, row, "1AM", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, crt_1am_state, 
                  bgcolor=crt_1am_state == "D_READY" ? color.green : color.gray)
        table.cell(dashboard, 2, row, "5AM", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 3, row, crt_5am_state, 
                  bgcolor=crt_5am_state == "D_READY" ? color.green : color.gray)
        
        row += 1
        table.cell(dashboard, 0, row, "9AM", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, crt_9am_state, 
                  bgcolor=crt_9am_state == "D_READY" ? color.green : color.gray)
        table.cell(dashboard, 2, row, "Session", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 3, row, session_state, bgcolor=color.new(color.gray, 70))
        
        // Entry & Risk Section
        row += 1
        table.merge_cells(dashboard, 0, row, 3, row)
        table.cell(dashboard, 0, row, "[ ENTRY & RISK ]", 
                  bgcolor=color.gray, text_color=color.white)
        
        // Entry Signal
        row += 1
        entry_color = entry_signal == "BUY" ? color.green : 
                     entry_signal == "SELL" ? color.red : color.gray
        table.cell(dashboard, 0, row, "Signal", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, entry_signal, bgcolor=entry_color)
        table.cell(dashboard, 2, row, "Score", bgcolor=color.new(color.gray, 90))
        score_color = entry_score >= 80 ? color.green : 
                     entry_score >= 60 ? color.yellow : color.red
        table.cell(dashboard, 3, row, str.tostring(entry_score) + "/100", 
                  bgcolor=score_color)
        
        // Risk Management
        row += 1
        table.cell(dashboard, 0, row, "Risk Status", bgcolor=color.new(color.gray, 90))
        table.cell(dashboard, 1, row, rm.tradingAllowed ? "ACTIVE" : "HALTED", 
                  bgcolor=rm.tradingAllowed ? color.green : color.red)
        table.cell(dashboard, 2, row, "Daily P&L", bgcolor=color.new(color.gray, 90))
        pnl_color = rm.currentDailyPnL >= 0 ? color.green : color.red
        table.cell(dashboard, 3, row, str.tostring(rm.currentDailyPnL, "#.##"), 
                  bgcolor=pnl_color)
        
        // Performance Section
        row += 1
        table.merge_cells(dashboard, 0, row, 3, row)
        table.cell(dashboard, 0, row, "[ PERFORMANCE ]", 
                  bgcolor=color.gray, text_color=color.white)
        
        row += 1
        table.cell(dashboard, 0, row, "Win Rate", bgcolor=color.new(color.gray, 90))
        wr_color = pt.winRate >= 60 ? color.green : 
                  pt.winRate >= 40 ? color.yellow : color.red
        table.cell(dashboard, 1, row, str.tostring(pt.winRate, "#.#") + "%", 
                  bgcolor=wr_color)
        table.cell(dashboard, 2, row, "Sharpe", bgcolor=color.new(color.gray, 90))
        sharpe_color = pt.sharpeRatio >= 1.5 ? color.green : 
                      pt.sharpeRatio >= 0.5 ? color.yellow : color.red
        table.cell(dashboard, 3, row, str.tostring(pt.sharpeRatio, "#.##"), 
                  bgcolor=sharpe_color)

// =======================
// === ALERTS ============
// =======================

// Advanced alerts with scoring
alertcondition(entry_signal == "BUY" and entry_score >= 80, 
               title="HIGH CONFIDENCE BUY", 
               message="Strong BUY Signal - Score: " + str.tostring(entry_score))

alertcondition(entry_signal == "SELL" and entry_score >= 80, 
               title="HIGH CONFIDENCE SELL", 
               message="Strong SELL Signal - Score: " + str.tostring(entry_score))

alertcondition(ms.brokenStructure, 
               title="Market Structure Break", 
               message="Market Structure Changed to " + ms.trend)

// Liquidity sweep alerts
alertcondition(check_liquidity_sweep("BUY"), 
               title="Bullish Liquidity Sweep", 
               message="Sell-side liquidity swept - Potential reversal up")

alertcondition(check_liquidity_sweep("SELL"), 
               title="Bearish Liquidity Sweep", 
               message="Buy-side liquidity swept - Potential reversal down")

// =======================
// === SYSTEM INFO =======
// =======================

var string system_version = "7.0.0"
var string build_date = "2024-01-15"
var string edition = "PROFESSIONAL"

plotchar(barstate.islast ? 1 : na, title="CRT v7 Pro", char='', 
         location=location.abovebar, color=color.new(color.white, 100))
//@version=5
indicator("CRT State Engine v9.0 - LUXALGO SMC ORDER BLOCKS", "CRT-v9.0-LUXALGO", overlay=true, max_labels_count=200, max_lines_count=200, max_boxes_count=50, dynamic_requests=true)

// ═══════════════════════════════════════════════════════════════════════════════
//                     CRT STATE ENGINE v9.0 - LUXALGO SMC EDITION
//                    SUPERIOR ORDER BLOCK SYSTEM WITH LUXALGO SMC
// 
//  V9.0 LUXALGO INCLUDES:
//  ✓ INTEGRATED: Complete LuxAlgo SMC order block detection system
//  ✓ SUPERIOR: Advanced leg detection and structure analysis
//  ✓ ENHANCED: Internal and swing order block management
//  ✓ OPTIMIZED: LuxAlgo CISD (Change in Structure Direction) detection
//  ✓ PROFESSIONAL: Market structure analysis with strength calculation
//  ✓ All previous CRT features maintained with superior order block detection
//
// ═══════════════════════════════════════════════════════════════════════════════

// =======================
// === TYPE DEFINITIONS ===
// =======================

type MarketStructure
    float lastHH
    float lastHL
    float lastLH
    float lastLL
    string trend
    int strength
    bool brokenStructure
    int trendBars

// LUXALGO ORDER BLOCK TYPE - SUPERIOR TO PREVIOUS IMPLEMENTATION
type OrderBlock
    float barHigh
    float barLow
    int barTime    
    int bias

type bin 
    line ln
    bool active
    chart.point cp1
    chart.point cp2
    bool broken = false

type swing 
    chart.point cp
    line ln
    line wick
    bool active = false
    
type LiquidityPool
    float price
    string poolType
    int touches
    float volume
    bool swept
    int barIndex

type VolumeProfile
    float poc
    float vah
    float val
    float totalVolume
    bool bullishImbalance
    bool bearishImbalance

type CorrelationData
    string symbol
    float correlation
    bool divergence
    string divergenceType
    float strength

type EntryFilter
    bool marketStructureAligned
    bool liquiditySwept
    bool volumeConfirmation
    bool correlationConfirmation
    bool timeOfDayOptimal
    int score

type RiskManager
    float accountBalance
    float riskPerTrade
    float maxDailyLoss
    float currentDailyPnL
    int maxConcurrentTrades
    int currentOpenTrades
    float positionSize
    bool tradingAllowed

type PerformanceTracker
    int totalSignals
    int winningSignals
    int losingSignals
    float winRate
    float avgWin
    float avgLoss
    float profitFactor
    float sharpeRatio
    array<float> returns

// =======================
// === COMPLETE INPUT PARAMETERS ===
// =======================

// ╔═══════════════════════════════════════════════════════════════════════════════
// 0. TIMEZONE SETTINGS - CRITICAL
// ╚═══════════════════════════════════════════════════════════════════════════════
timezone_mode = input.string("America/New_York", "🕐 Timezone for CRT Models", options=["America/New_York", "GMT", "Europe/London"], group="0. 🚨 TIMEZONE (CRITICAL)", tooltip="CRT models use New York time.")
show_timezone_info = input.bool(true, "Show Timezone Info on Chart", group="0. 🚨 TIMEZONE (CRITICAL)", tooltip="Displays current NY time and GMT for verification")

// ╔═══════════════════════════════════════════════════════════════════════════════
// 1. CRT MODELS
// ╚═══════════════════════════════════════════════════════════════════════════════
enable_9pm_crt = input.bool(true, "9PM NY Overnight Model", group="1. CRT Models") 
enable_1am_crt = input.bool(true, "1AM NY Model", group="1. CRT Models")
enable_5am_crt = input.bool(true, "5AM NY Model", group="1. CRT Models")
enable_9am_crt = input.bool(true, "9AM NY Model", group="1. CRT Models")

// ╔═══════════════════════════════════════════════════════════════════════════════
// 2. CORE SYSTEM
// ╚═══════════════════════════════════════════════════════════════════════════════
cisd_detection_method = input.string('Liquidity Sweep', 'CISD Detection Method', options=['Classic', 'Liquidity Sweep'], group="2. Core System", tooltip="Liquidity Sweep: More advanced, based on sweeps of swing points.\nClassic: Based on candle structure breaks.")
ob_detection_method = input.string("Strict (Cursor)", "Order Block Method", options=["Strict (Cursor)", "Lenient (Claude)"], group="2. Core System")
enable_dol_engine = input.bool(true, "Enable DOL Analysis Engine", group="2. Core System")
pivot_strength = input.int(10, "DOL Pivot Strength", minval=5, maxval=50, group="2. Core System")
enable_session_engine = input.bool(true, "Enable Session State Machine", group="2. Core System")
enable_entry_engine = input.bool(true, "Enable Live Entry Signals", group="2. Core System")
enable_debug_mode = input.bool(false, "Debug Mode (Show All States)", group="2. Core System")


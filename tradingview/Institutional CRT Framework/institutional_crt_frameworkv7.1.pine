var string build_date = "2024-01-15"
var string edition = "HOTFIX"

plotchar(barstate.islast ? 1 : na, title="CRT v7.1 Hotfix", char='', location=location.abovebar, color=color.new(color.white, 100), text="CRT Engine v" + system_version + "\nBuild: " + build_date + "\nEdition: " + edition)
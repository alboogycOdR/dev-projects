if barstate.isfirst
    rm.accountBalance := account_balance
    rm.riskPerTrade := account_balance * (risk_per_trade_pct / 100)
    rm.maxDailyLoss := account_balance * (max_daily_loss_pct / 100)
    rm.maxConcurrentTrades := max_concurrent_trades
    rm.currentOpenTrades := 0
    rm.currentDailyPnL := 0
    rm.tradingAllowed := true

// =======================
// === TIMEZONE FUNCTIONS ===
// =======================

get_tz_hour() => hour(time, timezone_mode)
get_tz_minute() => minute(time, timezone_mode)
get_tz_minutes() => get_tz_hour() * 60 + get_tz_minute()

is_in_tz_window(int start_hour, int start_min, int end_hour, int end_min) =>
    current_minutes = get_tz_minutes()
    start_minutes = start_hour * 60 + start_min
    end_minutes = end_hour * 60 + end_min
    
    if start_minutes <= end_minutes
        current_minutes >= start_minutes and current_minutes <= end_minutes
    else
        current_minutes >= start_minutes or current_minutes <= end_minutes


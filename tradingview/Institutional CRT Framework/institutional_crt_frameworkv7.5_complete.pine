// =======================
// === TYPE DEFINITIONS ===
// =======================

type MarketStructure
    float lastHH
    float lastHL
    float lastLH
    float lastLL
    string trend
    int strength
    bool brokenStructure
    int trendBars

type LiquidityPool
    float price
    string poolType
    int touches
    float volume
    bool swept
    int barIndex

type VolumeProfile
    float poc
    float vah
    float val
    float totalVolume
    bool bullishImbalance
    bool bearishImbalance

type CorrelationData
    string symbol
    float correlation
    bool divergence
    string divergenceType
    float strength

type EntryFilter
    bool marketStructureAligned
    bool liquiditySwept
    bool volumeConfirmation
    bool correlationConfirmation
    bool timeOfDayOptimal
    int score

type RiskManager
    float accountBalance
    float riskPerTrade
    float maxDailyLoss
    float currentDailyPnL
    int maxConcurrentTrades
    int currentOpenTrades
    float positionSize
    bool tradingAllowed

type PerformanceTracker
    int totalSignals
    int winningSignals
    int losingSignals
    float winRate
    float avgWin
    float avgLoss
    float profitFactor
    float sharpeRatio
    array<float> returns


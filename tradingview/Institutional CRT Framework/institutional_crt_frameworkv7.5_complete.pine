// =======================
// === CORE SYSTEM FUNCTIONS ===
// =======================

var array<string> session_name_history = array.new<string>(100)
var array<string> session_behavior_history = array.new<string>(100)
var array<float> session_high_history = array.new<float>(100)
var array<float> session_low_history = array.new<float>(100)
var array<int> session_start_bars = array.new<int>(100)

track_session_history(string current_session, string current_behavior, float current_high, float current_low) =>
    if array.size(session_name_history) >= 100
        array.shift(session_name_history)
        array.shift(session_behavior_history)
        array.shift(session_high_history)
        array.shift(session_low_history)
        array.shift(session_start_bars)
    
    array.push(session_name_history, current_session)
    array.push(session_behavior_history, current_behavior)
    array.push(session_high_history, current_high)
    array.push(session_low_history, current_low)
    array.push(session_start_bars, bar_index)

get_session_behavior_lookback(int sessions_back) =>
    idx = array.size(session_behavior_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_behavior_history) ? array.get(session_behavior_history, idx) : "UNKNOWN"
    result

get_session_high_lookback(int sessions_back) =>
    idx = array.size(session_high_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_high_history) ? array.get(session_high_history, idx) : high
    result

get_session_low_lookback(int sessions_back) =>
    idx = array.size(session_low_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_low_history) ? array.get(session_low_history, idx) : low
    result

get_timeframe_multiplier() =>
    multiplier = 1.0
    if timeframe.isminutes
        multiplier := 240.0 / timeframe.multiplier
    else if timeframe.isdaily
        multiplier := 0.1667
    else if timeframe.isweekly
        multiplier := 0.0357
    multiplier

is_valid_timeframe() =>
    valid = (timeframe.isminutes and (timeframe.multiplier == 15 or timeframe.multiplier == 30 or timeframe.multiplier == 60 or timeframe.multiplier == 240)) or timeframe.isdaily or timeframe.isweekly
    valid

adjust_lookback_for_timeframe(int base_lookback) =>
    math.max(1, math.round(base_lookback * get_timeframe_multiplier()))

// =======================
// === DOL ANALYSIS ===
// =======================

adjusted_pivot_strength = math.round(pivot_strength * get_timeframe_multiplier())
adjusted_pivot_strength := math.max(2, math.min(50, adjusted_pivot_strength))

float pivot_high_price = ta.pivothigh(high, adjusted_pivot_strength, adjusted_pivot_strength)
float pivot_low_price = ta.pivotlow(low, adjusted_pivot_strength, adjusted_pivot_strength)

var float last_swing_high = na
var float last_swing_low = na
var float dol_target = na
var string dol_bias = "NEUTRAL"

if not na(pivot_high_price)
    last_swing_high := pivot_high_price
if not na(pivot_low_price)
    last_swing_low := pivot_low_price

if not na(last_swing_high) and not na(last_swing_low)
    float dist_to_high = math.abs(close - last_swing_high)
    float dist_to_low = math.abs(close - last_swing_low)
    dol_bias := dist_to_high < dist_to_low ? "BULLISH" : "BEARISH"
    dol_target := dist_to_high < dist_to_low ? last_swing_high : last_swing_low

// =======================
// === SESSION STATES (NY TIME) ===
// =======================

get_session_state() =>
    string state = "UNKNOWN"
    int h = get_tz_hour()
    
    // Sessions in NEW YORK TIME
    if h >= 13 and h < 17 and monitor_cbdr     // 1:00 PM - 5:00 PM NY
        state := "CBDR"
    else if h >= 17 and h < 21 and monitor_asia // 5:00 PM - 9:00 PM NY
        state := "ASIA"
    else if h >= 21 or h < 1                    // 9:00 PM - 1:00 AM NY
        state := "ASIA_LATE"
    else if h >= 1 and h < 3 and monitor_london // 1:00 AM - 3:00 AM NY
        state := "LONDON_PREP"
    else if h >= 3 and h < 5 and monitor_london // 3:00 AM - 5:00 AM NY
        state := "LONDON"
    else if h >= 5 and h < 9 and monitor_lunch  // 5:00 AM - 9:00 AM NY
        state := "LUNCH"
    else if h >= 9 and h < 13 and monitor_ny    // 9:00 AM - 1:00 PM NY
        state := "NY"
    else
        state := "POST_NY"
    
    state

string session_state = get_session_state()
var string session_behavior = "CONSOLIDATION"
var float session_high = na, var float session_low = na
var string prev_session = "", var float prev_session_high = na, var float prev_session_low = na

if session_state != prev_session
    if prev_session != ""
        track_session_history(prev_session, session_behavior, session_high, session_low)
    prev_session_high := session_high
    prev_session_low := session_low
    prev_session := session_state
    session_high := high
    session_low := low
    session_behavior := "CONSOLIDATION"
else
    session_high := math.max(nz(session_high, high), high)
    session_low := math.min(nz(session_low, low), low)
    float prev_session_range = nz(prev_session_high - prev_session_low, 0)
    if prev_session_range > 0
        session_behavior := high - low > prev_session_range * 1.5 ? "EXPANSION" : (high > nz(prev_session_high, high) or low < nz(prev_session_low, low) ? "MANIPULATION" : session_behavior)

// =======================
// === CRT PATTERN STATES (NY TIME) ===
// =======================

var string crt_1am_state = "INACTIVE", var string crt_5am_state = "INACTIVE", var string crt_9am_state = "INACTIVE"
var string profile_1am = "NONE", var string profile_5am = "NONE", var string profile_9am = "NONE"

london_made_hod_lod() =>
    london_sessions_back = session_state == "NY" ? 1 : session_state == "LUNCH" ? 0 : 2
    london_high = get_session_high_lookback(london_sessions_back)
    london_low = get_session_low_lookback(london_sessions_back)
    daily_high = ta.highest(high, adjust_lookback_for_timeframe(24))
    daily_low = ta.lowest(low, adjust_lookback_for_timeframe(24))
    (london_high - london_low > (daily_high - daily_low) * 0.6) or (london_high >= daily_high * 0.999) or (london_low <= daily_low * 1.001)

get_active_profile() =>
    result = "NONE"
    if profile_9am != "NONE" and crt_9am_state != "INACTIVE"
        result := profile_9am
    else if profile_5am != "NONE" and crt_5am_state != "INACTIVE"
        result := profile_5am
    else if profile_1am != "NONE" and crt_1am_state != "INACTIVE"
        result := profile_1am
    result

// 1AM NY MODEL
update_1am_crt_state() =>
    string state = crt_1am_state, string profile = profile_1am
    if enable_1am_crt and is_valid_timeframe()
        h = get_tz_hour()
        m = get_tz_minute()
        
        // A_FORMING: 1:00-1:30 AM NY
        if h == 1 and m < 30 and crt_1am_state == "INACTIVE"
            cbdr_behavior = get_session_behavior_lookback(2)
            asia_behavior = get_session_behavior_lookback(1)
            profile := cbdr_behavior == "CONSOLIDATION" and asia_behavior == "CONSOLIDATION" ? "NORMAL_PROTRACTION" : cbdr_behavior == "CONSOLIDATION" and asia_behavior == "MANIPULATION" ? "DELAYED_PROTRACTION" : "STANDARD"
            state := "A_FORMING"
        // M_LIVE: 5:00-5:30 AM NY
        else if h == 5 and m < 30 and crt_1am_state == "A_FORMING"
            state := "M_LIVE"
        // D_READY: 9:00-9:30 AM NY
        else if h == 9 and m < 30 and crt_1am_state == "M_LIVE"
            state := "D_READY"
        // Reset after 13:00 NY
        else if h >= 13 and crt_1am_state == "D_READY"
            state := "INACTIVE", profile := "NONE"
    [state, profile]
[temp_state, temp_profile] = update_1am_crt_state()
crt_1am_state := temp_state
profile_1am := temp_profile

// 5AM NY MODEL
update_5am_crt_state() =>
    string state = crt_5am_state, string profile = profile_5am
    if enable_5am_crt and is_valid_timeframe()
        h = get_tz_hour()
        m = get_tz_minute()
        
        // A_FORMING: 5:00-5:30 AM NY
        if h == 5 and m < 30 and crt_5am_state == "INACTIVE"
            london_extreme = london_made_hod_lod()
            profile := dol_bias == "BEARISH" and not london_extreme ? "LONDON_LUNCH_LOW" : dol_bias == "BULLISH" and london_extreme ? "NY_CONTINUATION" : dol_bias == "BEARISH" and london_extreme ? "NY_REVERSAL" : "STANDARD"
            state := "A_FORMING"
        // M_LIVE: 9:00-9:30 AM NY
        else if h == 9 and m < 30 and crt_5am_state == "A_FORMING"
            state := "M_LIVE"
        // D_READY: 1:00-1:30 PM NY
        else if h == 13 and m < 30 and crt_5am_state == "M_LIVE"
            state := "D_READY"
        // Reset after 17:00 NY
        else if h >= 17 and crt_5am_state == "D_READY"
            state := "INACTIVE", profile := "NONE"
    [state, profile]
[temp_state_5am, temp_profile_5am] = update_5am_crt_state()
crt_5am_state := temp_state_5am
profile_5am := temp_profile_5am

// 9AM NY MODEL
update_9am_crt_state() =>
    string state = crt_9am_state, string profile = profile_9am
    if enable_9am_crt and is_valid_timeframe()
        h = get_tz_hour()
        m = get_tz_minute()
        
        // A_FORMING: 9:00-9:30 AM NY
        if h == 9 and m < 30 and crt_9am_state == "INACTIVE"
            dol_reached = math.abs(close - dol_target) < (dol_target * 0.002)
            asia_protected = get_session_behavior_lookback(3) != "EXPANSION"
            london_protected = get_session_behavior_lookback(1) != "EXPANSION"
            profile := not dol_reached and london_made_hod_lod() ? "NY_CONTINUATION" : dol_reached and asia_protected and london_protected ? "NY_REVERSAL" : "STANDARD"
            state := "A_FORMING"
        // M_LIVE: 1:00-1:30 PM NY
        else if h == 13 and m < 30 and crt_9am_state == "A_FORMING"
            state := "M_LIVE"
        // D_READY: 5:00-5:30 PM NY
        else if h == 17 and m < 30 and crt_9am_state == "M_LIVE"
            state := "D_READY"
        // Reset after 21:00 NY
        else if h >= 21 and crt_9am_state == "D_READY"
            state := "INACTIVE", profile := "NONE"
    [state, profile]
[temp_state_9am, temp_profile_9am] = update_9am_crt_state()
crt_9am_state := temp_state_9am
profile_9am := temp_profile_9am

// =======================
// === KEY LEVEL DETECTION ===
// =======================

detect_order_block() =>
    bool is_ob = false
    string ob_type = "NONE"
    if bar_index >= 3
        if ob_detection_method == "Strict (Cursor)"
            bool bullish_imbalance = low[1] < low[2] and low[1] < low[3] and close > high[1]
            bool bullish_structure = close > open and close[1] < open[1]
            if bullish_imbalance and bullish_structure
                is_ob := true, ob_type := "BULLISH"
            
            bool bearish_imbalance = high[1] > high[2] and high[1] > high[3] and close < low[1]
            bool bearish_structure = close < open and close[1] > open[1]
            if bearish_imbalance and bearish_structure
                is_ob := true, ob_type := "BEARISH"
        else // Lenient (Claude)
            if low[1] < low[2] and low[1] < low[3] and close > high[1]
                is_ob := true, ob_type := "BULLISH"
            if high[1] > high[2] and high[1] > high[3] and close < low[1]
                is_ob := true, ob_type := "BEARISH"
    [is_ob, ob_type]
[is_order_block, ob_type] = detect_order_block()

detect_fvg() =>
    bool is_fvg = false
    string fvg_type = "NONE"
    float fvg_top = 0.0, float fvg_bottom = 0.0
    if bar_index >= 2
        if low > high[2]
            is_fvg := true, fvg_type := "BULLISH", fvg_top := low, fvg_bottom := high[2]
        if high < low[2]
            is_fvg := true, fvg_type := "BEARISH", fvg_top := low[2], fvg_bottom := high
    [is_fvg, fvg_type, fvg_top, fvg_bottom]
[is_fvg, fvg_type, fvg_top, fvg_bottom] = detect_fvg()

// =======================
// === V7 ADVANCED MODULES ===
// =======================

update_market_structure() =>
    if enable_market_structure
        pivotHigh = ta.pivothigh(high, 5, 5)
        pivotLow = ta.pivotlow(low, 5, 5)
        if not na(pivotHigh)
            if na(ms.lastHH) or pivotHigh > ms.lastHH
                ms.lastLH := ms.lastHH, ms.lastHH := pivotHigh
                if ms.trend == "BEARISH" and not na(ms.lastLH) and pivotHigh > ms.lastLH
                    ms.trend := "BULLISH", ms.brokenStructure := true, ms.trendBars := 0
            else
                ms.lastLH := pivotHigh
        if not na(pivotLow)
            if na(ms.lastLL) or pivotLow < ms.lastLL
                ms.lastHL := ms.lastLL, ms.lastLL := pivotLow
                if ms.trend == "BULLISH" and not na(ms.lastHL) and pivotLow < ms.lastHL
                    ms.trend := "BEARISH", ms.brokenStructure := true, ms.trendBars := 0
            else
                ms.lastHL := pivotLow
        ms.trendBars += 1
        if not na(ms.lastHH) and not na(ms.lastLL)
            range_hl = ms.lastHH - ms.lastLL
            if range_hl > 0
                ms.strength := ms.trend == "BULLISH" ? math.round(((close - ms.lastLL) / range_hl) * 100) : math.round(((ms.lastHH - close) / range_hl) * 100)
                ms.strength := math.max(0, math.min(100, ms.strength))
update_market_structure()

detect_liquidity_pools() =>
    if enable_liquidity_pools
        if high == high[1] and high > ta.highest(high[2], 10)
            array.push(liquidityPools, LiquidityPool.new(high, "BUYSIDE", 2, nz(volume, 0) + nz(volume[1], 0), false, bar_index))
        if low == low[1] and low < ta.lowest(low[2], 10)
            array.push(liquidityPools, LiquidityPool.new(low, "SELLSIDE", 2, nz(volume, 0) + nz(volume[1], 0), false, bar_index))
        if array.size(liquidityPools) > 0
            for i = array.size(liquidityPools) - 1 to 0
                pool = array.get(liquidityPools, i)
                if not pool.swept
                    if pool.poolType == "BUYSIDE" and high > pool.price
                        pool.swept := true
                    else if pool.poolType == "SELLSIDE" and low < pool.price
                        pool.swept := true
                if bar_index - pool.barIndex > 50
                    array.remove(liquidityPools, i)
detect_liquidity_pools()

check_liquidity_sweep(string direction) =>
    swept = false
    if array.size(liquidityPools) > 0
        for pool in liquidityPools
            if pool.swept and bar_index - pool.barIndex < 5 and ((direction == "BUY" and pool.poolType == "SELLSIDE") or (direction == "SELL" and pool.poolType == "BUYSIDE"))
                swept := true
                break
    swept

calculate_volume_profile(int lookback) =>
    vp = VolumeProfile.new(0.0, 0.0, 0.0, 0.0, false, false)
    if enable_volume_profile and barstate.isconfirmed
        effectiveLookback = math.min(lookback, 30)
        highest = ta.highest(high, effectiveLookback)
        lowest = ta.lowest(low, effectiveLookback)
        priceRange = highest - lowest
        if priceRange > 0 and not na(volume)
            numBins = 10
            binSize = priceRange / numBins
            var array<float> volumeLevels = array.new_float(10, 0), var array<float> priceLevels = array.new_float(10, 0)
            array.clear(volumeLevels), array.clear(priceLevels)
            for i = 0 to numBins - 1
                array.push(priceLevels, lowest + (i * binSize)), array.push(volumeLevels, 0.0)
            maxBars = math.min(effectiveLookback, bar_index + 1, 20)
            for i = 0 to maxBars - 1
                if i < bar_index
                    binIndex = math.max(0, math.min(numBins - 1, math.floor(((high[i] + low[i]) / 2 - lowest) / binSize)))
                    array.set(volumeLevels, binIndex, array.get(volumeLevels, binIndex) + nz(volume[i], 0))
            maxVol = 0.0, pocIndex = 0, totalVol = 0.0
            for i = 0 to numBins - 1
                vol = array.get(volumeLevels, i)
                totalVol += vol
                if vol > maxVol
                    maxVol := vol, pocIndex := i
            vp.totalVolume := totalVol
            if totalVol > 0
                vp.poc := array.get(priceLevels, pocIndex)
                vp.vah := array.get(priceLevels, math.min(pocIndex + 1, numBins - 1))
                vp.val := array.get(priceLevels, math.max(pocIndex - 1, 0))
                vp.bullishImbalance := close > vp.poc and close > vp.vah
                vp.bearishImbalance := close < vp.poc and close < vp.val
    vp
vp_current = calculate_volume_profile(20)

// Declare the pairs array for correlation
sym1 = input.symbol("GBPUSD", "Correlation Pair 1", group="3. Advanced Modules")
sym2 = input.symbol("AUDUSD", "Correlation Pair 2", group="3. Advanced Modules")

calculate_correlations() =>
    var array<CorrelationData> correlations = array.new<CorrelationData>()
    if enable_correlation
        array.clear(correlations)
        
        // Get data for correlation pairs
        [close1, change1] = request.security(sym1, timeframe.period, [close, close - close[1]], lookahead=barmerge.lookahead_on)
        [close2, change2] = request.security(sym2, timeframe.period, [close, close - close[1]], lookahead=barmerge.lookahead_on)
        
        currentChange = (close - close[1]) / close[1] * 100
        
        // Process first pair
        if not na(close1) and not na(change1) and close1[1] != 0
            pairChange1 = change1 / close1[1] * 100
            corr1 = ta.correlation(close, close1, 20)
            divergence1 = math.abs(corr1) > 0.7 and ((currentChange > 0 and pairChange1 < 0) or (currentChange < 0 and pairChange1 > 0))
            divType1 = divergence1 ? (currentChange > 0 ? "BULLISH_SMT" : "BEARISH_SMT") : "NONE"
            strength1 = divergence1 ? math.abs(currentChange - pairChange1) : 0
            array.push(correlations, CorrelationData.new(sym1, corr1, divergence1, divType1, strength1))
        
        // Process second pair
        if not na(close2) and not na(change2) and close2[1] != 0
            pairChange2 = change2 / close2[1] * 100
            corr2 = ta.correlation(close, close2, 20)
            divergence2 = math.abs(corr2) > 0.7 and ((currentChange > 0 and pairChange2 < 0) or (currentChange < 0 and pairChange2 > 0))
            divType2 = divergence2 ? (currentChange > 0 ? "BULLISH_SMT" : "BEARISH_SMT") : "NONE"
            strength2 = divergence2 ? math.abs(currentChange - pairChange2) : 0
            array.push(correlations, CorrelationData.new(sym2, corr2, divergence2, divType2, strength2))
    
    correlations

correlations = calculate_correlations()

check_smt_divergence(string direction) =>
    has_divergence = false
    if array.size(correlations) > 0
        for corr in correlations
            if corr.divergence and ((direction == "BUY" and corr.divergenceType == "BULLISH_SMT") or (direction == "SELL" and corr.divergenceType == "BEARISH_SMT"))
                has_divergence := true
                break
    has_divergence

evaluate_entry_filters(string direction) =>
    ef = EntryFilter.new(false, false, false, false, false, 0)
    ef.score := 0
    if (direction == "BUY" and ms.trend == "BULLISH") or (direction == "SELL" and ms.trend == "BEARISH")
        ef.marketStructureAligned := true, ef.score += 20
    if check_liquidity_sweep(direction)
        ef.liquiditySwept := true, ef.score += 25
    if (direction == "BUY" and close > vp_current.poc) or (direction == "SELL" and close < vp_current.poc)
        ef.volumeConfirmation := true, ef.score += 20
    if check_smt_divergence(direction)
        ef.correlationConfirmation := true, ef.score += 20
    if array.includes(array.from(2, 3, 6, 7, 8, 9, 10), get_tz_hour())
        ef.timeOfDayOptimal := true, ef.score += 15
    ef

calculate_position_size(float entryPrice, float stopLoss) =>
    position_size = 0.0
    if enable_risk_management
        pipRisk = math.abs(entryPrice - stopLoss)
        if pipRisk > 0
            pipValue = syminfo.type == "forex" ? 0.0001 : syminfo.mintick
            position_size := rm.riskPerTrade / (pipRisk / pipValue)
        rm.tradingAllowed := rm.currentOpenTrades < rm.maxConcurrentTrades and math.abs(rm.currentDailyPnL) < rm.maxDailyLoss
    position_size

// =======================
// === ENHANCED ENTRY SIGNALS ===
// =======================

var string entry_signal = "NONE", var float entry_price = na, var float stop_loss = na
var float take_profit = na, var float position_size = na, var int entry_score = 0

generate_advanced_entry_signal() =>
    string signal = "NONE"
    float price = na, float sl = na, float tp = na, float size = na
    int score = 0
    bool crt_active = crt_1am_state == "D_READY" or crt_5am_state == "D_READY" or crt_9am_state == "D_READY"
    if crt_active and enable_entry_engine
        h = get_tz_hour()
        m = get_tz_minute()
        
        // Check entry windows (NY TIME!)
        bool in_1am_window = crt_1am_state == "D_READY" and h >= 2 and h < 3  // 2:00-3:00 AM NY
        bool in_5am_window = crt_5am_state == "D_READY" and ((h == 6) or (h == 7) or (h == 8 and m < 30))  // 6:00-8:30 AM NY
        bool in_9am_window = crt_9am_state == "D_READY" and h >= 10 and h < 11  // 10:00-11:00 AM NY
        
        bool in_entry_window = in_1am_window or in_5am_window or in_9am_window
        
        if in_entry_window
            string direction = dol_bias == "BULLISH" ? "BUY" : "SELL"
            EntryFilter filters = evaluate_entry_filters(direction)
            score := filters.score
            if score >= min_entry_score
                if (direction == "BUY" and is_order_block and ob_type == "BULLISH") or (direction == "SELL" and is_order_block and ob_type == "BEARISH")
                    signal := direction, price := close
                    sl := direction == "BUY" ? low[1] - (ta.atr(14) * 0.5) : high[1] + (ta.atr(14) * 0.5)
                    size := calculate_position_size(price, sl)
                    if tp_calculation_method == "Dynamic (Cursor)"
                        tp := not na(ms.lastHH) and not na(ms.lastLL) ? (direction == "BUY" ? math.min(ms.lastHH, price + ((price - sl) * 3)) : math.max(ms.lastLL, price - ((sl - price) * 3))) : (direction == "BUY" ? price + ((price - sl) * 2) : price - ((sl - price) * 2))
                    else // Fixed R:R (Claude)
                        tp := direction == "BUY" ? price + ((price - sl) * risk_reward_ratio) : price - ((sl - price) * risk_reward_ratio)
    [signal, price, sl, tp, size, score]

[temp_signal, temp_price, temp_sl, temp_tp, temp_size, temp_score] = generate_advanced_entry_signal()

if temp_signal != "NONE"
    entry_signal := temp_signal, entry_price := temp_price, stop_loss := temp_sl
    take_profit := temp_tp, position_size := temp_size, entry_score := temp_score
else if entry_signal != "NONE"
    h = get_tz_hour()
    m = get_tz_minute()
    bool should_clear = not ((crt_1am_state == "D_READY" and h >= 2 and h < 3) or (crt_5am_state == "D_READY" and ((h == 6) or (h == 7) or (h == 8 and m < 30))) or (crt_9am_state == "D_READY" and h >= 10 and h < 11))
    if should_clear
        entry_signal := "NONE", entry_price := na, stop_loss := na
        take_profit := na, position_size := na, entry_score := 0

// =======================
// === VISUALIZATIONS ===
// =======================

if show_dol_lines and not na(last_swing_high)
    line.new(bar_index-50, last_swing_high, bar_index+10, last_swing_high, color=col_bearish_dol, style=line.style_dashed, width=2)
if show_dol_lines and not na(last_swing_low)
    line.new(bar_index-50, last_swing_low, bar_index+10, last_swing_low, color=col_bullish_dol, style=line.style_dashed, width=2)

if show_session_boxes and barstate.isconfirmed and session_state != prev_session and not na(prev_session_high) and not na(prev_session_low)
    color session_color = session_behavior == "CONSOLIDATION" ? col_consolidation : session_behavior == "MANIPULATION" ? col_manipulation : col_expansion
    box.new(bar_index-4, prev_session_high, bar_index, prev_session_low, bgcolor=session_color, border_width=1)

if show_market_structure and not na(ms.lastHH)
    line.new(bar_index-20, ms.lastHH, bar_index, ms.lastHH, color=color.new(color.blue, 50), style=line.style_dotted)
    label.new(bar_index-10, ms.lastHH, "HH", color=color.blue, style=label.style_label_down, size=size.tiny)
if show_market_structure and not na(ms.lastLL)
    line.new(bar_index-20, ms.lastLL, bar_index, ms.lastLL, color=color.new(color.blue, 50), style=line.style_dotted)
    label.new(bar_index-10, ms.lastLL, "LL", color=color.blue, style=label.style_label_up, size=size.tiny)

if show_liquidity_pools and array.size(liquidityPools) > 0
    for pool in liquidityPools
        if not pool.swept and bar_index - pool.barIndex < 50
            color poolColor = pool.poolType == "BUYSIDE" ? color.new(color.red, 70) : color.new(color.green, 70)
            line.new(pool.barIndex, pool.price, bar_index, pool.price, color=poolColor, width=2, style=line.style_dotted)

if show_volume_profile and barstate.islast
    if not na(vp_current.poc)
        line.new(bar_index-50, vp_current.poc, bar_index, vp_current.poc, color=color.new(color.orange, 30), width=3)
        label.new(bar_index, vp_current.poc, "POC", color=color.orange, style=label.style_label_left, size=size.small)
    if not na(vp_current.vah) and not na(vp_current.val)
        box.new(bar_index-50, vp_current.vah, bar_index, vp_current.val, bgcolor=color.new(color.blue, 90), border_width=1)

if show_entry_signals and entry_signal != "NONE" and barstate.isconfirmed
    color signal_color = entry_signal == "BUY" ? color.green : color.red
    string signal_text = entry_signal + " (Score: " + str.tostring(entry_score) + "/100)\n" + "Entry: " + str.tostring(entry_price, "#.####") + "\n" + "SL: " + str.tostring(stop_loss, "#.####") + "\n" + "TP: " + str.tostring(take_profit, "#.####")
    if not na(position_size)
        signal_text += "\nSize: " + str.tostring(position_size, "#.##") + " lots"
    label.new(bar_index, entry_signal == "BUY" ? low : high, signal_text, yloc = entry_signal == "BUY" ? yloc.belowbar : yloc.abovebar, style=label.style_label_center, size=size.normal, color=signal_color, textcolor=color.white)

if show_key_levels and is_order_block and barstate.isconfirmed
    color ob_color = ob_type == "BULLISH" ? color.green : color.red
    box.new(bar_index-1, high[1], bar_index+3, low[1], bgcolor=color.new(ob_color, 80), border_width=1)
    label.new(bar_index, (high[1]+low[1])/2, "OB", color=ob_color, textcolor=color.white, size=size.small)
if show_key_levels and is_fvg and barstate.isconfirmed
    color fvg_color = fvg_type == "BULLISH" ? color.green : color.red
    box.new(bar_index, fvg_top, bar_index+10, fvg_bottom, bgcolor=color.new(fvg_color, 90), border_width=1)

// =======================
// === TIMEZONE INFO DISPLAY ===
// =======================

if show_timezone_info and barstate.islast
    ny_hour = hour(time, "America/New_York")
    ny_minute = minute(time, "America/New_York")
    gmt_hour = hour(time, "GMT")
    gmt_minute = minute(time, "GMT")
    
    info_text = "🕐 TIME INFO\n"
    info_text += "━━━━━━━━━━━━━\n"
    info_text += "NY: " + str.format("{0,number,00}:{1,number,00}", ny_hour, ny_minute) + "\n"
    info_text += "GMT: " + str.format("{0,number,00}:{1,number,00}", gmt_hour, gmt_minute) + "\n"
    info_text += "TZ: " + timezone_mode
    
    label.new(bar_index + 5, high, info_text, 
              style=label.style_label_left, 
              color=color.new(color.blue, 0),
              textcolor=color.white,
              size=size.normal)

if enable_debug_mode and barstate.islast
    string debug_text = "=== CRT STATE ENGINE v7.5 ===\nTimeframe Valid: " + str.tostring(is_valid_timeframe()) + "\nDOL Bias: " + dol_bias + " → " + str.tostring(dol_target, "#.####") + "\nSession: " + session_state + " (" + session_behavior + ")\n1AM CRT: " + crt_1am_state + " [" + profile_1am + "]\n5AM CRT: " + crt_5am_state + " [" + profile_5am + "]\n9AM CRT: " + crt_9am_state + " [" + profile_9am + "]\nActive Profile: " + get_active_profile() + "\nEntry Signal: " + entry_signal + " (Score: " + str.tostring(entry_score) + ")\nMarket Structure: " + ms.trend + " (Strength: " + str.tostring(ms.strength) + "%)\nCurrent Time (" + timezone_mode + "): " + str.format("{0,time,HH:mm}", time, timezone_mode)
    label.new(bar_index, high + (high-low)*0.1, debug_text, style=label.style_label_down, size=size.large, color=color.yellow, textcolor=color.black)

// =======================
// === MODERN DASHBOARD ===
// =======================

if show_advanced_dashboard
    [header_bg, header_text, section_bg, section_text, label_bg, label_text, value_bg, value_text, success_bg, warning_bg, danger_bg, info_bg] = get_theme_colors()
    var table dashboard = table.new(position.top_right, 6, 20, border_width=0, frame_width=1, frame_color=color.new(color.white, 90))
    if barstate.islast
        // Get font sizes
        header_font_size = get_font_size(dashboard_header_size)
        label_font_size = get_font_size(dashboard_label_size)
        value_font_size = get_font_size(dashboard_value_size)
        
        // Modern Header with gradient effect - using merge_cells for proper centering
        table.cell(dashboard, 0, 0, "🚀 CRT ENGINE v7.5", bgcolor=header_bg, text_color=header_text, text_size=header_font_size)
        table.merge_cells(dashboard, 0, 0, 5, 0)  // Merge columns 0-5 in row 0
        table.cell(dashboard, 0, 1, "Professional Trading Dashboard", bgcolor=header_bg, text_color=header_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 1, 5, 1)  // Merge columns 0-5 in row 1
        
        // System Status Section - Modern Cards
        table.cell(dashboard, 0, 2, "⚙️ SYSTEM STATUS", bgcolor=section_bg, text_color=section_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 2, 5, 2)  // Merge columns 0-5 in row 2
        
        tf_status_color = is_valid_timeframe() ? success_bg : danger_bg
        table.cell(dashboard, 0, 3, "Timeframe", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 3, timeframe.period, bgcolor=tf_status_color, text_color=value_text, text_size=value_font_size)
        table.cell(dashboard, 2, 3, "Time", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 3, str.format("{0,time,HH:mm}", time, timezone_mode), bgcolor=value_bg, text_color=value_text, text_size=value_font_size)
        table.cell(dashboard, 4, 3, "Session", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        session_bg = session_state == "NY" ? success_bg : session_state == "LONDON" ? info_bg : section_bg
        table.cell(dashboard, 5, 3, session_state, bgcolor=session_bg, text_color=value_text, text_size=value_font_size)
        
        // Market Analysis Section - Enhanced Visual Design
        table.cell(dashboard, 0, 4, "📈 MARKET ANALYSIS", bgcolor=section_bg, text_color=section_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 4, 5, 4)  // Merge columns 0-5 in row 4
        
        // DOL Analysis with modern styling
        dol_bg = dol_bias == "BULLISH" ? success_bg : dol_bias == "BEARISH" ? danger_bg : section_bg
        table.cell(dashboard, 0, 5, "🎯 DOL Bias", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 5, dol_bias, bgcolor=dol_bg, text_color=value_text, text_size=value_font_size)
        table.cell(dashboard, 2, 5, "🎯 Target", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 5, str.tostring(dol_target, "#.####"), bgcolor=dol_bg, text_color=value_text, text_size=value_font_size)
        table.cell(dashboard, 4, 5, "📊 Structure", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        ms_bg = ms.trend == "BULLISH" ? success_bg : ms.trend == "BEARISH" ? danger_bg : section_bg
        table.cell(dashboard, 5, 5, ms.trend, bgcolor=ms_bg, text_color=value_text, text_size=value_font_size)
        
        // Market Structure Strength with progress bar effect
        strength_bg = ms.strength >= 70 ? success_bg : ms.strength >= 40 ? warning_bg : danger_bg
        table.cell(dashboard, 0, 6, "💪 Strength", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 6, str.tostring(ms.strength) + "%", bgcolor=strength_bg, text_color=value_text, text_size=value_font_size)
        
        // Volume Profile with modern indicators
        vp_status = vp_current.bullishImbalance ? "🐂 Bull Imbal" : vp_current.bearishImbalance ? "🐻 Bear Imbal" : "⚖️ Balanced"
        vp_bg = vp_current.bullishImbalance ? success_bg : vp_current.bearishImbalance ? danger_bg : section_bg
        table.cell(dashboard, 2, 6, "📊 Volume", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 6, vp_status, bgcolor=vp_bg, text_color=value_text, text_size=label_font_size)
        table.cell(dashboard, 4, 6, "🎯 POC", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 5, 6, str.tostring(vp_current.poc, "#.####"), bgcolor=warning_bg, text_color=value_text, text_size=value_font_size)
        
        // Session Behavior with enhanced styling
        behavior_icon = session_behavior == "CONSOLIDATION" ? "📊" : session_behavior == "MANIPULATION" ? "🎭" : "📈"
        behavior_bg = session_behavior == "CONSOLIDATION" ? section_bg : session_behavior == "MANIPULATION" ? warning_bg : info_bg
        table.cell(dashboard, 0, 7, "🔄 Behavior", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 7, behavior_icon + " " + session_behavior, bgcolor=behavior_bg, text_color=value_text, text_size=label_font_size)
        
        // CRT Models Section - Professional Cards
        table.cell(dashboard, 0, 8, "🎯 CRT MODELS", bgcolor=section_bg, text_color=section_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 8, 5, 8)  // Merge columns 0-5 in row 8
        
        // CRT Model Status with modern indicators
        crt_1am_icon = crt_1am_state == "D_READY" ? "✅" : crt_1am_state == "M_LIVE" ? "🔄" : "⏸️"
        crt_1am_bg = crt_1am_state == "D_READY" ? success_bg : crt_1am_state == "M_LIVE" ? warning_bg : section_bg
        table.cell(dashboard, 0, 9, "🌅 1AM CRT", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 9, crt_1am_icon + " " + crt_1am_state, bgcolor=crt_1am_bg, text_color=value_text, text_size=label_font_size)
        
        crt_5am_icon = crt_5am_state == "D_READY" ? "✅" : crt_5am_state == "M_LIVE" ? "🔄" : "⏸️"
        crt_5am_bg = crt_5am_state == "D_READY" ? success_bg : crt_5am_state == "M_LIVE" ? warning_bg : section_bg
        table.cell(dashboard, 2, 9, "🌄 5AM CRT", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 9, crt_5am_icon + " " + crt_5am_state, bgcolor=crt_5am_bg, text_color=value_text, text_size=label_font_size)
        
        crt_9am_icon = crt_9am_state == "D_READY" ? "✅" : crt_9am_state == "M_LIVE" ? "🔄" : "⏸️"
        crt_9am_bg = crt_9am_state == "D_READY" ? success_bg : crt_9am_state == "M_LIVE" ? warning_bg : section_bg
        table.cell(dashboard, 4, 9, "☀️ 9AM CRT", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 5, 9, crt_9am_icon + " " + crt_9am_state, bgcolor=crt_9am_bg, text_color=value_text, text_size=label_font_size)
        
        // Active Profile with enhanced styling
        active_profile = get_active_profile()
        profile_icon = active_profile == "NONE" ? "⏸️" : "🎯"
        profile_bg = active_profile == "NONE" ? section_bg : info_bg
        table.cell(dashboard, 0, 10, "🎯 Active Profile", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 10, profile_icon + " " + active_profile, bgcolor=profile_bg, text_color=value_text, text_size=label_font_size, width=5)
        
        // Entry & Risk Section - Modern Trading Interface
        table.cell(dashboard, 0, 11, "💰 ENTRY & RISK", bgcolor=section_bg, text_color=section_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 11, 5, 11)  // Merge columns 0-5 in row 11
        
        // Entry Signal with enhanced visual feedback
        signal_icon = entry_signal == "BUY" ? "🟢" : entry_signal == "SELL" ? "🔴" : "⚪"
        signal_bg = entry_signal == "BUY" ? success_bg : entry_signal == "SELL" ? danger_bg : section_bg
        table.cell(dashboard, 0, 12, "📊 Signal", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 12, signal_icon + " " + entry_signal, bgcolor=signal_bg, text_color=value_text, text_size=value_font_size)
        
        // Entry Score with progress indicator
        score_icon = entry_score >= 80 ? "🟢" : entry_score >= 60 ? "🟡" : "🔴"
        score_bg = entry_score >= 80 ? success_bg : entry_score >= 60 ? warning_bg : danger_bg
        table.cell(dashboard, 2, 12, "📈 Score", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 12, score_icon + " " + str.tostring(entry_score) + "/100", bgcolor=score_bg, text_color=value_text, text_size=value_font_size)
        
        // Risk Status with modern indicators
        risk_icon = rm.tradingAllowed ? "✅" : "⛔"
        risk_bg = rm.tradingAllowed ? success_bg : danger_bg
        table.cell(dashboard, 4, 12, "🛡️ Risk Status", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 5, 12, risk_icon + " " + (rm.tradingAllowed ? "ACTIVE" : "HALTED"), bgcolor=risk_bg, text_color=value_text, text_size=label_font_size)
        
        // Daily P&L with enhanced styling
        pnl_icon = rm.currentDailyPnL >= 0 ? "📈" : "📉"
        pnl_bg = rm.currentDailyPnL >= 0 ? success_bg : danger_bg
        table.cell(dashboard, 0, 13, "💰 Daily P&L", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 13, pnl_icon + " " + str.tostring(rm.currentDailyPnL, "#.##"), bgcolor=pnl_bg, text_color=value_text, text_size=value_font_size)
        
        // Key Levels with modern indicators
        key_levels_text = is_order_block ? "📦 OB " + ob_type : is_fvg ? "🕳️ FVG " + fvg_type : "⏸️ None"
        key_levels_bg = is_order_block ? warning_bg : is_fvg ? info_bg : section_bg
        table.cell(dashboard, 2, 13, "🎯 Key Levels", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 13, key_levels_text, bgcolor=key_levels_bg, text_color=value_text, text_size=label_font_size, width=3)
        
        // Performance Section - Professional Metrics
        table.cell(dashboard, 0, 14, "📊 PERFORMANCE", bgcolor=section_bg, text_color=section_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 14, 5, 14)  // Merge columns 0-5 in row 14
        
        // Win Rate with enhanced visual feedback
        wr_icon = pt.winRate >= 60 ? "🏆" : pt.winRate >= 40 ? "🥈" : "🥉"
        wr_bg = pt.winRate >= 60 ? success_bg : pt.winRate >= 40 ? warning_bg : danger_bg
        table.cell(dashboard, 0, 15, "🏆 Win Rate", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 1, 15, wr_icon + " " + str.tostring(pt.winRate, "#.#") + "%", bgcolor=wr_bg, text_color=value_text, text_size=value_font_size)
        
        // Sharpe Ratio with professional styling
        sharpe_icon = pt.sharpeRatio >= 1.5 ? "⭐" : pt.sharpeRatio >= 0.5 ? "✨" : "💫"
        sharpe_bg = pt.sharpeRatio >= 1.5 ? success_bg : pt.sharpeRatio >= 0.5 ? warning_bg : danger_bg
        table.cell(dashboard, 2, 15, "⭐ Sharpe", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 3, 15, sharpe_icon + " " + str.tostring(pt.sharpeRatio, "#.##"), bgcolor=sharpe_bg, text_color=value_text, text_size=value_font_size)
        
        // Additional Performance Metrics
        table.cell(dashboard, 4, 15, "📈 Avg Win", bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.cell(dashboard, 5, 15, str.tostring(pt.avgWin, "#.##"), bgcolor=success_bg, text_color=value_text, text_size=value_font_size)
        
        // Footer with summary
        table.cell(dashboard, 0, 16, "📋 SUMMARY", bgcolor=section_bg, text_color=section_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 16, 5, 16)  // Merge columns 0-5 in row 16
        
        // Quick Status Summary
        summary_text = "🎯 " + (entry_signal != "NONE" ? "Signal Active" : "No Signal") + " | 📊 " + (crt_1am_state == "D_READY" or crt_5am_state == "D_READY" or crt_9am_state == "D_READY" ? "CRT Ready" : "CRT Inactive") + " | 🛡️ " + (rm.tradingAllowed ? "Risk Active" : "Risk Halted")
        table.cell(dashboard, 0, 17, summary_text, bgcolor=label_bg, text_color=label_text, text_size=label_font_size)
        table.merge_cells(dashboard, 0, 17, 5, 17)  // Merge columns 0-5 in row 17
        
        // Version and timestamp
        table.cell(dashboard, 0, 18, "v7.5 COMPLETE | " + str.format("{0,date,yyyy-MM-dd HH:mm}", time, timezone_mode) + " " + timezone_mode, bgcolor=header_bg, text_color=header_text, text_size=size.tiny)
        table.merge_cells(dashboard, 0, 18, 5, 18)  // Merge columns 0-5 in row 18

// =======================
// === COMPREHENSIVE ALERTS ===
// =======================

alertcondition(crt_1am_state == "D_READY" and crt_1am_state[1] != "D_READY", title="1AM CRT Ready", message="1AM CRT Distribution Ready - Check Entry Window 02:00-03:00 NY Time")
alertcondition(crt_5am_state == "D_READY" and crt_5am_state[1] != "D_READY", title="5AM CRT Ready", message="5AM CRT Distribution Ready - Check Entry Window 06:00-08:30 NY Time")
alertcondition(crt_9am_state == "D_READY" and crt_9am_state[1] != "D_READY", title="9AM CRT Ready", message="9AM CRT Distribution Ready - Check Entry Window 09:30-11:00 NY Time")

alertcondition(entry_signal == "BUY" and entry_signal[1] != "BUY", title="BUY Signal", message="BUY Signal Generated - Check Dashboard for Details")
alertcondition(entry_signal == "SELL" and entry_signal[1] != "SELL", title="SELL Signal", message="SELL Signal Generated - Check Dashboard for Details")

alertcondition(entry_signal == "BUY" and entry_score >= 80, title="HIGH CONFIDENCE BUY", message="Strong BUY Signal - High Confidence Entry")
alertcondition(entry_signal == "SELL" and entry_score >= 80, title="HIGH CONFIDENCE SELL", message="Strong SELL Signal - High Confidence Entry")

alertcondition(ms.brokenStructure and not ms.brokenStructure[1], title="Market Structure Break", message="Market Structure Break Detected - Check Dashboard for Details")
alertcondition(check_liquidity_sweep("BUY"), title="Bullish Liquidity Sweep", message="Sell-side liquidity swept - Potential reversal up")
alertcondition(check_liquidity_sweep("SELL"), title="Bearish Liquidity Sweep", message="Buy-side liquidity swept - Potential reversal down")

alertcondition(session_state != session_state[1], title="Session Change", message="New Session Started")
alertcondition(dol_bias != dol_bias[1] and dol_bias != "NEUTRAL", title="DOL Bias Change", message="DOL Bias Changed - Review Trading Plan")

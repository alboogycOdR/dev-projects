get_font_size(string size_option) =>
    result = size.tiny
    if size_option == "Small"
        result := size.small
    else if size_option == "Normal"
        result := size.normal
    else if size_option == "Large"
        result := size.large
    else if size_option == "Huge"
        result := size.huge
    result


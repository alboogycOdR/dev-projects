        array.push(pattern_results, PatternRow.new(sym5,  l5, c5))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym6)  > 0
        [l6, c6]  = get_pattern_for_symbol(sym6)
        array.push(pattern_results, PatternRow.new(sym6,  l6, c6))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym7)  > 0
        [l7, c7]  = get_pattern_for_symbol(sym7)
        array.push(pattern_results, PatternRow.new(sym7,  l7, c7))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym8)  > 0
        [l8, c8]  = get_pattern_for_symbol(sym8)
        array.push(pattern_results, PatternRow.new(sym8,  l8, c8))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym9)  > 0
        [l9, c9]  = get_pattern_for_symbol(sym9)
        array.push(pattern_results, PatternRow.new(sym9,  l9, c9))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym10) > 0
        [l10, c10]  = get_pattern_for_symbol(sym10)
        array.push(pattern_results, PatternRow.new(sym10,  l10, c10))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym11) > 0
        [l11, c11]  = get_pattern_for_symbol(sym11)
        array.push(pattern_results, PatternRow.new(sym11,  l11, c11))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym12) > 0
        [l12, c12]  = get_pattern_for_symbol(sym12)
        array.push(pattern_results, PatternRow.new(sym12,  l12, c12))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym13) > 0
        [l13, c13]  = get_pattern_for_symbol(sym13)
        array.push(pattern_results, PatternRow.new(sym13,  l13, c13))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym14) > 0
        [l14, c14]  = get_pattern_for_symbol(sym14)
        array.push(pattern_results, PatternRow.new(sym14,  l14, c14))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))
    if str.length(sym15) > 0
        [l15, c15]  = get_pattern_for_symbol(sym15)
        array.push(pattern_results, PatternRow.new(sym15,  l15, c15))
    else

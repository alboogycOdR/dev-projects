    if str.length(sym16) > 0
        [l16, c16]  = get_pattern_for_symbol(sym16)
        array.push(pattern_results, PatternRow.new(sym16,  l16, c16))
    else
        array.push(pattern_results, PatternRow.new("-",  "-", color.gray))

// Populate table
if barstate.islast
    for i = 0 to 15
        row = i + 1
        if i < array.size(pattern_results)
            r = array.get(pattern_results, i)
            table.cell(tbl, 0, row, r.symbol, text_halign=text.align_left)
            table.cell(tbl, 1, row, r.label, bgcolor=r.bg, text_color=color.white, text_halign=text.align_center)

// Debug plots
plotchar(valid_2c_bull ? 1 : na, title="2C Bull Flag", char='▲', location=location.top, size=size.tiny, color=color.green)
plotchar(valid_2c_bear ? -1 : na, title="2C Bear Flag", char='▼', location=location.bottom, size=size.tiny, color=color.red)

// Time-anchored status display
var label debug_label = na
if use_time_anchored_4h and timeframe.period == "240" and barstate.islast
    if not na(debug_label)
        label.delete(debug_label)
    
    // Show when D candles are expected based on anchors + 8 hours
    anchor_01_hour = broker_4h_schedule == "Standard" ? 1 : 2
    anchor_05_hour = broker_4h_schedule == "Standard" ? 5 : 6
    d_01 = str.tostring((anchor_01_hour + 8) % 24)
    d_05 = str.tostring((anchor_05_hour + 8) % 24) 
    d_09 = str.tostring((9 + 8) % 24)
    
    status_text = "Time-Anchored 4H Active\nBroker: " + broker_4h_schedule + "\nD candles @ " + d_01 + "," + d_05 + "," + d_09 + "\nAnchors: " + 
                  (anchor_01_enabled ? "01✓ " : "01✗ ") + 
                  (anchor_05_enabled ? "05✓ " : "05✗ ") + 
                  (anchor_09_enabled ? "09✓" : "09✗")
    debug_label := label.new(bar_index, low - (high - low) * 0.1, status_text, 
                           xloc=xloc.bar_index, yloc=yloc.price, 
                           style=label.style_label_up, size=size.small, 
                           color=color.new(color.blue, 80), textcolor=color.white)
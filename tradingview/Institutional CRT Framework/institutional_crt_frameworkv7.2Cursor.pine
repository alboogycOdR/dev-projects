//@version=5
indicator("CRT State Engine v7.2 CURSOR", "CRT-v7.2crsr", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500, dynamic_requests=true)

// ═══════════════════════════════════════════════════════════════════════════════
//                     CRT STATE ENGINE V7.2 - CURSOR COMPLETE EDITION
//                          ALL CORE FUNCTIONALITIES RESTORED
// 
//  COMPLETE FEATURES IN V7.2:
//  ✓ All V6 core CRT state logic
//  ✓ All V6 visualization features (DOL lines, session boxes, key levels)
//  ✓ All V6 input parameters and color configurations
//  ✓ All V6 order block and FVG detection
//  ✓ All V6 debug mode functionality
//  ✓ All V7 advanced features (market structure, liquidity pools, volume profile)
//  ✓ All V7 correlation and risk management
//  ✓ Complete alert system from both versions
//  ✓ Performance optimizations for execution speed
//
// ═══════════════════════════════════════════════════════════════════════════════

// =======================
// === TYPE DEFINITIONS ===
// =======================

type MarketStructure
    float lastHH = na
    float lastHL = na
    float lastLH = na
    float lastLL = na
    string trend = "NEUTRAL"
    int strength = 0
    bool brokenStructure = false
    int trendBars = 0

type LiquidityPool
    float price
    string poolType
    int touches
    float volume
    bool swept
    int barIndex

type VolumeProfile
    float poc = 0.0
    float vah = 0.0
    float val = 0.0
    float totalVolume = 0.0
    bool bullishImbalance = false
    bool bearishImbalance = false

type CorrelationData
    string symbol
    float correlation
    bool divergence
    string divergenceType
    float strength

type EntryFilter
    bool marketStructureAligned
    bool liquiditySwept
    bool volumeConfirmation
    bool correlationConfirmation
    bool timeOfDayOptimal
    int score

type RiskManager
    float accountBalance = 10000
    float riskPerTrade = 100
    float maxDailyLoss = 300
    float currentDailyPnL = 0
    int maxConcurrentTrades = 3
    int currentOpenTrades = 0
    float positionSize = 0
    bool tradingAllowed = true

type PerformanceTracker
    int totalSignals = 0
    int winningSignals = 0
    int losingSignals = 0
    float winRate = 0
    float avgWin = 0
    float avgLoss = 0
    float profitFactor = 0
    float sharpeRatio = 0
    array<float> returns

// =======================
// === INPUT PARAMETERS ==
// =======================

// ═══════════════════════════════════════════════════════════════════════════════
// 1. CRT MODELS
// ═══════════════════════════════════════════════════════════════════════════════
enable_1am_crt = input.bool(true, "1AM CRT Model", group="1. CRT Models")
enable_5am_crt = input.bool(true, "5AM CRT Model", group="1. CRT Models")
enable_9am_crt = input.bool(true, "9AM CRT Model", group="1. CRT Models")

// ═══════════════════════════════════════════════════════════════════════════════
// 2. CORE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════
enable_dol_engine = input.bool(true, "Enable DOL Analysis Engine", group="2. Core System")
pivot_strength = input.int(10, "DOL Pivot Strength", minval=5, maxval=50, group="2. Core System", tooltip="Higher values = more significant swing points for institutional analysis")
enable_session_engine = input.bool(true, "Enable Session State Machine", group="2. Core System")
enable_entry_engine = input.bool(true, "Enable Live Entry Signals", group="2. Core System")
enable_debug_mode = input.bool(false, "Debug Mode (Show All States)", group="2. Core System")

// ═══════════════════════════════════════════════════════════════════════════════
// 3. ADVANCED MODULES
// ═══════════════════════════════════════════════════════════════════════════════
enable_market_structure = input.bool(true, "Enable Market Structure Analysis", group="3. Advanced Modules")
enable_liquidity_pools = input.bool(true, "Enable Liquidity Pool Detection", group="3. Advanced Modules")
enable_volume_profile = input.bool(true, "Enable Volume Profile Analysis", group="3. Advanced Modules")
enable_correlation = input.bool(true, "Enable Multi-Pair Correlation", group="3. Advanced Modules")
enable_risk_management = input.bool(true, "Enable Risk Management", group="3. Advanced Modules")
enable_performance_tracking = input.bool(true, "Enable Performance Tracking", group="3. Advanced Modules")

// ═══════════════════════════════════════════════════════════════════════════════
// 4. SESSION STATES
// ═══════════════════════════════════════════════════════════════════════════════
monitor_cbdr = input.bool(true, "Monitor CBDR (17:00)", group="4. Session States")
monitor_asia = input.bool(true, "Monitor Asia (21:00)", group="4. Session States")
monitor_london = input.bool(true, "Monitor London (01:00)", group="4. Session States")
monitor_lunch = input.bool(true, "Monitor London Lunch (05:00)", group="4. Session States")
monitor_ny = input.bool(true, "Monitor NY Open (09:00)", group="4. Session States")

// ═══════════════════════════════════════════════════════════════════════════════
// 5. ENTRY ENGINE
// ═══════════════════════════════════════════════════════════════════════════════
entry_timeframe = input.string("15", "Entry Timeframe", options=["5", "15", "30"], group="5. Entry Engine")
require_smt_confluence = input.bool(true, "Require SMT Confluence", group="5. Entry Engine")
auto_risk_management = input.bool(true, "Auto Risk Management", group="5. Entry Engine")
risk_reward_ratio = input.float(2.0, "Risk:Reward Ratio", minval=1.0, maxval=5.0, step=0.5, group="5. Entry Engine")

// ═══════════════════════════════════════════════════════════════════════════════
// 6. ENTRY FILTERS
// ═══════════════════════════════════════════════════════════════════════════════
min_entry_score = input.int(60, "Minimum Entry Score (0-100)", minval=0, maxval=100, step=5, group="6. Entry Filters")
require_structure_alignment = input.bool(true, "Require Market Structure Alignment", group="6. Entry Filters")
require_liquidity_sweep = input.bool(false, "Require Liquidity Sweep", group="6. Entry Filters")
require_volume_confluence = input.bool(true, "Require Volume Confluence", group="6. Entry Filters")

// ═══════════════════════════════════════════════════════════════════════════════
// 7. VISUAL
// ═══════════════════════════════════════════════════════════════════════════════
show_dol_lines = input.bool(true, "Show DOL Lines", group="7. Visual")
show_session_boxes = input.bool(true, "Show Session Boxes", group="7. Visual")
show_key_levels = input.bool(true, "Show Key Levels", group="7. Visual")
show_entry_signals = input.bool(true, "Show Entry Signals", group="7. Visual")
show_market_structure = input.bool(true, "Show Market Structure", group="7. Visual")
show_liquidity_pools = input.bool(true, "Show Liquidity Pools", group="7. Visual")
show_volume_profile = input.bool(true, "Show Volume Profile", group="7. Visual")
show_advanced_dashboard = input.bool(true, "Show Advanced Dashboard", group="7. Visual")

// ═══════════════════════════════════════════════════════════════════════════════
// 8. COLORS
// ═══════════════════════════════════════════════════════════════════════════════
col_bullish_dol = input.color(color.new(color.green, 20), "Bullish DOL", group="8. Colors")
col_bearish_dol = input.color(color.new(color.red, 20), "Bearish DOL", group="8. Colors")
col_consolidation = input.color(color.new(color.gray, 80), "Consolidation", group="8. Colors")
col_manipulation = input.color(color.new(color.orange, 80), "Manipulation", group="8. Colors")
col_expansion = input.color(color.new(color.blue, 80), "Expansion", group="8. Colors")

// ═══════════════════════════════════════════════════════════════════════════════
// 9. RISK MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════
account_balance = input.float(10000, "Account Balance", minval=100, group="9. Risk Management")
risk_per_trade_pct = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, group="9. Risk Management")
max_daily_loss_pct = input.float(3.0, "Max Daily Loss (%)", minval=1.0, maxval=10.0, step=0.5, group="9. Risk Management")
max_concurrent_trades = input.int(3, "Max Concurrent Trades", minval=1, maxval=10, group="9. Risk Management")

// =======================
// === INITIALIZE OBJECTS ===
// =======================

var MarketStructure ms = MarketStructure.new()
var array<LiquidityPool> liquidityPools = array.new<LiquidityPool>()
var RiskManager rm = RiskManager.new()
var PerformanceTracker pt = PerformanceTracker.new(0, 0, 0, 0, 0, 0, 0, 0, array.new<float>())

// Initialize Risk Manager
if barstate.isfirst
    rm.accountBalance := account_balance
    rm.riskPerTrade := account_balance * (risk_per_trade_pct / 100)
    rm.maxDailyLoss := account_balance * (max_daily_loss_pct / 100)
    rm.maxConcurrentTrades := max_concurrent_trades
    rm.currentOpenTrades := 0
    rm.currentDailyPnL := 0
    rm.tradingAllowed := true

// =======================
// === V6 CORE SYSTEM (FULLY RESTORED) ===
// =======================

// Session History Arrays
var array<string> session_name_history = array.new<string>(100)
var array<string> session_behavior_history = array.new<string>(100)
var array<float> session_high_history = array.new<float>(100)
var array<float> session_low_history = array.new<float>(100)
var array<int> session_start_bars = array.new<int>(100)

// Track session transitions
track_session_history(string current_session, string current_behavior, float current_high, float current_low) =>
    if array.size(session_name_history) >= 100
        array.shift(session_name_history)
        array.shift(session_behavior_history)
        array.shift(session_high_history)
        array.shift(session_low_history)
        array.shift(session_start_bars)
    
    array.push(session_name_history, current_session)
    array.push(session_behavior_history, current_behavior)
    array.push(session_high_history, current_high)
    array.push(session_low_history, current_low)
    array.push(session_start_bars, bar_index)

// Get historical session behavior
get_session_behavior_lookback(int sessions_back) =>
    idx = array.size(session_behavior_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_behavior_history) ? array.get(session_behavior_history, idx) : "UNKNOWN"
    result

get_session_high_lookback(int sessions_back) =>
    idx = array.size(session_high_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_high_history) ? array.get(session_high_history, idx) : high
    result

get_session_low_lookback(int sessions_back) =>
    idx = array.size(session_low_history) - 1 - sessions_back
    result = idx >= 0 and idx < array.size(session_low_history) ? array.get(session_low_history, idx) : low
    result

// Timeframe Support Functions
get_timeframe_multiplier() =>
    tf = timeframe.period
    multiplier = 1.0
    
    if timeframe.isminutes
        minutes = timeframe.multiplier
        multiplier := 240.0 / minutes
    else if timeframe.isdaily
        multiplier := 0.1667
    else if timeframe.isweekly
        multiplier := 0.0357
    else
        multiplier := 1.0
    
    multiplier

is_valid_timeframe() =>
    tf = timeframe.period
    valid = (timeframe.isminutes and (timeframe.multiplier == 15 or timeframe.multiplier == 30 or timeframe.multiplier == 60 or timeframe.multiplier == 240)) or timeframe.isdaily or timeframe.isweekly
    valid

adjust_lookback_for_timeframe(int base_lookback) =>
    multiplier = get_timeframe_multiplier()
    adjusted = math.round(base_lookback * multiplier)
    math.max(1, adjusted)

// Time Window Functions
get_current_minutes() =>
    h = hour(time, "GMT")
    m = minute(time, "GMT")
    h * 60 + m

is_in_time_window(int start_minutes, int end_minutes) =>
    current = get_current_minutes()
    start_minutes <= end_minutes ? (current >= start_minutes and current <= end_minutes) : (current >= start_minutes or current <= end_minutes)

// =======================
// === RESTORED DOL ANALYSIS ===
// =======================

adjusted_pivot_strength = math.round(pivot_strength * get_timeframe_multiplier())
adjusted_pivot_strength := math.max(2, math.min(50, adjusted_pivot_strength))

float pivot_high_price = ta.pivothigh(high, adjusted_pivot_strength, adjusted_pivot_strength)
float pivot_low_price = ta.pivotlow(low, adjusted_pivot_strength, adjusted_pivot_strength)

var float last_swing_high = na
var float last_swing_low = na
var float dol_target = na
var string dol_bias = "NEUTRAL"  // RESTORED MISSING VARIABLE

if not na(pivot_high_price)
    last_swing_high := pivot_high_price

if not na(pivot_low_price)
    last_swing_low := pivot_low_price

// RESTORED DOL CALCULATION
if not na(last_swing_high) and not na(last_swing_low)
    float dist_to_high = math.abs(close - last_swing_high)
    float dist_to_low = math.abs(close - last_swing_low)
    dol_bias := dist_to_high < dist_to_low ? "BULLISH" : "BEARISH"
    dol_target := dist_to_high < dist_to_low ? last_swing_high : last_swing_low

// =======================
// === SESSION STATES ====
// =======================

get_session_state() =>
    string state = "UNKNOWN"
    int h = hour(time, "GMT")
    
    if h >= 17 and h < 21
        state := "CBDR"
    else if h >= 21 or h < 1
        state := "ASIA"
    else if h >= 1 and h < 5
        state := "LONDON"
    else if h >= 5 and h < 9
        state := "LUNCH"
    else if h >= 9 and h < 13
        state := "NY"
    else
        state := "POST_NY"
    
    state

string session_state = get_session_state()
var string session_behavior = "CONSOLIDATION"
var float session_high = na
var float session_low = na
var string prev_session = ""
var float prev_session_high = na
var float prev_session_low = na

// Track session ranges and behavior
if session_state != prev_session
    if prev_session != ""
        track_session_history(prev_session, session_behavior, session_high, session_low)
    
    prev_session_high := session_high
    prev_session_low := session_low
    prev_session := session_state
    
    session_high := high
    session_low := low
    session_behavior := "CONSOLIDATION"
else
    session_high := math.max(nz(session_high, high), high)
    session_low := math.min(nz(session_low, low), low)
    
    float prev_session_range = nz(prev_session_high - prev_session_low, 0)
    float current_range = high - low
    if prev_session_range > 0
        session_behavior := current_range > prev_session_range * 1.5 ? "EXPANSION" : (high > nz(prev_session_high, high) or low < nz(prev_session_low, low) ? "MANIPULATION" : session_behavior)

// =======================
// === CRT STATES (COMPLETE V6 LOGIC) ===
// =======================

var string crt_1am_state = "INACTIVE"
var string crt_5am_state = "INACTIVE"
var string crt_9am_state = "INACTIVE"
var string profile_1am = "NONE"
var string profile_5am = "NONE"
var string profile_9am = "NONE"

// RESTORED london_made_hod_lod function
london_made_hod_lod() =>
    london_sessions_back = session_state == "NY" ? 1 : session_state == "LUNCH" ? 0 : 2
    
    london_high = get_session_high_lookback(london_sessions_back)
    london_low = get_session_low_lookback(london_sessions_back)
    
    daily_high = ta.highest(high, adjust_lookback_for_timeframe(24))
    daily_low = ta.lowest(low, adjust_lookback_for_timeframe(24))
    
    london_range = london_high - london_low
    daily_range = daily_high - daily_low
    
    made_extreme = (london_range > (daily_range * 0.6)) or (london_high >= daily_high * 0.999) or (london_low <= daily_low * 1.001)
    made_extreme

// Function to get the most relevant active profile
get_active_profile() =>
    result = "NONE"
    if profile_9am != "NONE" and crt_9am_state != "INACTIVE"
        result := profile_9am
    else if profile_5am != "NONE" and crt_5am_state != "INACTIVE"
        result := profile_5am
    else if profile_1am != "NONE" and crt_1am_state != "INACTIVE"
        result := profile_1am
    result

// 1AM CRT State Logic
update_1am_crt_state() =>
    string state = crt_1am_state
    string profile = profile_1am
    
    if enable_1am_crt and is_valid_timeframe()
        current_minutes = get_current_minutes()
        
        if is_in_time_window(60, 90)
            if crt_1am_state == "INACTIVE"
                cbdr_behavior = get_session_behavior_lookback(2)
                asia_behavior = get_session_behavior_lookback(1)
                
                if cbdr_behavior == "CONSOLIDATION" and asia_behavior == "CONSOLIDATION"
                    profile := "NORMAL_PROTRACTION"
                else if cbdr_behavior == "CONSOLIDATION" and asia_behavior == "MANIPULATION"
                    profile := "DELAYED_PROTRACTION"
                else
                    profile := "STANDARD"
                
                state := "A_FORMING"
        
        else if is_in_time_window(300, 330) and crt_1am_state == "A_FORMING"
            state := "M_LIVE"
        
        else if is_in_time_window(540, 570) and crt_1am_state == "M_LIVE"
            state := "D_READY"
        
        else if current_minutes > 780 or current_minutes < 60
            if crt_1am_state == "D_READY"
                state := "INACTIVE"
                profile := "NONE"
    
    [state, profile]

[new_1am_state, new_1am_profile] = update_1am_crt_state()
crt_1am_state := new_1am_state
profile_1am := new_1am_profile

// 5AM CRT State Logic
update_5am_crt_state() =>
    string state = crt_5am_state
    string profile = profile_5am
    
    if enable_5am_crt and is_valid_timeframe()
        current_minutes = get_current_minutes()
        
        if is_in_time_window(300, 330)
            if crt_5am_state == "INACTIVE"
                london_behavior = get_session_behavior_lookback(0)
                london_extreme = london_made_hod_lod()
                
                if dol_bias == "BEARISH" and not london_extreme
                    profile := "LONDON_LUNCH_LOW"
                else if dol_bias == "BULLISH" and london_extreme
                    profile := "NY_CONTINUATION"
                else if dol_bias == "BEARISH" and london_extreme
                    profile := "NY_REVERSAL"
                else
                    profile := "STANDARD"
                
                state := "A_FORMING"
        
        else if is_in_time_window(540, 570) and crt_5am_state == "A_FORMING"
            state := "M_LIVE"
        
        else if is_in_time_window(780, 810) and crt_5am_state == "M_LIVE"
            state := "D_READY"
        
        else if (current_minutes > 960 or current_minutes < 300) and crt_5am_state == "D_READY"
            state := "INACTIVE"
            profile := "NONE"
    
    [state, profile]

[new_5am_state, new_5am_profile] = update_5am_crt_state()
crt_5am_state := new_5am_state
profile_5am := new_5am_profile

// 9AM CRT State Logic
update_9am_crt_state() =>
    string state = crt_9am_state
    string profile = profile_9am
    
    if enable_9am_crt and is_valid_timeframe()
        current_minutes = get_current_minutes()
        
        if is_in_time_window(540, 570)
            if crt_9am_state == "INACTIVE"
                dol_reached = math.abs(close - dol_target) < (dol_target * 0.002)
                
                asia_behavior = get_session_behavior_lookback(3)
                london_behavior = get_session_behavior_lookback(1)
                
                asia_protected = asia_behavior != "EXPANSION"
                london_protected = london_behavior != "EXPANSION"
                
                if not dol_reached and london_made_hod_lod()
                    profile := "NY_CONTINUATION"
                else if dol_reached and asia_protected and london_protected
                    profile := "NY_REVERSAL"
                else
                    profile := "STANDARD"
                
                state := "A_FORMING"
        
        else if is_in_time_window(780, 810) and crt_9am_state == "A_FORMING"
            state := "M_LIVE"
        
        else if is_in_time_window(1020, 1050) and crt_9am_state == "M_LIVE"
            state := "D_READY"
        
        else if (current_minutes > 1200 or current_minutes < 540) and crt_9am_state == "D_READY"
            state := "INACTIVE"
            profile := "NONE"
    
    [state, profile]

[new_9am_state, new_9am_profile] = update_9am_crt_state()
crt_9am_state := new_9am_state
profile_9am := new_9am_profile

// =======================
// === RESTORED KEY LEVEL DETECTION ===
// =======================

// Order Block Detection
detect_order_block() =>
    bool is_ob = false
    string ob_type = "NONE"
    
    if bar_index >= 3
        bool bullish_imbalance = low[1] < low[2] and low[1] < low[3] and close > high[1]
        bool bullish_structure = close > open and close[1] < open[1]
        
        if bullish_imbalance and bullish_structure
            is_ob := true
            ob_type := "BULLISH"
        
        bool bearish_imbalance = high[1] > high[2] and high[1] > high[3] and close < low[1]
        bool bearish_structure = close < open and close[1] > open[1]
        
        if bearish_imbalance and bearish_structure
            is_ob := true
            ob_type := "BEARISH"
    
    [is_ob, ob_type]

[is_order_block, ob_type] = detect_order_block()

// FVG Detection (Fair Value Gap)
detect_fvg() =>
    bool is_fvg = false
    string fvg_type = "NONE"
    float fvg_top = 0.0
    float fvg_bottom = 0.0
    
    if bar_index >= 2
        if low > high[2]
            is_fvg := true
            fvg_type := "BULLISH"
            fvg_top := low
            fvg_bottom := high[2]
        
        if high < low[2]
            is_fvg := true
            fvg_type := "BEARISH"
            fvg_top := low[2]
            fvg_bottom := high
    
    [is_fvg, fvg_type, fvg_top, fvg_bottom]

[is_fvg, fvg_type, fvg_top, fvg_bottom] = detect_fvg()

// =======================
// === V7 MARKET STRUCTURE MODULE ===
// =======================

update_market_structure() =>
    if enable_market_structure
        pivotHigh = ta.pivothigh(high, 5, 5)
        pivotLow = ta.pivotlow(low, 5, 5)
        
        if not na(pivotHigh)
            if na(ms.lastHH) or pivotHigh > ms.lastHH
                ms.lastLH := ms.lastHH
                ms.lastHH := pivotHigh
                if ms.trend == "BEARISH" and not na(ms.lastLH) and pivotHigh > ms.lastLH
                    ms.trend := "BULLISH"
                    ms.brokenStructure := true
                    ms.trendBars := 0
            else
                ms.lastLH := pivotHigh
        
        if not na(pivotLow)
            if na(ms.lastLL) or pivotLow < ms.lastLL
                ms.lastHL := ms.lastLL
                ms.lastLL := pivotLow
                if ms.trend == "BULLISH" and not na(ms.lastHL) and pivotLow < ms.lastHL
                    ms.trend := "BEARISH"
                    ms.brokenStructure := true
                    ms.trendBars := 0
            else
                ms.lastHL := pivotLow
        
        ms.trendBars += 1
        if not na(ms.lastHH) and not na(ms.lastLL)
            range_hl = ms.lastHH - ms.lastLL
            if ms.trend == "BULLISH" and range_hl > 0
                ms.strength := math.round(((close - ms.lastLL) / range_hl) * 100)
            else if ms.trend == "BEARISH" and range_hl > 0
                ms.strength := math.round(((ms.lastHH - close) / range_hl) * 100)
            
            ms.strength := math.max(0, math.min(100, ms.strength))

update_market_structure()

// =======================
// === V7 LIQUIDITY POOL MODULE ===
// =======================

detect_liquidity_pools() =>
    if enable_liquidity_pools
        if high == high[1] and high > ta.highest(high[2], 10)
            pool = LiquidityPool.new()
            pool.price := high
            pool.poolType := "BUYSIDE"
            pool.touches := 2
            pool.volume := volume + volume[1]
            pool.swept := false
            pool.barIndex := bar_index
            array.push(liquidityPools, pool)
        
        if low == low[1] and low < ta.lowest(low[2], 10)
            pool = LiquidityPool.new()
            pool.price := low
            pool.poolType := "SELLSIDE"
            pool.touches := 2
            pool.volume := volume + volume[1]
            pool.swept := false
            pool.barIndex := bar_index
            array.push(liquidityPools, pool)
        
        if array.size(liquidityPools) > 0
            for i = array.size(liquidityPools) - 1 to 0
                pool = array.get(liquidityPools, i)
                
                if not pool.swept
                    if pool.poolType == "BUYSIDE" and high > pool.price
                        pool.swept := true
                    else if pool.poolType == "SELLSIDE" and low < pool.price
                        pool.swept := true
                
                if bar_index - pool.barIndex > 50
                    array.remove(liquidityPools, i)

detect_liquidity_pools()

check_liquidity_sweep(string direction) =>
    swept = false
    if array.size(liquidityPools) > 0
        for pool in liquidityPools
            if pool.swept and bar_index - pool.barIndex < 5
                if (direction == "BUY" and pool.poolType == "SELLSIDE") or (direction == "SELL" and pool.poolType == "BUYSIDE")
                    swept := true
                    break
    swept

// =======================
// === V7 VOLUME PROFILE MODULE (OPTIMIZED) ===
// =======================

calculate_volume_profile(int lookback) =>
    vp = VolumeProfile.new()
    
    if enable_volume_profile and barstate.isconfirmed
        effectiveLookback = math.min(lookback, 30)
        
        highest = ta.highest(high, effectiveLookback)
        lowest = ta.lowest(low, effectiveLookback)
        priceRange = highest - lowest
        
        if priceRange > 0 and not na(volume)
            numBins = 10
            binSize = priceRange / numBins
            
            var array<float> volumeLevels = array.new<float>(10, 0)
            var array<float> priceLevels = array.new<float>(10, 0)
            
            array.clear(volumeLevels)
            array.clear(priceLevels)
            
            for i = 0 to numBins - 1
                array.push(priceLevels, lowest + (i * binSize))
                array.push(volumeLevels, 0.0)
            
            maxBars = math.min(effectiveLookback, math.min(bar_index + 1, 20))
            for i = 0 to maxBars - 1
                if i < bar_index
                    barMid = (high[i] + low[i]) / 2
                    binIndex = math.floor((barMid - lowest) / binSize)
                    binIndex := math.max(0, math.min(numBins - 1, binIndex))
                    
                    currentVol = array.get(volumeLevels, binIndex)
                    array.set(volumeLevels, binIndex, currentVol + nz(volume[i], 0))
            
            maxVol = 0.0
            pocIndex = 0
            totalVol = 0.0
            
            for i = 0 to numBins - 1
                vol = array.get(volumeLevels, i)
                totalVol += vol
                if vol > maxVol
                    maxVol := vol
                    pocIndex := i
            
            vp.totalVolume := totalVol
            
            if totalVol > 0
                vp.poc := array.get(priceLevels, pocIndex)
                
                upperIndex = math.min(pocIndex + 1, numBins - 1)
                lowerIndex = math.max(pocIndex - 1, 0)
                
                vp.vah := array.get(priceLevels, upperIndex)
                vp.val := array.get(priceLevels, lowerIndex)
                
                vp.bullishImbalance := close > vp.poc and close > vp.vah
                vp.bearishImbalance := close < vp.poc and close < vp.val
            else
                vp.poc := (highest + lowest) / 2
                vp.vah := highest
                vp.val := lowest
        else
            vp.poc := close
            vp.vah := high
            vp.val := low
    
    vp

vp_current = calculate_volume_profile(20)

// =======================
// === V7 CORRELATION MODULE ===
// =======================

calculate_correlations() =>
    var array<CorrelationData> correlations = array.new<CorrelationData>()
    
    if enable_correlation
        array.clear(correlations)
        
        correlatedPairs = syminfo.ticker == "EURUSD" ? array.from("GBPUSD", "AUDUSD") : (syminfo.ticker == "GBPUSD" ? array.from("EURUSD", "AUDUSD") : (syminfo.ticker == "USDJPY" ? array.from("USDCHF", "USDCAD") : array.from("EURUSD", "GBPUSD")))
        
        for pair in correlatedPairs
            cd = CorrelationData.new()
            cd.symbol := pair
            
            pairClose = request.security(pair, timeframe.period, close)
            pairVolume = request.security(pair, timeframe.period, volume)
            pairChange = (pairClose - pairClose[1]) / pairClose[1] * 100
            
            currentChange = (close - close[1]) / close[1] * 100
            
            cd.correlation := ta.correlation(close, pairClose, 20)
            
            if math.abs(cd.correlation) > 0.7
                if (currentChange > 0 and pairChange < 0) or (currentChange < 0 and pairChange > 0)
                    cd.divergence := true
                    cd.divergenceType := currentChange > 0 ? "BULLISH_SMT" : "BEARISH_SMT"
                    cd.strength := math.abs(currentChange - pairChange)
            
            array.push(correlations, cd)
    
    correlations

correlations = calculate_correlations()

check_smt_divergence(string direction) =>
    has_divergence = false
    if array.size(correlations) > 0
        for corr in correlations
            if corr.divergence and ((direction == "BUY" and corr.divergenceType == "BULLISH_SMT") or (direction == "SELL" and corr.divergenceType == "BEARISH_SMT"))
                has_divergence := true
                break
    has_divergence

// =======================
// === V7 ENTRY FILTERS MODULE ===
// =======================

evaluate_entry_filters(string direction) =>
    ef = EntryFilter.new()
    ef.score := 0
    
    ef.marketStructureAligned := (direction == "BUY" and ms.trend == "BULLISH") or (direction == "SELL" and ms.trend == "BEARISH")
    if ef.marketStructureAligned
        ef.score += 20
    
    ef.liquiditySwept := check_liquidity_sweep(direction)
    if ef.liquiditySwept
        ef.score += 25
    
    ef.volumeConfirmation := (direction == "BUY" and close > vp_current.poc) or (direction == "SELL" and close < vp_current.poc)
    if ef.volumeConfirmation
        ef.score += 20
    
    ef.correlationConfirmation := check_smt_divergence(direction)
    if ef.correlationConfirmation
        ef.score += 20
    
    optimalHours = array.from(2, 3, 6, 7, 8, 9, 10)
    current_hour = hour(time, "GMT")
    ef.timeOfDayOptimal := array.includes(optimalHours, current_hour)
    if ef.timeOfDayOptimal
        ef.score += 15
    
    ef

// =======================
// === V7 RISK MANAGEMENT MODULE ===
// =======================

calculate_position_size(float entryPrice, float stopLoss) =>
    position_size = 0.0
    
    if enable_risk_management
        riskAmount = rm.riskPerTrade
        pipRisk = math.abs(entryPrice - stopLoss)
        
        pipValue = syminfo.type == "forex" ? 0.0001 : syminfo.mintick
        
        if pipRisk > 0
            position_size := riskAmount / (pipRisk / pipValue)
        
        rm.tradingAllowed := rm.currentOpenTrades < rm.maxConcurrentTrades and math.abs(rm.currentDailyPnL) < rm.maxDailyLoss
    
    position_size

update_daily_pnl(float pnl) =>
    if dayofweek != dayofweek[1]
        rm.currentDailyPnL := 0
    
    rm.currentDailyPnL += pnl

// =======================
// === V7 PERFORMANCE TRACKING MODULE ===
// =======================

track_signal_performance(bool signalHit, float returnPct) =>
    if enable_performance_tracking
        pt.totalSignals += 1
        
        if signalHit
            pt.winningSignals += 1
            pt.avgWin := (pt.avgWin * (pt.winningSignals - 1) + returnPct) / pt.winningSignals
        else
            pt.losingSignals += 1
            pt.avgLoss := (pt.avgLoss * (pt.losingSignals - 1) + math.abs(returnPct)) / pt.losingSignals
        
        array.push(pt.returns, returnPct)
        if array.size(pt.returns) > 100
            array.shift(pt.returns)
        
        pt.winRate := pt.totalSignals > 0 ? (pt.winningSignals / pt.totalSignals) * 100 : 0
        pt.profitFactor := pt.avgLoss > 0 ? pt.avgWin / pt.avgLoss : 0
        
        if array.size(pt.returns) > 20
            avgReturn = array.avg(pt.returns)
            stdDev = array.stdev(pt.returns)
            pt.sharpeRatio := stdDev > 0 ? (avgReturn / stdDev) * math.sqrt(252) : 0

// =======================
// === ENHANCED ENTRY SIGNALS ===
// =======================

var string entry_signal = "NONE"
var float entry_price = na
var float stop_loss = na
var float take_profit = na
var float position_size = na
var int entry_score = 0

generate_advanced_entry_signal() =>
    string signal = "NONE"
    float price = na
    float sl = na
    float tp = na
    float size = na
    int score = 0
    
    bool crt_active = (crt_1am_state == "D_READY") or (crt_5am_state == "D_READY") or (crt_9am_state == "D_READY")
    
    if crt_active and enable_entry_engine
        current_minutes = get_current_minutes()
        bool in_entry_window = false
        
        in_entry_window := (crt_1am_state == "D_READY" and is_in_time_window(120, 180)) or (crt_5am_state == "D_READY" and is_in_time_window(360, 510)) or (crt_9am_state == "D_READY" and is_in_time_window(570, 660))
        
        if in_entry_window
            direction = dol_bias == "BULLISH" ? "BUY" : "SELL"
            
            filters = evaluate_entry_filters(direction)
            score := filters.score
            
            if score >= min_entry_score
                if (direction == "BUY" and is_order_block and ob_type == "BULLISH") or (direction == "SELL" and is_order_block and ob_type == "BEARISH")
                    
                    signal := direction
                    price := close
                    atr = ta.atr(14)
                    sl := direction == "BUY" ? low[1] - (atr * 0.5) : high[1] + (atr * 0.5)
                    size := calculate_position_size(price, sl)
                    
                    if not na(ms.lastHH) and not na(ms.lastLL)
                        tp := direction == "BUY" ? math.min(ms.lastHH, price + ((price - sl) * 3)) : math.max(ms.lastLL, price - ((sl - price) * 3))
                    else
                        tp := direction == "BUY" ? price + ((price - sl) * 2) : price - ((sl - price) * 2)
    
    [signal, price, sl, tp, size, score]

[temp_signal, temp_price, temp_sl, temp_tp, temp_size, temp_score] = generate_advanced_entry_signal()

if temp_signal != "NONE"
    entry_signal := temp_signal
    entry_price := temp_price
    stop_loss := temp_sl
    take_profit := temp_tp
    position_size := temp_size
    entry_score := temp_score
else if entry_signal != "NONE"
    current_minutes = get_current_minutes()
    should_clear = true
    
    should_clear := not ((crt_1am_state == "D_READY" and is_in_time_window(120, 180)) or (crt_5am_state == "D_READY" and is_in_time_window(360, 510)) or (crt_9am_state == "D_READY" and is_in_time_window(570, 660)))
    
    if should_clear
        entry_signal := "NONE"
        entry_price := na
        stop_loss := na
        take_profit := na
        position_size := na
        entry_score := 0

// =======================
// === RESTORED VISUALIZATIONS ===
// =======================

// RESTORED DOL Lines
if show_dol_lines and not na(last_swing_high)
    line.new(bar_index-50, last_swing_high, bar_index+10, last_swing_high, color=col_bearish_dol, style=line.style_dashed, width=2)

if show_dol_lines and not na(last_swing_low)
    line.new(bar_index-50, last_swing_low, bar_index+10, last_swing_low, color=col_bullish_dol, style=line.style_dashed, width=2)

// RESTORED Session Boxes
if show_session_boxes and barstate.isconfirmed
    color session_color = session_behavior == "CONSOLIDATION" ? col_consolidation : session_behavior == "MANIPULATION" ? col_manipulation : col_expansion
    
    if session_state != prev_session and not na(prev_session_high) and not na(prev_session_low)
        box.new(bar_index-4, prev_session_high, bar_index, prev_session_low, bgcolor=session_color, border_width=1)

// Market Structure Visualization (V7)
if show_market_structure and not na(ms.lastHH)
    line.new(bar_index-20, ms.lastHH, bar_index, ms.lastHH, color=color.new(color.blue, 50), style=line.style_dotted)
    label.new(bar_index-10, ms.lastHH, "HH", color=color.blue, style=label.style_label_down, size=size.tiny)

if show_market_structure and not na(ms.lastLL)
    line.new(bar_index-20, ms.lastLL, bar_index, ms.lastLL, color=color.new(color.blue, 50), style=line.style_dotted)
    label.new(bar_index-10, ms.lastLL, "LL", color=color.blue, style=label.style_label_up, size=size.tiny)

// Liquidity Pool Visualization (V7)
if show_liquidity_pools and array.size(liquidityPools) > 0
    for pool in liquidityPools
        if not pool.swept and bar_index - pool.barIndex < 50
            poolColor = pool.poolType == "BUYSIDE" ? color.new(color.red, 70) : color.new(color.green, 70)
            line.new(pool.barIndex, pool.price, bar_index, pool.price, color=poolColor, width=2, style=line.style_dotted)

// Volume Profile Visualization (V7)
if show_volume_profile and barstate.islast
    if not na(vp_current.poc)
        line.new(bar_index-50, vp_current.poc, bar_index, vp_current.poc, color=color.new(color.orange, 30), width=3)
        label.new(bar_index, vp_current.poc, "POC", color=color.orange, style=label.style_label_left, size=size.small)
    
    if not na(vp_current.vah) and not na(vp_current.val)
        box.new(bar_index-50, vp_current.vah, bar_index, vp_current.val, bgcolor=color.new(color.blue, 90), border_width=1)

// RESTORED Entry Signals
if show_entry_signals and entry_signal != "NONE" and barstate.isconfirmed
    color signal_color = entry_signal == "BUY" ? color.green : color.red
    string signal_text = entry_signal + " (Score: " + str.tostring(entry_score) + "/100)\n" + "Entry: " + str.tostring(entry_price, "#.####") + "\n" + "SL: " + str.tostring(stop_loss, "#.####") + "\n" + "TP: " + str.tostring(take_profit, "#.####")
    
    if not na(position_size)
        signal_text += "\nSize: " + str.tostring(position_size, "#.##") + " lots"
    
    label.new(bar_index, entry_signal == "BUY" ? low : high, signal_text, yloc = entry_signal == "BUY" ? yloc.belowbar : yloc.abovebar, style=label.style_label_center, size=size.normal, color=signal_color, textcolor=color.white)

// RESTORED Key Level Visualization
if show_key_levels and is_order_block and barstate.isconfirmed
    color ob_color = ob_type == "BULLISH" ? color.green : color.red
    box.new(bar_index-1, high[1], bar_index+3, low[1], bgcolor=color.new(ob_color, 80), border_width=1)
    label.new(bar_index, (high[1]+low[1])/2, "OB", color=ob_color, textcolor=color.white, size=size.small)

if show_key_levels and is_fvg and barstate.isconfirmed
    color fvg_color = fvg_type == "BULLISH" ? color.green : color.red
    box.new(bar_index, fvg_top, bar_index+10, fvg_bottom, bgcolor=color.new(fvg_color, 90), border_width=1)

// RESTORED Debug Mode (V6)
if enable_debug_mode and barstate.islast
    active_profile = get_active_profile()
    
    string debug_text = "=== CRT STATE ENGINE v7.2 CURSOR ===\nTimeframe Valid: " + str.tostring(is_valid_timeframe()) + "\nDOL Bias: " + dol_bias + " → " + str.tostring(dol_target, "#.####") + "\nSession: " + session_state + " (" + session_behavior + ")\n1AM CRT: " + crt_1am_state + " [" + profile_1am + "]\n5AM CRT: " + crt_5am_state + " [" + profile_5am + "]\n9AM CRT: " + crt_9am_state + " [" + profile_9am + "]\nActive Profile: " + active_profile + "\nEntry Signal: " + entry_signal + " (Score: " + str.tostring(entry_score) + ")\nMarket Structure: " + ms.trend + " (Strength: " + str.tostring(ms.strength) + "%)\nCurrent Time (GMT): " + str.format("{0,time,HH:mm}", time)
    
    label.new(bar_index, high + (high-low)*0.1, debug_text, style=label.style_label_down, size=size.large, color=color.yellow, textcolor=color.black)

// =======================

        table.cell(dashboard, 3, row, str.tostring(pt.sharpeRatio, "#.##"), bgcolor=sharpe_color)

// =======================
// === COMPREHENSIVE ALERTS ===
// =======================

// CRT State Change Alerts (V6)
alertcondition(crt_1am_state == "D_READY" and crt_1am_state[1] != "D_READY", title="1AM CRT Ready", message="1AM CRT Distribution Ready - Check Entry Window 02:00-03:00 GMT")

alertcondition(crt_5am_state == "D_READY" and crt_5am_state[1] != "D_READY", title="5AM CRT Ready", message="5AM CRT Distribution Ready - Check Entry Window 06:00-08:30 GMT")

alertcondition(crt_9am_state == "D_READY" and crt_9am_state[1] != "D_READY", title="9AM CRT Ready", message="9AM CRT Distribution Ready - Check Entry Window 09:30-11:00 GMT")

// Basic Entry Signals (V6)
alertcondition(entry_signal == "BUY" and entry_signal[1] != "BUY", title="BUY Signal", message="BUY Signal Generated - Check Dashboard for Details")

alertcondition(entry_signal == "SELL" and entry_signal[1] != "SELL", title="SELL Signal", message="SELL Signal Generated - Check Dashboard for Details")

// High Confidence Entry Signals (V7)
alertcondition(entry_signal == "BUY" and entry_score >= 80, title="HIGH CONFIDENCE BUY", message="Strong BUY Signal - High Confidence Entry")

alertcondition(entry_signal == "SELL" and entry_score >= 80, title="HIGH CONFIDENCE SELL", message="Strong SELL Signal - High Confidence Entry")

// Market Structure Alerts (V7)
alertcondition(ms.brokenStructure, title="Market Structure Break", message="Market Structure Break Detected - Check Dashboard for Details")

// Liquidity Sweep Alerts (V7)
alertcondition(check_liquidity_sweep("BUY"), title="Bullish Liquidity Sweep", message="Sell-side liquidity swept - Potential reversal up")

alertcondition(check_liquidity_sweep("SELL"), title="Bearish Liquidity Sweep", message="Buy-side liquidity swept - Potential reversal down")

// Session and Market Alerts (V6)
alertcondition(session_state != session_state[1], title="Session Change", message="New Session Started")

alertcondition(dol_bias != dol_bias[1] and dol_bias != "NEUTRAL", title="DOL Bias Change", message="DOL Bias Changed - Review Trading Plan")

// Plot for data window (V6)
plotchar(entry_signal == "BUY" ? 1 : na, title="Buy Signal", char='▲', location=location.belowbar, size=size.small, color=color.green)
plotchar(entry_signal == "SELL" ? -1 : na, title="Sell Signal", char='▼', location=location.abovebar, size=size.small, color=color.red)

// =======================
// === SYSTEM INFO =======
// =======================

var string system_version = "7.2.0"
var string build_date = "2024-01-15"
var string edition = "CURSOR COMPLETE"

plotchar(barstate.islast ? 1 : na, title="CRT v7.2 Cursor Complete", char='', location=location.abovebar, color=color.new(color.white, 100), text="CRT Engine v" + system_version + "\nBuild: " + build_date + "\nEdition: " + edition)

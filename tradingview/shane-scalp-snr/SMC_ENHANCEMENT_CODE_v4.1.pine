// ═══════════════════════════════════════════════════════════════════════════════
// SMC ENHANCEMENT CODE FOR v4.1 - ALL 3 PHASES
// Add this code to wick_rejection_smc_strategy_v4.0.pine
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// ADDITIONAL INPUTS FOR ENHANCEMENTS
// ═══════════════════════════════════════════════════════════════════════════════
grp_smc_enhanced = "══════ SMC Enhanced Features ══════"
enable_fvg_tap_bonus = input.bool(true, "FVG Tap Bonus (+2)", group=grp_smc_enhanced)
enable_ob_confluence = input.bool(true, "Order Block Confluence (+2)", group=grp_smc_enhanced)
enable_recent_choch = input.bool(true, "Recent CHoCH Bonus (+2)", group=grp_smc_enhanced)
enable_htf_confluence = input.bool(true, "HTF Structure Confluence (+2)", group=grp_smc_enhanced)
enable_premium_discount_filter = input.bool(true, "Premium/Discount Zone Filter", group=grp_smc_enhanced, tooltip="Reject trades in wrong zone")
enable_sweep_choch_combo = input.bool(true, "Sweep+CHoCH Combo (+3)", group=grp_smc_enhanced)
enable_dynamic_sizing = input.bool(true, "Dynamic Position Sizing", group=grp_smc_enhanced)
enable_dynamic_rr = input.bool(true, "Dynamic R:R Based on Confidence", group=grp_smc_enhanced)

choch_lookback = input.int(20, "CHoCH Lookback Bars", minval=5, maxval=50, group=grp_smc_enhanced)
ob_tolerance = input.float(3.0, "OB Confluence Tolerance", minval=1.0, maxval=10.0, group=grp_smc_enhanced)
htf_tolerance = input.float(5.0, "HTF Confluence Tolerance", minval=1.0, maxval=20.0, group=grp_smc_enhanced)

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 1: CORE SMC INTEGRATION FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Function 1: FVG Tap Detection
f_check_fvg_tap(is_bullish) =>
    tapped = false
    if enable_fvg_tap_bonus
        if is_bullish and array.size(bullFVGs) > 0
            for i = 0 to array.size(bullFVGs) - 1
                fvg = array.get(bullFVGs, i)
                fvg_top = box.get_top(fvg)
                fvg_bot = box.get_bottom(fvg)
                if low <= fvg_top and low >= fvg_bot
                    tapped := true
                    break
        else if not is_bullish and array.size(bearFVGs) > 0
            for i = 0 to array.size(bearFVGs) - 1
                fvg = array.get(bearFVGs, i)
                fvg_top = box.get_top(fvg)
                fvg_bot = box.get_bottom(fvg)
                if high >= fvg_bot and high <= fvg_top
                    tapped := true
                    break
    tapped

// Function 2: Order Block Confluence
f_check_ob_confluence(price, is_bullish) =>
    confluence = false
    if enable_ob_confluence
        if is_bullish and array.size(bullOBs) > 0
            for i = 0 to array.size(bullOBs) - 1
                ob = array.get(bullOBs, i)
                ob_low = box.get_bottom(ob)
                ob_high = box.get_top(ob)
                if price >= ob_low - ob_tolerance and price <= ob_high + ob_tolerance
                    confluence := true
                    break
        else if not is_bullish and array.size(bearOBs) > 0
            for i = 0 to array.size(bearOBs) - 1
                ob = array.get(bearOBs, i)
                ob_low = box.get_bottom(ob)
                ob_high = box.get_top(ob)
                if price >= ob_low - ob_tolerance and price <= ob_high + ob_tolerance
                    confluence := true
                    break
    confluence

// Function 3: Recent CHoCH Detection
var int last_bull_choch_bar = 0
var int last_bear_choch_bar = 0

// Update CHoCH bars (add after CHoCH detection in main code)
if bullishCHoCH
    last_bull_choch_bar := bar_index
if bearishCHoCH
    last_bear_choch_bar := bar_index

f_recent_choch(is_bullish) =>
    recent = false
    if enable_recent_choch
        if is_bullish
            recent := bar_index - last_bull_choch_bar <= choch_lookback and last_bull_choch_bar > 0
        else
            recent := bar_index - last_bear_choch_bar <= choch_lookback and last_bear_choch_bar > 0
    recent

// Function 4: HTF Structure Confluence
f_htf_structure_confluence(price) =>
    confluence = false
    if enable_htf_confluence
        if not na(htfLastHigh) and math.abs(price - htfLastHigh) <= htf_tolerance
            confluence := true
        if not na(htfLastLow) and math.abs(price - htfLastLow) <= htf_tolerance
            confluence := true
    confluence

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 2: ADVANCED FILTERS
// ═══════════════════════════════════════════════════════════════════════════════

// Function 5: Premium/Discount Zone Check
f_in_correct_zone(is_bullish) =>
    correct_zone = true
    if enable_premium_discount_filter and not na(lastSwingHigh) and not na(lastSwingLow)
        eqPrice = (lastSwingHigh + lastSwingLow) / 2
        if is_bullish
            correct_zone := close <= eqPrice  // Buy only in discount zone
        else
            correct_zone := close >= eqPrice  // Sell only in premium zone
    correct_zone

// Function 6: Sweep + CHoCH Combo
var int last_buy_sweep_bar = 0
var int last_sell_sweep_bar = 0

// Update sweep bars (add after sweep detection in main code)
// In buy signal section, add: last_buy_sweep_bar := bar_index
// In sell signal section, add: last_sell_sweep_bar := bar_index

f_sweep_choch_combo(is_bullish) =>
    combo = false
    if enable_sweep_choch_combo
        if is_bullish
            sweep_recent = bar_index - last_buy_sweep_bar <= choch_lookback and last_buy_sweep_bar > 0
            choch_recent = bar_index - last_bull_choch_bar <= choch_lookback and last_bull_choch_bar > 0
            combo := sweep_recent and choch_recent and math.abs(last_buy_sweep_bar - last_bull_choch_bar) <= 5
        else
            sweep_recent = bar_index - last_sell_sweep_bar <= choch_lookback and last_sell_sweep_bar > 0
            choch_recent = bar_index - last_bear_choch_bar <= choch_lookback and last_bear_choch_bar > 0
            combo := sweep_recent and choch_recent and math.abs(last_sell_sweep_bar - last_bear_choch_bar) <= 5
    combo

// Function 7: SMC Structure Alignment Score
f_calculate_smc_alignment(is_bullish) =>
    score = 0
    if is_bullish
        if smcTrendDir == "Bullish"
            score += 1
        if bullishCHoCH or bullishBOS
            score += 1
        if array.size(bullFVGs) > 0
            score += 1
        if array.size(bullOBs) > 0
            score += 1
    else
        if smcTrendDir == "Bearish"
            score += 1
        if bearishCHoCH or bearishBOS
            score += 1
        if array.size(bearFVGs) > 0
            score += 1
        if array.size(bearOBs) > 0
            score += 1
    score

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3: DYNAMIC MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

// Function 8: Dynamic Position Sizing
f_calculate_position_size(confidence) =>
    base_size = 2.0
    multiplier = 1.0
    if enable_dynamic_sizing
        if confidence >= 15
            multiplier := 2.0      // 4% (PERFECT)
        else if confidence >= 12
            multiplier := 1.5      // 3% (EXCELLENT)
        else if confidence >= 9
            multiplier := 1.25     // 2.5% (GOOD)
        else if confidence >= 6
            multiplier := 1.0      // 2% (FAIR)
        else if confidence >= 3
            multiplier := 0.5      // 1% (WEAK)
        else
            multiplier := 0.0      // NO TRADE
    base_size * multiplier

// Function 9: Dynamic R:R Calculation
f_calculate_dynamic_rr(confidence) =>
    tp1 = 1.5
    tp2 = 2.5
    tp3 = 4.0
    if enable_dynamic_rr
        if confidence >= 15
            tp1 := 2.0
            tp2 := 3.5
            tp3 := 6.0
        else if confidence >= 12
            tp1 := 1.75
            tp2 := 3.0
            tp3 := 5.0
        else if confidence >= 9
            tp1 := 1.5
            tp2 := 2.5
            tp3 := 4.0
        else if confidence >= 6
            tp1 := 1.25
            tp2 := 2.0
            tp3 := 3.0
        else
            tp1 := 1.0
            tp2 := 1.5
            tp3 := 2.0
    [tp1, tp2, tp3]

// Function 10: Enhanced Confidence Tier
f_get_confidence_tier(confidence) =>
    tier = "REJECT"
    emoji = "❌"
    if confidence >= 15
        tier := "PERFECT"
        emoji := "🔥🔥🔥"
    else if confidence >= 12
        tier := "EXCELLENT"
        emoji := "🔥🔥"
    else if confidence >= 9
        tier := "GOOD"
        emoji := "🔥"
    else if confidence >= 6
        tier := "FAIR"
        emoji := "⚡"
    else if confidence >= 3
        tier := "WEAK"
        emoji := "⚠️"
    [tier, emoji]

// ═══════════════════════════════════════════════════════════════════════════════
// ENHANCED CONFIDENCE CALCULATION
// Replace the confidence calculation in f_check_support_signals() and f_check_resistance_signals()
// ═══════════════════════════════════════════════════════════════════════════════

f_calculate_enhanced_confidence(base_conf, is_bullish, level_price, is_sweep) =>
    conf = base_conf
    
    // PHASE 1 BONUSES
    if f_check_fvg_tap(is_bullish)
        conf += 2
    
    if f_check_ob_confluence(level_price, is_bullish)
        conf += 2
    
    if f_recent_choch(is_bullish)
        conf += 2
    
    if f_htf_structure_confluence(level_price)
        conf += 2
    
    // PHASE 2 BONUSES
    if is_sweep and f_sweep_choch_combo(is_bullish)
        conf += 3
    
    smc_alignment = f_calculate_smc_alignment(is_bullish)
    conf += smc_alignment
    
    conf

// ═══════════════════════════════════════════════════════════════════════════════
// INTEGRATION INSTRUCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/*
TO INTEGRATE INTO v4.0:

1. Add the additional inputs section after existing SMC inputs

2. Add all Phase 1, 2, 3 functions after the existing helper functions

3. In f_check_support_signals(), REPLACE the confidence calculation:
   OLD: _conf := 3 (for sweeps) or conf = 1 (for zone tests)
   NEW: _conf := f_calculate_enhanced_confidence(3, true, level_price, true)
        conf := f_calculate_enhanced_confidence(1, true, level_price, false)

4. In f_check_resistance_signals(), REPLACE the confidence calculation:
   OLD: _conf := 3 (for sweeps) or conf = 1 (for zone tests)
   NEW: _conf := f_calculate_enhanced_confidence(3, false, level_price, true)
        conf := f_calculate_enhanced_confidence(1, false, level_price, false)

5. Add Premium/Discount filter BEFORE signal execution:
   if buy_signal and not f_in_correct_zone(true)
       buy_signal := false
   if sell_signal and not f_in_correct_zone(false)
       sell_signal := false

6. Update sweep bar tracking in signal detection:
   When buy sweep detected: last_buy_sweep_bar := bar_index
   When sell sweep detected: last_sell_sweep_bar := bar_index

7. Replace position sizing in strategy.entry():
   OLD: default_qty_value=2
   NEW: qty = f_calculate_position_size(signal_confidence)
        strategy.entry("Long", strategy.long, qty=qty, ...)

8. Replace TP calculation:
   OLD: [tp1, tp2, tp3] = f_calculate_tp_levels(close, suggested_sl, true)
   NEW: [tp1_rr, tp2_rr, tp3_rr] = f_calculate_dynamic_rr(signal_confidence)
        Then use these RR values in f_calculate_tp_levels()

9. Update signal labels to show tier:
   [tier, emoji] = f_get_confidence_tier(signal_confidence)
   label_text = emoji + " BUY " + tier + " @" + str.tostring(signal_level, format.mintick)

10. Update info table to show confidence tier and score
*/

// ═══════════════════════════════════════════════════════════════════════════════
// END OF ENHANCEMENT CODE
// ═══════════════════════════════════════════════════════════════════════════════


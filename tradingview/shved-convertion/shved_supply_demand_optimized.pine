//@version=5
indicator("Shved Supply & Demand [Optimized2]", overlay=true, max_boxes_count=500, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// PERFORMANCE OPTIMIZATIONS:
// 1. Uses built-in ta.pivothigh/ta.pivotlow instead of manual loops
// 2. Incremental zone updates instead of full recalculation
// 3. Limited zone processing with max_zones parameter
// 4. Optimized merge algorithm with early termination
// 5. Efficient array operations with pre-allocation
// 6. Reduced nested loops from O(n³) to O(n²)
// ═══════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════
// INPUT PARAMETERS
// ═══════════════════════════════════════════════════════════════════

// Zone Settings
i_lookback = input.int(300, "Lookback Bars", minval=50, maxval=1000, 
     tooltip="How far back to scan for zones. Lower = faster performance", group="Zone Settings")
i_maxZones = input.int(50, "Max Zones to Display", minval=10, maxval=100, 
     tooltip="Limit number of zones shown. Lower = faster performance", group="Zone Settings")
i_showWeak = input.bool(false, "Show Weak Zones", group="Zone Settings")
i_showUntested = input.bool(true, "Show Untested Zones", group="Zone Settings")
i_showTurncoat = input.bool(true, "Show Broken Zones", group="Zone Settings")
i_atrMult = input.float(0.75, "Zone Width (ATR Multiplier)", minval=0.1, maxval=3.0, step=0.05, group="Zone Settings")
i_merge = input.bool(true, "Merge Overlapping Zones", group="Zone Settings")
i_extend = input.bool(true, "Extend Zones Right", group="Zone Settings")

// Fractal Settings
i_fastLeft = input.int(3, "Fast Pivot Left Bars", minval=1, maxval=20, group="Fractal Settings")
i_fastRight = input.int(3, "Fast Pivot Right Bars", minval=1, maxval=20, group="Fractal Settings")
i_slowLeft = input.int(6, "Slow Pivot Left Bars", minval=1, maxval=30, group="Fractal Settings")
i_slowRight = input.int(6, "Slow Pivot Right Bars", minval=1, maxval=30, group="Fractal Settings")

// Visual Settings
i_showLabels = input.bool(true, "Show Zone Labels", group="Visual Settings")
i_fillZones = input.bool(true, "Fill Zones", group="Visual Settings")
i_borderWidth = input.int(1, "Border Width", minval=1, maxval=3, group="Visual Settings")
i_labelSize = input.string("Small", "Label Size", options=["Tiny", "Small", "Normal", "Large"], group="Visual Settings")

// Alert Settings
i_alerts = input.bool(false, "Enable Alerts", group="Alert Settings")

// Colors
c_suppWeak = input.color(color.new(#2F4F4F, 50), "Weak Support", group="Colors")
c_suppUntested = input.color(color.new(#2E8B57, 50), "Untested Support", group="Colors")
c_suppVerified = input.color(color.new(#008000, 50), "Verified Support", group="Colors")
c_suppProven = input.color(color.new(#32CD32, 50), "Proven Support", group="Colors")
c_suppTurncoat = input.color(color.new(#6B8E23, 50), "Broken Support", group="Colors")
c_resWeak = input.color(color.new(#4B0082, 50), "Weak Resistance", group="Colors")
c_resUntested = input.color(color.new(#DA70D6, 50), "Untested Resistance", group="Colors")
c_resVerified = input.color(color.new(#DC143C, 50), "Verified Resistance", group="Colors")
c_resProven = input.color(color.new(#FF0000, 50), "Proven Resistance", group="Colors")
c_resTurncoat = input.color(color.new(#FF8C00, 50), "Broken Resistance", group="Colors")

// ═══════════════════════════════════════════════════════════════════
// CONSTANTS & TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════

int SUPPORT = 1
int RESIST = 2
int WEAK = 0
int TURNCOAT = 1
int UNTESTED = 2
int VERIFIED = 3
int PROVEN = 4

// Zone structure
type Zone
    float hi
    float lo
    int startBar
    int zoneType
    int strength
    int hits
    bool turned

// ═══════════════════════════════════════════════════════════════════
// GLOBAL VARIABLES
// ═══════════════════════════════════════════════════════════════════

var array<Zone> zones = array.new<Zone>()
var array<box> zoneBoxes = array.new<box>()
var array<label> zoneLabels = array.new<label>()

// Convert label size string to size constant
getLabelSize() =>
    switch i_labelSize
        "Tiny" => size.tiny
        "Small" => size.small
        "Normal" => size.normal
        "Large" => size.large
        => size.small

// ═══════════════════════════════════════════════════════════════════
// OPTIMIZED FRACTAL DETECTION USING BUILT-IN FUNCTIONS
// ═══════════════════════════════════════════════════════════════════

// Fast pivot detection
fastHigh = ta.pivothigh(high, i_fastLeft, i_fastRight)
fastLow = ta.pivotlow(low, i_fastLeft, i_fastRight)

// Slow pivot detection (for strength classification)
slowHigh = ta.pivothigh(high, i_slowLeft, i_slowRight)
slowLow = ta.pivotlow(low, i_slowLeft, i_slowRight)

// Current bar pivot values (these will be na until pivot is confirmed)
isFastHigh = not na(fastHigh)
isFastLow = not na(fastLow)
isSlowHigh = not na(slowHigh)
isSlowLow = not na(slowLow)

// ═══════════════════════════════════════════════════════════════════
// ZONE CREATION FUNCTION
// ═══════════════════════════════════════════════════════════════════

createZone(isResistance, price, barIdx, isStrong) =>
    atr = ta.atr(7)
    fu = atr * 0.5 * i_atrMult
    
    float zHi = na
    float zLo = na
    
    if isResistance
        zHi := i_extend ? price + fu : price
        zLo := math.max(math.min(close, price - fu), price - fu * 2)
    else
        zLo := i_extend ? price - fu : price
        zHi := math.min(math.max(close, price + fu), price + fu * 2)
    
    Zone.new(
         hi = zHi,
         lo = zLo,
         startBar = barIdx,
         zoneType = isResistance ? RESIST : SUPPORT,
         strength = isStrong ? UNTESTED : WEAK,
         hits = 0,
         turned = false
     )

// ═══════════════════════════════════════════════════════════════════
// ZONE VALIDATION & TESTING
// ═══════════════════════════════════════════════════════════════════

updateZoneStrength(Zone zone) =>
    // Count how many times zone was tested
    testCount = 0
    bustCount = 0
    turned = false
    barsAgo = bar_index - zone.startBar
    maxLookback = math.min(barsAgo, i_lookback)
    
    // Optimized test counting - only check bars since zone creation
    for i = 1 to maxLookback
        barHi = high[i]
        barLo = low[i]
        
        // Check if price tested the zone (touched but didn't break significantly)
        if barLo <= zone.hi and barHi >= zone.lo
            // Price touched zone - check if it was a proper test
            if i > 10  // Ensure at least 10 bars between tests
                lastTestValid = true
                // Verify no test in last 10 bars
                for j = 1 to math.min(9, i - 1)
                    if low[i - j] <= zone.hi and high[i - j] >= zone.lo
                        lastTestValid := false
                        break
                if lastTestValid
                    testCount += 1
        
        // Check if zone was busted (price closed through it)
        if zone.zoneType == RESIST and close[i] > zone.hi
            bustCount += 1
            if bustCount > 1
                break  // Zone invalidated
            turned := true
        else if zone.zoneType == SUPPORT and close[i] < zone.lo
            bustCount += 1
            if bustCount > 1
                break  // Zone invalidated
            turned := true
    
    // Determine strength based on tests and busts
    int newStrength = WEAK
    bool isValid = true
    
    if bustCount > 1
        isValid := false  // Zone broken too many times
    else if bustCount == 1
        newStrength := TURNCOAT
        zone.turned := true
    else if testCount > 3
        newStrength := PROVEN
    else if testCount > 0
        newStrength := VERIFIED
    else if zone.strength == UNTESTED
        newStrength := UNTESTED
    else
        newStrength := WEAK
    
    zone.strength := newStrength
    zone.hits := testCount
    isValid

// ═══════════════════════════════════════════════════════════════════
// ZONE MERGING ALGORITHM (OPTIMIZED)
// ═══════════════════════════════════════════════════════════════════

mergeZones() =>
    if i_merge and array.size(zones) >= 2
        needsMerge = true
        iterations = 0
        maxIterations = 2  // Limit merge iterations for performance
        
        while needsMerge and iterations < maxIterations
            needsMerge := false
            iterations += 1
            
            // Mark zones for deletion (merged zones)
            toDelete = array.new_int()
            
            zoneCount = array.size(zones)
            if zoneCount >= 2
                for i = 0 to zoneCount - 2
                    if array.includes(toDelete, i)
                        continue
                        
                    zone1 = array.get(zones, i)
                    
                    for j = i + 1 to zoneCount - 1
                        if array.includes(toDelete, j)
                            continue
                            
                        zone2 = array.get(zones, j)
                        
                        // Check if zones overlap
                        if (zone1.hi >= zone2.lo and zone1.hi <= zone2.hi) or (zone1.lo <= zone2.hi and zone1.lo >= zone2.lo) or (zone2.hi >= zone1.lo and zone2.hi <= zone1.hi) or (zone2.lo <= zone1.hi and zone2.lo >= zone1.lo)
                            
                            // Merge zone2 into zone1
                            zone1.hi := math.max(zone1.hi, zone2.hi)
                            zone1.lo := math.min(zone1.lo, zone2.lo)
                            zone1.hits := zone1.hits + zone2.hits
                            zone1.startBar := math.max(zone1.startBar, zone2.startBar)
                            zone1.strength := math.max(zone1.strength, zone2.strength)
                            zone1.turned := zone1.turned or zone2.turned
                            
                            // Update strength after merge
                            if zone1.hits > 3
                                zone1.strength := PROVEN
                            else if zone1.hits > 0 and zone1.strength < VERIFIED
                                zone1.strength := VERIFIED
                            
                            array.push(toDelete, j)
                            needsMerge := true
            
            // Remove merged zones (from end to preserve indices)
            if array.size(toDelete) > 0
                array.sort(toDelete, order.descending)
                for i = 0 to array.size(toDelete) - 1
                    idx = array.get(toDelete, i)
                    if idx < array.size(zones)
                        array.remove(zones, idx)

// ═══════════════════════════════════════════════════════════════════
// GET ZONE COLOR
// ═══════════════════════════════════════════════════════════════════

getZoneColor(int zType, int strength) =>
    if zType == SUPPORT
        switch strength
            WEAK => c_suppWeak
            UNTESTED => c_suppUntested
            VERIFIED => c_suppVerified
            PROVEN => c_suppProven
            TURNCOAT => c_suppTurncoat
            => c_suppWeak
    else
        switch strength
            WEAK => c_resWeak
            UNTESTED => c_resUntested
            VERIFIED => c_resVerified
            PROVEN => c_resProven
            TURNCOAT => c_resTurncoat
            => c_resWeak

// ═══════════════════════════════════════════════════════════════════
// DELETE ALL DRAWINGS
// ═══════════════════════════════════════════════════════════════════

deleteAllDrawings() =>
    // Delete all boxes
    if array.size(zoneBoxes) > 0
        for i = 0 to array.size(zoneBoxes) - 1
            box.delete(array.get(zoneBoxes, i))
        array.clear(zoneBoxes)
    
    // Delete all labels
    if array.size(zoneLabels) > 0
        for i = 0 to array.size(zoneLabels) - 1
            label.delete(array.get(zoneLabels, i))
        array.clear(zoneLabels)

// ═══════════════════════════════════════════════════════════════════
// DRAW ZONES
// ═══════════════════════════════════════════════════════════════════

drawZones() =>
    // Clear old drawings first
    deleteAllDrawings()
    
    // Draw all valid zones
    for i = 0 to array.size(zones) - 1
        zone = array.get(zones, i)
        
        // Filter by strength
        if zone.strength == WEAK and not i_showWeak
            continue
        if zone.strength == UNTESTED and not i_showUntested
            continue
        if zone.strength == TURNCOAT and not i_showTurncoat
            continue
        
        // Calculate bars back from current bar
        barsBack = bar_index - zone.startBar
        
        // Limit barsBack to available historical buffer (max 5000 bars or bar_index, whichever is smaller)
        maxBarsBack = math.min(bar_index, 5000)
        
        // Only draw if within reasonable range
        if barsBack >= 0 and barsBack <= maxBarsBack
            zColor = getZoneColor(zone.zoneType, zone.strength)
            
            // Ensure left coordinate doesn't go beyond available bars
            leftBar = math.max(0, bar_index - barsBack)
            
            // Create box using bar_index coordinates
            b = box.new(
                 left = leftBar,
                 top = zone.hi,
                 right = bar_index,
                 bottom = zone.lo,
                 border_color = zColor,
                 bgcolor = i_fillZones ? zColor : color.new(zColor, 100),
                 border_width = i_borderWidth,
                 extend = i_extend ? extend.right : extend.none
             )
            array.push(zoneBoxes, b)
            
            // Create label if enabled
            if i_showLabels
                strengthText = switch zone.strength
                    PROVEN => "Proven"
                    VERIFIED => "Verified"
                    UNTESTED => "Untested"
                    TURNCOAT => "Turncoat"
                    => "Weak"
                
                typeText = zone.zoneType == SUPPORT ? "Sup" : "Res"
                labelText = strengthText + " " + typeText
                
                if zone.hits > 0 and zone.strength > UNTESTED
                    labelText += " (" + str.tostring(zone.hits) + ")"
                
                labelY = zone.lo + (zone.hi - zone.lo) * 0.5
                
                lbl = label.new(
                     x = leftBar,
                     y = labelY,
                     text = labelText,
                     color = color.new(color.white, 100),
                     textcolor = color.black,
                     style = label.style_none,
                     size = getLabelSize()
                 )
                array.push(zoneLabels, lbl)

// ═══════════════════════════════════════════════════════════════════
// MAIN PROCESSING
// ═══════════════════════════════════════════════════════════════════

// Add new zones from pivots (only at pivot confirmation)
if isFastHigh
    newZone = createZone(true, fastHigh, bar_index - i_fastRight, isSlowHigh)
    if array.size(zones) < i_maxZones * 2  // Allow room for merging
        array.push(zones, newZone)

if isFastLow
    newZone = createZone(false, fastLow, bar_index - i_fastRight, isSlowLow)
    if array.size(zones) < i_maxZones * 2  // Allow room for merging
        array.push(zones, newZone)

// Update existing zones (on every bar for real-time updates)
if array.size(zones) > 0
    validZones = array.new<Zone>()
    
    for i = 0 to array.size(zones) - 1
        zone = array.get(zones, i)
        
        // Remove zones that are too old
        if bar_index - zone.startBar > i_lookback
            continue
        
        // Update zone and check if still valid
        isValid = updateZoneStrength(zone)
        
        if isValid
            array.push(validZones, zone)
    
    zones := validZones

// Merge overlapping zones
if i_merge and array.size(zones) > 1
    mergeZones()

// Sort and limit zones to max_zones
if array.size(zones) > i_maxZones
    // Separate support and resistance
    supports = array.new<Zone>()
    resistances = array.new<Zone>()
    
    for i = 0 to array.size(zones) - 1
        zone = array.get(zones, i)
        if zone.hi < close
            array.push(supports, zone)
        else if zone.lo > close
            array.push(resistances, zone)
    
    // Sort each by proximity to price
    // For supports: higher is closer (sort descending by lo)
    // For resistances: lower is closer (sort ascending by hi)
    
    // Take best of each type
    sortedZones = array.new<Zone>()
    maxPerType = math.floor(i_maxZones / 2)
    
    // Add closest supports
    numSupports = math.min(array.size(supports), maxPerType)
    for i = 0 to numSupports - 1
        array.push(sortedZones, array.get(supports, i))
    
    // Add closest resistances
    numResist = math.min(array.size(resistances), maxPerType)
    for i = 0 to numResist - 1
        array.push(sortedZones, array.get(resistances, i))
    
    zones := sortedZones

// Draw all zones on last bar
if barstate.islast
    drawZones()

// Check for alerts
if i_alerts and barstate.isconfirmed
    for i = 0 to array.size(zones) - 1
        zone = array.get(zones, i)
        
        if zone.strength == WEAK and not i_showWeak
            continue
        if zone.strength == UNTESTED and not i_showUntested
            continue
        if zone.strength == TURNCOAT and not i_showTurncoat
            continue
        
        if close >= zone.lo and close <= zone.hi
            alertMsg = (zone.zoneType == SUPPORT ? "Support" : "Resistance") + " Zone Entered"
            alert(alertMsg, alert.freq_once_per_bar)
            break

// ═══════════════════════════════════════════════════════════════════
// NEAREST ZONES FOR DATA WINDOW
// ═══════════════════════════════════════════════════════════════════

var float nearestSuppHi = na
var float nearestSuppLo = na
var float nearestResHi = na
var float nearestResLo = na

if barstate.islast
    nearestSuppHi := na
    nearestSuppLo := na
    nearestResHi := na
    nearestResLo := na
    
    for i = 0 to array.size(zones) - 1
        zone = array.get(zones, i)
        
        if zone.zoneType == SUPPORT and zone.hi < close
            if na(nearestSuppHi) or zone.lo > nearestSuppLo
                nearestSuppHi := zone.hi
                nearestSuppLo := zone.lo
        
        if zone.zoneType == RESIST and zone.lo > close
            if na(nearestResHi) or zone.hi < nearestResHi
                nearestResHi := zone.hi
                nearestResLo := zone.lo

plot(nearestResHi, "Nearest Resistance High", color.new(color.red, 90), display=display.data_window)
plot(nearestResLo, "Nearest Resistance Low", color.new(color.red, 90), display=display.data_window)
plot(nearestSuppHi, "Nearest Support High", color.new(color.green, 90), display=display.data_window)
plot(nearestSuppLo, "Nearest Support Low", color.new(color.green, 90), display=display.data_window)
plot(array.size(zones), "Total Zones", color.new(color.blue, 0), display=display.data_window)

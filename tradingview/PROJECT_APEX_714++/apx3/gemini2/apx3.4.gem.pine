i_london_col = input.color(color.new(color.green, 95), "🇬🇧 London Session", group=G_COLORS_SESSIONS, tooltip="Background tint for London session")
i_asia_col = input.color(color.new(color.yellow, 95), "🏯 Asian Session", group=G_COLORS_SESSIONS, tooltip="Background tint for Asian session")

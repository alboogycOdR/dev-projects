var float cisd_track_bull_price = na
var int cisd_track_bear_index = na
var float cisd_track_bear_price = na
var cisd_bin cisd_active_bull = cisd_bin.new(line.new(bar_index, open, bar_index, open), true, bar_index, high)
var cisd_bin cisd_active_bear = cisd_bin.new(line.new(bar_index, open, bar_index, open), true, bar_index, low)
cisd_bull_candle = close > open
cisd_bear_candle = close < open
cisd_is_sweep_mode = i_cisd_method == "Liquidity Sweep"
cisd_text_size = i_cisd_label_size == "Small" ? size.small : size.tiny

is_time_in_range(session, tz) =>
    t = time(timeframe.period, session, tz)
    not na(t)
bool inMidnightKZ = is_time_in_range(i_midnight_session, "UTC") and i_midnight_strategy != O_OFF
bool inLondonKZ = is_time_in_range(i_london_session, "UTC") and i_london_strategy != O_OFF
bool inNewYorkKZ = is_time_in_range(i_ny_session, "UTC") and i_ny_strategy != O_OFF
bool inAnyKZ = inMidnightKZ or inLondonKZ or inNewYorkKZ
string asianSession = "0000-0700"
bool inAsianSession = is_time_in_range(asianSession, "UTC")

// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
// SECTION 3: SMC ENGINE - POINT OF INTEREST (POI) DETECTION FUNCTIONS
// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
// ... (This entire section is unchanged and correct) ...
f_get_htf_bias() =>
    htf_close = request.security(syminfo.tickerid, i_htf_timeframe, close, lookahead=barmerge.lookahead_on)
    htf_ema = ta.ema(htf_close, 50)
    htf_bias = close > htf_ema ? "BULLISH" : "BEARISH"
    htf_bias
string htfBias = f_get_htf_bias()
f_isSwingHigh(len) => high[len] == ta.highest(high, len * 2 + 1)
f_isSwingLow(len) => low[len] == ta.lowest(low, len * 2 + 1)
drawChar(x, y, txt, col, isUp) =>
    int x_int = int(x)
    if isUp
        label.new(x=x_int, y=y, text=txt, color=color.new(col, 0), textcolor=color.white, style=label.style_triangleup, size=size.small)
    else
        label.new(x=x_int, y=y, text=txt, color=color.new(col, 0), textcolor=color.white, style=label.style_triangledown, size=size.small)
fvg(gapSize) =>
    var array<box> fvgBoxes = array.new<box>()
    var array<line> midlineLines = array.new<line>()
    if gapSize > 0
        if low[2] > high[0]
            box.new(left=bar_index[2], top=high[0], right=bar_index, bottom=low[2], bgcolor=color.new(c_bullish, 90), border_color=c_bullish)
            array.push(fvgBoxes, box.new(left=bar_index[2], top=high[0], right=bar_index, bottom=low[2], bgcolor=color.new(c_bullish, 90), border_color=c_bullish))
            midline = (high[0] + low[2]) / 2
            array.push(midlineLines, line.new(x1=bar_index[2], y1=midline, x2=bar_index, y2=midline, color=c_bullish, style=line.style_dotted, width=1))
            label.new(x=bar_index[1], y=midline, text="FVG", color=color.new(c_bullish, 0), textcolor=color.white, style=label.style_label_center, size=size.small)
    else if gapSize < 0
        if high[2] < low[0]
            box.new(left=bar_index[2], top=low[0], right=bar_index, bottom=high[2], bgcolor=color.new(c_bearish, 90), border_color=c_bearish)
            array.push(fvgBoxes, box.new(left=bar_index[2], top=low[0], right=bar_index, bottom=high[2], bgcolor=color.new(c_bearish, 90), border_color=c_bearish))
            midline = (low[0] + high[2]) / 2
            array.push(midlineLines, line.new(x1=bar_index[2], y1=midline, x2=bar_index, y2=midline, color=c_bearish, style=line.style_dotted, width=1))
            label.new(x=bar_index[1], y=midline, text="FVG", color=color.new(c_bearish, 0), textcolor=color.white, style=label.style_label_center, size=size.small)
    [fvgBoxes, midlineLines]
var float lastBullishBOSPrice = na
var float lastBearishBOSPrice = na
var float lastSwingHigh = na
var float lastSwingLow = na
var float recentSwingHighForSL = na
var float recentSwingLowForSL = na
var float smallUpper = na
var float smallLower = na
if f_isSwingHigh(5)
    lastSwingHigh := high[5]
    recentSwingHighForSL := high[5]
if f_isSwingLow(5)
    lastSwingLow := low[5]
    recentSwingLowForSL := low[5]

// Internal structure detection (smaller swings for CHoCH)
if f_isSwingHigh(3)
    smallUpper := high[3]
if f_isSwingLow(3)
    smallLower := low[3]
isBullishBOS = close > lastSwingHigh and not na(lastSwingHigh) and htfBias == "BULLISH"
isBearishBOS = close < lastSwingLow and not na(lastSwingLow) and htfBias == "BEARISH"
isBullishMSS = close > lastSwingHigh and not na(lastSwingHigh) and htfBias == "BEARISH"
isBearishMSS = close < lastSwingLow and not na(lastSwingLow) and htfBias == "BULLISH"
if isBullishBOS or isBullishMSS
    lastBullishBOSPrice := lastSwingHigh
    lastSwingHigh := na
if isBearishBOS or isBearishMSS
    lastBearishBOSPrice := lastSwingLow
    lastSwingLow := na
var int bullishStructureBar = na
var float bullishStructurePrice = na
var string bullishStructureText = na
var int bearishStructureBar = na
var float bearishStructurePrice = na
var string bearishStructureText = na
if i_show_bos_mss
    if ta.change(lastBullishBOSPrice)
        line.new(bar_index[1], lastBullishBOSPrice, bar_index, lastBullishBOSPrice, color=color.new(c_bullish, 50), style=line.style_dotted, width=1)
        bullishStructureBar := bar_index
        bullishStructurePrice := lastBullishBOSPrice
        bullishStructureText := isBullishBOS ? "BOS" : "MSS"
    if ta.change(lastBearishBOSPrice)
        line.new(bar_index[1], lastBearishBOSPrice, bar_index, lastBearishBOSPrice, color=color.new(c_bearish, 50), style=line.style_dotted, width=1)
        bearishStructureBar := bar_index
        bearishStructurePrice := lastBearishBOSPrice
        bearishStructureText := isBearishMSS ? "MSS" : "BOS"
if not na(bullishStructureBar) and bar_index == bullishStructureBar
    label.new(x=bullishStructureBar, y=low, yloc=yloc.belowbar, text=bullishStructureText, color=color.new(c_bullish, 0), textcolor=color.white, style=label.style_triangleup, size=size.tiny)
if not na(bearishStructureBar) and bar_index == bearishStructureBar
    label.new(x=bearishStructureBar, y=high, yloc=yloc.abovebar, text=bearishStructureText, color=color.new(c_bearish, 0), textcolor=color.white, style=label.style_triangledown, size=size.tiny)
var float asiaHigh = na
var float asiaLow = na
int asianSessionStartBar = ta.barssince(inAsianSession and not inAsianSession[1])
int rawSessionLength = not na(asianSessionStartBar) and asianSessionStartBar >= 0 ? math.max(1, bar_index - asianSessionStartBar) : 1
int asianSessionLength = math.min(rawSessionLength, 5000)
float currentAsiaHigh = ta.highest(high, asianSessionLength)
float currentAsiaLow = ta.lowest(low, asianSessionLength)
if not inAsianSession and inAsianSession[1] and not na(asianSessionLength) and asianSessionLength > 0 and asianSessionLength <= bar_index
    asiaHigh := currentAsiaHigh[1]
    asiaLow := currentAsiaLow[1]
    if i_show_session_ranges and not na(asiaHigh) and not na(asiaLow)
        sessionStartBar = bar_index - asianSessionLength
        sessionEndBar = bar_index
        box.new(sessionStartBar, asiaHigh, sessionEndBar, asiaLow, border_color=na, bgcolor=c_session_range)
        line.new(sessionStartBar, asiaHigh, sessionEndBar, asiaHigh, color=c_session_range, style=line.style_dotted)
        line.new(sessionStartBar, asiaLow, sessionEndBar, asiaLow, color=c_session_range, style=line.style_dotted)
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_on)
isAsiaHighSweep = high > asiaHigh and not na(asiaHigh)
isAsiaLowSweep = low < asiaLow and not na(asiaLow)
isPDHSweep = high > pdh and not na(pdh)
isPDLSweep = low < pdl and not na(pdl)
isAnyLiquiditySweep = isAsiaHighSweep or isAsiaLowSweep or isPDHSweep or isPDLSweep
var bool isBullish_ICHoch = false
var bool isBearish_ICHoch = false
drawStructureInternals() =>
    if i_show_int_structure
        var keyValues = map.new<string, float>()
        if keyValues.size() == 0
            keyValues.put("movingSmall", 0)
        if not na(smallUpper) and smallUpper != 0
            keyValues.put("upsideSmall", 1)
            keyValues.put("upaxisSmall", smallUpper)
            keyValues.put("upaxis2Small", bar_index - i_int_sens)
        if not na(smallLower) and smallLower != 0
            keyValues.put("downsideSmall", 1)
            keyValues.put("dnaxisSmall", smallLower)
            keyValues.put("dnaxis2Small", bar_index - i_int_sens)
        bullish_str = ""
        bearish_str = ""
        upaxisVal = keyValues.get("upaxisSmall")
        if not na(upaxisVal) and ta.crossover(close, upaxisVal) and keyValues.get("upsideSmall") != 0
            bullish_str := keyValues.get("movingSmall") < 0 ? i_int_structure != "BoS" ? 'I-CHoCH' : "" : i_int_structure != "CHoCH" ? 'I-BoS' : ""
            if i_int_structure == "All" or str.contains(i_int_structure, bullish_str)
                drawChar(keyValues.get("upaxis2Small"), upaxisVal, bullish_str, c_bullish, true)
            keyValues.put("upsideSmall", 0)
            keyValues.put("movingSmall", 1)
        dnaxisVal = keyValues.get("dnaxisSmall")
        if not na(dnaxisVal) and ta.crossunder(close, dnaxisVal) and keyValues.get("downsideSmall") != 0
            bearish_str := keyValues.get("movingSmall") > 0 ? i_int_structure != "BoS" ? 'I-CHoCH' : "" : i_int_structure != "CHoCH" ? 'I-BoS' : ""
            if i_int_structure == "All" or str.contains(i_int_structure, bearish_str)
                drawChar(keyValues.get("dnaxis2Small"), dnaxisVal, bearish_str, c_bearish, false)
            keyValues.put("downsideSmall", 0)
            keyValues.put("movingSmall", -1)
        [bullish_str, bearish_str]
    else
        ["", ""]
[bull_str, bear_str] = drawStructureInternals()
isBullish_ICHoch := bull_str == 'I-CHoCH'
isBearish_ICHoch := bear_str == 'I-CHoCH'
if i_show_cisd
    ph = ta.pivothigh(i_cisd_swing_length, 1)
    pl = ta.pivotlow(i_cisd_swing_length, 1)
    if not na(ph)
        cisd_swings_high.push(cisd_swing.new(bar_index - 1, ph))
        cisd_last_ph_index := bar_index - 1
        cisd_last_ph_price := ph
    if not na(pl)
        cisd_swings_low.push(cisd_swing.new(bar_index - 1, pl))
        cisd_last_pl_index := bar_index - 1
        cisd_last_pl_price := pl
    if cisd_bull_candle and cisd_bear_candle[1]
        cisd_track_bull_index := bar_index
        cisd_track_bull_price := open
    if cisd_bear_candle and cisd_bull_candle[1]
        cisd_track_bear_index := bar_index
        cisd_track_bear_price := open
    if not na(cisd_last_ph_price) and close > cisd_last_ph_price
        cisd_last_ph_index := na
        cisd_last_ph_price := na
    if not na(cisd_last_pl_price) and close < cisd_last_pl_price
        cisd_last_pl_index := na
        cisd_last_pl_price := na
    if not cisd_is_sweep_mode
        if barstate.isconfirmed and cisd_bull_candle and cisd_bear_candle[1]
            if cisd_active_bull.active and not cisd_active_bull.broken
                cisd_active_bull.ln.delete()
            cisd_active_bull.active := true
            cisd_active_bull.ln := line.new(cisd_track_bull_index, cisd_track_bull_price, bar_index, cisd_track_bull_price, color=color.new(i_cisd_bull_color, 40))
            cisd_active_bull.start_index := not na(cisd_last_ph_index) ? cisd_last_ph_index : bar_index
            cisd_active_bull.start_price := not na(cisd_last_ph_price) ? cisd_last_ph_price : high
            cisd_active_bull.broken := false
        if barstate.isconfirmed and cisd_bear_candle and cisd_bull_candle[1]
            if cisd_active_bear.active and not cisd_active_bear.broken
                cisd_active_bear.ln.delete()
            cisd_active_bear.active := true
            cisd_active_bear.ln := line.new(cisd_track_bear_index, cisd_track_bear_price, bar_index, cisd_track_bear_price, color=color.new(i_cisd_bear_color, 40))
            cisd_active_bear.start_index := not na(cisd_last_pl_index) ? cisd_last_pl_index : bar_index
            cisd_active_bear.start_price := not na(cisd_last_pl_price) ? cisd_last_pl_price : low
            cisd_active_bear.broken := false
        if cisd_active_bull.active and bar_index - cisd_active_bull.ln.get_x1() <= i_cisd_max_validity
            cisd_active_bull.ln.set_x2(bar_index)
            if close < cisd_active_bull.ln.get_y2()
                if bar_index - cisd_active_bull.ln.get_x1() >= i_cisd_min_duration
                    cisd_active_bull.ln.set_color(i_cisd_bear_color)
                    if cisd_trend == -1
                        cisd_active_bull.ln.set_style(line.style_dashed)
                    cisd_active_bull.active := false
                    cisd_active_bull.broken := true
                    cisd_trend := -1
                    x = int(math.ceil(math.avg(cisd_active_bull.ln.get_x1(), bar_index)))
                    label.new(x, cisd_active_bull.ln.get_y2(), style=label.style_label_up, textcolor=i_cisd_bear_color, text='CISD', size=cisd_text_size, color=color.new(color.white, 100))
                else
                    cisd_active_bull.active := false
                    cisd_active_bull.ln.delete()
            else if cisd_active_bull.active
                cisd_active_bull.active := false
                cisd_active_bull.ln.delete()
        if cisd_active_bear.active and bar_index - cisd_active_bear.ln.get_x1() <= i_cisd_max_validity
            cisd_active_bear.ln.set_x2(bar_index)
            if close > cisd_active_bear.ln.get_y2()
                if bar_index - cisd_active_bear.ln.get_x1() >= i_cisd_min_duration
                    cisd_active_bear.ln.set_color(i_cisd_bull_color)
                    if cisd_trend == 1
                        cisd_active_bear.ln.set_style(line.style_dashed)
                    cisd_active_bear.active := false
                    cisd_active_bear.broken := true
                    cisd_trend := 1
                    x = int(math.ceil(math.avg(cisd_active_bear.ln.get_x1(), bar_index)))
                    label.new(x, cisd_active_bear.ln.get_y2(), style=label.style_label_down, textcolor=i_cisd_bull_color, text='CISD', color=color.new(color.white, 100), size=cisd_text_size)
                else
                    cisd_active_bear.active := false
                    cisd_active_bear.ln.delete()
            else if cisd_active_bear.active
                cisd_active_bear.active := false
                cisd_active_bear.ln.delete()
var float confirmedBullishIFVGLevel = na
var float confirmedBearishIFVGLevel = na
isBullishIFVG_simple = low[2] > high[0] and low < low[2] and close > low[2]
isBearishIFVG_simple = high[2] < low[0] and high > high[2] and close < high[2]
if isBullishIFVG_simple
    confirmedBullishIFVGLevel := low[2]
if isBearishIFVG_simple
    confirmedBearishIFVGLevel := high[2]
f_detect_smt() =>
    [corr_h, corr_l] = request.security(i_corr_asset_ticker, timeframe.period, [high, low])
    main_higher_high = high > high[1]
    corr_lower_high = corr_h < corr_h[1]
    main_lower_low = low < low[1]
    corr_higher_low = corr_l > corr_l[1]
    is_bearish_smt = main_higher_high and corr_lower_high
    is_bullish_smt = main_lower_low and corr_higher_low
    [is_bullish_smt, is_bearish_smt]
[isBullishSMT, isBearishSMT] = f_detect_smt()
isAnySMT = isBullishSMT or isBearishSMT

// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
// SECTION 4: STATE MACHINE & STRATEGY LOGIC
// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████

// --- DEFINITIVE FIX v3.5: Complete ground-up rewrite of the State Machine and all Strategy Logic ---

// 1. Determine the current state based on time and reset flags accordingly.
if inAnyKZ
    // If we just entered a Killzone from a STANDBY state, switch to HUNTING and reset all persistent strategy flags.
    if protocolStatus[1] == S_STANDBY
        protocolStatus := S_HUNTING
        mrev_event1_inducement := false
        mrev_event2_reversal_confirm := false
        event1_manipulation := false
        event2_structure_break := false
        event3_htf_poi_return := false
        event4_ltf_confirmation := false
        sb_event1_sweep := false
        sb_event2_fvg := false
        activeKillzone := "None" // Force re-evaluation of the active killzone
        activeStrategy := "None"
    // If a trade was ARMED on the previous bar, the setup is complete. Reset status to HUNTING for the next potential setup.
    else if protocolStatus[1] == S_ARMED
        protocolStatus := S_HUNTING
        mrev_event1_inducement := false
        mrev_event2_reversal_confirm := false
        event1_manipulation := false
        event2_structure_break := false
        event3_htf_poi_return := false
        event4_ltf_confirmation := false
        sb_event1_sweep := false
        sb_event2_fvg := false
else
    // If we are outside any killzone, always be in STANDBY.
    protocolStatus := S_STANDBY
    activeKillzone := "None"
    activeStrategy := "None"
        
// 2. Determine active strategy ONLY when HUNTING for the first time in a session.
if protocolStatus == S_HUNTING and activeKillzone == "None"
    if inMidnightKZ
        activeKillzone := "Midnight"
        activeStrategy := i_midnight_strategy
    else if inLondonKZ
        activeKillzone := "London"
        activeStrategy := i_london_strategy
    else if inNewYorkKZ
        activeKillzone := "New York"
        activeStrategy := i_ny_strategy

// 3. Main Strategy Logic execution block.
if inAnyKZ and activeStrategy != O_OFF and protocolStatus != S_ARMED
    
    // --- Strategy Module C: "The Midnight Reversal" (Rewritten Logic) ---
    if activeStrategy == O_MIDNIGHT
        // Step 1: Hunt for Inducement (E1)
        if not mrev_event1_inducement[1] // Only look for E1 if it wasn't confirmed on the PREVIOUS bar
            is_inducement = (htfBias == "BULLISH" and ta.change(cisd_trend) and cisd_trend == -1) or (htfBias == "BEARISH" and ta.change(cisd_trend) and cisd_trend == 1)
            if is_inducement
                mrev_event1_inducement := true
                protocolStatus := S_CONFIRMING
                isBullishSignal := htfBias == "BULLISH"
        
        // Step 2: Hunt for Reversal (E2) only if E1 was confirmed on the PREVIOUS bar
        else if mrev_event1_inducement[1]
            is_reversal = (isBullishSignal and ((ta.change(cisd_trend) and cisd_trend == 1) or isBullish_ICHoch)) or (not isBullishSignal and ((ta.change(cisd_trend) and cisd_trend == -1) or isBearish_ICHoch))
            if is_reversal
                mrev_event2_reversal_confirm := true
                protocolStatus := S_ARMED
                entryPrice := close
                stopLossPrice := isBullishSignal ? recentSwingLowForSL : recentSwingHighForSL
                signalBarIndex := bar_index
                armedTrigger += 1

    // --- Strategy Module A: "The Core SMC Model" (Rewritten Logic) ---
    if activeStrategy == O_CORE
        // Step 1: Manipulation (E1)
        if not event1_manipulation[1]
            if isAnyLiquiditySweep or isAnySMT
                event1_manipulation := true
                protocolStatus := S_CONFIRMING
        
        // Step 2: Structure Break (E2)
        else if event1_manipulation[1] and not event2_structure_break[1]
            if isBullishMSS or isBearishMSS or isBullishBOS or isBearishBOS
                event2_structure_break := true
                isBullishSignal := isBullishMSS or isBullishBOS

        // Step 3: Return to POI (E3)
        else if event2_structure_break[1] and not event3_htf_poi_return[1]
            bool bullish_poi_return = false
            bool bearish_poi_return = false
            if isBullishSignal and lowBlock.size() > 0
                bullish_poi_return := low <= lowBlock.last().get_top()
            else if not isBullishSignal and highBlock.size() > 0
                bearish_poi_return := high >= highBlock.last().get_bottom()
            if bullish_poi_return or bearish_poi_return
                event3_htf_poi_return := true

        // Step 4: LTF Confirmation (E4) -> ARMED
        else if event3_htf_poi_return[1]
            if (isBullishSignal and isBullishIFVG_simple) or (not isBullishSignal and isBearishIFVG_simple)
                event4_ltf_confirmation := true
                protocolStatus := S_ARMED
                entryPrice := isBullishSignal ? confirmedBullishIFVGLevel : confirmedBearishIFVGLevel
                stopLossPrice := isBullishSignal ? recentSwingLowForSL : recentSwingHighForSL
                signalBarIndex := bar_index
                armedTrigger += 1

    // --- Strategy Module B: "ICT Silver Bullet" (Rewritten Logic) ---
    if activeStrategy == O_SILVER
        // Step 1: Liquidity Sweep (E1)
        if not sb_event1_sweep[1]
            if isAnyLiquiditySweep
                sb_event1_sweep := true
                protocolStatus := S_CONFIRMING
                isBullishSignal := low < pdl or low < asiaLow
        
        // Step 2: Displacement FVG (E2) -> ARMED
        else if sb_event1_sweep[1]
            [currentFVGUp, _] = fvg(3)
            [currentFVGDn, _] = fvg(-3)
            if (isBullishSignal and currentFVGUp.size() > 0) or (not isBullishSignal and currentFVGDn.size() > 0)
                sb_event2_fvg := true
                protocolStatus := S_ARMED
                if isBullishSignal and currentFVGUp.size() > 0
                    entryPrice := currentFVGUp.last().get_bottom()
                else if not isBullishSignal and currentFVGDn.size() > 0
                    entryPrice := currentFVGDn.last().get_top()
                stopLossPrice := isBullishSignal ? recentSwingLowForSL : recentSwingHighForSL
                signalBarIndex := bar_index
                armedTrigger += 1

// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
// SECTION 5: ON-CHART DASHBOARD & VISUALS
// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
// ... (This entire section is unchanged and correct) ...
var table dashboard = table.new(position.top_right, 2, 13, bgcolor=c_dashboard_bg, border_color=c_dashboard_border, frame_color=c_dashboard_border, border_width=2, frame_width=2)
nyHour = hour(timenow, "America/New_York")
nyMinute = minute(timenow, "America/New_York")
calculateTimeDifference(timestamp1, timestamp2) =>
    timeDifference = timestamp2 - timestamp1
    hours = math.floor(timeDifference / 3600000)
    minutes = math.floor((timeDifference % 3600000) / 60000)
    [hours, minutes]
dayAdjustment = (hour(timenow, "America/New_York") < 2) ? dayofmonth(timenow) + 1 : dayofmonth(timenow)
timeIsInRange(startHour, startMinute, endHour, endMinute) => (nyHour > startHour or (nyHour == startHour and nyMinute >= startMinute)) and (nyHour < endHour or (nyHour == endHour and nyMinute <= endMinute))
[chartcol, timetilchange, stringCol, stringCol2] = switch
    timeIsInRange(9, 30, 16, 0) =>
        [#f24968, timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 16, 0, 0), "New York", "Asia"]
    timeIsInRange(20, 0, 2, 0) =>
        [#14D990, timestamp("America/New_York", year(timenow), month(timenow), dayAdjustment, 2, 0, 0), "Asia", "London"]
    timeIsInRange(3, 0, 11, 30) =>
        [#F2B807, timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 11, 30, 0), "London", "New York"]
    =>
        [color.gray, int(na), "Dead Zone", (nyHour > 16 or nyHour < 3) ? "London" : (nyHour >= 11 and nyHour < 20) ? "Asia" : "New York"]
[hours, minutes] = calculateTimeDifference(timenow, timetilchange)
timetilchange2 = switch
    timeIsInRange(9, 30, 16, 0) =>
        timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 20, 0, 0)
    timeIsInRange(20, 0, 2, 0) =>
        timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 3, 0, 0)
    timeIsInRange(3, 0, 11, 30) =>
        timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 9, 30, 0)
    =>
        na
if na(timetilchange2)
    timetilchange2 := switch
        nyHour < 9 or (nyHour == 9 and nyMinute < 30) =>
            timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 9, 30, 0)
        nyHour < 20 or (nyHour >= 16 and nyHour < 20) =>
            timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 20, 0, 0)
        nyHour < 3 or (nyHour >= 2 and nyHour < 3) =>
            timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), 3, 0, 0)
        =>
            na
[hours2, minutes2] = calculateTimeDifference(timenow, timetilchange2)

if barstate.islast
    table.cell(dashboard, 0, 0, "APEX PROTOCOL", text_color=color.yellow, text_size=size.normal, text_halign=text.align_left)
    table.merge_cells(dashboard, 0, 0, 1, 0)
    table.cell(dashboard, 0, 1, "Status:", text_color=c_dashboard_header, text_halign=text.align_left)
    table.cell(dashboard, 1, 1, protocolStatus, text_color=protocolStatus == S_ARMED ? c_dashboard_status_armed : c_dashboard_status_other, text_halign=text.align_left, text_size=size.normal)
    table.cell(dashboard, 0, 2, "HTF Bias:", text_color=c_dashboard_header, text_halign=text.align_left)
    table.cell(dashboard, 1, 2, htfBias, text_color=htfBias == "BULLISH" ? c_dashboard_bias_bull : c_dashboard_bias_bear, text_halign=text.align_left)
    table.cell(dashboard, 0, 3, "Session:", text_color=c_dashboard_header, text_halign=text.align_left)
    table.cell(dashboard, 1, 3, stringCol, text_color=c_dashboard_text)
    table.cell(dashboard, 0, 4, "Session Close:", text_color=c_dashboard_header, text_halign=text.align_left)
    table.cell(dashboard, 1, 4, stringCol != "Dead Zone" ? str.tostring(hours) + "h " + str.tostring(minutes) + "m" : "Dead Zone", text_color=c_dashboard_text)
    table.cell(dashboard, 0, 5, "Next Session:", text_color=c_dashboard_header, text_halign=text.align_left)
    table.cell(dashboard, 1, 5, stringCol2, text_color=c_dashboard_text)
    table.cell(dashboard, 0, 6, "Next Session Open:", text_color=c_dashboard_header, text_halign=text.align_left)
    table.cell(dashboard, 1, 6, str.tostring(hours2) + "h:" + str.tostring(minutes2) + "m", text_color=c_dashboard_text)
    table.cell(dashboard, 0, 7, " ")
    table.merge_cells(dashboard, 0, 7, 1, 7)
    table.cell(dashboard, 0, 8, "▼ " + activeStrategy + " CHECKLIST", text_color=c_dashboard_checklist_header, text_size=size.small, text_halign=text.align_left)
    table.merge_cells(dashboard, 0, 8, 1, 8)
    if activeStrategy == O_MIDNIGHT
        table.cell(dashboard, 0, 9, (mrev_event1_inducement ? CHECK : NO_CHECK) + " E1: Inducement Confirmed", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 9, 1, 9)
        table.cell(dashboard, 0, 10, (mrev_event2_reversal_confirm ? CHECK : NO_CHECK) + " E2: Reversal Confirmed", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 10, 1, 10)
    else if activeStrategy == O_CORE
        table.cell(dashboard, 0, 9, (event1_manipulation ? CHECK : NO_CHECK) + " E1: Manipulation", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 9, 1, 9)
        table.cell(dashboard, 0, 10, (event2_structure_break ? CHECK : NO_CHECK) + " E2: Structure Break", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 10, 1, 10)
        table.cell(dashboard, 0, 11, (event3_htf_poi_return ? CHECK : NO_CHECK) + " E3: Return to HTF POI", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 11, 1, 11)
        table.cell(dashboard, 0, 12, (event4_ltf_confirmation ? CHECK : NO_CHECK) + " E4: LTF Confirmation", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 12, 1, 12)
    else if activeStrategy == O_SILVER
        table.cell(dashboard, 0, 9, (sb_event1_sweep ? CHECK : NO_CHECK) + " E1: Liquidity Sweep", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 9, 1, 9)
        table.cell(dashboard, 0, 10, (sb_event2_fvg ? CHECK : NO_CHECK) + " E2: Displacement FVG", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 10, 1, 10)
    else
        table.cell(dashboard, 0, 9, "No active strategy in this Killzone.", text_color=c_dashboard_checklist_text, text_halign=text.align_left, text_size=size.small)
        table.merge_cells(dashboard, 0, 9, 1, 9)

nyHour2 = hour(time, "America/New_York")
nyMinute2 = minute(time, "America/New_York")
timeIsInRange2(startHour, startMinute, endHour, endMinute) =>
    if endHour >= startHour
        (nyHour2 > startHour or (nyHour2 == startHour and nyMinute2 >= startMinute)) and (nyHour2 < endHour or (nyHour2 == endHour and nyMinute2 <= endMinute))
    else
        (nyHour2 > startHour or (nyHour2 == startHour and nyMinute2 >= startMinute)) or (nyHour2 < endHour or (nyHour2 == endHour and nyMinute2 <= endMinute))
bgcolor(timeIsInRange2(9, 30, 16, 0) ? color.new(i_ny_col, i_session_transparency) : na)
bgcolor(timeIsInRange2(20, 0, 2, 0) ? color.new(i_asia_col, i_session_transparency) : na)
bgcolor(timeIsInRange2(3, 0, 11, 30) ? color.new(i_london_col, i_session_transparency) : na)
        
f_draw_trade_visuals(entry, sl, tp, isBull) =>
    risk_distance = math.abs(entry - sl)
    if not na(risk_distance) and risk_distance > 0
        line.new(signalBarIndex, entry, bar_index + 20, entry, color=c_entry, width=2)
        line.new(signalBarIndex, sl, bar_index + 20, sl, color=c_stop_loss, style=line.style_dashed, width=1)
        line.new(signalBarIndex, tp, bar_index + 20, tp, color=c_take_profit, style=line.style_dashed, width=1)
        label.new(signalBarIndex, entry, " Entry", color=color.new(c_entry, 100), textcolor=c_entry, style=label.style_label_right)
        label.new(signalBarIndex, sl, " SL", color=color.new(c_stop_loss, 100), textcolor=c_stop_loss, style=label.style_label_right)
        label.new(signalBarIndex, tp, " TP", color=color.new(c_take_profit, 100), textcolor=c_take_profit, style=label.style_label_right)
if protocolStatus == S_ARMED and bar_index == signalBarIndex
    riskDistance = math.abs(entryPrice - stopLossPrice)
    if isBullishSignal
        takeProfitPrice := entryPrice + (riskDistance * i_rr_ratio)
    else
        takeProfitPrice := entryPrice - (riskDistance * i_rr_ratio)
    if barstate.islast
        f_draw_trade_visuals(entryPrice, stopLossPrice, takeProfitPrice, isBullishSignal)
if protocolStatus == S_ARMED and not na(signalBarIndex) and barstate.islast
    f_draw_trade_visuals(entryPrice, stopLossPrice, takeProfitPrice, isBullishSignal)

// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████
// SECTION 6: ALERTING MECHANISM
// ██████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████

if protocolStatus == S_ARMED and ta.change(armedTrigger)
    alert(str.format("APEX: {0} '{1}' {2} Signal! Entry: {3}, SL: {4}, TP: {5}", activeKillzone, activeStrategy, isBullishSignal ? "BUY" : "SELL", str.tostring(entryPrice, '#.#####'), str.tostring(stopLossPrice, '#.#####'), str.tostring(takeProfitPrice, '#.#####')), alert.freq_once_per_bar_close)


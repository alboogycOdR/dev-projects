//@version=5
library("AuthLib", true, true)
//correct category
// --- USER DATABASE ---
// Note: Moved inside function to avoid global scope issues in libraries

export _isUserAuthorized(string currentUsername) =>
    // Define authorized users inside the function (library requirement)
    authorizedUsers = array.from("nuburo", "Reniersauls7")
    array.includes(authorizedUsers, currentUsername)

export type DrawingData
    box[]   kzone1Boxes
    box[]   kzone2Boxes
    box[]   kzone3Boxes
    box[]   kzone4Boxes
    box[]   kzone5Boxes
    box[]   kzone6Boxes
    label[] kzone1Labels
    label[] kzone2Labels
    label[] kzone3Labels
    label[] kzone4Labels
    label[] kzone5Labels
    label[] kzone6Labels
    line[]  kzone1TrendLines
    line[]  kzone2TrendLines
    line[]  kzone3TrendLines
    line[]  kzone4TrendLines
    line[]  kzone5TrendLines
    line[]  kzone6TrendLines
    label[] kzone1PriceLabels
    label[] kzone2PriceLabels
    label[] kzone3PriceLabels
    label[] kzone4PriceLabels
    label[] kzone5PriceLabels
    label[] kzone6PriceLabels

export createDrawingData() =>
    DrawingData.new(        array.new_box(), array.new_box(), array.new_box(), array.new_box(), array.new_box(), array.new_box(),        array.new_label(), array.new_label(), array.new_label(), array.new_label(), array.new_label(), array.new_label(),        array.new_line(),  array.new_line(),  array.new_line(),  array.new_line(),  array.new_line(),  array.new_line(),        array.new_label(), array.new_label(), array.new_label(), array.new_label(), array.new_label(), array.new_label()    )

export getSessionKey(string tz, string currentUsername) =>
    if _isUserAuthorized(currentUsername)
        year(time, tz) * 10000 + month(time, tz) * 100 + dayofmonth(time, tz)
    else
        na

export drawKillzoneSessions(DrawingData data, string tz, array<string> killzoneLabels_, array<int> killzoneStartH, array<int> killzoneStartM, array<int> killzoneEndH, array<int> killzoneEndM, int lookbackDays, color killzoneColor, color extKillzoneColor, color killzoneLabelColor, string killzoneLabelSize, color trendLineColor, int trendLineWidth, color trendPriceLabelColor, color trendPriceLabelTextColor, string trendPriceLabelSize, string currentUsername) =>
    // guard unauthorized
    if not _isUserAuthorized(currentUsername)
        na
    // session arrays
    var float[] sessionOpenPrices = array.new_float(6, na)
    var int[]   lastSessionKeys   = array.new_int(6, na)
    var float[] sessionHighs      = array.new_float(6, na)
    var float[] sessionLows       = array.new_float(6, na)
    // loop killzones
    for i = 0 to 5
        lbl  = array.get(killzoneLabels_, i)
        sH   = array.get(killzoneStartH, i)
        sM   = array.get(killzoneStartM, i)
        eH   = array.get(killzoneEndH, i)
        eM   = array.get(killzoneEndM, i)
        hNY  = hour(time, tz)
        mNY  = minute(time, tz)
        currentSessionKey = getSessionKey(tz, currentUsername)
        // new session?
        isNewSession = hNY == sH and mNY == sM and (na(array.get(lastSessionKeys, i)) or currentSessionKey != array.get(lastSessionKeys, i))
        if isNewSession
            array.set(sessionOpenPrices, i, open)
            array.set(lastSessionKeys, i, currentSessionKey)
            array.set(sessionHighs, i, high)
            array.set(sessionLows, i, low)
        else
            // update highs/lows
            if (hNY > sH or (hNY == sH and mNY >= sM)) and (hNY < eH or (hNY == eH and mNY < eM))
                array.set(sessionHighs, i, na(array.get(sessionHighs, i)) ? high : math.max(array.get(sessionHighs, i), high))
                array.set(sessionLows, i, na(array.get(sessionLows, i)) ? low  : math.min(array.get(sessionLows, i), low))
        // end session?
        if hNY == eH and mNY == eM and not na(array.get(sessionHighs, i)) and not na(array.get(sessionLows, i))
            boxes   = i==0 ? data.kzone1Boxes   : i==1 ? data.kzone2Boxes   : i==2 ? data.kzone3Boxes   : i==3 ? data.kzone4Boxes   : i==4 ? data.kzone5Boxes   : data.kzone6Boxes
            labels  = i==0 ? data.kzone1Labels  : i==1 ? data.kzone2Labels  : i==2 ? data.kzone3Labels  : i==3 ? data.kzone4Labels  : i==4 ? data.kzone5Labels  : data.kzone6Labels
            tlines  = i==0 ? data.kzone1TrendLines : i==1 ? data.kzone2TrendLines : i==2 ? data.kzone3TrendLines : i==3 ? data.kzone4TrendLines : i==4 ? data.kzone5TrendLines : data.kzone6TrendLines
            plabels = i==0 ? data.kzone1PriceLabels: i==1 ? data.kzone2PriceLabels: i==2 ? data.kzone3PriceLabels: i==3 ? data.kzone4PriceLabels: i==4 ? data.kzone5PriceLabels: data.kzone6PriceLabels
            // trim old
            if array.size(boxes) > lookbackDays
                box.delete(array.shift(boxes))
                label.delete(array.shift(labels))
            if array.size(tlines) > lookbackDays
                line.delete(array.shift(tlines))
                label.delete(array.shift(plabels))
            // draw
            sessStart = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), sH, sM)
            sessEnd   = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), eH, eM)
            isExt     = lbl == "714AM-EXT" or lbl == "714AFTERNOON-EXT" or lbl == "ny-open-ext"
            boxColor  = isExt ? extKillzoneColor : killzoneColor
            b         = box.new(sessStart, array.get(sessionHighs, i), sessEnd, array.get(sessionLows, i), xloc=xloc.bar_time, bgcolor=boxColor, border_color=boxColor)
            labelY    = isExt ? array.get(sessionLows, i) : array.get(sessionHighs, i)
            labelStyle = isExt ? label.style_label_up : label.style_label_down
            l         = label.new(sessStart, labelY, lbl, xloc=xloc.bar_time, color=killzoneColor, style=labelStyle, textcolor=killzoneLabelColor, size=killzoneLabelSize)
            array.push(boxes, b)
            array.push(labels, l)
            
            // Create trendlines for main killzones (not extended ones)
            if not isExt
                // Only create trendlines for the first killzone in each pair
                if lbl == "714AM"
                    // 714AM trendline extends to end of 714AM-EXT (3:30 AM)
                    pairedEndH = 3
                    pairedEndM = 30
                    pairedEnd = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), pairedEndH, pairedEndM)
                    // Convert timestamps to bar indices for line.get_price compatibility
                    startBarIndex = bar_index - (time - sessStart) / (time - time[1])
                    endBarIndex = bar_index - (time - pairedEnd) / (time - time[1])
                    t = line.new(startBarIndex, array.get(sessionOpenPrices, i), endBarIndex, array.get(sessionOpenPrices, i), color=trendLineColor, width=trendLineWidth, xloc=xloc.bar_index)
                    pl2 = label.new(pairedEnd, array.get(sessionOpenPrices, i), str.tostring(array.get(sessionOpenPrices, i), format.mintick), xloc=xloc.bar_time, style=label.style_label_down, color=trendPriceLabelColor, textcolor=trendPriceLabelTextColor, size=trendPriceLabelSize)
                    array.push(tlines, t)
                    array.push(plabels, pl2)
                else if lbl == "714AFTERNOON"
                    // 714AFTERNOON trendline extends to end of 714AFTERNOON-EXT (12:00 PM)
                    pairedEndH = 12
                    pairedEndM = 0
                    pairedEnd = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), pairedEndH, pairedEndM)
                    // Convert timestamps to bar indices for line.get_price compatibility
                    startBarIndex = bar_index - (time - sessStart) / (time - time[1])
                    endBarIndex = bar_index - (time - pairedEnd) / (time - time[1])
                    t = line.new(startBarIndex, array.get(sessionOpenPrices, i), endBarIndex, array.get(sessionOpenPrices, i), color=trendLineColor, width=trendLineWidth, xloc=xloc.bar_index)
                    pl2 = label.new(pairedEnd, array.get(sessionOpenPrices, i), str.tostring(array.get(sessionOpenPrices, i), format.mintick), xloc=xloc.bar_time, style=label.style_label_down, color=trendPriceLabelColor, textcolor=trendPriceLabelTextColor, size=trendPriceLabelSize)
                    array.push(tlines, t)
                    array.push(plabels, pl2)
                else if lbl == "ny-open"
                    // ny-open trendline extends to end of ny-open-ext (9:00 AM)
                    pairedEndH = 9
                    pairedEndM = 0
                    pairedEnd = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), pairedEndH, pairedEndM)
                    // Convert timestamps to bar indices for line.get_price compatibility
                    startBarIndex = bar_index - (time - sessStart) / (time - time[1])
                    endBarIndex = bar_index - (time - pairedEnd) / (time - time[1])
                    t = line.new(startBarIndex, array.get(sessionOpenPrices, i), endBarIndex, array.get(sessionOpenPrices, i), color=trendLineColor, width=trendLineWidth, xloc=xloc.bar_index)
                    pl2 = label.new(pairedEnd, array.get(sessionOpenPrices, i), str.tostring(array.get(sessionOpenPrices, i), format.mintick), xloc=xloc.bar_time, style=label.style_label_down, color=trendPriceLabelColor, textcolor=trendPriceLabelTextColor, size=trendPriceLabelSize)
                    array.push(tlines, t)
                    array.push(plabels, pl2)
            
            // clear
            array.set(sessionHighs, i, na)
            array.set(sessionLows, i, na)
    // end of function

export isInKillzonePairFullRange(string tz, int pairIndex, string currentUsername) =>
    _isUserAuthorized(currentUsername) and (        pairIndex == 0 ? (hour(time, tz) == 1 or hour(time, tz) == 2 or (hour(time, tz) == 3 and minute(time, tz) < 30)) :        pairIndex == 1 ? (hour(time, tz) == 10 or hour(time, tz) == 11) :        pairIndex == 2 ? (hour(time, tz) == 7 or hour(time, tz) == 8) :        false    )

export processWickRejections(DrawingData data, string tz, bool showRejectionMarkers, color rejectionUpColor, color rejectionDownColor, string currentUsername) =>
    if not _isUserAuthorized(currentUsername) or not showRejectionMarkers
        [false, false]
    
    // Return values for plotting at top level
    bool upperRejection = false
    bool lowerRejection = false
    
    // Reset rejection flags for the current bar before any checks
    var bool[] upperRejections = array.new_bool(3, false)
    var bool[] lowerRejections = array.new_bool(3, false)
    
    for pair = 0 to 2
        array.set(upperRejections, pair, false)
        array.set(lowerRejections, pair, false)

    // Loop through each of the 3 killzone pairs
    for pair = 0 to 2
        // Check if the current bar's time falls within the active range for this pair
        if isInKillzonePairFullRange(tz, pair, currentUsername)
            // Select the correct trendline array based on the pair index
            // Pair 0 -> 714AM -> kzone1TrendLines
            // Pair 1 -> 714AFTERNOON -> kzone3TrendLines
            // Pair 2 -> ny-open -> kzone5TrendLines
            trendlineArray = pair == 0 ? data.kzone1TrendLines : pair == 1 ? data.kzone3TrendLines : data.kzone5TrendLines

            // Proceed only if a trendline for today has been created and stored in the array
            if array.size(trendlineArray) > 0
                // KEY FIX: Get only the MOST RECENT (current day's) trendline.
                // The latest trendline is always the last one added to the array.
                latestTrendline = array.get(trendlineArray, array.size(trendlineArray) - 1)
                
                if not na(latestTrendline)
                    // Get the price level of this specific trendline at the current bar's position
                    trendlinePrice = line.get_price(latestTrendline, bar_index)

                    if not na(trendlinePrice)
                        priceTolerance = syminfo.mintick * 10 // A small buffer for price interaction

                        // Check for Upper Wick Rejection:
                        // The high must interact with the line, but the candle body must stay below it.
                        if high >= trendlinePrice - priceTolerance and close < trendlinePrice and open < trendlinePrice
                            array.set(upperRejections, pair, true)
                            // Create visual marker for upper wick rejection (only if showRejectionMarkers is true)
                            if showRejectionMarkers
                                label.new(bar_index, high, "⏷", color=rejectionDownColor, style=label.style_label_down, textcolor=color.white, size=size.small)

                        // Check for Lower Wick Rejection:
                        // The low must interact with the line, but the candle body must stay above it.
                        if low <= trendlinePrice + priceTolerance and close > trendlinePrice and open > trendlinePrice
                            array.set(lowerRejections, pair, true)
                            // Create visual marker for lower wick rejection (only if showRejectionMarkers is true)
                            if showRejectionMarkers
                                label.new(bar_index, low, "⏶", color=rejectionUpColor, style=label.style_label_up, textcolor=color.white, size=size.small)

    // Set the overall rejection flags
    upperRejection := array.get(upperRejections, 0) or array.get(upperRejections, 1) or array.get(upperRejections, 2)
    lowerRejection := array.get(lowerRejections, 0) or array.get(lowerRejections, 1) or array.get(lowerRejections, 2)
    
    [upperRejection, lowerRejection]

export processSMCLogic(string obFvgTimeframe, bool showOB, int maxOBs, color obBullColor, color obBearColor, color obLabelTextColor, string obLabelSize, bool showFVG, int maxFVGs, color fvgBullColor, color fvgBearColor, color fvgLabelTextColor, string fvgLabelSize, bool showCISD, int maxCISD, color cisdBullColor, color cisdBearColor, color cisdLabelTextColor, string cisdLabelSize, bool showOBFVGInteractions, int maxOBFVGInteractions, color obFvgInteractionColor, string obFvgInteractionLabelSize, bool enableAlerts, string alertOBMitigatedMsg, string alertFVGFillMsg, string alertCISDMsg, string currentUsername) =>
    // Authorization check - control all functionality based on user authorization
    isAuthorized = _isUserAuthorized(currentUsername)
    
    // State arrays for SMC elements
    var box[] obBoxes = array.new_box()
    var label[] obLabels = array.new_label()
    var box[] fvgBoxes = array.new_box()
    var label[] fvgLabels = array.new_label()
    var label[] cisdLabels = array.new_label()
    var label[] interactionLabels = array.new_label()

    [f_open, f_high, f_low, f_close] = request.security(syminfo.tickerid, obFvgTimeframe, [open, high, low, close])

    // FVG DETECTION (only for authorized users)
    bullFVG = isAuthorized and showFVG and (f_low > f_high[2] and f_close[1] > f_open[1])
    bearFVG = isAuthorized and showFVG and (f_high < f_low[2] and f_close[1] < f_open[1])

    if bullFVG
        b = box.new(left=bar_index[2], top=f_low, right=bar_index, bottom=f_high[2], bgcolor=fvgBullColor, border_color=fvgBullColor)
        array.unshift(fvgBoxes, b)
        lbl = label.new(bar_index, f_low, "FVG", style=label.style_label_down, color=fvgBullColor, textcolor=fvgLabelTextColor, size=fvgLabelSize)
        array.unshift(fvgLabels, lbl)
        if array.size(fvgBoxes) > maxFVGs
            box.delete(array.pop(fvgBoxes))
            label.delete(array.pop(fvgLabels))

    if bearFVG
        b = box.new(left=bar_index[2], top=f_high, right=bar_index, bottom=f_low[2], bgcolor=fvgBearColor, border_color=fvgBearColor)
        array.unshift(fvgBoxes, b)
        lbl = label.new(bar_index, f_high, "FVG", style=label.style_label_up, color=fvgBearColor, textcolor=fvgLabelTextColor, size=fvgLabelSize)
        array.unshift(fvgLabels, lbl)
        if array.size(fvgBoxes) > maxFVGs
            box.delete(array.pop(fvgBoxes))
            label.delete(array.pop(fvgLabels))

    // OB DETECTION (only for authorized users)
    ob_bull = isAuthorized and showOB and (f_close[1] < f_open[1] and f_close > f_open and f_high[1] < f_high and f_low[1] < f_low)
    ob_bear = isAuthorized and showOB and (f_close[1] > f_open[1] and f_close < f_open and f_low[1] > f_low and f_high[1] > f_high)

    if ob_bull
        ob = box.new(left=bar_index, top=f_open, right=bar_index+10, bottom=f_low, bgcolor=obBullColor, border_color=obBullColor, xloc=xloc.bar_index)
        array.unshift(obBoxes, ob)
        lbl = label.new(bar_index, f_open, "OB", style=label.style_label_down, color=obBullColor, textcolor=obLabelTextColor, size=obLabelSize)
        array.unshift(obLabels, lbl)
        if array.size(obBoxes) > maxOBs
            box.delete(array.pop(obBoxes))
            label.delete(array.pop(obLabels))

    if ob_bear
        ob = box.new(left=bar_index, top=f_high, right=bar_index+10, bottom=f_open, bgcolor=obBearColor, border_color=obBearColor, xloc=xloc.bar_index)
        array.unshift(obBoxes, ob)
        lbl = label.new(bar_index, f_high, "OB", style=label.style_label_up, color=obBearColor, textcolor=obLabelTextColor, size=obLabelSize)
        array.unshift(obLabels, lbl)
        if array.size(obBoxes) > maxOBs
            box.delete(array.pop(obBoxes))
            label.delete(array.pop(obLabels))

    // OB/FVG INTERACTIONS (only for authorized users)
    if isAuthorized and showOBFVGInteractions
        // Check FVG interactions
        if array.size(fvgBoxes) > 0
            for i = 0 to array.size(fvgBoxes) - 1
                b = array.get(fvgBoxes, i)
                if not na(b)
                    t = box.get_top(b)
                    bot = box.get_bottom(b)
                    if ((high >= bot and low <= t) or (close >= bot and close <= t))
                        lbl = label.new(bar_index, t, "INT", color=obFvgInteractionColor, style=label.style_label_down, textcolor=color.black, size=obFvgInteractionLabelSize)
                        array.unshift(interactionLabels, lbl)
                        if array.size(interactionLabels) > maxOBFVGInteractions
                            label.delete(array.pop(interactionLabels))
                        if enableAlerts
                            alert(alertFVGFillMsg, alert.freq_once_per_bar_close)
        
        // Check OB interactions
        if array.size(obBoxes) > 0
            for i = 0 to array.size(obBoxes) - 1
                ob = array.get(obBoxes, i)
                if not na(ob)
                    t = box.get_top(ob)
                    bot = box.get_bottom(ob)
                    if ((high >= bot and low <= t) or (close >= bot and close <= t))
                        lbl = label.new(bar_index, t, "INT", color=obFvgInteractionColor, style=label.style_label_down, textcolor=color.black, size=obFvgInteractionLabelSize)
                        array.unshift(interactionLabels, lbl)
                        if array.size(interactionLabels) > maxOBFVGInteractions
                            label.delete(array.pop(interactionLabels))
                        if enableAlerts
                            alert(alertOBMitigatedMsg, alert.freq_once_per_bar_close)

    // CISD LOGIC (only for authorized users)
    if isAuthorized and showCISD
        swingLen = 10
        ph = ta.pivothigh(swingLen, 1)
        pl = ta.pivotlow(swingLen, 1)
        if not na(ph)
            lbl = label.new(bar_index-1, ph, "CISD", style=label.style_label_down, color=cisdBullColor, textcolor=cisdLabelTextColor, size=cisdLabelSize)
            array.unshift(cisdLabels, lbl)
            if array.size(cisdLabels) > maxCISD
                label.delete(array.pop(cisdLabels))
            if enableAlerts
                alert(alertCISDMsg, alert.freq_once_per_bar_close)
        if not na(pl)
            lbl = label.new(bar_index-1, pl, "CISD", style=label.style_label_up, color=cisdBearColor, textcolor=cisdLabelTextColor, size=cisdLabelSize)
            array.unshift(cisdLabels, lbl)
            if array.size(cisdLabels) > maxCISD
                label.delete(array.pop(cisdLabels))
            if enableAlerts
                alert(alertCISDMsg, alert.freq_once_per_bar_close)

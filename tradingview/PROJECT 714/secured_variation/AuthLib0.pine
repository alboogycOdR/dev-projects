
//@version=5
// @description Library with deeply integrated authentication for Pine Script indicators.
library("AuthLib", overlay=true)

// --- USER DATABASE ---
// This array holds the TradingView usernames of authorized users.
// It is now a constant array, which is allowed in libraries.
// You must update this list and republish the library (as a new version) 
// every time you add or remove a user.
string[] AUTHORIZED_USERS = array.from(
     "nuburo", // IMPORTANT: Replace with your actual TradingView username for testing!
     "Reniersauls7" // Add other authorized usernames here
     )

// --- INTERNAL AUTHENTICATION FUNCTION ---
// This function is private to the library and not accessible from outside.
// It checks if the provided username is in the AUTHORIZED_USERS list.
_isUserAuthorized(currentUsername) =>
    array.includes(AUTHORIZED_USERS, currentUsername)

// --- Killzone Session UDT ---
// UDTs for state management. These are passed by reference.
export type KillzoneState
    box[] kzone1Boxes
    box[] kzone2Boxes
    box[] kzone3Boxes
    box[] kzone4Boxes
    box[] kzone5Boxes
    box[] kzone6Boxes
    label[] kzone1Labels
    label[] kzone2Labels
    label[] kzone3Labels
    label[] kzone4Labels
    label[] kzone5Labels
    label[] kzone6Labels
    line[] kzone1TrendLines
    line[] kzone2TrendLines
    line[] kzone3TrendLines
    line[] kzone4TrendLines
    line[] kzone5TrendLines
    line[] kzone6TrendLines
    label[] kzone1PriceLabels
    label[] kzone2PriceLabels
    label[] kzone3PriceLabels
    label[] kzone4PriceLabels
    label[] kzone5PriceLabels
    label[] kzone6PriceLabels
    float[] sessionOpenPrices
    int[] lastSessionKeys
    float[] sessionHighs
    float[] sessionLows
    float[] todayOpenPrices

export newKillzoneState() =>
    KillzoneState.new(
      array.new_box(), array.new_box(), array.new_box(), array.new_box(), array.new_box(), array.new_box(),
      array.new<label>(), array.new<label>(), array.new<label>(), array.new<label>(), array.new<label>(), array.new<label>(),
      array.new_line(), array.new_line(), array.new_line(), array.new_line(), array.new_line(), array.new_line(),
      array.new<label>(), array.new<label>(), array.new<label>(), array.new<label>(), array.new<label>(), array.new<label>(),
      array.new_float(6, na), array.new_int(6, na), array.new_float(6, na), array.new_float(6, na), array.new_float(6, na)
    )

// --- Wick Rejection UDT ---
export type WickRejectionState
    bool[] upperRejections
    bool[] lowerRejections

export newWickRejectionState() =>
    WickRejectionState.new(
        array.new_bool(3, false),
        array.new_bool(3, false)
    )

// --- SMC State UDT ---
export type SmcState
    box[] obBoxes
    label[] obLabels
    box[] fvgBoxes
    label[] fvgLabels
    label[] cisdLabels
    label[] interactionLabels

export newSmcState() =>
    SmcState.new(
        array.new_box(), array.new<label>(),
        array.new_box(), array.new<label>(),
        array.new<label>(), array.new<label>()
    )

// --- EXPORTED CORE FUNCTIONS WITH BUILT-IN AUTHENTICATION ---

// --- Killzone Session Functions ---
export getSessionKey(string tz, string currentUsername) =>
    if _isUserAuthorized(currentUsername)
        year(time, tz) * 10000 + month(time, tz) * 100 + dayofmonth(time, tz)
    else
        na

export drawKillzoneSessions(KillzoneState state, string tz, array<string> killzoneLabels_, array<int> killzoneStartH, array<int> killzoneStartM, array<int> killzoneEndH, array<int> killzoneEndM, int lookbackDays, color killzoneColor, color extKillzoneColor, color killzoneLabelColor, string killzoneLabelSize, color trendLineColor, int trendLineWidth, color trendPriceLabelColor, color trendPriceLabelTextColor, string trendPriceLabelSize, string currentUsername) =>
    if _isUserAuthorized(currentUsername)
        for i = 0 to 5
            lbl = array.get(killzoneLabels_, i)
            sH = array.get(killzoneStartH, i)
            sM = array.get(killzoneStartM, i)
            eH = array.get(killzoneEndH, i)
            eM = array.get(killzoneEndM, i)
            hNY = hour(time, tz)
            mNY = minute(time, tz)
            currentSessionKey = getSessionKey(tz, currentUsername)

            isNewSession = (hNY == sH and mNY == sM and (na(array.get(state.lastSessionKeys, i)) or currentSessionKey != array.get(state.lastSessionKeys, i)))
            if isNewSession
                array.set(state.sessionOpenPrices, i, open)
                array.set(state.lastSessionKeys, i, currentSessionKey)
                array.set(state.sessionHighs, i, high)
                array.set(state.sessionLows, i, low)
            else if (hNY > sH or (hNY == sH and mNY >= sM)) and (hNY < eH or (hNY == eH and mNY < eM))
                array.set(state.sessionHighs, i, na(array.get(state.sessionHighs, i)) ? high : math.max(array.get(state.sessionHighs, i), high))
                array.set(state.sessionLows, i,  na(array.get(state.sessionLows, i))  ? low  : math.min(array.get(state.sessionLows, i), low))

            endSession = (hNY == eH and mNY == eM)
            if endSession and not na(array.get(state.sessionHighs, i)) and not na(array.get(state.sessionLows, i))
                boxes = i==0?state.kzone1Boxes:i==1?state.kzone2Boxes:i==2?state.kzone3Boxes:i==3?state.kzone4Boxes:i==4?state.kzone5Boxes:state.kzone6Boxes
                labels= i==0?state.kzone1Labels:i==1?state.kzone2Labels:i==2?state.kzone3Labels:i==3?state.kzone4Labels:i==4?state.kzone5Labels:state.kzone6Labels
                tlines= i==0?state.kzone1TrendLines:i==1?state.kzone2TrendLines:i==2?state.kzone3TrendLines:i==3?state.kzone4TrendLines:i==4?state.kzone5TrendLines:state.kzone6TrendLines
                plabels= i==0?state.kzone1PriceLabels:i==1?state.kzone2PriceLabels:i==2?state.kzone3PriceLabels:i==3?state.kzone4PriceLabels:i==4?state.kzone5PriceLabels:state.kzone6PriceLabels

                if array.size(boxes) > lookbackDays
                    box.delete(array.shift(boxes))
                    label.delete(array.shift(labels))
                if array.size(tlines) > lookbackDays
                    line.delete(array.shift(tlines))
                    label.delete(array.shift(plabels))

                sessStart = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), sH, sM)
                sessEnd   = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), eH, eM)
                
                isExt = lbl == "714AM-EXT" or lbl == "714AFTERNOON-EXT" or lbl == "ny-open-ext"
                boxColor = isExt ? extKillzoneColor : killzoneColor
                
                b = box.new(sessStart, array.get(state.sessionHighs, i), sessEnd, array.get(state.sessionLows, i), xloc=xloc.bar_time, bgcolor=boxColor, border_color=boxColor)
                
                labelY = isExt ? array.get(state.sessionLows, i) : array.get(state.sessionHighs, i)
                labelStyle = isExt ? label.style_label_up : label.style_label_down
                l = label.new(sessStart, labelY, lbl, xloc=xloc.bar_time, color=killzoneColor, style=labelStyle, textcolor=killzoneLabelColor, size=killzoneLabelSize)
                
                array.push(boxes, b)
                array.push(labels, l)
                
                if not isExt
                    // Only create trendlines for the first killzone in each pair
                    if lbl == "714AM"
                        // 714AM trendline extends to end of 714AM-EXT (3:30 AM)
                        pairedEndH = 3
                        pairedEndM = 30
                        pairedEnd = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), pairedEndH, pairedEndM)
                        // Convert timestamps to bar indices for line.get_price compatibility
                        startBarIndex = bar_index - (time - sessStart) / (time - time[1])
                        endBarIndex = bar_index - (time - pairedEnd) / (time - time[1])
                        t = line.new(startBarIndex, array.get(state.sessionOpenPrices, i), endBarIndex, array.get(state.sessionOpenPrices, i), color=trendLineColor, width=trendLineWidth, xloc=xloc.bar_index)
                        pl2 = label.new(pairedEnd, array.get(state.sessionOpenPrices, i), str.tostring(array.get(state.sessionOpenPrices, i), format.mintick), xloc=xloc.bar_time, style=label.style_label_down, color=color.new(color.white, 100), textcolor=color.black, size=trendPriceLabelSize)
                        array.push(tlines, t)
                        array.push(plabels, pl2)
                    else if lbl == "714AFTERNOON"
                        // 714AFTERNOON trendline extends to end of 714AFTERNOON-EXT (12:00 PM)
                        pairedEndH = 12
                        pairedEndM = 0
                        pairedEnd = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), pairedEndH, pairedM)
                        // Convert timestamps to bar indices for line.get_price compatibility
                        startBarIndex = bar_index - (time - sessStart) / (time - time[1])
                        endBarIndex = bar_index - (time - pairedEnd) / (time - time[1])
                        t = line.new(startBarIndex, array.get(state.sessionOpenPrices, i), endBarIndex, array.get(state.sessionOpenPrices, i), color=trendLineColor, width=trendLineWidth, xloc=xloc.bar_index)
                        pl2 = label.new(pairedEnd, array.get(state.sessionOpenPrices, i), str.tostring(array.get(state.sessionOpenPrices, i), format.mintick), xloc=xloc.bar_time, style=label.style_label_down, color=color.new(color.white, 100), textcolor=color.black, size=trendPriceLabelSize)
                        array.push(tlines, t)
                        array.push(plabels, pl2)
                    else if lbl == "ny-open"
                        // ny-open trendline extends to end of ny-open-ext (9:00 AM)
                        pairedEndH = 9
                        pairedEndM = 0
                        pairedEnd = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), pairedEndH, pairedEndM)
                        // Convert timestamps to bar indices for line.get_price compatibility
                        startBarIndex = bar_index - (time - sessStart) / (time - time[1])
                        endBarIndex = bar_index - (time - pairedEnd) / (time - time[1])
                        t = line.new(startBarIndex, array.get(state.sessionOpenPrices, i), endBarIndex, array.get(state.sessionOpenPrices, i), color=trendLineColor, width=trendLineWidth, xloc=xloc.bar_index)
                        pl2 = label.new(pairedEnd, array.get(state.sessionOpenPrices, i), str.tostring(array.get(state.sessionOpenPrices, i), format.mintick), xloc=xloc.bar_time, style=label.style_label_down, color=color.new(color.white, 100), textcolor=color.black, size=trendPriceLabelSize)
                        array.push(tlines, t)
                        array.push(plabels, pl2)

                array.set(state.sessionHighs, i, na)
                array.set(state.sessionLows, i, na)

        for i = 0 to 5
            sH = array.get(killzoneStartH, i)
            sM = array.get(killzoneStartM, i)
            hNY = hour(time, tz)
            mNY = minute(time, tz)
            if (hNY == sH and mNY == sM)
                array.set(state.todayOpenPrices, i, open)

// --- Wick Rejection Functions ---
export isInKillzonePairFullRange(string tz, int pairIndex, string currentUsername) =>
    if not _isUserAuthorized(currentUsername)
        false

    hNY = hour(time, tz)
    mNY = minute(time, tz)
    
    if pairIndex == 0  // 714AM pair (1:00 AM - 3:30 AM) - includes both 714AM and 714AM-EXT
        (hNY == 1 or hNY == 2 or (hNY == 3 and mNY < 30))
    else if pairIndex == 1  // 714AFTERNOON pair (10:00 AM - 12:00 PM) - includes both sessions
        (hNY == 10 or hNY == 11)
    else if pairIndex == 2  // ny-open pair (7:00 AM - 9:00 AM) - includes both sessions
        (hNY == 7 or hNY == 8)
    else
        false

export processWickRejections(WickRejectionState state, string tz, bool showRejectionMarkers, array<line> kzone1TrendLines, array<line> kzone3TrendLines, array<line> kzone5TrendLines, color rejectionUpColor, color rejectionDownColor, string currentUsername) =>
    // Return values for plotting at top level
    bool upperRejection = false
    bool lowerRejection = false
    
    if _isUserAuthorized(currentUsername) and showRejectionMarkers
        // Reset rejection flags for the current bar before any checks
        for pair = 0 to 2
            array.set(state.upperRejections, pair, false)
            array.set(state.lowerRejections, pair, false)

        // Loop through each of the 3 killzone pairs
        for pair = 0 to 2
            // Check if the current bar\"s time falls within the active range for this pair
            if isInKillzonePairFullRange(tz, pair, currentUsername)
                // Select the correct trendline array based on the pair index
                // Pair 0 -> 714AM -> kzone1TrendLines
                // Pair 1 -> 714AFTERNOON -> kzone3TrendLines
                // Pair 2 -> ny-open -> kzone5TrendLines
                trendlineArray = pair == 0 ? kzone1TrendLines : pair == 1 ? kzone3TrendLines : kzone5TrendLines

                // Proceed only if a trendline for today has been created and stored in the array
                if array.size(trendlineArray) > 0
                    // KEY FIX: Get only the MOST RECENT (current day\"s) trendline.
                    // The latest trendline is always the last one added to the array.
                    latestTrendline = array.get(trendlineArray, array.size(trendlineArray) - 1)
                    
                    if not na(latestTrendline)
                        // Get the price level of this specific trendline at the current bar\"s position
                        trendlinePrice = line.get_price(latestTrendline, bar_index)

                        if not na(trendlinePrice)
                            priceTolerance = syminfo.mintick * 10 // A small buffer for price interaction

                            // Check for Upper Wick Rejection:
                            // The high must interact with the line, but the candle body must stay below it.
                            if high >= trendlinePrice - priceTolerance and close < trendlinePrice and open < trendlinePrice
                                array.set(state.upperRejections, pair, true)

                            // Check for Lower Wick Rejection:
                            // The low must interact with the line, but the candle body must stay above it.
                            if low <= trendlinePrice + priceTolerance and close > trendlinePrice and open > trendlinePrice
                                array.set(state.lowerRejections, pair, true)

        // Set the overall rejection flags
        upperRejection := array.get(state.upperRejections, 0) or array.get(state.upperRejections, 1) or array.get(state.upperRejections, 2)
        lowerRejection := array.get(state.lowerRejections, 0) or array.get(state.lowerRejections, 1) or array.get(state.lowerRejections, 2)
    else
        upperRejection := false
        lowerRejection := false
    
    [upperRejection, lowerRejection]


// --- SMC Functions ---
export processSMCLogic(SmcState state, string obFvgTimeframe, bool showOB, int maxOBs, color obBullColor, color obBearColor, color obLabelTextColor, string obLabelSize, bool showFVG, int maxFVGs, color fvgBullColor, color fvgBearColor, color fvgLabelTextColor, string fvgLabelSize, bool showCISD, int maxCISD, color cisdBullColor, color cisdBearColor, color cisdLabelTextColor, string cisdLabelSize, bool showOBFVGInteractions, int maxOBFVGInteractions, color obFvgInteractionColor, string obFvgInteractionLabelSize, bool enableAlerts, string alertOBMitigatedMsg, string alertFVGFillMsg, string alertCISDMsg, string currentUsername) =>
    if not _isUserAuthorized(currentUsername)
        return

    [f_open, f_high, f_low, f_close] = request.security(syminfo.tickerid, obFvgTimeframe, [open, high, low, close])

    // FVG DETECTION
    bullFVG = showFVG and (f_low > f_high[2] and f_close[1] > f_open[1])
    bearFVG = showFVG and (f_high < f_low[2] and f_close[1] < f_open[1])

    if bullFVG
        b = box.new(left=bar_index[2], top=f_low, right=bar_index, bottom=f_high[2], bgcolor=fvgBullColor, border_color=fvgBullColor)
        array.unshift(state.fvgBoxes, b)
        lbl = label.new(bar_index, f_low, "FVG", style=label.style_label_down, color=fvgBullColor, textcolor=fvgLabelTextColor, size=fvgLabelSize)
        array.unshift(state.fvgLabels, lbl)
        if array.size(state.fvgBoxes) > maxFVGs
            box.delete(array.pop(state.fvgBoxes))
            label.delete(array.pop(state.fvgLabels))

    if bearFVG
        b = box.new(left=bar_index[2], top=f_high, right=bar_index, bottom=f_low[2], bgcolor=fvgBearColor, border_color=fvgBearColor)
        array.unshift(state.fvgBoxes, b)
        lbl = label.new(bar_index, f_high, "FVG", style=label.style_label_up, color=fvgBearColor, textcolor=fvgLabelTextColor, size=fvgLabelSize)
        array.unshift(state.fvgLabels, lbl)
        if array.size(state.fvgBoxes) > maxFVGs
            box.delete(array.pop(state.fvgBoxes))
            label.delete(array.pop(state.fvgLabels))

    // OB DETECTION
    ob_bull = showOB and (f_close[1] < f_open[1] and f_close > f_open and f_high[1] < f_high and f_low[1] < f_low)
    ob_bear = showOB and (f_close[1] > f_open[1] and f_close < f_open and f_low[1] > f_low and f_high[1] > f_high)

    if ob_bull
        ob = box.new(left=bar_index, top=f_open, right=bar_index+10, bottom=f_low, bgcolor=obBullColor, border_color=obBullColor, xloc=xloc.bar_index)
        array.unshift(state.obBoxes, ob)
        lbl = label.new(bar_index, f_open, "OB", style=label.style_label_down, color=obBullColor, textcolor=obLabelTextColor, size=obLabelSize)
        array.unshift(state.obLabels, lbl)
        if array.size(state.obBoxes) > maxOBs
            box.delete(array.pop(state.obBoxes))
            label.delete(array.pop(state.obLabels))

    if ob_bear
        ob = box.new(left=bar_index, top=f_high, right=bar_index+10, bottom=f_open, bgcolor=obBearColor, border_color=obBearColor, xloc=xloc.bar_index)
        array.unshift(state.obBoxes, ob)
        lbl = label.new(bar_index, f_high, "OB", style=label.style_label_up, color=obBearColor, textcolor=obLabelTextColor, size=obLabelSize)
        array.unshift(state.obLabels, lbl)
        if array.size(state.obBoxes) > maxOBs
            box.delete(array.pop(state.obBoxes))
            label.delete(array.pop(state.obLabels))

    // OB/FVG INTERACTIONS
    if showOBFVGInteractions
        // Check FVG interactions
        if array.size(state.fvgBoxes) > 0
            for i = 0 to array.size(state.fvgBoxes) - 1
                b = array.get(state.fvgBoxes, i)
                if not na(b)
                    t = box.get_top(b)
                    bot = box.get_bottom(b)
                    if ((high >= bot and low <= t) or (close >= bot and close <= t))
                        lbl = label.new(bar_index, t, "INT", color=obFvgInteractionColor, style=label.style_label_down, textcolor=color.black, size=obFvgInteractionLabelSize)
                        array.unshift(state.interactionLabels, lbl)
                        if array.size(state.interactionLabels) > maxOBFVGInteractions
                            label.delete(array.pop(state.interactionLabels))
                        if enableAlerts
                            alert(alertFVGFillMsg, alert.freq_once_per_bar_close)
        
        // Check OB interactions
        if array.size(state.obBoxes) > 0
            for i = 0 to array.size(state.obBoxes) - 1
                ob = array.get(state.obBoxes, i)
                if not na(ob)
                    t = box.get_top(ob)
                    bot = box.get_bottom(ob)
                    if ((high >= bot and low <= t) or (close >= bot and close <= t))
                        lbl = label.new(bar_index, t, "INT", color=obFvgInteractionColor, style=label.style_label_down, textcolor=color.black, size=obFvgInteractionLabelSize)
                        array.unshift(state.interactionLabels, lbl)
                        if array.size(state.interactionLabels) > maxOBFVGInteractions
                            label.delete(array.pop(state.interactionLabels))
                        if enableAlerts
                            alert(alertOBMitigatedMsg, alert.freq_once_per_bar_close)

    // CISD LOGIC
    if showCISD
        swingLen = 10
        ph = ta.pivothigh(swingLen, 1)
        pl = ta.pivotlow(swingLen, 1)
        if not na(ph)
            lbl = label.new(bar_index-1, ph, "CISD", style=label.style_label_down, color=cisdBullColor, textcolor=cisdLabelTextColor, size=cisdLabelSize)
            array.unshift(state.cisdLabels, lbl)
            if array.size(state.cisdLabels) > maxCISD
                label.delete(array.pop(state.cisdLabels))
            if enableAlerts
                alert(alertCISDMsg, alert.freq_once_per_bar_close)
        if not na(pl)
            lbl = label.new(bar_index-1, pl, "CISD", style=label.style_label_up, color=cisdBearColor, textcolor=cisdLabelTextColor, size=cisdLabelSize)
            array.unshift(state.cisdLabels, lbl)
            if array.size(state.cisdLabels) > maxCISD
                label.delete(array.pop(state.cisdLabels))
            if enableAlerts
                alert(alertCISDMsg, alert.freq_once_per_bar_close)



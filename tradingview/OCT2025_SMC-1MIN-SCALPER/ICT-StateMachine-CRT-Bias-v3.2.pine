//@version=5
indicator("ICT State Machine v3.2 [Targeted CRT Sweep]", overlay=true, max_labels_count=500, max_boxes_count=500, dynamic_requests=true)

// ════════════════════════════════════════════════════════════════════════════
// STATE MACHINE DEFINITIONS
// ════════════════════════════════════════════════════════════════════════════

// State Constants
STATE_AWAITING_BIAS = 0
STATE_AWAITING_MANIPULATION = 1  
STATE_AWAITING_MACRO = 2
STATE_AWAITING_SWEEP = 3
STATE_AWAITING_MSS = 4
STATE_AWAITING_CISD = 5
STATE_AWAITING_FVG = 6
STATE_AWAITING_RETRACEMENT = 7
STATE_READY_FOR_ENTRY = 8
STATE_IN_POSITION = 9
STATE_RESET = -1

// ════════════════════════════════════════════════════════════════════════════
// INPUTS - STATE CONFIGURATION
// ════════════════════════════════════════════════════════════════════════════

// State Enable/Disable Controls
enableHtfBias = input.bool(true, "★ Use 4-Hour CRT for Bias?", group="State Configuration")
enableAsianRange = input.bool(true, "1. Require Asian Range", group="State Configuration")
enableManipulation = input.bool(true, "2. Require Manipulation", group="State Configuration")
enableMacro = input.bool(true, "3. Require Macro Window", group="State Configuration")
enableSweep = input.bool(true, "4. Require Liquidity Sweep", group="State Configuration")
enableMSS = input.bool(true, "5. Require Market Structure Shift", group="State Configuration")
enableCISD = input.bool(true, "6. Require CISD", group="State Configuration")
enableFVG = input.bool(true, "7. Require Fair Value Gap", group="State Configuration")
enableRetracement = input.bool(true, "8. Require Retracement to FVG", group="State Configuration")

// Quick Presets
preset = input.string("Custom", "Quick Presets",     options=["Custom", "Full Sequence (All 8)", "Minimal (Sweep+FVG)", "No CISD/MSS", "Macro+Sweep Only"],     group="State Configuration")

// Display
showStateFlow = input.bool(true, "Show State Flow Labels", group="Display")
showStateTable = input.bool(true, "Show State Dashboard", group="Display")
showEntryZones = input.bool(true, "Show Entry Zones", group="Display")
showDebugInfo = input.bool(false, "Show Debug Info", group="Display")
showSkippedStates = input.bool(true, "Show Skipped States", group="Display")
showHistoricEvents = input.bool(false, "Show Historic Events (Last 7 Days)", group="Display")

// Sessions
asianSession = input.session("1900-0200", "Asian Session", group="Sessions")
londonSession = input.session("0200-0700", "London Session", group="Sessions")
nySession = input.session("0700-1200", "NY Session", group="Sessions")

// Macros
macro1 = input.session("0850-0910", "NY Pre-Open Macro (8:50-9:10)", group="Macros")
enableMacro1 = input.bool(true, "└─ Enable Pre-Open Macro", group="Macros")
macro2 = input.session("0950-1010", "NY Continuation Macro (9:50-10:10)", group="Macros")
enableMacro2 = input.bool(true, "└─ Enable Continuation Macro", group="Macros")
macro3 = input.session("1050-1110", "NY Close Macro (10:50-11:10)", group="Macros")
enableMacro3 = input.bool(true, "└─ Enable Close Macro", group="Macros")

// State Parameters
minAsianRange = input.float(0.2, "Min Asian Range %", minval=0.1, maxval=1.0, group="State Settings")
sweepTimeout = input.int(10, "Sweep Timeout (bars after macro)", minval=5, maxval=20, group="State Settings")
mssTimeout = input.int(5, "MSS Timeout (bars after sweep)", minval=3, maxval=10, group="State Settings")
cisdMinCandles = input.int(3, "Min CISD Candles", minval=2, maxval=5, group="State Settings")
fvgMinSize = input.float(0.1, "Min FVG Size (% of ATR)", minval=0.05, maxval=0.5, group="State Settings")
retracementTimeout = input.int(20, "Retracement Timeout (bars)", minval=10, maxval=50, group="State Settings")

// Risk Management
riskPercent = input.float(1.0, "Risk Per Trade %", minval=0.1, maxval=5.0, group="Risk")
accountBalance = input.float(10000, "Account Balance", minval=100, group="Risk")

// ════════════════════════════════════════════════════════════════════════════
// PRESET MANAGEMENT
// ════════════════════════════════════════════════════════════════════════════

// Apply presets (these override individual settings)
reqAsianRange = preset == "Full Sequence (All 8)" ? true :                 preset == "Minimal (Sweep+FVG)" ? false :                preset == "No CISD/MSS" ? true :                preset == "Macro+Sweep Only" ? false : enableAsianRange
reqManipulation = preset == "Full Sequence (All 8)" ? true : preset == "Minimal (Sweep+FVG)" ? false : preset == "No CISD/MSS" ? true : preset == "Macro+Sweep Only" ? false : enableManipulation
reqMacro = preset == "Full Sequence (All 8)" ? true : preset == "Minimal (Sweep+FVG)" ? false : preset == "No CISD/MSS" ? true : preset == "Macro+Sweep Only" ? true : enableMacro
reqSweep = preset == "Full Sequence (All 8)" ? true : preset == "Minimal (Sweep+FVG)" ? true : preset == "No CISD/MSS" ? true : preset == "Macro+Sweep Only" ? true : enableSweep
reqMSS = preset == "Full Sequence (All 8)" ? true :        preset == "Minimal (Sweep+FVG)" ? false :        preset == "No CISD/MSS" ? false :        preset == "Macro+Sweep Only" ? false : enableMSS
reqCISD = preset == "Full Sequence (All 8)" ? true : preset == "Minimal (Sweep+FVG)" ? false : preset == "No CISD/MSS" ? false : preset == "Macro+Sweep Only" ? false : enableCISD
reqFVG = preset == "Full Sequence (All 8)" ? true :        preset == "Minimal (Sweep+FVG)" ? true :        preset == "No CISD/MSS" ? true :        preset == "Macro+Sweep Only" ? false : enableFVG
reqRetracement = preset == "Full Sequence (All 8)" ? true :                preset == "Minimal (Sweep+FVG)" ? false :                preset == "No CISD/MSS" ? true :                preset == "Macro+Sweep Only" ? false : enableRetracement

// ════════════════════════════════════════════════════════════════════════════
// 4-HOUR CANDLE RANGE THEORY (CRT) BIAS
// ════════════════════════════════════════════════════════════════════════════

var string htfBias = "NEUTRAL"
var float crtSweepTargetHigh = na // MODIFICATION: Added variable to store the specific high to be swept.
var float crtSweepTargetLow = na  // MODIFICATION: Added variable to store the specific low to be swept.

if enableHtfBias
    refCandleHigh = request.security(syminfo.tickerid, "240", high[2], lookahead=barmerge.lookahead_on)
    refCandleLow = request.security(syminfo.tickerid, "240", low[2], lookahead=barmerge.lookahead_on)
    
    sweepCandleHigh = request.security(syminfo.tickerid, "240", high[1], lookahead=barmerge.lookahead_on)
    sweepCandleLow = request.security(syminfo.tickerid, "240", low[1], lookahead=barmerge.lookahead_on)

    if (sweepCandleLow < refCandleLow) and (sweepCandleHigh <= refCandleHigh)
        htfBias := "BULLISH"
        crtSweepTargetLow := sweepCandleLow // MODIFICATION: Store the 4H sweep candle's low as the target.
        crtSweepTargetHigh := na
    else if (sweepCandleHigh > refCandleHigh) and (sweepCandleLow >= refCandleLow)
        htfBias := "BEARISH"
        crtSweepTargetHigh := sweepCandleHigh // MODIFICATION: Store the 4H sweep candle's high as the target.
        crtSweepTargetLow := na
    else 
        htfBias := "NEUTRAL"
        crtSweepTargetHigh := na // MODIFICATION: Ensure targets are cleared if bias is neutral.
        crtSweepTargetLow := na
        
// ════════════════════════════════════════════════════════════════════════════
// STATE VARIABLES
// ════════════════════════════════════════════════════════════════════════════

// Core State Machine
var int currentState = STATE_AWAITING_BIAS
var int previousState = STATE_AWAITING_BIAS
var string biasDirection = "NEUTRAL"
var bool sequenceComplete = false
var int stateTimer = 0
var int barsInState = 0
var string[] skippedStates = array.new<string>()

// State-Specific Data
var float asianHigh = na
var float asianLow = na
var float asianRange = na
var float manipulationLevel = na
var string manipulationType = ""
var float sweepLevel = na
var int sweepBarIndex = na
var float mssLevel = na
var int mssBarIndex = na
var bool cisdActive = false
var int cisdCandles = 0
var float fvgHigh = na
var float fvgLow = na
var float fvgCE = na
var int fvgBarIndex = na
var float entryPrice = na
var float stopLoss = na
var float takeProfit1 = na
var float takeProfit2 = na

// Visual Elements
var box asianBox = na
var line manipulationLine = na
var line sweepLine = na
var line mssLine = na
var box fvgBox = na
var label stateLabel = na

// ════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ════════════════════════════════════════════════════════════════════════════

getNextState(int fromState) =>
    nextState = fromState
    if fromState == STATE_AWAITING_BIAS
        nextState := reqManipulation ? STATE_AWAITING_MANIPULATION : reqMacro ? STATE_AWAITING_MACRO : reqSweep ? STATE_AWAITING_SWEEP : reqMSS ? STATE_AWAITING_MSS : reqCISD ? STATE_AWAITING_CISD : reqFVG ? STATE_AWAITING_FVG : reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_MANIPULATION
        nextState := reqMacro ? STATE_AWAITING_MACRO : reqSweep ? STATE_AWAITING_SWEEP : reqMSS ? STATE_AWAITING_MSS : reqCISD ? STATE_AWAITING_CISD : reqFVG ? STATE_AWAITING_FVG : reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_MACRO
        nextState := reqSweep ? STATE_AWAITING_SWEEP : reqMSS ? STATE_AWAITING_MSS : reqCISD ? STATE_AWAITING_CISD : reqFVG ? STATE_AWAITING_FVG : reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_SWEEP
        nextState := reqMSS ? STATE_AWAITING_MSS : reqCISD ? STATE_AWAITING_CISD : reqFVG ? STATE_AWAITING_FVG : reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_MSS
        nextState := reqCISD ? STATE_AWAITING_CISD : reqFVG ? STATE_AWAITING_FVG : reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_CISD
        nextState := reqFVG ? STATE_AWAITING_FVG : reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_FVG
        nextState := reqRetracement ? STATE_AWAITING_RETRACEMENT : STATE_READY_FOR_ENTRY
    else if fromState == STATE_AWAITING_RETRACEMENT
        nextState := STATE_READY_FOR_ENTRY
    else if fromState == STATE_READY_FOR_ENTRY
        nextState := STATE_IN_POSITION
    nextState

recordSkippedStates(int fromState, int toState) =>
    if showSkippedStates
        if fromState == STATE_AWAITING_BIAS and toState > STATE_AWAITING_MANIPULATION and not reqManipulation
            array.push(skippedStates, "Manipulation")
        if toState > STATE_AWAITING_MACRO and not reqMacro
            array.push(skippedStates, "Macro")
        if toState > STATE_AWAITING_SWEEP and not reqSweep
            array.push(skippedStates, "Sweep")
        if toState > STATE_AWAITING_MSS and not reqMSS
            array.push(skippedStates, "MSS")
        if toState > STATE_AWAITING_CISD and not reqCISD
            array.push(skippedStates, "CISD")
        if toState > STATE_AWAITING_FVG and not reqFVG
            array.push(skippedStates, "FVG")
        if toState > STATE_AWAITING_RETRACEMENT and not reqRetracement
            array.push(skippedStates, "Retracement")

shouldShowVisuals() =>
    sevenDaysAgo = timestamp(year, month, dayofmonth, 0, 0) - 7 * 24 * 60 * 60 * 1000
    isCurrentDay = dayofmonth == dayofmonth(timenow) and month == month(timenow) and year == year(timenow)
    isWithinLast7Days = time >= sevenDaysAgo
    isCurrentDay or (showHistoricEvents and isWithinLast7Days)

// ════════════════════════════════════════════════════════════════════════════
// SESSION DETECTION (New York Time - EST/EDT)
// ════════════════════════════════════════════════════════════════════════════

inAsian = not na(time(timeframe.period, asianSession, "America/New_York"))
inLondon = not na(time(timeframe.period, londonSession, "America/New_York"))
inNY = not na(time(timeframe.period, nySession, "America/New_York"))
inMacro1 = enableMacro1 and not na(time(timeframe.period, macro1, "America/New_York"))
inMacro2 = enableMacro2 and not na(time(timeframe.period, macro2, "America/New_York"))
inMacro3 = enableMacro3 and not na(time(timeframe.period, macro3, "America/New_York"))
isInMacro = inMacro1 or inMacro2 or inMacro3

getCurrentMacro() =>
    if inMacro1
        "Pre-Open"
    else if inMacro2
        "Continuation"
    else if inMacro3
        "Close"
    else
        "None"

// ════════════════════════════════════════════════════════════════════════════
// STATE MACHINE EXECUTION
// ════════════════════════════════════════════════════════════════════════════

if enableHtfBias
    biasDirection := htfBias
if currentState != previousState
    barsInState := 0
    previousState := currentState
else
    barsInState += 1

if currentState == STATE_AWAITING_BIAS
    if reqAsianRange and not enableHtfBias
        if inAsian
            if na(asianHigh) or high > asianHigh
                asianHigh := high
            if na(asianLow) or low < asianLow
                asianLow := low
            asianRange := asianHigh - asianLow
        else if not inAsian and inAsian[1]
            if (asianHigh - asianLow) / close * 100 >= minAsianRange
                currentState := getNextState(STATE_AWAITING_BIAS)
                recordSkippedStates(STATE_AWAITING_BIAS, currentState)
                if showStateFlow and shouldShowVisuals()
                    label.new(bar_index, asianHigh, "→ Asian Range Set\nNext: " + str.tostring(currentState), style=label.style_label_down, color=color.blue, size=size.small)
    else
        currentState := getNextState(STATE_AWAITING_BIAS)
        if not reqAsianRange or enableHtfBias
            array.push(skippedStates, "Asian Range")

if currentState == STATE_AWAITING_MANIPULATION
    if inLondon and not enableHtfBias
        refHigh = reqAsianRange and not na(asianHigh) ? asianHigh : ta.highest(high, 50)
        refLow = reqAsianRange and not na(asianLow) ? asianLow : ta.lowest(low, 50)
        
        if high > refHigh
            manipulationLevel := high
            manipulationType := "UP"
            biasDirection := "BEARISH"
            currentState := getNextState(STATE_AWAITING_MANIPULATION)
            if showStateFlow and shouldShowVisuals()
                label.new(bar_index, manipulationLevel, "→ Manipulation UP\nBias: BEARISH", style=label.style_label_down, color=color.yellow, size=size.small)
        else if low < refLow
            manipulationLevel := low
            manipulationType := "DOWN"
            biasDirection := "BULLISH"
            currentState := getNextState(STATE_AWAITING_MANIPULATION)
            if showStateFlow and shouldShowVisuals()
                label.new(bar_index, manipulationLevel, "→ Manipulation DOWN\nBias: BULLISH", style=label.style_label_up, color=color.yellow, size=size.small)

if currentState == STATE_AWAITING_MACRO
    if inNY and isInMacro
        currentState := getNextState(STATE_AWAITING_MACRO)
        stateTimer := 0
        if showStateFlow and shouldShowVisuals()
            label.new(bar_index, high, "→ Macro Active: " + getCurrentMacro(), style=label.style_label_down, color=color.purple, size=size.small)
    else if not reqMacro
        currentState := getNextState(STATE_AWAITING_MACRO)

// STATE 4: LIQUIDITY SWEEP
if currentState == STATE_AWAITING_SWEEP
    stateTimer += 1
    
    // MODIFICATION: Redefined refLevel logic to prioritize specific CRT targets.
    refLevel = if enableHtfBias
        // If CRT bias is on, the ONLY valid target is the specific high/low from the 4H candle.
        if biasDirection == "BULLISH"
            crtSweepTargetLow
        else if biasDirection == "BEARISH"
            crtSweepTargetHigh
        else
            na
    else
        // Fallback to original logic if CRT is disabled.
        na(manipulationLevel) ? (biasDirection == "BULLISH" ? ta.lowest(low, 20) : ta.highest(high, 20)) : manipulationLevel

    sweepDetected = false
    
    if not na(refLevel) // Only proceed if we have a valid reference level.
        if biasDirection == "BULLISH"
            if low < refLevel and close > refLevel
                sweepLevel := low
                sweepBarIndex := bar_index
                sweepDetected := true
        else if biasDirection == "BEARISH"
            if high > refLevel and close < refLevel
                sweepLevel := high
                sweepBarIndex := bar_index
                sweepDetected := true
        else if biasDirection == "NEUTRAL"
            if low < refLevel and close > refLevel
                sweepLevel := low
                sweepBarIndex := bar_index
                sweepDetected := true
                biasDirection := "BULLISH"
            else if high > refLevel and close < refLevel
                sweepLevel := high
                sweepBarIndex := bar_index
                sweepDetected := true
                biasDirection := "BEARISH"
            
    if sweepDetected
        currentState := getNextState(STATE_AWAITING_SWEEP)
        stateTimer := 0
        if showStateFlow and shouldShowVisuals()
            label.new(bar_index, sweepLevel, "→ Sweep Detected", style=label.style_label_center, color=color.red, size=size.small)
            
    else if reqMacro and stateTimer > sweepTimeout
        currentState := STATE_RESET

if currentState == STATE_AWAITING_MSS
    stateTimer += 1
    mssDetected = false
    if biasDirection == "BULLISH"
        if close > ta.highest(high[1], 10)
            mssLevel := ta.highest(high[1], 10)
            mssBarIndex := bar_index
            mssDetected := true
    else if biasDirection == "BEARISH"
        if close < ta.lowest(low[1], 10)
            mssLevel := ta.lowest(low[1], 10)
            mssBarIndex := bar_index
            mssDetected := true
    if mssDetected
        currentState := getNextState(STATE_AWAITING_MSS)
        stateTimer := 0
        if showStateFlow and shouldShowVisuals()
            label.new(bar_index, mssLevel, "→ MSS Confirmed", style=label.style_label_center, color=color.green, size=size.small)
    else if stateTimer > mssTimeout
        currentState := STATE_RESET

detectCISD() =>
    bodies = array.new_float(cisdMinCandles, 0)
    allBullish = true
    allBearish = true
    for i = 0 to cisdMinCandles - 1
        array.set(bodies, i, math.abs(close[i] - open[i]))
        if close[i] <= open[i]
            allBullish := false
        if close[i] >= open[i]
            allBearish := false
    avgBody = array.avg(bodies)
    maxVariance = 0.0
    for bodySize in bodies
        maxVariance := math.max(maxVariance, avgBody > 0 ? math.abs(bodySize - avgBody) / avgBody * 100 : 0)
    maxVariance < 20 and ((biasDirection == "BULLISH" and allBullish) or (biasDirection == "BEARISH" and allBearish))

if currentState == STATE_AWAITING_CISD
    if detectCISD()
        cisdActive := true
        cisdCandles := cisdMinCandles
        currentState := getNextState(STATE_AWAITING_CISD)
        if showStateFlow and shouldShowVisuals()
            label.new(bar_index, close, "→ CISD Active (" + str.tostring(cisdCandles) + " candles)", style=label.style_label_center, color=color.purple, size=size.small)

if currentState == STATE_AWAITING_FVG
    atr = ta.atr(14)
    minGap = atr * fvgMinSize
    fvgDetected = false
    if biasDirection == "BULLISH" and low > high[2] and (low - high[2]) > minGap
        fvgHigh := low
        fvgLow := high[2]
        fvgCE := (low + high[2]) / 2
        fvgBarIndex := bar_index
        fvgDetected := true
    else if biasDirection == "BEARISH" and high < low[2] and (low[2] - high) > minGap
        fvgHigh := low[2]
        fvgLow := high
        fvgCE := (low[2] + high) / 2
        fvgBarIndex := bar_index
        fvgDetected := true
    if fvgDetected
        currentState := getNextState(STATE_AWAITING_FVG)
        stateTimer := 0
        if showStateFlow and shouldShowVisuals()
            label.new(bar_index, fvgCE, "→ FVG Created", style=label.style_label_center, color=color.orange, size=size.small)
        if showEntryZones and shouldShowVisuals()
            box.delete(fvgBox)
            fvgBox := box.new(bar_index, fvgHigh, bar_index + 50, fvgLow, bgcolor=biasDirection == "BULLISH" ? color.new(color.green, 90) : color.new(color.red, 90), border_color=biasDirection == "BULLISH" ? color.green : color.red)

if currentState == STATE_AWAITING_RETRACEMENT
    stateTimer += 1
    entryZoneHigh = reqFVG ? fvgHigh : sweepLevel
    entryZoneLow = reqFVG ? fvgLow : sweepLevel
    retracementDetected = false
    if biasDirection == "BULLISH"
        retracementDetected := low <= entryZoneHigh and (reqFVG ? low >= entryZoneLow : low < high[1])
        entryPrice := close
    else if biasDirection == "BEARISH"
        retracementDetected := high >= entryZoneLow and (reqFVG ? high <= entryZoneHigh : high > low[1])
        entryPrice := close
    if retracementDetected
        currentState := STATE_READY_FOR_ENTRY
        if showStateFlow and shouldShowVisuals()
            label.new(bar_index, entryPrice, "→ Retracement Complete", style=label.style_label_center, color=color.blue, size=size.small)
    else if stateTimer > retracementTimeout
        currentState := STATE_RESET

if currentState == STATE_READY_FOR_ENTRY
    atr = ta.atr(14)
    stopRef = not na(sweepLevel) ? sweepLevel : not na(manipulationLevel) ? manipulationLevel : biasDirection == "BULLISH" ? ta.lowest(low, 20) : ta.highest(high, 20)
    activeStates = ""
    if enableHtfBias
        activeStates += "✓4H-CRT "
    if reqAsianRange
        activeStates += "✓Asian "
    if reqManipulation
        activeStates += "✓Manip "
    if reqMacro
        activeStates += "✓Macro "
    if reqSweep
        activeStates += "✓Sweep "
    if reqMSS
        activeStates += "✓MSS "
    if reqCISD
        activeStates += "✓CISD "
    if reqFVG
        activeStates += "✓FVG "
    if reqRetracement
        activeStates += "✓Retrace"
    
    if biasDirection == "BULLISH"
        stopLoss := stopRef - atr * 0.2
        stopDistance = entryPrice - stopLoss
        takeProfit1 := entryPrice + stopDistance * 1.5
        takeProfit2 := entryPrice + stopDistance * 2.0
        if shouldShowVisuals()
            label.new(bar_index, entryPrice, "▲ BUY ENTRY\n" + getCurrentMacro() + "\n" + activeStates, style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)
    else if biasDirection == "BEARISH"
        stopLoss := stopRef + atr * 0.2
        stopDistance = stopLoss - entryPrice
        takeProfit1 := entryPrice - stopDistance * 1.5
        takeProfit2 := entryPrice - stopDistance * 2.0
        if shouldShowVisuals()
            label.new(bar_index, entryPrice, "▼ SELL ENTRY\n" + getCurrentMacro() + "\n" + activeStates, style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)
            
    if showEntryZones and shouldShowVisuals()
        line.new(bar_index, entryPrice, bar_index + 50, entryPrice, color=color.blue, width=2)
        line.new(bar_index, stopLoss, bar_index + 50, stopLoss, color=color.red, width=2)
        line.new(bar_index, takeProfit1, bar_index + 50, takeProfit1, color=color.green, width=1)
        line.new(bar_index, takeProfit2, bar_index + 50, takeProfit2, color=color.green, width=1)
    
    currentState := STATE_IN_POSITION
    sequenceComplete := true
    alert("ICT Entry | " + biasDirection + " | Entry: " + str.tostring(entryPrice) + " | Config: " + preset, alert.freq_once_per_bar)

resetReason = ""
if currentState == STATE_AWAITING_SWEEP and reqMacro and stateTimer > sweepTimeout
    resetReason := "Sweep timeout"
else if currentState == STATE_AWAITING_MSS and stateTimer > mssTimeout
    resetReason := "MSS timeout"
else if currentState == STATE_AWAITING_RETRACEMENT and stateTimer > retracementTimeout
    resetReason := "Retracement timeout"
else if reqMacro and not isInMacro and currentState >= STATE_AWAITING_SWEEP and currentState < STATE_IN_POSITION
    resetReason := "Macro ended"
else if time[1] < timestamp("GMT-4", year(time), month(time), dayofmonth(time), 19, 0) and time >= timestamp("GMT-4", year(time), month(time), dayofmonth(time), 19, 0)
    resetReason := "New trading day"

if resetReason != ""
    if showDebugInfo and shouldShowVisuals()
        label.new(bar_index, high, "⟲ RESET: " + resetReason, style=label.style_label_down, color=color.gray, size=size.small)
    
    currentState := STATE_AWAITING_BIAS
    biasDirection := "NEUTRAL"
    if enableHtfBias
        biasDirection := htfBias
    asianHigh := na
    asianLow := na
    manipulationLevel := na
    sweepLevel := na
    mssLevel := na
    cisdActive := false
    fvgHigh := na
    fvgLow := na
    sequenceComplete := false
    stateTimer := 0
    crtSweepTargetHigh := na
    crtSweepTargetLow := na
    array.clear(skippedStates)
    box.delete(asianBox)
    box.delete(fvgBox)
    line.delete(manipulationLine)

bgcolor(inAsian ? color.new(color.blue, 96) : na, title="Asian Session")
bgcolor(inLondon ? color.new(color.yellow, 96) : na, title="London Session")
bgcolor(inNY ? color.new(color.orange, 96) : na, title="NY Session")
bgcolor(isInMacro ? color.new(color.purple, 92) : na, title="Macro Window")
plot(reqAsianRange and not na(asianHigh) ? asianHigh : na, "Asian High", color=color.blue, style=plot.style_linebr)
plot(reqAsianRange and not na(asianLow) ? asianLow : na, "Asian Low", color=color.blue, style=plot.style_linebr)
plot(reqManipulation and not na(manipulationLevel) ? manipulationLevel : na, "Manipulation", color=color.purple, style=plot.style_cross)
plot(reqSweep and not na(sweepLevel) ? sweepLevel : na, "Sweep Level", color=color.red, style=plot.style_circles)
plot(reqMSS and not na(mssLevel) ? mssLevel : na, "MSS Level", color=color.green, style=plot.style_circles)

if showStateTable
    var table stateTable = table.new(position.top_right, 3, 12, frame_color=color.new(color.blue, 30), frame_width=2, border_color=color.new(color.gray, 60), border_width=1)
    if barstate.islast
        table.cell(stateTable, 0, 0, "🎯 STATE MACHINE", text_color=color.white, bgcolor=color.new(#1E3A5F, 0))
        table.cell(stateTable, 1, 0, "STATUS", text_color=color.white, bgcolor=color.new(#1E3A5F, 0))
        table.cell(stateTable, 2, 0, "VALUE", text_color=color.white, bgcolor=color.new(#1E3A5F, 0))
        
        table.cell(stateTable, 0, 1, "CONFIG", bgcolor=color.new(#2C3E50, 20))
        table.cell(stateTable, 1, 1, preset, text_color=color.aqua, bgcolor=color.new(#2C3E50, 20))
        enabledCount = (enableHtfBias ? 1:0) + (reqAsianRange ? 1:0) + (reqManipulation ? 1:0) + (reqMacro ? 1:0) + (reqSweep ? 1:0) + (reqMSS ? 1:0) + (reqCISD ? 1:0) + (reqFVG ? 1:0) + (reqRetracement ? 1:0)
        table.cell(stateTable, 2, 1, str.tostring(enabledCount) + " STEPS", text_color=color.yellow, bgcolor=color.new(#2C3E50, 20))
        
        stateText = switch currentState
            STATE_AWAITING_BIAS => "1: BIAS"
            STATE_AWAITING_MANIPULATION => "2: MANIP"
            STATE_AWAITING_MACRO => "3: MACRO"
            STATE_AWAITING_SWEEP => "4: SWEEP"
            STATE_AWAITING_MSS => "5: MSS"
            STATE_AWAITING_CISD => "6: CISD"
            STATE_AWAITING_FVG => "7: FVG"
            STATE_AWAITING_RETRACEMENT => "8: RETRACE"
            STATE_READY_FOR_ENTRY => "✓ READY"
            STATE_IN_POSITION => "✓ IN POS"
            => "RESET"
        stateColorBg = currentState == STATE_READY_FOR_ENTRY ? color.new(color.green, 70) : currentState == STATE_IN_POSITION ? color.new(color.blue, 70) : color.new(#34495E, 30)
        table.cell(stateTable, 0, 2, "CURRENT STATE", bgcolor=stateColorBg)
        table.cell(stateTable, 1, 2, stateText, text_color=color.white, bgcolor=stateColorBg)
        table.cell(stateTable, 2, 2, str.tostring(barsInState) + " bars", bgcolor=stateColorBg)
        
        biasBgColor = biasDirection == "BULLISH" ? color.new(color.green, 80) : biasDirection == "BEARISH" ? color.new(color.red, 80) : color.new(#34495E, 30)
        biasSource = enableHtfBias ? " (4H CRT)" : manipulationType != "" ? " (" + manipulationType + ")" : ""
        table.cell(stateTable, 0, 3, "BIAS", bgcolor=biasBgColor)
        biasColor = biasDirection == "BULLISH" ? color.lime : biasDirection == "BEARISH" ? color.new(#FF6B6B, 0) : color.silver
        table.cell(stateTable, 1, 3, biasDirection, text_color=biasColor, bgcolor=biasBgColor)
        table.cell(stateTable, 2, 3, biasSource, bgcolor=biasBgColor)
        
        table.cell(stateTable, 0, 4, "✓ CHECKPOINTS", text_color=color.white, bgcolor=color.new(#1E3A5F, 0))
        table.cell(stateTable, 1, 4, "Required", text_color=color.white, bgcolor=color.new(#1E3A5F, 0))
        table.cell(stateTable, 2, 4, "Status", text_color=color.white, bgcolor=color.new(#1E3A5F, 0))
        
        isBiasSet = biasDirection != "NEUTRAL"
        rowBg1 = color.new(#2C3E50, 40)
        reqBiasLogic = not enableHtfBias and (reqAsianRange or reqManipulation)
        table.cell(stateTable, 0, 5, "1. Bias Logic", bgcolor=rowBg1)
        reqColor1 = enableHtfBias ? color.aqua : reqBiasLogic ? color.lime : color.new(#7F8C8D, 0)
        table.cell(stateTable, 1, 5, enableHtfBias ? "4H CRT" : reqBiasLogic ? "✓" : "—", text_color=reqColor1, text_size=size.large, bgcolor=rowBg1)
        statusColor = isBiasSet ? color.lime : color.orange
        table.cell(stateTable, 2, 5, isBiasSet ? "✓ SET" : "⏳", text_color=statusColor, text_size=size.large, bgcolor=rowBg1)
        
        macroActive = isInMacro or currentState > STATE_AWAITING_MACRO
        rowBg2 = color.new(#34495E, 40)
        table.cell(stateTable, 0, 6, "2. Macro Window", bgcolor=rowBg2)
        table.cell(stateTable, 1, 6, reqMacro ? "✓" : "—", text_color=reqMacro ? color.lime : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg2)
        table.cell(stateTable, 2, 6, reqMacro ? (macroActive ? "✓" : "⏳") : "—", text_color=reqMacro ? (macroActive ? color.lime : color.orange) : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg2)
        
        sweepComplete = not na(sweepLevel)
        table.cell(stateTable, 0, 7, "3. Sweep", bgcolor=rowBg1)
        table.cell(stateTable, 1, 7, reqSweep ? "✓" : "—", text_color=reqSweep ? color.lime : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg1)
        table.cell(stateTable, 2, 7, reqSweep ? (sweepComplete ? "✓" : "⏳") : "—", text_color=reqSweep ? (sweepComplete ? color.lime : color.orange) : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg1)
        
        mssComplete = not na(mssLevel)
        table.cell(stateTable, 0, 8, "4. MSS", bgcolor=rowBg2)
        table.cell(stateTable, 1, 8, reqMSS ? "✓" : "—", text_color=reqMSS ? color.lime : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg2)
        table.cell(stateTable, 2, 8, reqMSS ? (mssComplete ? "✓" : "⏳") : "—", text_color=reqMSS ? (mssComplete ? color.lime : color.orange) : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg2)
        
        table.cell(stateTable, 0, 9, "5. CISD", bgcolor=rowBg1)
        table.cell(stateTable, 1, 9, reqCISD ? "✓" : "—", text_color=reqCISD ? color.lime : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg1)
        table.cell(stateTable, 2, 9, reqCISD ? (cisdActive ? "✓" : "⏳") : "—", text_color=reqCISD ? (cisdActive ? color.lime : color.orange) : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg1)
        
        fvgComplete = not na(fvgCE)
        table.cell(stateTable, 0, 10, "6. FVG", bgcolor=rowBg2)
        table.cell(stateTable, 1, 10, reqFVG ? "✓" : "—", text_color=reqFVG ? color.lime : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg2)
        table.cell(stateTable, 2, 10, reqFVG ? (fvgComplete ? "✓" : "⏳") : "—", text_color=reqFVG ? (fvgComplete ? color.lime : color.orange) : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg2)
        
        retraceComplete = currentState >= STATE_READY_FOR_ENTRY
        table.cell(stateTable, 0, 11, "7. Retrace", bgcolor=rowBg1)
        table.cell(stateTable, 1, 11, reqRetracement ? "✓" : "—", text_color=reqRetracement ? color.lime : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg1)
        table.cell(stateTable, 2, 11, reqRetracement ? (retraceComplete ? "✓" : "⏳") : "—", text_color=reqRetracement ? (retraceComplete ? color.lime : color.orange) : color.new(#7F8C8D, 0), text_size=size.large, bgcolor=rowBg1)